# Очистка установочных .tar файлов после загрузки image
cleanup_tar_files() {
    # Стандартные директории куда пользователь попадает по SSH
    local search_dirs=(
        "/root"
        "/tmp"
        "/opt"
        "$BOT_PATH"
        "$(pwd)"
    )
    
    # Добавляем домашние директории пользователей
    if [[ -d "/home" ]]; then
        for user_home in /home/*; do
            [[ -d "$user_home" ]] && search_dirs+=("$user_home")
        done
    fi
    
    # Собираем уникальные tar файлы
    local -A found_files  # ассоциативный массив для уникальности
    
    for dir in "${search_dirs[@]}"; do
        [[ ! -d "$dir" ]] && continue
        
        while IFS= read -r -d '' file; do
            # Используем realpath для уникальности
            local real_path=$(realpath "$file" 2>/dev/null || echo "$file")
            found_files["$real_path"]=1
        done < <(find "$dir" -maxdepth 1 -name "rwp_shop*.tar" -type f -print0 2>/dev/null)
    done
    
    # Преобразуем в массив
    local tar_files=("${!found_files[@]}")
    
    # Если файлов нет - выходим
    [[ ${#tar_files[@]} -eq 0 ]] && return 0
    
    echo ""
    print_message "INFO" "Найдены установочные файлы Docker image:"
    echo ""
    
    local total_size=0
    for file in "${tar_files[@]}"; do
        local size=$(du -h "$file" 2>/dev/null | cut -f1)
        local size_bytes=$(stat -c %s "$file" 2>/dev/null || echo 0)
        total_size=$((total_size + size_bytes))
        echo -e "  ${CYAN}${file}${RESET}"
        echo -e "    Размер: ${YELLOW}${size}${RESET}"
    done
    
    echo ""
    local total_human=$(numfmt --to=iec $total_size 2>/dev/null || echo "${total_size} bytes")
    echo -e "  ${WHITE}${BOLD}Всего: ${total_human}${RESET}"
    echo ""
    
    print_message "INFO" "Эти файлы больше не нужны - image уже загружен в Docker"
    echo ""
    
    local confirm=""
    while [[ ! "$confirm" =~ ^[YyNn]$ ]]; do
        read -erp "Удалить установочные файлы? (y/n): " confirm
        if [[ ! "$confirm" =~ ^[YyNn]$ ]]; then
            echo -e "${YELLOW}Введите 'y' для да или 'n' для нет${RESET}"
        fi
    done
    
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        local deleted=0
        for file in "${tar_files[@]}"; do
            local filename=$(basename "$file")
            if rm -f "$file" 2>/dev/null; then
                ((deleted++))
                print_message "OK" "Удалён: ${file}"
                debug_log "CLEANUP" "Deleted: $file"
            else
                print_message "WARN" "Не удалось удалить: ${file}"
            fi
        done
        echo ""
        print_message "SUCCESS" "Удалено файлов: $deleted"
    else
        print_message "INFO" "Файлы оставлены"
    fi
}

# Предложить обновить compose файл
offer_compose_update() {
    local compose_version="$1"
    local loaded_version="$2"
    local image_name="$3"
    
    # Определяем compose файл
    local compose_file=""
    [[ -f "$BOT_PATH/compose.yaml" ]] && compose_file="$BOT_PATH/compose.yaml"
    [[ -f "$BOT_PATH/docker-compose.yml" ]] && compose_file="$BOT_PATH/docker-compose.yml"
    
    if [[ -z "$compose_file" ]]; then
        print_message "ERROR" "Compose файл не найден"
        return 1
    fi
    
    echo -e "${CYAN}Обновить версию в compose файле? ${compose_version} → ${loaded_version}${RESET}"
    echo -e "  [1] Да, обновить и перезапустить контейнеры"
    echo -e "  [2] Да, только обновить файл (без перезапуска)"
    echo -e "  [3] Нет, оставить как есть"
    echo ""
    read -erp "Выберите действие [1-3]: " choice
    
    # Определяем текущую версию в compose для проверки лицензии
    # Проверяем LICENSE_KEY если ТЕКУЩАЯ версия в compose >= 3.25.5
    # (независимо от того, обновляет пользователь или нет)
    local current_needs_license=false
    if version_gte "$compose_version" "3.25.5"; then
        current_needs_license=true
    fi
    
    # Проверяем нужен ли LICENSE_KEY для НОВОЙ версии
    local new_needs_license=false
    if version_gte "$loaded_version" "3.25.5"; then
        new_needs_license=true
    fi
    
    case "$choice" in
        1)
            print_message "INFO" "Обновление compose файла..."
            if update_compose_image_version "$compose_file" "$loaded_version" "$image_name"; then
                print_message "SUCCESS" "Compose файл обновлён"
                
                # Проверяем LICENSE_KEY и machine-id volume для новой версии
                if [[ "$new_needs_license" == true ]]; then
                    ensure_machine_id_volume "$compose_file"
                    ensure_license_key_in_env
                fi
                
                echo ""
                print_message "INFO" "Перезапуск контейнеров..."
                cd "$BOT_PATH" || return 1
                docker compose down 2>/dev/null
                sleep 2
                docker compose up -d 2>/dev/null
                sleep 3
                
                # Проверяем статус
                if docker ps | grep -q "$BOT_CONTAINER_NAME"; then
                    print_message "SUCCESS" "Контейнеры запущены с версией ${loaded_version}"
                else
                    print_message "ERROR" "Ошибка запуска контейнеров!"
                    print_message "INFO" "Проверьте логи: docker compose logs"
                fi
                
                # Очистка временных tar файлов
                cleanup_tar_files
            else
                print_message "ERROR" "Ошибка обновления compose файла"
            fi
            ;;
        2)
            print_message "INFO" "Обновление compose файла..."
            if update_compose_image_version "$compose_file" "$loaded_version" "$image_name"; then
                print_message "SUCCESS" "Compose файл обновлён"
                
                # Проверяем LICENSE_KEY и machine-id volume для новой версии
                if [[ "$new_needs_license" == true ]]; then
                    ensure_machine_id_volume "$compose_file"
                    ensure_license_key_in_env
                fi
                
                # Очистка временных tar файлов
                cleanup_tar_files
                
                print_message "INFO" "Для применения выполните: docker compose down && docker compose up -d"
            else
                print_message "ERROR" "Ошибка обновления compose файла"
            fi
            ;;
        3|*)
            print_message "INFO" "Compose файл не изменён"
            
            # ВАЖНО: Даже если пользователь отказался от обновления версии,
            # проверяем LICENSE_KEY и machine-id для ТЕКУЩЕЙ версии в compose
            if [[ "$current_needs_license" == true ]]; then
                echo ""
                print_message "INFO" "Проверка требований лицензии для текущей версии ${compose_version}..."
                ensure_machine_id_volume "$compose_file"
                ensure_license_key_in_env
            fi
            ;;
    esac
}

# Проверка и добавление LICENSE_KEY в .env файл (требуется с версии 3.25.5+)
ensure_license_key_in_env() {
    local env_file="$BOT_PATH/.env"
    local compose_file=""
    
    # Определяем compose файл для проверки конфигурации
    [[ -f "$BOT_PATH/compose.yaml" ]] && compose_file="$BOT_PATH/compose.yaml"
    [[ -f "$BOT_PATH/docker-compose.yml" ]] && compose_file="$BOT_PATH/docker-compose.yml"
    
    if [[ ! -f "$env_file" ]]; then
        debug_log "LICENSE" ".env file not found: $env_file"
        return 1
    fi
    
    # Определяем тип конфигурации: env_file или environment
    # Если в compose есть "env_file:" для сервиса bot — переменные читаются напрямую из .env
    # Если используется "environment:" — нужна явная ссылка LICENSE_KEY=${LICENSE_KEY:-}
    local uses_env_file=false
    if [[ -n "$compose_file" ]]; then
        # Проверяем есть ли env_file в секции bot
        if grep -A 30 "^\s*bot:" "$compose_file" | grep -q "env_file:"; then
            uses_env_file=true
            debug_log "LICENSE" "Compose uses env_file: direct .env reading"
        else
            debug_log "LICENSE" "Compose uses environment: variables via \${VAR}"
        fi
    fi
    
    # Проверяем есть ли уже LICENSE_KEY в .env
    if grep -q "^LICENSE_KEY=" "$env_file"; then
        local existing_key=$(grep "^LICENSE_KEY=" "$env_file" | cut -d'=' -f2-)
        if [[ -n "$existing_key" && "$existing_key" != '""' && "$existing_key" != "''" ]]; then
            debug_log "LICENSE" "LICENSE_KEY already exists in .env (value set)"
            return 0
        fi
        debug_log "LICENSE" "LICENSE_KEY exists but is empty"
    fi
    
    # Очищаем экран чтобы рамка была вверху (в debug режиме показывает разделитель)
    clear_screen
    
    # Рамка LICENSE_KEY (64 символа внутри = 62 контент + 2 границы)
    local B="${RED}${BOLD}"  # Border color
    local R="${RESET}"
    local C="${CYAN}"
    local Y="${YELLOW}"
    
    echo -e "${B}╔══════════════════════════════════════════════════════════════╗${R}"
    echo -e "${B}║${R}            [!] ТРЕБУЕТСЯ LICENSE_KEY                         ${B}║${R}"
    echo -e "${B}╠══════════════════════════════════════════════════════════════╣${R}"
    echo -e "${B}║${R}                                                              ${B}║${R}"
    echo -e "${B}║${R}  Начиная с версии ${C}3.25.5${R} для работы бота требуется           ${B}║${R}"
    echo -e "${B}║${R}  лицензионный ключ (LICENSE_KEY).                            ${B}║${R}"
    echo -e "${B}║${R}                                                              ${B}║${R}"
    echo -e "${B}║${R}  ${Y}LICENSE_KEY не найден или пустой в .env файле!${R}              ${B}║${R}"
    echo -e "${B}║${R}                                                              ${B}║${R}"
    echo -e "${B}╠══════════════════════════════════════════════════════════════╣${R}"
    echo -e "${B}║${R}  Получите ключ в боте: ${C}https://t.me/rwp_shop_bot${R}             ${B}║${R}"
    echo -e "${B}║${R}  Формат ключа: 64 символа (hex)                              ${B}║${R}"
    echo -e "${B}╚══════════════════════════════════════════════════════════════╝${R}"
    echo ""
    
    # Цикл ввода с валидацией
    local license_key=""
    while true; do
        read -erp "Введите LICENSE_KEY (или Enter чтобы пропустить): " license_key
        
        # Пустой ввод — пропустить
        if [[ -z "$license_key" ]]; then
            break
        fi
        
        # Убираем пробелы по краям
        license_key=$(echo "$license_key" | tr -d '[:space:]')
        
        # Приводим к нижнему регистру
        license_key=$(echo "$license_key" | tr '[:upper:]' '[:lower:]')
        
        # Валидация: точно 64 символа hex (0-9, a-f)
        if [[ "$license_key" =~ ^[0-9a-f]{64}$ ]]; then
            break
        else
            echo ""
            print_message "ERROR" "Неверный формат LICENSE_KEY!"
            echo -e "  Ожидается: ${CYAN}64 символа (0-9, a-f)${RESET}"
            echo -e "  Получено:  ${YELLOW}${#license_key} символов${RESET}"
            echo ""
        fi
    done
    
    if [[ -n "$license_key" ]]; then
        # Проверяем есть ли уже строка LICENSE_KEY= (пустая)
        if grep -q "^LICENSE_KEY=" "$env_file"; then
            # Заменяем существующую пустую строку
            sed -i "s|^LICENSE_KEY=.*|LICENSE_KEY=$license_key|" "$env_file"
        else
            # Добавляем LICENSE_KEY в конец .env файла
            echo "" >> "$env_file"
            echo "# License key (required from v3.25.5)" >> "$env_file"
            echo "LICENSE_KEY=$license_key" >> "$env_file"
        fi
        print_message "SUCCESS" "LICENSE_KEY добавлен в .env"
        
        # Предупреждаем только если используется environment (не env_file)
        # При env_file переменные читаются напрямую из .env — всё ОК
        if [[ "$uses_env_file" == false && -n "$compose_file" ]]; then
            if ! grep -q "LICENSE_KEY" "$compose_file"; then
                echo ""
                print_message "WARN" "В compose файле отсутствует переменная LICENSE_KEY в environment!"
                echo -e "${YELLOW}Ваш compose использует секцию environment (не env_file).${RESET}"
                echo -e "${YELLOW}Рекомендуется добавить в секцию environment сервиса bot:${RESET}"
                echo -e "${CYAN}      - LICENSE_KEY=\${LICENSE_KEY:-}${RESET}"
                echo ""
                echo -e "Или перейдите на формат с env_file — тогда все переменные"
                echo -e "из .env будут доступны автоматически."
                echo ""
                print_message "INFO" "Скачайте актуальный compose файл из документации"
                read -erp "Нажмите Enter для продолжения..." dummy
            fi
        fi
        return 0
    else
        echo ""
        # Рамка предупреждения (62 символа контента)
        local B="${RED}${BOLD}"
        local R="${RESET}"
        local Y="${YELLOW}${BOLD}"
        local C="${CYAN}"
        local W="${WHITE}${BOLD}"
        
        echo -e "${B}┌──────────────────────────────────────────────────────────────┐${R}"
        echo -e "${B}│${R}   ${Y}[!] LICENSE_KEY не добавлен. Бот может не запуститься!${R}     ${B}│${R}"
        echo -e "${B}├──────────────────────────────────────────────────────────────┤${R}"
        echo -e "${B}│${R}                                                              ${B}│${R}"
        echo -e "${B}│${R}  Добавьте вручную в .env:                                    ${B}│${R}"
        echo -e "${B}│${R}     ${C}LICENSE_KEY=ваш_ключ_64_символа${R}                          ${B}│${R}"
        echo -e "${B}│${R}                                                              ${B}│${R}"
        echo -e "${B}│${R}   ${W}Получить ключ:${R} ${C}https://t.me/rwp_shop_bot${R}                   ${B}│${R}"
        echo -e "${B}│${R}                                                              ${B}│${R}"
        echo -e "${B}└──────────────────────────────────────────────────────────────┘${R}"
        echo ""
        read -erp "Нажмите Enter для продолжения..." dummy
        return 1
    fi
}

# Проверка и добавление machine-id volume в compose файл (требуется с версии 3.25.5+ для лицензии)
ensure_machine_id_volume() {
    local compose_file="$1"
    
    if [[ ! -f "$compose_file" ]]; then
        debug_log "MACHINE_ID" "Compose file not found: $compose_file"
        return 1
    fi
    
    # Проверяем есть ли уже machine-id volume
    if grep -q "/etc/machine-id" "$compose_file"; then
        debug_log "MACHINE_ID" "machine-id volume already exists in compose"
        return 0
    fi
    
    # Очищаем экран чтобы рамка была вверху (в debug режиме показывает разделитель)
    clear_screen
    
    # Короткие алиасы
    local B="${RED}${BOLD}"
    local R="${RESET}"
    local C="${CYAN}"
    local Y="${YELLOW}"
    
    echo -e "${B}╔══════════════════════════════════════════════════════════════╗${R}"
    echo -e "${B}║${R}          [!] ОТСУТСТВУЕТ VOLUME ДЛЯ ЛИЦЕНЗИИ                 ${B}║${R}"
    echo -e "${B}╠══════════════════════════════════════════════════════════════╣${R}"
    echo -e "${B}║${R}                                                              ${B}║${R}"
    echo -e "${B}║${R}  В compose файле не найден обязательный volume:              ${B}║${R}"
    echo -e "${B}║${R}  ${C}/etc/machine-id:/etc/machine-id:ro${R}                          ${B}║${R}"
    echo -e "${B}║${R}                                                              ${B}║${R}"
    echo -e "${B}║${R}  Этот volume необходим для привязки лицензии к серверу.      ${B}║${R}"
    echo -e "${B}║${R}  ${Y}Без него бот не сможет проверить лицензию!${R}                  ${B}║${R}"
    echo -e "${B}║${R}                                                              ${B}║${R}"
    echo -e "${B}╠══════════════════════════════════════════════════════════════╣${R}"
    echo -e "${B}║${R}  Нужно добавить в секцию volumes сервиса bot:                ${B}║${R}"
    echo -e "${B}║${R}  ${C}volumes:${R}                                                    ${B}║${R}"
    echo -e "${B}║${R}  ${C}  - /etc/machine-id:/etc/machine-id:ro${R}                      ${B}║${R}"
    echo -e "${B}╚══════════════════════════════════════════════════════════════╝${R}"
    echo ""
    
    local confirm=""
    while [[ ! "$confirm" =~ ^[YyNn]$ ]]; do
        read -erp "Добавить автоматически? (y/n): " confirm
        if [[ ! "$confirm" =~ ^[YyNn]$ ]]; then
            echo -e "${YELLOW}Введите 'y' для да или 'n' для нет${RESET}"
        fi
    done
    
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        # Создаём бэкап
        cp "$compose_file" "${compose_file}.bak.machine-id"
        
        # Ищем секцию volumes в сервисе bot и добавляем machine-id
        # Используем sed для добавления после строки с volumes: в секции bot
        
        # Сначала проверяем есть ли уже секция volumes у bot
        if grep -A 20 "^\s*bot:" "$compose_file" | grep -q "^\s*volumes:"; then
            # Есть секция volumes - добавляем после неё
            # Ищем первую строку volumes: после bot: и добавляем после неё
            local in_bot=false
            local volumes_found=false
            local temp_file=$(mktemp)
            
            while IFS= read -r line; do
                echo "$line" >> "$temp_file"
                
                # Определяем что мы в секции bot
                if [[ "$line" =~ ^[[:space:]]*bot: ]]; then
                    in_bot=true
                    volumes_found=false
                fi
                
                # Выходим из секции bot если встретили другой сервис
                if [[ "$in_bot" == true && "$line" =~ ^[[:space:]]{2}[a-z] && ! "$line" =~ ^[[:space:]]*bot: && ! "$line" =~ ^[[:space:]]{4} ]]; then
                    in_bot=false
                fi
                
                # Если мы в bot и нашли volumes: - добавляем machine-id
                if [[ "$in_bot" == true && "$volumes_found" == false && "$line" =~ ^[[:space:]]*volumes: ]]; then
                    volumes_found=true
                    echo "      - /etc/machine-id:/etc/machine-id:ro" >> "$temp_file"
                fi
            done < "$compose_file"
            
            mv "$temp_file" "$compose_file"
            print_message "SUCCESS" "Volume /etc/machine-id добавлен в compose файл"
            print_message "INFO" "Бэкап сохранён: ${compose_file}.bak.machine-id"
            echo ""
            read -erp "Нажмите Enter для продолжения..." dummy
        else
            # Нет секции volumes - нужно добавить вручную
            print_message "ERROR" "Секция volumes не найдена в сервисе bot"
            print_message "INFO" "Добавьте вручную в docker-compose.yml:"
            echo ""
            echo -e "${CYAN}services:"
            echo -e "  bot:"
            echo -e "    volumes:"
            echo -e "      - /etc/machine-id:/etc/machine-id:ro${RESET}"
            read -erp "Нажмите Enter для продолжения..." dummy
            return 1
        fi
        return 0
    else
        print_message "WARN" "Volume не добавлен. Лицензия может не работать!"
        print_message "INFO" "Добавьте вручную: /etc/machine-id:/etc/machine-id:ro"
        read -erp "Нажмите Enter для продолжения..." dummy
        return 1
    fi
}

# Обновление image версии в docker-compose файле
# Поддерживает все варианты именования image
update_compose_image_version() {
    local compose_file="$1"
    local new_version="$2"
    local new_image_name="$3"  # Опционально: имя нового image
    
    debug_log "COMPOSE" "=== update_compose_image_version() ==="
    debug_log "COMPOSE" "  compose_file=$compose_file"
    debug_log "COMPOSE" "  new_version=$new_version"
    debug_log "COMPOSE" "  new_image_name=$new_image_name"
    
    if [[ ! -f "$compose_file" ]]; then
        debug_log "COMPOSE" "Compose file not found: $compose_file"
        print_message "ERROR" "Compose файл не найден: $compose_file"
        return 1
    fi
    
    # Если новое имя image не указано, используем rwp_shop (официальное)
    [[ -z "$new_image_name" ]] && new_image_name="rwp_shop"
    debug_log "COMPOSE" "Target image name: $new_image_name"
    
    # Список всех возможных имён image бота
    local image_patterns=(
        "rwp_shop"
        "private-remnawave-telegram-shop-bot"
        "telegram-shop"
        "shopbot"
    )
    
    local found=false
    for pattern in "${image_patterns[@]}"; do
        debug_log "COMPOSE" "Checking for pattern: $pattern"
        if grep -qE "image:\s*['\"]?${pattern}:" "$compose_file"; then
            debug_log "COMPOSE" "Pattern matched: $pattern"
            # Заменяем на новое имя и версию
            sed -i -E "s|(image:\s*['\"]?)${pattern}:[0-9]+\.[0-9]+\.[0-9]+|\1${new_image_name}:${new_version}|g" "$compose_file"
            found=true
            debug_log "COMPOSE" "Sed replacement done: ${pattern} -> ${new_image_name}:${new_version}"
            print_message "SUCCESS" "Image обновлён: ${pattern} → ${new_image_name}:${new_version}"
            break
        fi
    done
    
    if [[ "$found" == "false" ]]; then
        debug_log "COMPOSE" "No matching image pattern found in compose file"
        print_message "ERROR" "Не найден image бота в compose файле"
        print_message "INFO" "Искали паттерны: ${image_patterns[*]}"
        return 1
    fi
    
    debug_log "COMPOSE" "update_compose_image_version() completed successfully"
    return 0
}

# Проверка здоровья БД
check_db_health() {
    local db_container="$1"
    local max_attempts="${2:-30}"
    local attempt=1
    
    debug_log "HEALTH" "check_db_health($db_container, max=$max_attempts)"
    
    while [[ $attempt -le $max_attempts ]]; do
        local health=$(docker inspect -f '{{.State.Health.Status}}' "$db_container" 2> "$SILENT_LOG")
        debug_log "HEALTH" "  attempt $attempt: health=$health"
        
        if [[ "$health" == "healthy" ]]; then
            debug_log "HEALTH" "DB healthy via docker healthcheck"
            return 0
        fi
        
        # Альтернативная проверка через pg_isready
        if docker exec "$db_container" pg_isready -U "$DB_USER" > "$SILENT_LOG" 2>&1; then
            debug_log "HEALTH" "DB healthy via pg_isready"
            return 0
        fi
        
        echo -ne "\r  Ожидание БД... ($attempt/$max_attempts)"
        sleep 1
        ((attempt++))
    done
    
    debug_log "HEALTH" "DB health check failed after $max_attempts attempts"
    echo ""
    return 1
}

# Проверка что контейнер бота запустился и работает
check_bot_health() {
    local bot_container="$1"
    local max_attempts="${2:-20}"
    local attempt=1
    
    debug_log "HEALTH" "check_bot_health($bot_container, max=$max_attempts)"
    
    while [[ $attempt -le $max_attempts ]]; do
        local status=$(docker inspect -f '{{.State.Status}}' "$bot_container" 2> "$SILENT_LOG")
        local running=$(docker inspect -f '{{.State.Running}}' "$bot_container" 2> "$SILENT_LOG")
        debug_log "HEALTH" "  attempt $attempt: status=$status, running=$running"
        
        if [[ "$status" == "running" && "$running" == "true" ]]; then
            # Проверяем что контейнер не рестартует
            sleep 2
            local status2=$(docker inspect -f '{{.State.Status}}' "$bot_container" 2> "$SILENT_LOG")
            debug_log "HEALTH" "  stability check: status2=$status2"
            if [[ "$status2" == "running" ]]; then
                debug_log "HEALTH" "Bot healthy and stable"
                return 0
            fi
        fi
        
        echo -ne "\r  Ожидание бота... ($attempt/$max_attempts)"
        sleep 1
        ((attempt++))
    done
    
    debug_log "HEALTH" "Bot health check failed after $max_attempts attempts"
    echo ""
    return 1
}

# Получить последний бэкап БД для возможного rollback
get_latest_db_backup() {
    local latest=$(find "$BACKUP_DIR" -maxdepth 1 -type f \( -name "lazarus_db_*.tar.gz" -o -name "lazarus_db_*.tar.gz.enc" \) -printf '%T@ %p\n' 2> "$SILENT_LOG" | sort -rn | head -1 | awk '{print $2}')
    echo "$latest"
}

# ═══════════════════════════════════════════════════════════════════════════════
# AUTO UPDATE - Автоматическое обновление бота без интерактива
# ═══════════════════════════════════════════════════════════════════════════════
# Использование: lazarus auto_update [LICENSE_KEY]
#   LICENSE_KEY - опционально, если не передан и нужен - будет запрошен
#
# Примеры:
#   lazarus auto_update                           # Обновить, спросит ключ если нужен
#   lazarus auto_update abc123...                 # Обновить с указанным ключом
#   LICENSE_KEY=abc123 lazarus auto_update        # Через переменную окружения
# ═══════════════════════════════════════════════════════════════════════════════
auto_update_bot() {
    local provided_key="${1:-$LICENSE_KEY}"  # Из аргумента или env
    
    echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════${RESET}"
    echo -e "${GREEN}${BOLD}  LAZARUS Auto Update v${VERSION}${RESET}"
    echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════${RESET}"
    echo ""
    
    # === 1. ПРОВЕРКА ПУТИ К БОТУ ===
    log_message "INFO" "[AUTO] Starting auto update..."
    
    if [[ -z "$BOT_PATH" || ! -d "$BOT_PATH" ]]; then
        # Пробуем найти автоматически
        if [[ -d "$DEFAULT_BOT_PATH" && ( -f "$DEFAULT_BOT_PATH/docker-compose.yml" || -f "$DEFAULT_BOT_PATH/compose.yaml" ) ]]; then
            BOT_PATH="$DEFAULT_BOT_PATH"
            save_config
        else
            ensure_bot_path || {
                print_message "ERROR" "Путь к боту не найден!"
                echo "Укажите BOT_PATH в config.env или установите бота"
                return 1
            }
        fi
    fi
    
    print_message "INFO" "Путь к боту: $BOT_PATH"
    
    # === 2. ОПРЕДЕЛЯЕМ COMPOSE ФАЙЛ ===
    local compose_file=""
    [[ -f "$BOT_PATH/compose.yaml" ]] && compose_file="$BOT_PATH/compose.yaml"
    [[ -f "$BOT_PATH/docker-compose.yml" ]] && compose_file="$BOT_PATH/docker-compose.yml"
    
    if [[ -z "$compose_file" ]]; then
        print_message "ERROR" "Compose файл не найден в $BOT_PATH"
        return 1
    fi
    
    # === 3. ТЕКУЩАЯ ВЕРСИЯ ===
    local current_version=$(get_current_bot_version)
    print_message "INFO" "Текущая версия: ${current_version:-не определена}"
    
    # === 4. ПОИСК НОВОЙ ВЕРСИИ ===
    # Сначала проверяем Docker images
    local latest_docker_version=""
    local latest_docker_image=""
    local docker_images=$(get_loaded_bot_images)
    
    if [[ -n "$docker_images" ]]; then
        while IFS='|' read -r img_name img_ver; do
            [[ -z "$img_ver" ]] && continue
            if [[ -z "$latest_docker_version" ]] || version_gt "$img_ver" "$latest_docker_version"; then
                latest_docker_version="$img_ver"
                latest_docker_image="$img_name"
            fi
        done <<< "$docker_images"
    fi
    
    # Затем ищем .tar файлы
    local latest_tar_version=""
    local latest_tar_file=""
    local tar_files=$(find_all_bot_image_files)
    
    if [[ -n "$tar_files" ]]; then
        while IFS= read -r file; do
            [[ -z "$file" ]] && continue
            local fversion=$(extract_version_from_filename "$(basename "$file")")
            if [[ -n "$fversion" ]]; then
                if [[ -z "$latest_tar_version" ]] || version_gt "$fversion" "$latest_tar_version"; then
                    latest_tar_version="$fversion"
                    latest_tar_file="$file"
                fi
            fi
        done <<< "$tar_files"
    fi
    
    # Определяем что использовать
    local selected_version=""
    local selected_file=""
    local selected_image=""
    local need_docker_load=false
    
    # Приоритет: Docker image > tar file
    if [[ -n "$latest_docker_version" ]]; then
        if [[ -z "$current_version" ]] || version_gt "$latest_docker_version" "$current_version"; then
            selected_version="$latest_docker_version"
            selected_image="$latest_docker_image"
            print_message "SUCCESS" "Найден образ в Docker: ${selected_image}:${selected_version}"
        fi
    fi
    
    if [[ -z "$selected_version" && -n "$latest_tar_version" ]]; then
        if [[ -z "$current_version" ]] || version_gt "$latest_tar_version" "$current_version"; then
            # Проверяем не загружен ли уже этот tar в Docker
            local tar_image=$(get_image_name_from_tar "$latest_tar_file")
            if is_image_loaded_in_docker "$tar_image" "$latest_tar_version"; then
                selected_version="$latest_tar_version"
                selected_image="$tar_image"
                print_message "SUCCESS" "Образ из .tar уже в Docker: ${selected_image}:${selected_version}"
            else
                selected_version="$latest_tar_version"
                selected_file="$latest_tar_file"
                need_docker_load=true
                print_message "SUCCESS" "Найден .tar файл: $(basename "$latest_tar_file")"
            fi
        fi
    fi
    
    if [[ -z "$selected_version" ]]; then
        if [[ -n "$current_version" ]]; then
            print_message "SUCCESS" "Установлена последняя версия: $current_version"
        else
            print_message "ERROR" "Не найдено образов для обновления"
            echo ""
            echo "Скачайте образ бота и положите в $BOT_PATH"
            return 1
        fi
        # Даже если обновлений нет - проверяем конфигурацию
        selected_version="$current_version"
    fi
    
    # === 5. ПРОВЕРКА ТРЕБОВАНИЙ v3.25.5+ ===
    if version_gte "$selected_version" "3.25.5"; then
        echo ""
        print_message "INFO" "Проверка требований для v3.25.5+..."
        
        # Проверяем machine-id volume
        if ! has_machine_id_volume; then
            print_message "WARN" "Добавляем machine-id volume в compose..."
            
            # Автоматическое добавление machine-id
            if grep -A 20 "^\s*bot:" "$compose_file" | grep -q "^\s*volumes:"; then
                cp "$compose_file" "${compose_file}.bak.auto"
                local temp_file=$(mktemp)
                local in_bot=false
                local volumes_found=false
                
                while IFS= read -r line; do
                    echo "$line" >> "$temp_file"
                    if [[ "$line" =~ ^[[:space:]]*bot: ]]; then
                        in_bot=true
                        volumes_found=false
                    fi
                    if [[ "$in_bot" == true && "$line" =~ ^[[:space:]]{2}[a-z] && ! "$line" =~ ^[[:space:]]*bot: && ! "$line" =~ ^[[:space:]]{4} ]]; then
                        in_bot=false
                    fi
                    if [[ "$in_bot" == true && "$volumes_found" == false && "$line" =~ ^[[:space:]]*volumes: ]]; then
                        volumes_found=true
                        echo "      - /etc/machine-id:/etc/machine-id:ro" >> "$temp_file"
                    fi
                done < "$compose_file"
                
                mv "$temp_file" "$compose_file"
                print_message "SUCCESS" "machine-id volume добавлен"
            else
                print_message "ERROR" "Не удалось добавить machine-id автоматически"
                echo "Добавьте вручную в секцию volumes:"
                echo "  - /etc/machine-id:/etc/machine-id:ro"
                return 1
            fi
        else
            print_message "SUCCESS" "machine-id volume: ✓"
        fi
        
        # Проверяем LICENSE_KEY
        if ! has_license_key; then
            if [[ -n "$provided_key" && "$provided_key" =~ ^[0-9a-f]{64}$ ]]; then
                # Ключ передан как параметр
                local env_file="$BOT_PATH/.env"
                if grep -q "^LICENSE_KEY=" "$env_file" 2>/dev/null; then
                    sed -i "s|^LICENSE_KEY=.*|LICENSE_KEY=$provided_key|" "$env_file"
                else
                    echo "" >> "$env_file"
                    echo "# License key (required from v3.25.5)" >> "$env_file"
                    echo "LICENSE_KEY=$provided_key" >> "$env_file"
                fi
                print_message "SUCCESS" "LICENSE_KEY добавлен"
            elif [[ "$IS_INTERACTIVE" == true ]]; then
                print_message "WARN" "LICENSE_KEY не найден!"
                echo ""
                echo -e "Получите ключ: ${CYAN}https://t.me/rwp_shop_bot${RESET}"
                echo ""
                read -erp "Введите LICENSE_KEY (64 hex символа): " input_key
                input_key=$(echo "$input_key" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
                
                if [[ "$input_key" =~ ^[0-9a-f]{64}$ ]]; then
                    local env_file="$BOT_PATH/.env"
                    if grep -q "^LICENSE_KEY=" "$env_file" 2>/dev/null; then
                        sed -i "s|^LICENSE_KEY=.*|LICENSE_KEY=$input_key|" "$env_file"
                    else
                        echo "" >> "$env_file"
                        echo "# License key (required from v3.25.5)" >> "$env_file"
                        echo "LICENSE_KEY=$input_key" >> "$env_file"
                    fi
                    print_message "SUCCESS" "LICENSE_KEY добавлен"
                else
                    print_message "ERROR" "Неверный формат LICENSE_KEY!"
                    return 1
                fi
            else
                # Неинтерактивный режим - пропускаем без ключа
                print_message "WARN" "LICENSE_KEY не найден! Передайте ключ через параметр:"
                print_message "INFO" "  lazarus -b -u YOUR_LICENSE_KEY"
                print_message "INFO" "  или: LICENSE_KEY=... lazarus -b -u"
            fi
        else
            print_message "SUCCESS" "LICENSE_KEY: ✓"
        fi
    fi
    
    # === 6. ОБНОВЛЕНИЕ (если есть новая версия) ===
    if [[ -n "$selected_version" && "$selected_version" != "$current_version" ]]; then
        echo ""
        print_message "INFO" "Обновление: $current_version → $selected_version"
        
        # Загружаем образ если нужно
        if [[ "$need_docker_load" == true && -n "$selected_file" ]]; then
            print_message "INFO" "Загрузка образа в Docker..."
            if ! docker load -i "$selected_file"; then
                print_message "ERROR" "Ошибка загрузки образа!"
                return 1
            fi
            selected_image=$(get_image_name_from_tar "$selected_file")
            print_message "SUCCESS" "Образ загружен: ${selected_image}:${selected_version}"
        fi
        
        # Обновляем версию в compose
        print_message "INFO" "Обновление compose файла..."
        if ! update_compose_image_version "$compose_file" "$selected_version" "$selected_image"; then
            print_message "ERROR" "Ошибка обновления compose файла!"
            return 1
        fi
        
        # Перезапускаем контейнер
        print_message "INFO" "Перезапуск бота..."
        cd "$BOT_PATH" || return 1
        
        docker compose down 2>/dev/null || docker-compose down 2>/dev/null
        sleep 2
        docker compose up -d 2>/dev/null || docker-compose up -d 2>/dev/null
        
        sleep 3
        
        # Проверяем статус
        local new_status=$(docker compose ps --format "{{.Status}}" 2>/dev/null | head -1)
        if [[ "$new_status" == *"Up"* ]]; then
            print_message "SUCCESS" "Бот успешно обновлён до версии $selected_version"
        else
            print_message "WARN" "Бот запущен, но статус: $new_status"
            echo "Проверьте логи: docker logs rwp_shop"
        fi
    else
        echo ""
        print_message "SUCCESS" "Обновление не требуется"
    fi
    
    echo ""
    log_message "INFO" "[AUTO] Auto update completed"
    return 0
}

