# =============================================================================
# RECOVER-HISTORICAL: восстановление исторических данных из старого дампа
# =============================================================================
# Контекст: 2025-11-01 при восстановлении из бэкапа ~700 пользователей получили
# одинаковую created_at='2025-11-01 22:38:50.539351+00', а платежи и рефералы
# до этой даты потерялись. См. .github/RECOVERY_ANALYSIS.md
#
# Стратегия:
#   1) Поднять старый дамп во временную БД lazarus_recover_<ts> в том же
#      Postgres-контейнере.
#   2) Через TSV-pipeline (COPY TO STDOUT → COPY FROM STDIN во временные
#      таблицы основной БД) выполнить три операции:
#        Step 1: UPDATE customer.created_at для записей с фейковой датой,
#                сопоставление по telegram_id (уникальный ключ).
#        Step 2: INSERT старых purchase (id назначается SERIAL, customer_id
#                перепривязывается через telegram_id).
#        Step 3: INSERT старых referral (referrer_id/referee_id — это
#                telegram_id, не меняются; дубли отсеиваются NOT EXISTS).
#   3) Удалить временную БД.
#
# Безопасность:
#   - Перед любыми изменениями делается полный safety snapshot текущей БД.
#   - Каждый шаг идёт в собственной транзакции; перед EXECUTE — dry-run счётчик
#     и подтверждение (или флаг --yes для неинтерактивного запуска).
#   - Без --yes интерактивно запрашивается подтверждение перед каждым шагом.
# =============================================================================

# Helper: psql в указанной БД через docker exec, на stdout — результат tAc
_rh_psql_q() {
    # $1 = db name, $2 = SQL
    docker exec -i "$DB_CONTAINER_NAME" psql -U "$_RH_DB_USER" -d "$1" -tAc "$2" 2> "$SILENT_LOG"
}

# Helper: psql -f stdin (для многострочных запросов с транзакциями), возвращает exit code
_rh_psql_run() {
    # $1 = db name; SQL читается из stdin
    docker exec -i "$DB_CONTAINER_NAME" psql -U "$_RH_DB_USER" -d "$1" -v ON_ERROR_STOP=1 2> "$SILENT_LOG"
}

recover_historical_data() {
    local old_dump="$1"
    local auto_yes="false"
    [[ "$2" == "--yes" || "$2" == "-y" || "$AUTO_CONFIRM" == "true" ]] && auto_yes="true"

    clear_screen
    echo -e "${RED}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
    echo -e "${RED}${BOLD}  🩺  ВОССТАНОВЛЕНИЕ ИСТОРИЧЕСКИХ ДАННЫХ (recover-historical)      ${RESET}"
    echo -e "${RED}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
    echo ""

    # === 1. Валидация аргумента ===
    if [[ -z "$old_dump" ]]; then
        print_message "ERROR" "Не указан путь к старому SQL-дампу."
        echo ""
        echo "Использование: lazarus recover-historical <old_dump.sql[.gz]> [--yes]"
        echo ""
        echo "Дамп должен быть plain-SQL pg_dump (НЕ custom-формат)."
        return 1
    fi
    if [[ ! -f "$old_dump" ]]; then
        print_message "ERROR" "Файл не найден: $old_dump"
        return 1
    fi

    local dump_size; dump_size=$(du -h "$old_dump" 2>/dev/null | cut -f1)

    # === 2. Детекция БД ===
    detect_bot_installation > "$SILENT_LOG" 2>&1 || true
    if [[ -z "$DB_CONTAINER_NAME" ]]; then
        print_message "ERROR" "Не удалось определить контейнер БД (DB_CONTAINER_NAME пуст)."
        return 1
    fi
    if ! docker inspect "$DB_CONTAINER_NAME" > /dev/null 2> "$SILENT_LOG"; then
        print_message "ERROR" "Контейнер $DB_CONTAINER_NAME не найден."
        return 1
    fi
    local _RH_DB_USER; _RH_DB_USER=$(get_db_user)
    local _RH_DB_NAME; _RH_DB_NAME=$(get_db_name)
    if [[ -z "$_RH_DB_USER" || -z "$_RH_DB_NAME" ]]; then
        print_message "ERROR" "Не удалось определить DB_USER/DB_NAME."
        return 1
    fi

    if ! docker exec "$DB_CONTAINER_NAME" pg_isready -U "$_RH_DB_USER" -d "$_RH_DB_NAME" > "$SILENT_LOG" 2>&1; then
        print_message "ERROR" "БД не готова (pg_isready failed)."
        return 1
    fi

    # === 3. Печать плана ===
    local CORRUPT_DATE="2025-11-01 22:38:50.539351+00"
    local CUTOFF_DATE="2025-11-02"
    local ts; ts=$(date +%Y%m%d_%H%M%S)
    local temp_db="lazarus_recover_${ts}"
    local snapshot_file="${BACKUP_DIR}/pre_recover_snapshot_${ts}.sql.gz"

    echo -e "${CYAN}Параметры:${RESET}"
    echo "  Старый дамп:        $old_dump ($dump_size)"
    echo "  Контейнер БД:       $DB_CONTAINER_NAME"
    echo "  Текущая БД:         $_RH_DB_NAME (user=$_RH_DB_USER)"
    echo "  Временная БД:       $temp_db"
    echo "  Safety snapshot:    $snapshot_file"
    echo "  Метка фейк-даты:    $CORRUPT_DATE"
    echo "  Граница импорта:    created_at < $CUTOFF_DATE"
    echo ""
    echo -e "${YELLOW}Будут выполнены 3 шага в отдельных транзакциях:${RESET}"
    echo "  1) UPDATE customer.created_at для записей с фейковой датой"
    echo "  2) INSERT старых purchase (с пере-маппингом customer_id через telegram_id)"
    echo "  3) INSERT старых referral (NOT EXISTS защита от дублей)"
    echo ""

    if [[ "$auto_yes" != "true" ]]; then
        local _ans=""
        read -erp "Продолжить? [y/N]: " _ans
        if [[ ! "$_ans" =~ ^[YyДд]$ ]]; then
            print_message "INFO" "Отменено пользователем."
            return 0
        fi
    fi

    # === 4. Safety snapshot ===
    echo ""
    print_message "INFO" "Создание safety snapshot..."
    mkdir -p "$BACKUP_DIR" 2> "$SILENT_LOG"
    if ! docker exec "$DB_CONTAINER_NAME" pg_dump -U "$_RH_DB_USER" "$_RH_DB_NAME" 2> "$SILENT_LOG" \
            | gzip > "$snapshot_file"; then
        print_message "ERROR" "Не удалось создать safety snapshot. Восстановление прервано."
        rm -f "$snapshot_file"
        return 1
    fi
    local snap_size; snap_size=$(du -h "$snapshot_file" 2>/dev/null | cut -f1)
    print_message "SUCCESS" "Snapshot: $snapshot_file ($snap_size)"

    # === 5. Создание временной БД и заливка старого дампа ===
    echo ""
    print_message "INFO" "Создание временной БД '$temp_db'..."
    if ! docker exec "$DB_CONTAINER_NAME" psql -U "$_RH_DB_USER" -d postgres \
            -c "CREATE DATABASE \"$temp_db\"" > "$SILENT_LOG" 2>&1; then
        print_message "ERROR" "CREATE DATABASE $temp_db не удалось."
        return 1
    fi

    print_message "INFO" "Загрузка старого дампа в $temp_db (это может занять время)..."
    local load_rc=0
    if [[ "$old_dump" =~ \.gz$ ]]; then
        zcat "$old_dump" | docker exec -i "$DB_CONTAINER_NAME" \
            psql -U "$_RH_DB_USER" -d "$temp_db" -v ON_ERROR_STOP=0 > "$SILENT_LOG" 2>&1 || load_rc=$?
    else
        docker exec -i "$DB_CONTAINER_NAME" \
            psql -U "$_RH_DB_USER" -d "$temp_db" -v ON_ERROR_STOP=0 < "$old_dump" > "$SILENT_LOG" 2>&1 || load_rc=$?
    fi

    # Проверяем что таблицы customer/purchase/referral реально появились
    local _check
    _check=$(_rh_psql_q "$temp_db" "SELECT count(*) FROM information_schema.tables WHERE table_schema='public' AND table_name IN ('customer','purchase','referral')")
    if [[ "$_check" != "3" ]]; then
        print_message "ERROR" "После загрузки дампа в $temp_db найдено таблиц customer/purchase/referral: ${_check:-0}/3."
        print_message "ERROR" "Дамп либо повреждён, либо это не дамп бота."
        docker exec "$DB_CONTAINER_NAME" psql -U "$_RH_DB_USER" -d postgres \
            -c "DROP DATABASE \"$temp_db\"" > "$SILENT_LOG" 2>&1
        return 1
    fi
    print_message "SUCCESS" "Старый дамп загружен (rc=$load_rc, customer/purchase/referral присутствуют)"

    local total_failures=0

    # === STEP 1: Исправление created_at ===
    echo ""
    echo -e "${BOLD}━━━ Шаг 1/3: customer.created_at ━━━${RESET}"
    local n_corrupt
    n_corrupt=$(_rh_psql_q "$_RH_DB_NAME" "SELECT count(*) FROM customer WHERE created_at = '$CORRUPT_DATE'")
    n_corrupt=${n_corrupt:-0}
    local n_old_customers
    n_old_customers=$(_rh_psql_q "$temp_db" "SELECT count(*) FROM customer")
    n_old_customers=${n_old_customers:-0}
    echo "  В текущей БД с фейковой датой: $n_corrupt"
    echo "  В старом дампе (источник):     $n_old_customers"

    if [[ "$n_corrupt" -gt 0 && "$n_old_customers" -gt 0 ]]; then
        local proceed1="y"
        if [[ "$auto_yes" != "true" ]]; then
            read -erp "Выполнить Шаг 1? [Y/n]: " proceed1
            proceed1="${proceed1:-y}"
        fi
        if [[ "$proceed1" =~ ^[YyДд]$ ]]; then
            print_message "INFO" "Перенос (telegram_id, created_at) и UPDATE..."
            local rc1=0
            {
                printf '%s\n' \
                    'BEGIN;' \
                    'CREATE TEMP TABLE _ohist (telegram_id BIGINT, created_at TIMESTAMPTZ);' \
                    'COPY _ohist FROM STDIN;'
                docker exec "$DB_CONTAINER_NAME" psql -U "$_RH_DB_USER" -d "$temp_db" \
                    -tAc "COPY (SELECT telegram_id, created_at FROM customer WHERE telegram_id IS NOT NULL) TO STDOUT" 2> "$SILENT_LOG"
                printf '\\.\n'
                printf '%s\n' \
                    'UPDATE customer c' \
                    '   SET created_at = h.created_at' \
                    '  FROM _ohist h' \
                    ' WHERE c.telegram_id = h.telegram_id' \
                    "   AND c.created_at = '$CORRUPT_DATE';" \
                    'COMMIT;'
            } | _rh_psql_run "$_RH_DB_NAME" || rc1=$?
            if [[ $rc1 -eq 0 ]]; then
                local n_after
                n_after=$(_rh_psql_q "$_RH_DB_NAME" "SELECT count(*) FROM customer WHERE created_at = '$CORRUPT_DATE'")
                local fixed=$(( n_corrupt - ${n_after:-0} ))
                print_message "SUCCESS" "Шаг 1: исправлено $fixed записей (осталось с фейк-датой: ${n_after:-?})"
            else
                print_message "ERROR" "Шаг 1: psql вернул rc=$rc1"
                total_failures=$((total_failures + 1))
            fi
        else
            print_message "INFO" "Шаг 1 пропущен."
        fi
    else
        print_message "INFO" "Нет данных для Шага 1 (n_corrupt=$n_corrupt, n_old=$n_old_customers)."
    fi

    # === STEP 2: Восстановление purchase ===
    echo ""
    echo -e "${BOLD}━━━ Шаг 2/3: purchase (старые платежи) ━━━${RESET}"
    local n_old_purch
    n_old_purch=$(_rh_psql_q "$temp_db" "SELECT count(*) FROM purchase WHERE created_at < '$CUTOFF_DATE'")
    n_old_purch=${n_old_purch:-0}
    echo "  Старых платежей до $CUTOFF_DATE: $n_old_purch"

    if [[ "$n_old_purch" -gt 0 ]]; then
        local proceed2="y"
        if [[ "$auto_yes" != "true" ]]; then
            read -erp "Выполнить Шаг 2? [Y/n]: " proceed2
            proceed2="${proceed2:-y}"
        fi
        if [[ "$proceed2" =~ ^[YyДд]$ ]]; then
            print_message "INFO" "Перенос старых purchase через telegram_id..."
            local rc2=0
            local _s2_pre _s2_post
            _s2_pre=$(cat <<'SQL_S2_PRE'
BEGIN;
CREATE TEMP TABLE _opurch (
    telegram_id        BIGINT,
    amount             NUMERIC,
    created_at         TIMESTAMPTZ,
    month              INTEGER,
    paid_at            TIMESTAMPTZ,
    currency           TEXT,
    expire_at          TIMESTAMPTZ,
    status             TEXT,
    invoice_type       TEXT,
    crypto_invoice_id  TEXT,
    crypto_invoice_url TEXT,
    yookasa_url        TEXT,
    yookasa_id         TEXT
);
COPY _opurch FROM STDIN;
SQL_S2_PRE
)
            _s2_post=$(cat <<'SQL_S2_POST'
INSERT INTO purchase (
    amount, customer_id, created_at, month, paid_at,
    currency, expire_at, status, invoice_type,
    crypto_invoice_id, crypto_invoice_url, yookasa_url, yookasa_id
)
SELECT
    p.amount, c.id, p.created_at, p.month, p.paid_at,
    p.currency, p.expire_at, p.status, p.invoice_type,
    p.crypto_invoice_id, p.crypto_invoice_url, p.yookasa_url, p.yookasa_id
  FROM _opurch p
  JOIN customer c ON c.telegram_id = p.telegram_id;
COMMIT;
SQL_S2_POST
)
            {
                printf '%s\n' "$_s2_pre"
                docker exec "$DB_CONTAINER_NAME" psql -U "$_RH_DB_USER" -d "$temp_db" \
                    -tAc "COPY (SELECT oc.telegram_id, p.amount, p.created_at, p.month, p.paid_at, p.currency, p.expire_at, p.status, p.invoice_type, p.crypto_invoice_id, p.crypto_invoice_url, p.yookasa_url, p.yookasa_id FROM purchase p JOIN customer oc ON oc.id = p.customer_id WHERE p.created_at < '$CUTOFF_DATE') TO STDOUT" 2> "$SILENT_LOG"
                printf '\\.\n'
                printf '%s\n' "$_s2_post"
            } | _rh_psql_run "$_RH_DB_NAME" || rc2=$?
            if [[ $rc2 -eq 0 ]]; then
                local n_purch_after
                n_purch_after=$(_rh_psql_q "$_RH_DB_NAME" "SELECT count(*) FROM purchase WHERE created_at < '$CUTOFF_DATE'")
                print_message "SUCCESS" "Шаг 2: в текущей БД старых платежей теперь: ${n_purch_after:-?}"
            else
                print_message "ERROR" "Шаг 2: psql вернул rc=$rc2"
                print_message "WARN" "Возможно отсутствуют какие-то поля purchase в текущей схеме. См. snapshot для отката."
                total_failures=$((total_failures + 1))
            fi
        else
            print_message "INFO" "Шаг 2 пропущен."
        fi
    else
        print_message "INFO" "Нет старых платежей в дампе."
    fi

    # === STEP 3: Восстановление referral ===
    echo ""
    echo -e "${BOLD}━━━ Шаг 3/3: referral (старые рефералы) ━━━${RESET}"
    local n_old_ref
    n_old_ref=$(_rh_psql_q "$temp_db" "SELECT count(*) FROM referral WHERE used_at < '$CUTOFF_DATE'")
    n_old_ref=${n_old_ref:-0}
    echo "  Старых рефералов до $CUTOFF_DATE: $n_old_ref"

    if [[ "$n_old_ref" -gt 0 ]]; then
        local proceed3="y"
        if [[ "$auto_yes" != "true" ]]; then
            read -erp "Выполнить Шаг 3? [Y/n]: " proceed3
            proceed3="${proceed3:-y}"
        fi
        if [[ "$proceed3" =~ ^[YyДд]$ ]]; then
            print_message "INFO" "Перенос старых referral..."
            local rc3=0
            local _s3_pre _s3_post
            _s3_pre=$(cat <<'SQL_S3_PRE'
BEGIN;
CREATE TEMP TABLE _oref (
    referrer_id    BIGINT,
    referee_id     BIGINT,
    used_at        TIMESTAMPTZ,
    bonus_granted  BOOLEAN
);
COPY _oref FROM STDIN;
SQL_S3_PRE
)
            _s3_post=$(cat <<'SQL_S3_POST'
INSERT INTO referral (referrer_id, referee_id, used_at, bonus_granted)
SELECT o.referrer_id, o.referee_id, o.used_at, o.bonus_granted
  FROM _oref o
 WHERE NOT EXISTS (
       SELECT 1 FROM referral r
        WHERE r.referrer_id = o.referrer_id
          AND r.referee_id  = o.referee_id
 );
COMMIT;
SQL_S3_POST
)
            {
                printf '%s\n' "$_s3_pre"
                docker exec "$DB_CONTAINER_NAME" psql -U "$_RH_DB_USER" -d "$temp_db" \
                    -tAc "COPY (SELECT referrer_id, referee_id, used_at, bonus_granted FROM referral WHERE used_at < '$CUTOFF_DATE') TO STDOUT" 2> "$SILENT_LOG"
                printf '\\.\n'
                printf '%s\n' "$_s3_post"
            } | _rh_psql_run "$_RH_DB_NAME" || rc3=$?
            if [[ $rc3 -eq 0 ]]; then
                local n_ref_after
                n_ref_after=$(_rh_psql_q "$_RH_DB_NAME" "SELECT count(*) FROM referral WHERE used_at < '$CUTOFF_DATE'")
                print_message "SUCCESS" "Шаг 3: в текущей БД старых рефералов теперь: ${n_ref_after:-?}"
            else
                print_message "ERROR" "Шаг 3: psql вернул rc=$rc3"
                total_failures=$((total_failures + 1))
            fi
        else
            print_message "INFO" "Шаг 3 пропущен."
        fi
    else
        print_message "INFO" "Нет старых рефералов в дампе."
    fi

    # === 6. Cleanup временной БД ===
    echo ""
    print_message "INFO" "Удаление временной БД '$temp_db'..."
    docker exec "$DB_CONTAINER_NAME" psql -U "$_RH_DB_USER" -d postgres \
        -c "DROP DATABASE \"$temp_db\"" > "$SILENT_LOG" 2>&1 || \
        print_message "WARN" "Не удалось удалить $temp_db автоматически."

    # === 7. Итог ===
    echo ""
    if [[ $total_failures -eq 0 ]]; then
        echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
        echo -e "${GREEN}${BOLD}  ✓ recover-historical завершён без ошибок                         ${RESET}"
        echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
    else
        echo -e "${YELLOW}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
        echo -e "${YELLOW}${BOLD}  ⚠  recover-historical: $total_failures шаг(а) завершилось с ошибкой${RESET}"
        echo -e "${YELLOW}${BOLD}  Откат: zcat $snapshot_file | docker exec -i $DB_CONTAINER_NAME \\${RESET}"
        echo -e "${YELLOW}${BOLD}    psql -U $_RH_DB_USER -d $_RH_DB_NAME                            ${RESET}"
        echo -e "${YELLOW}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
    fi
    return $total_failures
}

case "$1" in
    backup_full) create_backup "full" ;;
    backup_db)   create_backup "db_only" ;;
    backup_files) create_backup "files_only" ;;
    backup|-B)
        case "$2" in
            create|full|-c)     create_backup "full" ;;
            db|-d)              create_backup "db_only" ;;
            files|-f)           create_backup "files_only" ;;
            list|-l)            menu_list_backups ;;
            *)
                echo "Использование: lazarus backup <команда>"
                echo "           или: lazarus -B <команда>"
                echo ""
                echo "Команды:"
                echo "  create, -c      - Создать полный бэкап (БД + файлы)"
                echo "  full            - Алиас для create"
                echo "  db,     -d      - Создать бэкап только БД"
                echo "  files,  -f      - Создать бэкап только файлов"
                echo "  list,   -l      - Список бэкапов"
                echo ""
                echo "Примеры:"
                echo "  lazarus backup create"
                echo "  lazarus backup db"
                echo "  lazarus -B -c"
                echo "  lazarus -B -d"
                ;;
        esac
        ;;
    cleanup|cleanup_old_backups)
        cleanup_old_backups ;;
    restore) menu_restore ;;
    check_update) check_for_updates ;;
    install-migrator) install_migrator ;;
    recover-historical) recover_historical_data "$2" "$3" ;;
    upgrade) auto_update_bot "$2" ;;
    bot|-b)
        case "$2" in
            up)                 bot_up ;;
            down)               bot_down ;;
            status|-s)          bot_status ;;
            upgrade|update|-u)  auto_update_bot "$3" ;;
            *)
                echo "Использование: lazarus bot <команда>"
                echo "           или: lazarus -b <команда>"
                echo ""
                echo "Команды:"
                echo "  up              - Запустить бота (если не запущен)"
                echo "  down            - Остановить бота"
                echo "  status,  -s     - Статус контейнера, версия, healthcheck"
                echo "  upgrade, -u     - Обновить бота до последней версии"
                echo "  update          - Алиас для upgrade"
                echo ""
                echo "Примеры:"
                echo "  lazarus bot status"
                echo "  lazarus bot upgrade"
                echo "  lazarus -b -s"
                echo "  lazarus -b -u"
                ;;
        esac
        ;;
    s3|-S)
        case "$2" in
            test|-t)
                # Тест подключения к S3
                if [[ "$REMOTE_STORAGE_TYPE" != "s3" ]]; then
                    echo -e "${RED}S3 не настроен!${RESET} Используйте: lazarus → Настройки → Удалённое хранилище"
                    exit 1
                fi
                echo "Проверка подключения к S3..."
                _s3_test_opts=()
                [[ -n "$S3_ENDPOINT" ]] && _s3_test_opts+=(--endpoint-url "$S3_ENDPOINT")
                [[ -n "$S3_REGION" ]] && _s3_test_opts+=(--region "$S3_REGION")
                if _s3_aws_run s3 ls "s3://${S3_BUCKET}/" "${_s3_test_opts[@]}" --max-items 1 > /dev/null 2>&1; then
                    echo -e "${GREEN}✓${RESET} Подключение успешно!"
                    echo "  Bucket: $S3_BUCKET"
                    [[ -n "$S3_PATH" ]] && echo "  Path: $S3_PATH"
                else
                    echo -e "${RED}✗${RESET} Ошибка подключения!"
                fi
                ;;
            list|-l)
                # Список файлов в S3
                if [[ "$REMOTE_STORAGE_TYPE" != "s3" ]]; then
                    echo -e "${RED}S3 не настроен!${RESET}"
                    exit 1
                fi
                _s3_list_opts=()
                [[ -n "$S3_ENDPOINT" ]] && _s3_list_opts+=(--endpoint-url "$S3_ENDPOINT")
                [[ -n "$S3_REGION" ]] && _s3_list_opts+=(--region "$S3_REGION")
                _s3_list_path="${S3_PATH%/}"
                [[ -n "$_s3_list_path" ]] && _s3_list_path="${_s3_list_path}/"
                echo "Файлы в s3://${S3_BUCKET}/${_s3_list_path}:"
                _s3_aws_run s3 ls "s3://${S3_BUCKET}/${_s3_list_path}" "${_s3_list_opts[@]}" --human-readable
                ;;
            upload|-u)
                # Загрузить файл в S3
                if [[ "$REMOTE_STORAGE_TYPE" != "s3" ]]; then
                    echo -e "${RED}S3 не настроен!${RESET}"
                    exit 1
                fi
                _s3_file_to_upload="$3"
                if [[ -z "$_s3_file_to_upload" ]]; then
                    echo "Использование: lazarus s3 upload <файл>"
                    exit 1
                fi
                if [[ ! -f "$_s3_file_to_upload" ]]; then
                    echo -e "${RED}Файл не найден: $_s3_file_to_upload${RESET}"
                    exit 1
                fi
                SEND_TO_REMOTE="true"
                upload_to_remote "$_s3_file_to_upload"
                ;;
            *)
                echo "Использование: lazarus s3 <команда>"
                echo "           или: lazarus -S <команда>"
                echo ""
                echo "Команды:"
                echo "  test,   -t      - Проверить подключение к S3"
                echo "  list,   -l      - Список файлов в bucket"
                echo "  upload, -u      - Загрузить файл в S3"
                echo ""
                echo "Примеры:"
                echo "  lazarus s3 test"
                echo "  lazarus s3 list"
                echo "  lazarus s3 upload backup.tar.gz"
                echo "  lazarus -S -t"
                ;;
        esac
        ;;
    *)
        # Проверка несоответствия cron при первом запуске интерактивного режима
        check_cron_mismatch
        
        # === ПРОВЕРКА ТРЕБОВАНИЙ ЛИЦЕНЗИИ ДЛЯ БОТА v3.25.5+ ===
        # Проверяем конфигурацию бота при старте скрипта
        
        # Если BOT_PATH пуст — пробуем найти автоматически
        if [[ -z "$BOT_PATH" || ! -d "$BOT_PATH" ]]; then
            # Пробуем стандартные пути
            for _try_path in "$DEFAULT_BOT_PATH" "/opt/rwp_shop" "/opt/remnawave-telegram-shop"; do
                if [[ -d "$_try_path" && ( -f "$_try_path/docker-compose.yml" || -f "$_try_path/compose.yaml" ) ]]; then
                    BOT_PATH="$_try_path"
                    break
                fi
            done
        fi
        
        if [[ -n "$BOT_PATH" && -d "$BOT_PATH" ]]; then
            _current_bot_version=$(get_current_bot_version 2>/dev/null)
            if [[ -n "$_current_bot_version" ]] && version_gte "$_current_bot_version" "3.25.5"; then
                _has_key=false
                _has_mid=false
                has_license_key && _has_key=true
                has_machine_id_volume && _has_mid=true
                
                if [[ "$_has_key" == "false" || "$_has_mid" == "false" ]]; then
                    clear_screen
                    echo -e "${RED}${BOLD}═══════════════════════════════════════════════════${RESET}"
                    echo -e "${RED}${BOLD}  ⚠️  ВНИМАНИЕ: ТРЕБУЕТСЯ НАСТРОЙКА ЛИЦЕНЗИИ${RESET}"
                    echo -e "${RED}${BOLD}═══════════════════════════════════════════════════${RESET}"
                    echo ""
                    echo -e "Бот версии ${CYAN}$_current_bot_version${RESET} требует LICENSE_KEY и machine-id."
                    echo ""
                    echo -e "${YELLOW}${BOLD}Статус конфигурации:${RESET}"
                    if [[ "$_has_key" == "true" ]]; then
                        echo -e "  LICENSE_KEY:     ${GREEN}✓ настроен${RESET}"
                    else
                        echo -e "  LICENSE_KEY:     ${RED}✗ отсутствует в .env${RESET}"
                    fi
                    if [[ "$_has_mid" == "true" ]]; then
                        echo -e "  machine-id:      ${GREEN}✓ настроен${RESET}"
                    else
                        echo -e "  machine-id:      ${RED}✗ отсутствует в compose${RESET}"
                    fi
                    echo ""
                    echo -e "Получить ключ: ${CYAN}https://t.me/rwp_shop_bot${RESET}"
                    echo ""
                    read -erp "Настроить сейчас? [Y/n]: " setup_now
                    if [[ ! "$setup_now" =~ ^[Nn]$ ]]; then
                        if [[ "$_has_key" == "false" ]]; then
                            ensure_license_key_in_env
                        fi
                        if [[ "$_has_mid" == "false" ]]; then
                            _compose_file=""
                            [[ -f "$BOT_PATH/compose.yaml" ]] && _compose_file="$BOT_PATH/compose.yaml"
                            [[ -f "$BOT_PATH/docker-compose.yml" ]] && _compose_file="$BOT_PATH/docker-compose.yml"
                            [[ -n "$_compose_file" ]] && ensure_machine_id_volume "$_compose_file"
                        fi
                    fi
                fi
            fi
        fi
        
        # Тихая проверка обновлений скрипта при первом запуске меню
        check_updates_silent 2>/dev/null
        
        while true; do
            # Получаем актуальные статусы из cron
            CRON_STATUS_FULL=$(get_cron_status "full")
            CRON_STATUS_DB=$(get_cron_status "db")
            CRON_STATUS_FILES=$(get_cron_status "files")
            
            # Получаем статистику бэкапов
            get_backup_stats
            
            # Цветовая индикация статусов cron
            # Full и DB — обязательные (красные если выключены оба), Files — опциональный (серый если выключен)
            NO_CRITICAL_BACKUP=false
            [[ "$CRON_STATUS_FULL" == "Выкл" && "$CRON_STATUS_DB" == "Выкл" ]] && NO_CRITICAL_BACKUP=true
            
            COLOR_FULL="$GRAY"; [[ "$CRON_STATUS_FULL" != "Выкл" ]] && COLOR_FULL="$YELLOW"
            COLOR_DB="$GRAY"; [[ "$CRON_STATUS_DB" != "Выкл" ]] && COLOR_DB="$YELLOW"
            COLOR_FILES="$GRAY"; [[ "$CRON_STATUS_FILES" != "Выкл" ]] && COLOR_FILES="$YELLOW"
            
            BOT_VERSION=$(get_bot_version_display)
            CONTAINER_STATUS=$(get_container_status)
            
            # Цвет статуса контейнера
            STATUS_COLOR="$GREEN"
            [[ "$CONTAINER_STATUS" != "Online" ]] && STATUS_COLOR="$RED"
            
            clear_screen
            echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════${RESET}"
            echo -e "${GREEN}${BOLD}  LAZARUS Backup Manager v${VERSION}${RESET}"
            echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════${RESET}"
            echo -e "Бот: ${CYAN}${BOT_VERSION}${RESET} | Контейнер: ${STATUS_COLOR}${CONTAINER_STATUS}${RESET}"
            echo ""
            
            # Уведомление о доступном обновлении скрипта
            if [[ -n "$UPDATE_AVAILABLE" && -n "$UPDATE_REMOTE_VERSION" ]]; then
                echo -e "${CYAN}${BOLD}🆕 Доступно обновление скрипта: ${VERSION} → ${UPDATE_REMOTE_VERSION}${RESET}"
                echo -e "${GRAY}   Выберите пункт 8 для обновления${RESET}"
                echo ""
            fi
            
            # Статистика бэкапов
            echo -e "Бэкапы: ${STATS_FULL} Full | ${STATS_DB} DB | ${STATS_FILES} Files | ${BOLD}${STATS_SIZE}${RESET} всего"
            if [[ -n "$STATS_LAST" ]]; then
                echo -e "Последний: ${STATS_LAST} (${STATS_LAST_AGO})"
            fi
            echo ""
            
            # Предупреждение если нет критических авто-бэкапов
            if [[ "$NO_CRITICAL_BACKUP" == true ]]; then
                echo -e "${RED}${BOLD}⚠️  ВНИМАНИЕ: Авто-бэкап не настроен!${RESET}"
                echo -e "${RED}   Рекомендуется включить Full или DB бэкап${RESET}"
                echo ""
            fi
            
            # Предупреждение если Telegram не настроен
            if [[ -z "$BOT_TOKEN" || -z "$CHAT_ID" ]]; then
                echo -e "${YELLOW}ℹ️  Telegram не настроен (уведомления отключены)${RESET}"
                echo ""
            fi
            
            echo -e "Авто-бэкап (cron):"
            echo -e " • Full:  ${COLOR_FULL}${CRON_STATUS_FULL}${RESET}"
            echo -e " • DB:    ${COLOR_DB}${CRON_STATUS_DB}${RESET}"
            echo -e " • Files: ${COLOR_FILES}${CRON_STATUS_FILES}${RESET}"
            echo ""
            echo " --- ДЕЙСТВИЯ ---"
            echo " 1. Ручной бекап (Full / DB / Files)"
            echo " 2. Настроить авто-бекап"
            echo " 3. Восстановить из бэкапа"
            echo " 4. Настройки (Пути / Токены / Ротация)"
            
            CLEANUP_LABEL=""
            if [[ "$DELETE_MODE" == "time" ]]; then
                CLEANUP_LABEL="(>$RETENTION_DAYS дней)"
            else
                CLEANUP_LABEL="(>$MAX_BACKUPS_COUNT шт.)"
            fi
            echo " 5. Удалить старые бэкапы $CLEANUP_LABEL"
            echo -e " 6. ${CYAN}Обновить бота${RESET}"
            echo -e " 7. ${MAGENTA}Миграция между ботами${RESET}"
            echo ""
            
            # Подсветка пункта обновления если доступно
            if [[ -n "$UPDATE_AVAILABLE" ]]; then
                echo -e " ${CYAN}${BOLD}8. Проверить обновления скрипта [NEW!]${RESET}"
            else
                echo -e " 8. Проверить обновления скрипта"
            fi
            echo -e "${RED} 666. Удалить скрипт (Uninstall)${RESET}"
            echo " 0. Выход"
            echo ""
            read -erp "Выбор (Enter - выход): " opt; [[ -z "$opt" ]] && exit 0
            case $opt in
                1) menu_manual_backup ;; 2) menu_automation ;; 3) menu_restore ;; 
                4) menu_settings ;; 5) cleanup_old_backups ;; 6) update_bot ;; 
                7) menu_migration ;; 8) check_for_updates ;; 666) uninstall_script ;; 0) exit 0 ;;
            esac
        done
        ;;
esac

fi
