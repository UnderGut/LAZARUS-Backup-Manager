# show_skipped_report: вывод полного отчёта о пропущенных файлах последнего бэкапа.
# Читает $BACKUP_DIR/.last_skipped.txt + meta, форматирует human-friendly, группирует
# по причине, страничный вывод через less при наличии.
show_skipped_report() {
    local report="$BACKUP_DIR/.last_skipped.txt"
    local meta="$BACKUP_DIR/.last_skipped.meta"

    clear_screen
    echo -e "${CYAN}${BOLD}━━━ Пропущенные файлы (последний бэкап) ━━━${RESET}"
    echo ""

    if [[ -f "$meta" ]]; then
        local _arch _bp _cnt _ts _note
        _arch=$(grep '^archive='   "$meta" | cut -d= -f2-)
        _bp=$(grep   '^bot_path='  "$meta" | cut -d= -f2-)
        _cnt=$(grep  '^count='     "$meta" | cut -d= -f2-)
        _ts=$(grep   '^timestamp=' "$meta" | cut -d= -f2-)
        _note=$(grep '^note='      "$meta" | cut -d= -f2-)
        echo -e "${GRAY}Архив:    ${_arch:-?}${RESET}"
        echo -e "${GRAY}BOT_PATH: ${_bp:-?}${RESET}"
        echo -e "${GRAY}Дата:     ${_ts:-?}${RESET}"
        echo -e "${GRAY}Файлов:   ${_cnt:-0}${RESET}"
        [[ -n "$_note" ]] && echo -e "${YELLOW}Примечание: ${_note}${RESET}"
        echo ""
    fi

    if [[ ! -f "$report" || ! -s "$report" ]]; then
        echo -e "${GREEN}✓ Все файлы вошли в архив. Пропущенных нет.${RESET}"
        echo ""
        read -erp "Enter..." dummy
        return 0
    fi

    # Группируем по причине + сортируем внутри группы по размеру
    local _tmp
    _tmp=$(mktemp 2> "$SILENT_LOG") || _tmp="/tmp/lazarus_skipped_view.$$"
    local _total_bytes
    _total_bytes=$(awk -F'\t' '{s+=$1} END{print s+0}' "$report")
    # Полные пути НЕ обрезаем — show_skipped_report детальный, без потерь префикса.
    awk -F'\t' '{print $3 "\t" $1 "\t" $2}' "$report" \
        | sort -t$'\t' -k1,1 -k2,2rn \
        | awk -F'\t' '
            BEGIN { last_reason = "" }
            {
                reason = $1; sz = $2; path = $3;
                if (reason != last_reason) {
                    if (last_reason != "") print "";
                    printf "\033[33m\033[1m[%s]\033[0m\n", reason;
                    last_reason = reason;
                }
                h = sz; u = "B";
                if (h>=1024) { h/=1024; u="K" }
                if (h>=1024) { h/=1024; u="M" }
                if (h>=1024) { h/=1024; u="G" }
                printf "  %7.1f%s  %s\n", h, u, path;
            }
        ' > "$_tmp"

    local _human_total
    _human_total=$(awk -v b="$_total_bytes" 'BEGIN{
        h=b; u="B";
        if (h>=1024) { h/=1024; u="K" }
        if (h>=1024) { h/=1024; u="M" }
        if (h>=1024) { h/=1024; u="G" }
        printf "%.1f%s", h, u
    }')

    echo -e "${GRAY}Общий вес пропущенных: ${_human_total}${RESET}"
    echo ""
    # less используем только если stdout — TTY. В non-tty (pipe, redirect)
    # `less` либо падает с "WARNING: terminal is not fully functional", либо ждёт.
    # При `lazarus skipped > file.txt` или `lazarus skipped | grep ...` — просто cat.
    if [[ -t 1 ]] && command -v less > "$SILENT_LOG" 2>&1; then
        # -R: пропускать ANSI-цвета
        # -F: auto-quit если контент влезает на один экран (output останется в терминале)
        # -X: не очищать экран при выходе (контент остаётся виден)
        # --prompt: показывает подсказку как выйти
        echo -e "${GRAY}💡 Стрелки/PgUp/PgDn — прокрутка, ${BOLD}q${RESET}${GRAY} — выход${RESET}"
        echo ""
        sleep 1
        less -R -F -X --prompt="[Пропущенные файлы] стрелки=прокрутка | q=выход" "$_tmp"
    else
        cat "$_tmp"
        # Prompt только в интерактиве (без него `lazarus skipped > file` тупо ждёт ввода)
        if [[ -t 0 && -t 1 ]]; then
            echo ""
            safe_read -rp "Enter — продолжить " dummy
        fi
    fi
    rm -f "$_tmp"
    return 0
}

# menu_list_backups: показать общий список бэкапов (все категории).
# Используется командой `lazarus backup list` / `lazarus -B -l`.
menu_list_backups() {
    clear_screen
    echo -e "${GREEN}${BOLD}Список бэкапов${RESET}"
    echo -e "${GRAY}Каталог: ${BACKUP_DIR}${RESET}"
    echo ""

    local total_count=0
    local total_size_bytes=0
    for prefix in lazarus_full lazarus_db lazarus_files; do
        local label
        case "$prefix" in
            lazarus_full)  label="📦 Полные (БД+файлы)" ;;
            lazarus_db)    label="🗄 Только БД" ;;
            lazarus_files) label="📂 Только файлы" ;;
        esac
        local files=()
        while IFS= read -r f; do [[ -n "$f" ]] && files+=("$f"); done < <(
            find "$BACKUP_DIR" -maxdepth 1 -type f \
                \( -name "${prefix}_*.tar.gz" -o -name "${prefix}_*.tar.gz.enc" \) 2> "$SILENT_LOG" | sort -r
        )
        local n=${#files[@]}
        total_count=$((total_count + n))
        if [[ $n -eq 0 ]]; then
            echo -e "  ${GRAY}${label}: пусто${RESET}"
        else
            local cat_bytes=0
            for f in "${files[@]}"; do
                local sz
                sz=$(stat -c%s "$f" 2>/dev/null || echo 0)
                cat_bytes=$((cat_bytes + sz))
            done
            total_size_bytes=$((total_size_bytes + cat_bytes))
            local cat_h
            cat_h=$(awk -v b="$cat_bytes" 'BEGIN{h=b;u="B";if(h>=1024){h/=1024;u="K"}if(h>=1024){h/=1024;u="M"}if(h>=1024){h/=1024;u="G"}printf "%.1f%s",h,u}')
            echo -e "  ${CYAN}${label}: ${n} шт${RESET} ${GRAY}(${cat_h})${RESET}"
            local _shown=0
            for f in "${files[@]}"; do
                [[ $_shown -ge 3 ]] && break
                local fname=$(basename "$f")
                local fsize=$(du -h "$f" 2>/dev/null | cut -f1)
                echo -e "      ${GRAY}${fsize}\t${fname}${RESET}"
                _shown=$((_shown + 1))
            done
            [[ $n -gt 3 ]] && echo -e "      ${GRAY}... ещё $((n - 3)) (см. меню 3 Восстановить)${RESET}"
        fi
    done

    local total_h
    total_h=$(awk -v b="$total_size_bytes" 'BEGIN{h=b;u="B";if(h>=1024){h/=1024;u="K"}if(h>=1024){h/=1024;u="M"}if(h>=1024){h/=1024;u="G"}printf "%.1f%s",h,u}')
    echo ""
    echo -e "${BOLD}Всего: ${total_count} файлов, ${total_h}${RESET}"
    echo ""
    safe_read -rp "Enter — назад " _dummy
}

menu_manual_backup() {
    while true; do
        clear_screen; echo -e "${GREEN}Создание ручного бэкапа${RESET}"
        echo " 1. Полный бэкап (БД + Файлы)"
        echo " 2. Только БД"
        echo " 3. Только Файлы"
        echo " 0. Назад"
        echo ""
        safe_read -erp "Ваш выбор (Enter - Назад): " m_choice
        [[ -z "$m_choice" ]] && return
        case $m_choice in
            1) create_backup "full";       _post_backup_prompt; return ;;
            2) create_backup "db_only";    _post_backup_prompt; return ;;
            3) create_backup "files_only"; _post_backup_prompt; return ;;
            0) return ;;
        esac
    done
}

# _post_backup_prompt: интерактивный prompt после create_backup с опциями:
#   77 — топ-5 крупных файлов в архиве (что попало)
#   88 — пропущенные файлы (что НЕ попало) с группировкой по причине
#   99 — настроить удалённое хранилище (если REMOTE_STORAGE_TYPE=off)
#   Enter / 0 — вернуться в меню
_post_backup_prompt() {
    local _skipped="$BACKUP_DIR/.last_skipped.txt"
    local _has_skipped=0
    [[ -f "$_skipped" && -s "$_skipped" ]] && _has_skipped=$(wc -l < "$_skipped" | tr -d ' ')

    while true; do
        printf '\n'
        printf '%s\n' "─────────────────────────────────────────────"
        printf '%s\n' "  77 — топ-5 крупных файлов в архиве"
        if [[ "$_has_skipped" -gt 0 ]]; then
            printf '%b\n' "  ${YELLOW}88${RESET} — пропущенные файлы (${_has_skipped} шт)"
        fi
        if [[ "$REMOTE_STORAGE_TYPE" == "off" ]]; then
            printf '%b\n' "  ${RED}99${RESET} — настроить S3 / FTP / WebDAV хранилище"
        fi
        printf '%s\n' "  Enter или 0 — вернуться"
        printf '%s\n' "─────────────────────────────────────────────"
        safe_read -rp "Ваш выбор: " _pb_choice
        case "$_pb_choice" in
            77) _show_top_in_archive ;;
            88)
                if [[ "$_has_skipped" -gt 0 ]]; then
                    show_skipped_report
                else
                    print_message "INFO" "Пропущенных файлов нет."
                    sleep 1
                fi
                ;;
            99)
                if [[ "$REMOTE_STORAGE_TYPE" == "off" ]]; then
                    configure_remote_storage
                else
                    print_message "INFO" "Хранилище уже настроено: $REMOTE_STORAGE_TYPE"
                    sleep 1
                fi
                ;;
            ""|0) return ;;
            *) print_message "ERROR" "Введите 77, 88, 99 или Enter" ; sleep 1 ;;
        esac
    done
}

# _show_top_in_archive: показывает топ-5 крупных файлов которые ПОПАЛИ в архив.
# Используется из пункта 77 в _post_backup_prompt.
_show_top_in_archive() {
    clear_screen
    echo -e "${CYAN}${BOLD}━━━ Самые крупные файлы в архиве (топ-5) ━━━${RESET}"
    if [[ -z "$BOT_PATH" || ! -d "$BOT_PATH" ]]; then
        echo -e "${GRAY}(BOT_PATH не задан)${RESET}"
    else
        echo -e "${GRAY}из ${BOT_PATH}${RESET}"
        echo ""
        local _top
        _top=$(get_top_files_in_archive "$BOT_PATH" "${MAX_FILE_SIZE_MB:-0}" "${EXCLUDE_DIRS:-}" 5 2> "$SILENT_LOG")
        if [[ -n "$_top" ]]; then
            echo "$_top"
        else
            echo -e "${GRAY}(нет данных, требуется GNU find -printf)${RESET}"
        fi
    fi
    echo ""
    echo -e "${GRAY}💡 Чтобы исключить — Настройки → 5 (EXCLUDE_DIRS) или → 6 (MAX_FILE_SIZE_MB)${RESET}"
    echo ""
    safe_read -rp "Enter — назад " _dummy
}

menu_restore() {
    while true; do
        # СТРОГАЯ ЛОГИКА ПОДСЧЕТА
        local n_full=$(find "$BACKUP_DIR" -type f \( -name "lazarus_full_*.tar.gz" -o -name "lazarus_full_*.tar.gz.enc" \) 2> "$SILENT_LOG" | wc -l)
        local n_db=$(find "$BACKUP_DIR" -type f \( -name "lazarus_db_*.tar.gz" -o -name "lazarus_db_*.tar.gz.enc" \) 2> "$SILENT_LOG" | wc -l)
        local n_files=$(find "$BACKUP_DIR" -type f \( -name "lazarus_files_*.tar.gz" -o -name "lazarus_files_*.tar.gz.enc" \) 2> "$SILENT_LOG" | wc -l)

        local c_f="$CYAN"; [[ "$n_full" == "0" ]] && c_f="$GRAY"
        local c_d="$CYAN"; [[ "$n_db" == "0" ]] && c_d="$GRAY"
        local c_fl="$CYAN"; [[ "$n_files" == "0" ]] && c_fl="$GRAY"

        clear_screen; echo -e "${GREEN}Меню восстановления${RESET}"
        echo -e " 1. Полный бэкап      ${c_f}[${n_full} шт]${RESET}"
        echo -e " 2. Только БД         ${c_d}[${n_db} шт]${RESET}"
        echo -e " 3. Только Файлы      ${c_fl}[${n_files} шт]${RESET}"
        echo " 0. Назад"
        echo ""
        read -erp "Выбор (Enter - Назад): " r_choice
        [[ -z "$r_choice" ]] && return

        local SELECTED_FILE=""
        case $r_choice in
            1) if select_backup_file "lazarus_full" "Полные бэкапы"; then execute_restore "full" "$SELECTED_FILE"; fi ;;
            2) if select_backup_file "lazarus_db" "Бэкапы БД"; then execute_restore "db_only" "$SELECTED_FILE"; fi ;;
            3) if select_backup_file "lazarus_files" "Бэкапы Файлов"; then
                   execute_restore "files_only" "$SELECTED_FILE"
               fi ;;
            0) return ;;
        esac
    done
}

setup_cron_task() {
    local TASK_TYPE="$1"; local JOB_CMD=""; local JOB_ID=""
    if [[ "$TASK_TYPE" == "db" ]]; then JOB_CMD="$SYMLINK_PATH backup_db"; JOB_ID="# LAZARUS-JOB-DB"
    elif [[ "$TASK_TYPE" == "files" ]]; then if ! ensure_bot_path; then return; fi; JOB_CMD="$SYMLINK_PATH backup_files"; JOB_ID="# LAZARUS-JOB-FILES"
    elif [[ "$TASK_TYPE" == "full" ]]; then if ! ensure_bot_path; then return; fi; JOB_CMD="$SYMLINK_PATH backup_full"; JOB_ID="# LAZARUS-JOB-FULL"; fi

    # Получаем текущий статус
    local CURRENT_STATUS=$(get_cron_status "$TASK_TYPE")
    local STATUS_COLOR="$GRAY"; [[ "$CURRENT_STATUS" != "Выкл" ]] && STATUS_COLOR="$YELLOW"
    
    # Человекочитаемое название типа
    local TYPE_NAME=""
    case "$TASK_TYPE" in
        "full") TYPE_NAME="Полный бэкап" ;;
        "db") TYPE_NAME="Только БД" ;;
        "files") TYPE_NAME="Только Файлы" ;;
    esac

    clear_screen
    echo -e "${GREEN}${BOLD}Настройка расписания: ${TYPE_NAME}${RESET}"
    echo -e "Текущий статус: [${STATUS_COLOR}${CURRENT_STATUS}${RESET}]"
    echo ""
    echo -e " 1. Ежечасно          ${GRAY}[в :00]${RESET}"
    echo -e " 2. Ежедневно         ${GRAY}[в 04:00]${RESET}"
    echo -e " 3. Еженедельно       ${GRAY}[Пн в 04:00]${RESET}"
    echo -e " 4. Своё время        ${GRAY}[ЧЧ:ММ]${RESET}"
    echo -e " 5. Каждые N минут    ${GRAY}[1-59]${RESET}"
    echo ""
    if [[ "$CURRENT_STATUS" != "Выкл" ]]; then
        echo -e " ${RED}0. Отключить${RESET}"
    else
        echo " 0. Назад"
    fi
    echo ""
    read -erp "Выбор (Enter - Назад): " c
    [[ -z "$c" ]] && return
    
    local NEW_CRON_LINES=""; local DISPLAY_TIME=""

    case $c in
        1) NEW_CRON_LINES="0 * * * * $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"; DISPLAY_TIME="Ежечасно" ;;
        2) NEW_CRON_LINES="0 4 * * * $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"; DISPLAY_TIME="Ежедневно 04:00" ;;
        3) NEW_CRON_LINES="0 4 * * 1 $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"; DISPLAY_TIME="Еженедельно" ;;
        4) 
           echo ""
           echo "Введите время (ЧЧ:ММ), можно несколько через пробел:"
           echo -e "${GRAY}Пример: 09:00 18:30${RESET}"
           read -erp "> " times_input
           if [[ -z "$times_input" ]]; then print_message "ERROR" "Время не введено!"; sleep 1; return; fi
           for t in $times_input; do 
               if [[ "$t" =~ ^([0-9]{1,2}):([0-9]{1,2})$ ]]; then 
                   h=$((10#${BASH_REMATCH[1]})); m=$((10#${BASH_REMATCH[2]}))
                   NEW_CRON_LINES+="$m $h * * * $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"$'\n'
               fi
           done
           DISPLAY_TIME="Свое: $times_input" ;;
        5) 
           echo ""
           echo "Введите интервал в минутах (1-59):"
           read -erp "> " interval
           if [[ "$interval" =~ ^[0-9]+$ ]] && [ "$interval" -gt 0 ] && [ "$interval" -lt 60 ]; then
               NEW_CRON_LINES="*/$interval * * * * $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"
               DISPLAY_TIME="Каждые $interval мин"
           else print_message "ERROR" "Введите число от 1 до 59."; sleep 1; return; fi ;;
        0) 
           if [[ "$CURRENT_STATUS" != "Выкл" ]]; then
               DISPLAY_TIME="Выкл"
           else
               return
           fi ;;
        *) return ;;
    esac

    local CURRENT_CRON=$(crontab -l 2> "$SILENT_LOG" | grep -v "$JOB_ID")
    if [[ "$DISPLAY_TIME" != "Выкл" && -n "$NEW_CRON_LINES" ]]; then echo -e "$CURRENT_CRON\n$NEW_CRON_LINES" | crontab -
    else echo "$CURRENT_CRON" | crontab -; fi

    # Синхронизируем настройки с реальным состоянием cron
    sync_cron_with_config
    
    log_message "INFO" "Cron task updated: $TASK_TYPE -> $DISPLAY_TIME"
    print_message "SUCCESS" "Расписание обновлено!"; sleep 1
}

menu_automation() {
    while true; do
        # Получаем актуальные статусы из cron
        local CRON_FULL=$(get_cron_status "full")
        local CRON_DB=$(get_cron_status "db")
        local CRON_FILES=$(get_cron_status "files")
        
        # Цветовая индикация: жёлтый если активен, серый если выключен
        local COLOR_FULL="$GRAY"; [[ "$CRON_FULL" != "Выкл" ]] && COLOR_FULL="$YELLOW"
        local COLOR_DB="$GRAY"; [[ "$CRON_DB" != "Выкл" ]] && COLOR_DB="$YELLOW"
        local COLOR_FILES="$GRAY"; [[ "$CRON_FILES" != "Выкл" ]] && COLOR_FILES="$YELLOW"
        
        # Проверяем есть ли хоть один активный авто-бэкап
        local HAS_ANY_CRON=false
        [[ "$CRON_FULL" != "Выкл" || "$CRON_DB" != "Выкл" || "$CRON_FILES" != "Выкл" ]] && HAS_ANY_CRON=true
        
        clear_screen
        echo -e "${GREEN}${BOLD}Настройка Автоматического Бэкапа${RESET}"
        echo ""
        echo -e " 1. Полный бэкап  [${COLOR_FULL}${CRON_FULL}${RESET}]"
        echo -e " 2. Только БД     [${COLOR_DB}${CRON_DB}${RESET}]"
        echo -e " 3. Только Файлы  [${COLOR_FILES}${CRON_FILES}${RESET}]"
        echo ""
        if [[ "$HAS_ANY_CRON" == true ]]; then
            echo -e " ${RED}9. Отключить все авто-бэкапы${RESET}"
            echo ""
        fi
        echo " 0. Назад"
        echo ""
        read -erp "Выбор (Enter - Назад): " ac
        [[ -z "$ac" ]] && return
        case $ac in
            1) setup_cron_task "full" ;;
            2) setup_cron_task "db" ;;
            3) setup_cron_task "files" ;;
            9) 
                if [[ "$HAS_ANY_CRON" == true ]]; then
                    disable_all_cron_tasks
                fi
                ;;
            0) return ;;
        esac
    done
}

# Отключение всех cron-задач LAZARUS
disable_all_cron_tasks() {
    echo ""
    print_message "WARN" "Вы уверены, что хотите отключить ВСЕ авто-бэкапы?"
    read -erp "Подтвердить? (y/n): " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        # Удаляем все cron-задачи LAZARUS
        local current_cron
        current_cron=$(crontab -l 2> "$SILENT_LOG" || echo "")
        local new_cron
        new_cron=$(echo "$current_cron" | grep -v "# LAZARUS-JOB-")
        
        if [[ -z "$new_cron" ]]; then
            crontab -r 2> "$SILENT_LOG" || true
        else
            echo "$new_cron" | crontab -
        fi
        
        # Обновляем конфиг
        SCHEDULE_FULL="Выкл"
        SCHEDULE_DB="Выкл"
        SCHEDULE_FILES="Выкл"
        save_config
        
        print_message "SUCCESS" "Все авто-бэкапы отключены"
        log_message "INFO" "All LAZARUS cron tasks disabled by user"
        sleep 1.5
    else
        print_message "INFO" "Отменено"
        sleep 1
    fi
}

