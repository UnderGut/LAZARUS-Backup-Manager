# --- Функция: Определить тип архива Bedolaga ---
# Возвращает: tar.gz | zip | tar | unknown
detect_bedolaga_archive_type() {
    local archive_path="$1"
    local file_name=$(basename "$archive_path")
    
    # Функция для чтения magic bytes без xxd
    get_magic_bytes() {
        local file="$1"
        local len="${2:-2}"
        if command -v xxd &>/dev/null; then
            xxd -l"$len" -p "$file" 2>/dev/null
        elif command -v od &>/dev/null; then
            od -An -tx1 -N"$len" "$file" 2>/dev/null | tr -d ' \n'
        else
            # Fallback: head + hexdump-like через printf
            head -c"$len" "$file" 2>/dev/null | od -An -tx1 2>/dev/null | tr -d ' \n'
        fi
    }
    
    # Проверка по расширению + magic bytes
    
    # ZIP: расширение .zip или .tar.zip
    if [[ "$file_name" == *.tar.zip ]] || [[ "$file_name" == *.zip ]]; then
        local magic=$(get_magic_bytes "$archive_path" 2)
        if [[ "$magic" == "504b" ]]; then  # PK
            echo "zip"
            return 0
        fi
    fi
    
    # TAR.GZ: расширение .tar.gz или .tgz
    if [[ "$file_name" == *.tar.gz ]] || [[ "$file_name" == *.tgz ]]; then
        local magic=$(get_magic_bytes "$archive_path" 2)
        if [[ "$magic" == "1f8b" ]]; then  # gzip magic
            echo "tar.gz"
            return 0
        fi
    fi
    
    # Plain TAR
    if [[ "$file_name" == *.tar ]]; then
        echo "tar"
        return 0
    fi
    
    # Если расширение не помогло — проверяем по magic bytes
    local magic=$(get_magic_bytes "$archive_path" 2)
    case "$magic" in
        504b)  echo "zip"; return 0 ;;      # PK (ZIP)
        1f8b)  echo "tar.gz"; return 0 ;;   # gzip
    esac
    
    echo "unknown"
    return 1
}

# --- Функция: Проверить и установить unzip если нужно ---
ensure_unzip_installed() {
    # Если уже установлен — ничего не делаем
    command -v unzip &>/dev/null && return 0
    
    debug_log "MIGRATE" "unzip not found, attempting auto-install"
    
    # Пытаемся установить в зависимости от пакетного менеджера
    if command -v apt-get &>/dev/null; then
        apt-get update -qq 2>/dev/null && apt-get install -y -qq unzip >/dev/null 2>&1
    elif command -v yum &>/dev/null; then
        yum install -y -q unzip >/dev/null 2>&1
    elif command -v dnf &>/dev/null; then
        dnf install -y -q unzip >/dev/null 2>&1
    elif command -v apk &>/dev/null; then
        apk add --quiet unzip >/dev/null 2>&1
    elif command -v pacman &>/dev/null; then
        pacman -S --noconfirm --quiet unzip >/dev/null 2>&1
    elif command -v zypper &>/dev/null; then
        zypper install -y -q unzip >/dev/null 2>&1
    fi
    
    # Проверяем успешность
    if command -v unzip &>/dev/null; then
        debug_log "MIGRATE" "unzip installed successfully"
        return 0
    else
        debug_log "MIGRATE" "Failed to install unzip"
        return 1
    fi
}

# --- Функция: Проверить и установить 7z (p7zip) если нужно ---
# 7z нужен для AES-зашифрованных ZIP архивов (unzip не поддерживает AES)
ensure_7z_installed() {
    # Проверяем разные варианты имён
    command -v 7z &>/dev/null && return 0
    command -v 7za &>/dev/null && return 0
    command -v 7zr &>/dev/null && return 0
    
    debug_log "MIGRATE" "7z not found, attempting auto-install"
    
    # Пытаемся установить в зависимости от пакетного менеджера
    if command -v apt-get &>/dev/null; then
        apt-get update -qq 2>/dev/null && apt-get install -y -qq p7zip-full >/dev/null 2>&1
    elif command -v yum &>/dev/null; then
        yum install -y -q p7zip p7zip-plugins >/dev/null 2>&1
    elif command -v dnf &>/dev/null; then
        dnf install -y -q p7zip p7zip-plugins >/dev/null 2>&1
    elif command -v apk &>/dev/null; then
        apk add --quiet p7zip >/dev/null 2>&1
    elif command -v pacman &>/dev/null; then
        pacman -S --noconfirm --quiet p7zip >/dev/null 2>&1
    elif command -v zypper &>/dev/null; then
        zypper install -y -q p7zip >/dev/null 2>&1
    fi
    
    # Проверяем успешность
    if command -v 7z &>/dev/null || command -v 7za &>/dev/null; then
        debug_log "MIGRATE" "7z installed successfully"
        return 0
    else
        debug_log "MIGRATE" "Failed to install 7z"
        return 1
    fi
}

# --- Функция: Получить команду 7z ---
get_7z_command() {
    command -v 7z &>/dev/null && echo "7z" && return 0
    command -v 7za &>/dev/null && echo "7za" && return 0
    command -v 7zr &>/dev/null && echo "7zr" && return 0
    return 1
}

# --- Функция: Проверить, использует ли ZIP AES шифрование ---
is_zip_aes_encrypted() {
    local archive_path="$1"
    
    # Проверяем через file command
    if file "$archive_path" 2>/dev/null | grep -qi "AES"; then
        return 0  # AES шифрование
    fi
    
    # Альтернативная проверка через unzip -v
    if unzip -v "$archive_path" 2>&1 | grep -qi "AES"; then
        return 0
    fi
    
    return 1  # Не AES
}

# --- Функция: Проверить, требует ли архив пароль ---
# Поддерживает:
#   1) ZIP с ZipCrypto шифрованием (unzip)
#   2) ZIP с AES шифрованием (7z)
is_archive_password_protected() {
    local archive_path="$1"
    local archive_type=$(detect_bedolaga_archive_type "$archive_path")
    
    if [[ "$archive_type" != "zip" ]]; then
        return 1  # Только ZIP может быть защищён паролем
    fi
    
    # Проверяем AES шифрование (unzip не поддерживает AES!)
    if is_zip_aes_encrypted "$archive_path"; then
        debug_log "MIGRATE" "Archive uses AES encryption"
        return 0  # AES = требуется пароль
    fi
    
    # Убеждаемся что unzip установлен
    ensure_unzip_installed || return 1
    
    # Для ZipCrypto — пробуем распаковать без пароля
    local temp_dir=$(mktemp -d)
    
    if unzip -o -q "$archive_path" -d "$temp_dir" 2>/dev/null; then
        # ZIP распаковался без пароля — проверяем содержимое
        if find "$temp_dir" -name "database.json" 2>/dev/null | grep -q . || \
           find "$temp_dir" -name "*.tar.gz" 2>/dev/null | grep -q .; then
            rm -rf "$temp_dir"
            return 1  # Пароль НЕ требуется
        fi
    fi
    
    rm -rf "$temp_dir"
    return 0  # Требуется пароль
}

# --- Функция: Healthcheck архива Bedolaga ---
# Проверяет: целостность архива, наличие database.json, структуру JSON
# Поддерживает: tar.gz, tar, zip (в т.ч. запароленный)
migration_healthcheck_archive() {
    local archive_path="${1:-$MIGRATION_SOURCE_BACKUP}"
    local verbose="${2:-true}"
    local errors=0
    local warnings=0
    
    # Убеждаемся что unzip установлен (для ZIP архивов)
    ensure_unzip_installed 2>/dev/null
    
    [[ "$verbose" == "true" ]] && echo -e "\n${CYAN}━━━ 🏥 HEALTHCHECK: Архив Bedolaga ━━━${RESET}\n"
    
    # 1) Файл существует
    if [[ ! -f "$archive_path" ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Файл не найден: $archive_path"
        return 1
    fi
    [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Файл существует"
    
    # 2) Размер файла > 0
    local file_size=$(stat -c%s "$archive_path" 2>/dev/null || stat -f%z "$archive_path" 2>/dev/null)
    if [[ -z "$file_size" || "$file_size" -eq 0 ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Файл пустой"
        return 1
    fi
    local size_human=$(numfmt --to=iec-i --suffix=B "$file_size" 2>/dev/null || echo "${file_size} bytes")
    [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Размер файла: $size_human"
    
    # 3) Определяем тип архива
    local archive_type=$(detect_bedolaga_archive_type "$archive_path")
    [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Тип архива: $archive_type"
    
    if [[ "$archive_type" == "unknown" ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Неизвестный формат архива"
        return 1
    fi
    
    # 4) Проверка защиты паролем (только для ZIP)
    local needs_password=false
    if [[ "$archive_type" == "zip" ]]; then
        if is_archive_password_protected "$archive_path"; then
            needs_password=true
            [[ "$verbose" == "true" ]] && echo -e "  ${YELLOW}🔒${RESET} Архив защищён паролем"
            
            # Проверяем есть ли сохранённый пароль
            if [[ -z "$BEDOLAGA_BACKUP_PASSWORD" ]]; then
                [[ "$verbose" == "true" ]] && echo -e "  ${YELLOW}○${RESET} Пароль потребуется при распаковке"
                ((warnings++))
            else
                [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Пароль сохранён"
            fi
        else
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Архив не защищён паролем"
        fi
    fi
    
    # 5) Проверка целостности
    case "$archive_type" in
        "tar.gz")
            if ! gzip -t "$archive_path" 2>/dev/null; then
                [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Повреждён gzip архив"
                return 1
            fi
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Целостность gzip: OK"
            
            if ! tar -tzf "$archive_path" &>/dev/null; then
                [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Повреждён tar архив"
                return 1
            fi
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Целостность tar: OK"
            ;;
        "tar")
            if ! tar -tf "$archive_path" &>/dev/null; then
                [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Повреждён tar архив"
                return 1
            fi
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Целостность tar: OK"
            ;;
        "zip")
            # Для защищённых ZIP проверяем с паролем если он есть
            if [[ "$needs_password" == "true" ]]; then
                if [[ -n "$BEDOLAGA_BACKUP_PASSWORD" ]]; then
                    # Пробуем проверить с паролем через 7z или unzip
                    local integrity_ok=false
                    if is_zip_aes_encrypted "$archive_path"; then
                        # AES — только 7z
                        if ensure_7z_installed; then
                            local cmd_7z=$(get_7z_command)
                            if $cmd_7z t -p"$BEDOLAGA_BACKUP_PASSWORD" "$archive_path" &>/dev/null; then
                                integrity_ok=true
                            fi
                        fi
                    else
                        # ZipCrypto — unzip
                        if unzip -t -P "$BEDOLAGA_BACKUP_PASSWORD" "$archive_path" &>/dev/null; then
                            integrity_ok=true
                        fi
                    fi
                    
                    if [[ "$integrity_ok" == "true" ]]; then
                        [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Целостность ZIP: OK (проверено с паролем)"
                    else
                        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Ошибка целостности или неверный пароль"
                        ((errors++))
                    fi
                else
                    [[ "$verbose" == "true" ]] && echo -e "  ${YELLOW}○${RESET} Целостность ZIP: требуется пароль для проверки"
                    ((warnings++))
                fi
            else
                if ! unzip -t "$archive_path" &>/dev/null; then
                    [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Повреждён ZIP архив"
                    return 1
                fi
                [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Целостность ZIP: OK"
            fi
            ;;
    esac
    
    # 6) Проверка содержимого (database.json)
    local temp_dir=$(mktemp -d)
    TEMP_DIRS+=("$temp_dir")
    local json_file=""
    
    case "$archive_type" in
        "tar.gz")
            # Проверяем наличие database.json
            if ! tar -tzf "$archive_path" | grep -q "database.json"; then
                [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Не найден database.json в архиве"
                rm -rf "$temp_dir"
                return 1
            fi
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} database.json присутствует"
            
            # Извлекаем для проверки JSON
            tar -xzf "$archive_path" -C "$temp_dir" --wildcards '*/database.json' 2>/dev/null || \
            tar -xzf "$archive_path" -C "$temp_dir" 'database.json' 2>/dev/null
            json_file=$(find "$temp_dir" -name "database.json" -type f 2>/dev/null | head -1)
            ;;
        "tar")
            if ! tar -tf "$archive_path" | grep -q "database.json"; then
                [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Не найден database.json в архиве"
                rm -rf "$temp_dir"
                return 1
            fi
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} database.json присутствует"
            
            tar -xf "$archive_path" -C "$temp_dir" --wildcards '*/database.json' 2>/dev/null || \
            tar -xf "$archive_path" -C "$temp_dir" 'database.json' 2>/dev/null
            json_file=$(find "$temp_dir" -name "database.json" -type f 2>/dev/null | head -1)
            ;;
        "zip")
            if [[ "$needs_password" == "true" ]]; then
                # Пытаемся с сохранённым паролем
                if [[ -n "$BEDOLAGA_BACKUP_PASSWORD" ]]; then
                    # Проверяем AES шифрование
                    local is_aes="false"
                    if is_zip_aes_encrypted "$archive_path"; then
                        is_aes="true"
                    fi
                    
                    # Извлекаем внутренний архив (7z для AES, unzip для ZipCrypto)
                    if [[ "$is_aes" == "true" ]]; then
                        if ! ensure_7z_installed; then
                            [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} 7z не установлен (требуется для AES)"
                            rm -rf "$temp_dir"
                            return 1
                        fi
                        local cmd_7z=$(get_7z_command)
                        $cmd_7z x -p"$BEDOLAGA_BACKUP_PASSWORD" -o"$temp_dir" "$archive_path" -y &>/dev/null
                    else
                        unzip -P "$BEDOLAGA_BACKUP_PASSWORD" -q "$archive_path" -d "$temp_dir" 2>/dev/null
                    fi
                    
                    # Ищем внутренний tar.gz
                    local inner_archive=$(find "$temp_dir" -name "*.tar.gz" -o -name "*.tar" 2>/dev/null | head -1)
                    if [[ -n "$inner_archive" ]]; then
                        local inner_temp="$temp_dir/inner"
                        mkdir -p "$inner_temp"
                        if [[ "$inner_archive" == *.tar.gz ]]; then
                            tar -xzf "$inner_archive" -C "$inner_temp" 2>/dev/null
                        else
                            tar -xf "$inner_archive" -C "$inner_temp" 2>/dev/null
                        fi
                        json_file=$(find "$inner_temp" -name "database.json" -type f 2>/dev/null | head -1)
                    else
                        json_file=$(find "$temp_dir" -name "database.json" -type f 2>/dev/null | head -1)
                    fi
                    
                    if [[ -z "$json_file" ]]; then
                        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Не найден database.json в архиве"
                        rm -rf "$temp_dir"
                        return 1
                    fi
                    [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} database.json присутствует"
                else
                    [[ "$verbose" == "true" ]] && echo -e "  ${YELLOW}○${RESET} database.json: требуется пароль для проверки"
                    ((warnings++))
                fi
            else
                # Без пароля — проверяем содержимое
                if ! unzip -l "$archive_path" 2>/dev/null | grep -q "database.json"; then
                    # Проверяем внутренний архив
                    unzip -q "$archive_path" -d "$temp_dir" 2>/dev/null
                    local inner_archive=$(find "$temp_dir" -name "*.tar.gz" -o -name "*.tar" 2>/dev/null | head -1)
                    if [[ -n "$inner_archive" ]]; then
                        if [[ "$inner_archive" == *.tar.gz ]]; then
                            if ! tar -tzf "$inner_archive" | grep -q "database.json"; then
                                [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Не найден database.json"
                                rm -rf "$temp_dir"
                                return 1
                            fi
                        fi
                    else
                        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Не найден database.json"
                        rm -rf "$temp_dir"
                        return 1
                    fi
                fi
                [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} database.json присутствует"
            fi
            ;;
    esac
    
    # Если json_file не найден и нет пароля — пропускаем проверку JSON
    if [[ -z "$json_file" || ! -f "$json_file" ]]; then
        if [[ "$needs_password" == "true" && -z "$BEDOLAGA_BACKUP_PASSWORD" ]]; then
            [[ "$verbose" == "true" ]] && echo -e "  ${YELLOW}○${RESET} Проверка JSON структуры: требуется пароль"
            ((warnings++))
            rm -rf "$temp_dir"
            
            # Результат с предупреждением
            if [[ "$verbose" == "true" ]]; then
                echo ""
                echo -e "  ${YELLOW}${BOLD}⚠️  АРХИВ ТРЕБУЕТ ПАРОЛЬ${RESET}"
                echo -e "  ${YELLOW}   Укажите пароль для полной проверки${RESET}"
            fi
            
            debug_log "HEALTHCHECK" "Archive check: password required, path=$archive_path"
            return 0  # Возвращаем успех, т.к. базовые проверки пройдены
        fi
        
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Не удалось извлечь database.json"
        rm -rf "$temp_dir"
        return 1
    fi
    
    # Проверка валидности JSON через Python
    local python_cmd="${PYTHON_CMD:-python3}"
    if ! $python_cmd -c "import json; json.load(open('$json_file'))" 2>/dev/null; then
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} database.json не является валидным JSON"
        rm -rf "$temp_dir"
        return 1
    fi
    [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} JSON структура валидна"
    
    # 7) Проверка обязательных таблиц
    # Структура JSON: {"metadata": {...}, "data": {"users": [...], ...}}
    # Таблицы находятся в d['data'], не в корне!
    local required_tables=("users")
    local optional_tables=("transactions" "promocodes" "subscriptions" "tickets")
    
    for table in "${required_tables[@]}"; do
        # Проверяем в d['data']['table'] (новый формат) или d['table'] (старый формат)
        if $python_cmd -c "
import json
d = json.load(open('$json_file'))
data = d.get('data', d)  # Если есть 'data' - используем его, иначе корень
exit(0 if '$table' in data else 1)
" 2>/dev/null; then
            local count=$($python_cmd -c "
import json
d = json.load(open('$json_file'))
data = d.get('data', d)
print(len(data.get('$table', [])))
" 2>/dev/null)
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Таблица '$table': $count записей"
        else
            [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Отсутствует обязательная таблица: $table"
            ((errors++))
        fi
    done
    
    for table in "${optional_tables[@]}"; do
        if $python_cmd -c "
import json
d = json.load(open('$json_file'))
data = d.get('data', d)
exit(0 if '$table' in data else 1)
" 2>/dev/null; then
            local count=$($python_cmd -c "
import json
d = json.load(open('$json_file'))
data = d.get('data', d)
print(len(data.get('$table', [])))
" 2>/dev/null)
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Таблица '$table': $count записей"
        else
            [[ "$verbose" == "true" ]] && echo -e "  ${YELLOW}○${RESET} Таблица '$table' отсутствует (опционально)"
            ((warnings++))
        fi
    done
    
    rm -rf "$temp_dir"
    
    # Результат
    if [[ "$verbose" == "true" ]]; then
        echo ""
        if [[ $errors -eq 0 ]]; then
            echo -e "  ${GREEN}${BOLD}✅ АРХИВ ВАЛИДЕН${RESET}"
            [[ $warnings -gt 0 ]] && echo -e "  ${YELLOW}   (предупреждений: $warnings)${RESET}"
        else
            echo -e "  ${RED}${BOLD}❌ АРХИВ НЕВАЛИДЕН${RESET} (ошибок: $errors)"
        fi
    fi
    
    debug_log "HEALTHCHECK" "Archive check: errors=$errors, warnings=$warnings, path=$archive_path"
    
    return $errors
}

# --- Функция: Healthcheck БД перед импортом ---
# Проверяет: подключение, наличие таблиц, права на запись
migration_healthcheck_db_pre() {
    local verbose="${1:-true}"
    local errors=0
    local warnings=0
    
    [[ "$verbose" == "true" ]] && echo -e "\n${CYAN}━━━ 🏥 HEALTHCHECK: БД RWP-Shop (PRE-IMPORT) ━━━${RESET}\n"
    
    # Проверяем что контейнер задан
    if [[ -z "$MIGRATION_TARGET_CONTAINER" ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Не задан контейнер БД"
        return 1
    fi
    
    # 1) Контейнер запущен
    if ! docker ps --format '{{.Names}}' | grep -q "^${MIGRATION_TARGET_CONTAINER}$"; then
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Контейнер не запущен: $MIGRATION_TARGET_CONTAINER"
        return 1
    fi
    [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Контейнер запущен: $MIGRATION_TARGET_CONTAINER"
    
    # 2) Healthcheck контейнера (pg_isready)
    local db_user="${MIGRATION_TARGET_USER:-postgres}"
    local db_name="${MIGRATION_TARGET_DB:-postgres}"
    
    if ! docker exec "$MIGRATION_TARGET_CONTAINER" pg_isready -U "$db_user" &>/dev/null; then
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} PostgreSQL не готов (pg_isready failed)"
        return 1
    fi
    [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} PostgreSQL готов к подключению"
    
    # 3) Подключение к БД
    if ! docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -c "SELECT 1" &>/dev/null; then
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Не удалось подключиться к БД: $db_name"
        return 1
    fi
    [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Подключение к БД: $db_name"
    
    # 4) Проверка обязательных таблиц
    local required_tables=("customer" "promo" "purchase")
    local optional_tables=("referral" "promo_usage" "support_ticket" "support_message" "broadcast")
    
    for table in "${required_tables[@]}"; do
        local exists=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
            "SELECT EXISTS (SELECT FROM information_schema.tables WHERE table_name = '$table')" 2>/dev/null)
        if [[ "$exists" == "t" ]]; then
            local count=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
                "SELECT COUNT(*) FROM $table" 2>/dev/null)
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Таблица '$table': $count записей"
        else
            [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Отсутствует таблица: $table"
            ((errors++))
        fi
    done
    
    for table in "${optional_tables[@]}"; do
        local exists=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
            "SELECT EXISTS (SELECT FROM information_schema.tables WHERE table_name = '$table')" 2>/dev/null)
        if [[ "$exists" == "t" ]]; then
            local count=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
                "SELECT COUNT(*) FROM $table" 2>/dev/null)
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Таблица '$table': $count записей"
        else
            [[ "$verbose" == "true" ]] && echo -e "  ${YELLOW}○${RESET} Таблица '$table' отсутствует"
            ((warnings++))
        fi
    done
    
    # 5) Проверка прав на запись (создаём и удаляем тестовую запись)
    local write_test=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
        "CREATE TEMP TABLE _lazarus_write_test (id int); INSERT INTO _lazarus_write_test VALUES (1); SELECT COUNT(*) FROM _lazarus_write_test;" 2>&1)
    # Удаляем пробелы и проверяем результат
    write_test=$(echo "$write_test" | tr -d '[:space:]')
    if [[ "$write_test" == "1" ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Права на запись: OK"
    elif [[ "$write_test" =~ "ERROR" ]] || [[ -z "$write_test" ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Нет прав на запись в БД"
        ((errors++))
    else
        # Другой ответ — возможно OK
        [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Права на запись: OK"
    fi
    
    # 6) Проверка свободного места в контейнере
    local disk_free=$(docker exec "$MIGRATION_TARGET_CONTAINER" df -h /var/lib/postgresql/data 2>/dev/null | tail -1 | awk '{print $4}')
    if [[ -n "$disk_free" ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} Свободное место: $disk_free"
    fi
    
    # Результат
    if [[ "$verbose" == "true" ]]; then
        echo ""
        if [[ $errors -eq 0 ]]; then
            echo -e "  ${GREEN}${BOLD}✅ БД ГОТОВА К ИМПОРТУ${RESET}"
            [[ $warnings -gt 0 ]] && echo -e "  ${YELLOW}   (предупреждений: $warnings)${RESET}"
        else
            echo -e "  ${RED}${BOLD}❌ БД НЕ ГОТОВА${RESET} (ошибок: $errors)"
        fi
    fi
    
    # Сохраняем счётчики ДО импорта для сравнения
    HEALTHCHECK_PRE_COUNTS=""
    for table in customer promo purchase referral; do
        local count=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
            "SELECT COUNT(*) FROM $table" 2>/dev/null || echo "0")
        HEALTHCHECK_PRE_COUNTS+="$table:$count "
    done
    
    debug_log "HEALTHCHECK" "DB pre-import: errors=$errors, warnings=$warnings, counts=$HEALTHCHECK_PRE_COUNTS"
    
    return $errors
}

# --- Функция: Healthcheck БД после импорта ---
# Проверяет: изменение счётчиков, целостность FK, отсутствие orphans
migration_healthcheck_db_post() {
    local verbose="${1:-true}"
    local errors=0
    local warnings=0
    
    [[ "$verbose" == "true" ]] && echo -e "\n${CYAN}━━━ 🏥 HEALTHCHECK: БД RWP-Shop (POST-IMPORT) ━━━${RESET}\n"
    
    local db_user="${MIGRATION_TARGET_USER:-postgres}"
    local db_name="${MIGRATION_TARGET_DB:-postgres}"
    
    # 1) Сравнение счётчиков (до/после)
    [[ "$verbose" == "true" ]] && echo -e "  ${BLUE}📊 Изменение количества записей:${RESET}"
    
    for table in customer promo purchase referral; do
        local pre_count=$(echo "$HEALTHCHECK_PRE_COUNTS" | grep -oP "$table:\K\d+")
        local post_count=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
            "SELECT COUNT(*) FROM $table" 2>/dev/null || echo "0")
        local diff=$((post_count - pre_count))
        
        if [[ $diff -gt 0 ]]; then
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} $table: $pre_count → $post_count (+$diff)"
        elif [[ $diff -eq 0 ]]; then
            [[ "$verbose" == "true" ]] && echo -e "  ${YELLOW}○${RESET} $table: $pre_count → $post_count (без изменений)"
        else
            [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} $table: $pre_count → $post_count ($diff) - УМЕНЬШИЛОСЬ!"
            ((warnings++))
        fi
    done
    
    # 2) Проверка FK integrity (orphan referrals)
    [[ "$verbose" == "true" ]] && echo -e "\n  ${BLUE}🔗 Проверка целостности связей:${RESET}"
    
    # Orphan referrals (referrer_id не существует в customer)
    local orphan_referrers=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
        "SELECT COUNT(*) FROM referral r WHERE NOT EXISTS (SELECT 1 FROM customer c WHERE c.telegram_id = r.referrer_id)" 2>/dev/null || echo "0")
    if [[ "$orphan_referrers" -eq 0 ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} referral.referrer_id → customer: OK"
    else
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} referral.referrer_id → customer: $orphan_referrers orphans"
        ((warnings++))
    fi
    
    # Orphan referees
    local orphan_referees=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
        "SELECT COUNT(*) FROM referral r WHERE NOT EXISTS (SELECT 1 FROM customer c WHERE c.telegram_id = r.referee_id)" 2>/dev/null || echo "0")
    if [[ "$orphan_referees" -eq 0 ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} referral.referee_id → customer: OK"
    else
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} referral.referee_id → customer: $orphan_referees orphans"
        ((warnings++))
    fi
    
    # Orphan promo_usage
    local orphan_promo=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
        "SELECT COUNT(*) FROM promo_usage pu WHERE NOT EXISTS (SELECT 1 FROM promo p WHERE p.id = pu.promo_id)" 2>/dev/null || echo "0")
    if [[ "$orphan_promo" -eq 0 ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} promo_usage.promo_id → promo: OK"
    else
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} promo_usage.promo_id → promo: $orphan_promo orphans"
        ((warnings++))
    fi
    
    # 3) Проверка на NULL в обязательных полях
    [[ "$verbose" == "true" ]] && echo -e "\n  ${BLUE}⚠️  Проверка данных:${RESET}"
    
    local null_telegram_id=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
        "SELECT COUNT(*) FROM customer WHERE telegram_id IS NULL" 2>/dev/null || echo "0")
    if [[ "$null_telegram_id" -eq 0 ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} customer.telegram_id: нет NULL"
    else
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} customer.telegram_id: $null_telegram_id NULL записей"
        ((errors++))
    fi
    
    # 4) Проверка дубликатов telegram_id
    local dup_telegram=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$db_user" -d "$db_name" -tAc \
        "SELECT COUNT(*) FROM (SELECT telegram_id FROM customer GROUP BY telegram_id HAVING COUNT(*) > 1) t" 2>/dev/null || echo "0")
    if [[ "$dup_telegram" -eq 0 ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} customer.telegram_id: нет дубликатов"
    else
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} customer.telegram_id: $dup_telegram дубликатов"
        ((errors++))
    fi
    
    # Результат
    if [[ "$verbose" == "true" ]]; then
        echo ""
        if [[ $errors -eq 0 && $warnings -eq 0 ]]; then
            echo -e "  ${GREEN}${BOLD}✅ ИМПОРТ ПРОШЁЛ УСПЕШНО${RESET}"
        elif [[ $errors -eq 0 ]]; then
            echo -e "  ${YELLOW}${BOLD}⚠️  ИМПОРТ ЗАВЕРШЁН С ПРЕДУПРЕЖДЕНИЯМИ${RESET} ($warnings)"
        else
            echo -e "  ${RED}${BOLD}❌ ОБНАРУЖЕНЫ ПРОБЛЕМЫ${RESET} (ошибок: $errors, предупреждений: $warnings)"
        fi
    fi
    
    debug_log "HEALTHCHECK" "DB post-import: errors=$errors, warnings=$warnings"
    
    return $errors
}

# --- Функция: Healthcheck CSV файлов ---
# Проверяет: наличие файлов, заголовки, количество строк
migration_healthcheck_csv() {
    local export_dir="${1:-$MIGRATION_WORK_DIR/export}"
    local verbose="${2:-true}"
    local errors=0
    local warnings=0
    local total_records=0
    
    [[ "$verbose" == "true" ]] && echo -e "\n${CYAN}━━━ 🏥 HEALTHCHECK: Экспортированные CSV ━━━${RESET}\n"
    
    if [[ ! -d "$export_dir" ]]; then
        [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} Папка экспорта не найдена: $export_dir"
        return 1
    fi
    
    # Обязательные файлы
    local required_files=("users.csv")
    local optional_files=("transactions.csv" "promocodes.csv" "subscriptions.csv" "referrals.csv" 
                          "promocode_uses.csv" "tickets.csv" "ticket_messages.csv")
    
    for file in "${required_files[@]}"; do
        if [[ -f "$export_dir/$file" ]]; then
            local lines=$(wc -l < "$export_dir/$file")
            local records=$((lines - 1))  # минус заголовок
            total_records=$((total_records + records))
            
            if [[ $records -gt 0 ]]; then
                [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} $file: $records записей"
            else
                [[ "$verbose" == "true" ]] && echo -e "  ${YELLOW}○${RESET} $file: пустой (только заголовок)"
                ((warnings++))
            fi
        else
            [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} $file: НЕ НАЙДЕН (обязательный)"
            ((errors++))
        fi
    done
    
    for file in "${optional_files[@]}"; do
        if [[ -f "$export_dir/$file" ]]; then
            local lines=$(wc -l < "$export_dir/$file")
            local records=$((lines - 1))
            total_records=$((total_records + records))
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} $file: $records записей"
        else
            [[ "$verbose" == "true" ]] && echo -e "  ${DIM}○${RESET} $file: отсутствует (опционально)"
        fi
    done
    
    # Проверка заголовков CSV
    [[ "$verbose" == "true" ]] && echo -e "\n  ${BLUE}📋 Проверка заголовков:${RESET}"
    
    if [[ -f "$export_dir/users.csv" ]]; then
        local header=$(head -1 "$export_dir/users.csv")
        if echo "$header" | grep -q "telegram_id"; then
            [[ "$verbose" == "true" ]] && echo -e "  ${GREEN}✓${RESET} users.csv: заголовок корректен"
        else
            [[ "$verbose" == "true" ]] && echo -e "  ${RED}✗${RESET} users.csv: отсутствует telegram_id в заголовке"
            ((errors++))
        fi
    fi
    
    # Результат
    if [[ "$verbose" == "true" ]]; then
        echo ""
        echo -e "  ${BLUE}Всего записей для импорта:${RESET} $total_records"
        echo ""
        if [[ $errors -eq 0 ]]; then
            echo -e "  ${GREEN}${BOLD}✅ CSV ФАЙЛЫ ВАЛИДНЫ${RESET}"
        else
            echo -e "  ${RED}${BOLD}❌ ПРОБЛЕМЫ С CSV${RESET} (ошибок: $errors)"
        fi
    fi
    
    debug_log "HEALTHCHECK" "CSV check: errors=$errors, total_records=$total_records, dir=$export_dir"
    
    return $errors
}

# --- Функция: Полный healthcheck (все проверки) ---
migration_healthcheck_full() {
    local verbose="${1:-true}"
    local archive_ok=0
    local db_pre_ok=0
    local csv_ok=0
    local archive_needs_password=0
    
    echo -e "\n${MAGENTA}${BOLD}╔════════════════════════════════════════════════════════╗${RESET}"
    echo -e "${MAGENTA}${BOLD}║        🏥 ПОЛНЫЙ HEALTHCHECK МИГРАЦИИ                  ║${RESET}"
    echo -e "${MAGENTA}${BOLD}╚════════════════════════════════════════════════════════╝${RESET}"
    
    # Архив
    if [[ -n "$MIGRATION_SOURCE_BACKUP" ]]; then
        # Проверяем, нужен ли пароль но не введён
        local archive_type=$(detect_bedolaga_archive_type "$MIGRATION_SOURCE_BACKUP" 2>/dev/null)
        if [[ "$archive_type" == "zip" ]] && is_archive_password_protected "$MIGRATION_SOURCE_BACKUP" 2>/dev/null; then
            if [[ -z "$BEDOLAGA_BACKUP_PASSWORD" ]]; then
                archive_needs_password=1
            fi
        fi
        
        migration_healthcheck_archive "$MIGRATION_SOURCE_BACKUP" "$verbose" && archive_ok=1
    else
        [[ "$verbose" == "true" ]] && echo -e "\n  ${YELLOW}○${RESET} Архив не выбран - пропуск проверки"
    fi
    
    # БД
    if [[ -n "$MIGRATION_TARGET_CONTAINER" ]]; then
        migration_healthcheck_db_pre "$verbose" && db_pre_ok=1
    else
        [[ "$verbose" == "true" ]] && echo -e "\n  ${YELLOW}○${RESET} Контейнер БД не задан - пропуск проверки"
    fi
    
    # CSV (если есть)
    if [[ -d "$MIGRATION_WORK_DIR/export" ]]; then
        migration_healthcheck_csv "$MIGRATION_WORK_DIR/export" "$verbose" && csv_ok=1
    fi
    
    # Итог
    echo -e "\n${BLUE}━━━ ИТОГ ━━━${RESET}\n"
    
    # Архив: если требуется пароль — показываем предупреждение вместо OK
    if [[ $archive_needs_password -eq 1 ]]; then
        echo -e "  ${YELLOW}⚠${RESET} Архив: ТРЕБУЕТСЯ ПАРОЛЬ"
    elif [[ $archive_ok -eq 1 ]]; then
        echo -e "  ${GREEN}✓${RESET} Архив: OK"
    else
        echo -e "  ${RED}✗${RESET} Архив: ОШИБКА"
    fi
    
    [[ $db_pre_ok -eq 1 ]] && echo -e "  ${GREEN}✓${RESET} БД: OK" || echo -e "  ${RED}✗${RESET} БД: ОШИБКА"
    [[ -d "$MIGRATION_WORK_DIR/export" ]] && { [[ $csv_ok -eq 1 ]] && echo -e "  ${GREEN}✓${RESET} CSV: OK" || echo -e "  ${RED}✗${RESET} CSV: ОШИБКА"; }
    
    echo ""
    return 0
}

# --- Функция: Сохранить непереносимые данные ---
migration_save_not_migrated_data() {
    [[ -z "$MIGRATION_NOT_MIGRATED_DIR" ]] && migration_create_not_migrated_dir
    
    local export_dir="$MIGRATION_WORK_DIR/export"
    
    # 1) Балансы пользователей (если есть)
    if [[ -f "$export_dir/user_balances.csv" ]]; then
        cp "$export_dir/user_balances.csv" "$MIGRATION_NOT_MIGRATED_DIR/"
        print_message "INFO" "Сохранены балансы пользователей → NOT_MIGRATED/"
    fi
    
    # 2) Реферальные балансы
    if [[ -f "$export_dir/referral_balances.csv" ]]; then
        cp "$export_dir/referral_balances.csv" "$MIGRATION_NOT_MIGRATED_DIR/"
        print_message "INFO" "Сохранены реферальные балансы → NOT_MIGRATED/"
    fi
    
    # 3) Промокоды на баланс (не поддерживаются в RWP-Shop)
    if [[ -f "$export_dir/promocodes_balance_type.csv" ]]; then
        local balance_promo_count=$(($(wc -l < "$export_dir/promocodes_balance_type.csv") - 1))
        if [[ $balance_promo_count -gt 0 ]]; then
            cp "$export_dir/promocodes_balance_type.csv" "$MIGRATION_NOT_MIGRATED_DIR/"
            print_message "INFO" "Сохранены промокоды на баланс ($balance_promo_count) → NOT_MIGRATED/"
        fi
    fi
    
    # 4) Неизвестные платежи (собираем из transactions)
    if [[ -f "$export_dir/transactions.csv" ]]; then
        # Фильтруем транзакции с unknown payment_method
        head -1 "$export_dir/transactions.csv" > "$MIGRATION_NOT_MIGRATED_DIR/unknown_payments.csv"
        grep ",unknown," "$export_dir/transactions.csv" >> "$MIGRATION_NOT_MIGRATED_DIR/unknown_payments.csv" 2>/dev/null
        
        local unknown_count=$(wc -l < "$MIGRATION_NOT_MIGRATED_DIR/unknown_payments.csv")
        unknown_count=$((unknown_count - 1))
        
        if [[ $unknown_count -gt 0 ]]; then
            print_message "INFO" "Сохранены неизвестные платежи ($unknown_count) → NOT_MIGRATED/"
        else
            rm -f "$MIGRATION_NOT_MIGRATED_DIR/unknown_payments.csv"
        fi
    fi
    
    debug_log "MIGRATE" "Not migrated data saved to $MIGRATION_NOT_MIGRATED_DIR"
}

# --- Функция: Показать подробный анализ данных ---
migration_show_detailed_analysis() {
    if [[ -z "$MIGRATION_SOURCE_BACKUP" || ! -f "$MIGRATION_SOURCE_BACKUP" ]]; then
        print_message "ERROR" "Архив не выбран"
        return 1
    fi
    
    clear_screen
    local archive_name=$(basename "$MIGRATION_SOURCE_BACKUP")
    echo -e "${CYAN}${BOLD}+----------------------------------------------------------------------+${RESET}"
    printf "${CYAN}${BOLD}|  АНАЛИЗ ДАННЫХ: %-51s |${RESET}\n" "$archive_name"
    echo -e "${CYAN}${BOLD}+----------------------------------------------------------------------+${RESET}"
    echo ""
    
    # Проверяем, требуется ли пароль
    local archive_type=$(detect_bedolaga_archive_type "$MIGRATION_SOURCE_BACKUP" 2>/dev/null)
    local is_aes=false
    
    if [[ "$archive_type" == "zip" ]] && is_zip_aes_encrypted "$MIGRATION_SOURCE_BACKUP" 2>/dev/null; then
        is_aes=true
    fi
    
    if [[ "$archive_type" == "zip" ]] && is_archive_password_protected "$MIGRATION_SOURCE_BACKUP" 2>/dev/null; then
        if [[ -z "$BEDOLAGA_BACKUP_PASSWORD" ]]; then
            echo -e "${YELLOW}  ⚠️  Архив защищён паролем${RESET}"
            echo ""
            if [[ "$is_aes" == "true" ]]; then
                print_message "INFO" "🔒 Шифрование: AES-256"
            fi
            read -ersp "  Введите пароль: " BEDOLAGA_BACKUP_PASSWORD
            echo ""
            echo ""
            
            # Проверяем пароль
            if [[ -n "$BEDOLAGA_BACKUP_PASSWORD" ]]; then
                local temp_dir=$(mktemp -d)
                TEMP_DIRS+=("$temp_dir")
                local password_ok=false
                
                print_message "INFO" "Проверка пароля..."
                
                if [[ "$is_aes" == "true" ]]; then
                    # AES — используем 7z
                    if ! ensure_7z_installed; then
                        print_message "ERROR" "Для AES-зашифрованных архивов требуется 7z (p7zip)"
                        print_message "INFO" "Установите: apt install p7zip-full"
                        rm -rf "$temp_dir"
                        BEDOLAGA_BACKUP_PASSWORD=""
                        return 1
                    fi
                    
                    local cmd_7z=$(get_7z_command)
                    if $cmd_7z x -p"$BEDOLAGA_BACKUP_PASSWORD" -o"$temp_dir" "$MIGRATION_SOURCE_BACKUP" -y &>/dev/null; then
                        if find "$temp_dir" -name "database.json" 2>/dev/null | grep -q . || \
                           find "$temp_dir" -type f \( -name "*.tar.gz" -o -name "*.gz" \) 2>/dev/null | grep -q .; then
                            password_ok=true
                        fi
                    fi
                else
                    # ZipCrypto — используем unzip
                    ensure_unzip_installed 2>/dev/null
                    if unzip -P "$BEDOLAGA_BACKUP_PASSWORD" -o -q "$MIGRATION_SOURCE_BACKUP" -d "$temp_dir" 2>/dev/null; then
                        if find "$temp_dir" -name "database.json" 2>/dev/null | grep -q . || \
                           find "$temp_dir" -type f \( -name "*.tar.gz" -o -name "*.gz" \) 2>/dev/null | grep -q .; then
                            password_ok=true
                        fi
                    fi
                fi
                
                rm -rf "$temp_dir"
                
                if [[ "$password_ok" == "true" ]]; then
                    print_message "SUCCESS" "✅ Пароль верный"
                    echo ""
                else
                    print_message "ERROR" "❌ Неверный пароль"
                    BEDOLAGA_BACKUP_PASSWORD=""
                    return 1
                fi
            else
                print_message "ERROR" "Пароль не введён"
                return 1
            fi
        fi
    fi
    
    # Получаем анализ
    if [[ -z "$MIGRATION_DATA_ANALYSIS" ]]; then
        print_message "INFO" "Анализ архива..."
        MIGRATION_DATA_ANALYSIS=$(migration_quick_analyze "$MIGRATION_SOURCE_BACKUP" "$BEDOLAGA_BACKUP_PASSWORD")
    fi
    
    if [[ -z "$MIGRATION_DATA_ANALYSIS" ]]; then
        print_message "ERROR" "Не удалось проанализировать архив"
        echo ""
        echo "  Возможные причины:"
        echo "  • Неверный пароль (попробуйте выбрать архив заново — пункт 2)"
        echo "  • Повреждённый архив"
        echo "  • Архив не содержит database.json"
        echo ""
        return 1
    fi
    
    # Парсим результаты
    local users=$(echo "$MIGRATION_DATA_ANALYSIS" | grep "^users:" | cut -d: -f2)
    local transactions=$(echo "$MIGRATION_DATA_ANALYSIS" | grep "^transactions:" | cut -d: -f2)
    local promocodes=$(echo "$MIGRATION_DATA_ANALYSIS" | grep "^promocodes:" | cut -d: -f2)
    local subscriptions=$(echo "$MIGRATION_DATA_ANALYSIS" | grep "^subscriptions:" | cut -d: -f2)
    local tickets=$(echo "$MIGRATION_DATA_ANALYSIS" | grep "^tickets:" | cut -d: -f2)
    local referrals=$(echo "$MIGRATION_DATA_ANALYSIS" | grep "^referrals:" | cut -d: -f2)
    local total_balance=$(echo "$MIGRATION_DATA_ANALYSIS" | grep "^total_balance_kopeks:" | cut -d: -f2)
    local users_with_balance=$(echo "$MIGRATION_DATA_ANALYSIS" | grep "^users_with_balance:" | cut -d: -f2)
    
    # Конвертируем копейки в рубли (без bc, используем awk)
    local balance_rub
    if [[ -n "$total_balance" && "$total_balance" != "0" ]]; then
        balance_rub=$(awk "BEGIN {printf \"%.2f\", ${total_balance}/100}")
    else
        balance_rub="0.00"
    fi
    
    echo -e "${GREEN}  БУДЕТ ПЕРЕНЕСЕНО:${RESET}"
    echo ""
    printf "    %-40s %10s   %s\n" "Bedolaga" "Записей" "RWP-Shop"
    echo "    ────────────────────────────────────────────────────────────────"
    printf "    %-40s %10s   %s\n" "users" "${users:-0}" "-> customer"
    printf "    %-40s %10s   %s\n" "referrals" "${referrals:-0}" "-> referral"
    printf "    %-40s %10s   %s\n" "subscriptions (active)" "${subscriptions:-0}" "-> customer.*"
    printf "    %-40s %10s   %s\n" "transactions" "${transactions:-0}" "-> purchase"
    printf "    %-40s %10s   %s\n" "promocodes" "${promocodes:-0}" "-> promo"
    printf "    %-40s %10s   %s\n" "tickets" "${tickets:-0}" "-> support_ticket"
    echo ""
    
    if [[ "${users_with_balance:-0}" -gt 0 ]]; then
        echo -e "${YELLOW}  НЕ БУДЕТ ПЕРЕНЕСЕНО (сохранится в CSV):${RESET}"
        echo ""
        printf "    %-40s %10s   %s\n" "balances ($users_with_balance users)" "${balance_rub} RUB" "-> NOT_MIGRATED/"
        echo ""
    fi
    
    echo -e "  ${GRAY}Непереносимые данные сохранятся в: NOT_MIGRATED/${RESET}"
    echo ""
}

# --- Функция: Выбор архива из списка ---
migration_select_archive() {
    # Собираем все архивы
    local search_paths=(
        "$BOT_PATH"
        "/opt/private-remnawave-telegram-shop-bot"
        "/opt/rwp-shop"
        "/opt/bedolaga"
        "/opt/vpn-bot"
        "/root"
        "$BACKUP_DIR"
        "$HOME"
    )
    
    local all_archives=()
    
    for path in "${search_paths[@]}"; do
        [[ ! -d "$path" ]] && continue
        # Ищем tar.gz И tar.zip (запароленные)
        while IFS= read -r -d '' archive; do
            all_archives+=("$archive")
        done < <(find "$path" -maxdepth 3 -type f \( -name "backup_*.tar.gz" -o -name "backup_*.tar.zip" -o -name "backup_*.zip" \) -print0 2>/dev/null)
    done
    
    if [[ ${#all_archives[@]} -eq 0 ]]; then
        clear_screen
        echo -e "${CYAN}${BOLD}═══ ВЫБОР АРХИВА BEDOLAGA ═══${RESET}"
        echo ""
        echo -e "${YELLOW}Архивы backup_*.tar.gz / backup_*.tar.zip не найдены${RESET}"
        echo ""
        echo "Поддерживаемые форматы:"
        echo "  • backup_*.tar.gz      — обычный архив"
        echo "  • backup_*.tar.zip     — запароленный архив"
        echo ""
        echo "Где найти архив:"
        echo "  • Скачайте бэкап из Telegram (если бот отправлял)"
        echo "  • Скопируйте из папки Bedolaga: /opt/bedolaga/backups/"
        echo "  • Положите в папку RWP-Shop бота"
        echo ""
        read -erp "Введите полный путь к архиву (Enter - назад): " manual_path
        [[ -z "$manual_path" ]] && return 1
        
        if [[ -f "$manual_path" ]]; then
            _migration_set_archive "$manual_path"
            return 0
        else
            print_message "ERROR" "Файл не найден: $manual_path"
            return 1
        fi
    fi
    
    # Сортируем архивы по дате
    local sorted_archives=()
    while IFS= read -r archive; do
        sorted_archives+=("$archive")
    done < <(printf '%s\n' "${all_archives[@]}" | xargs -I {} stat --format='%Y %n' {} 2>/dev/null | sort -rn | awk '{print $2}')
    
    local total_count=${#sorted_archives[@]}
    local show_limit=5
    local show_filenames=false
    
    while true; do
        clear_screen
        echo -e "${CYAN}${BOLD}═══ ВЫБОР АРХИВА BEDOLAGA ═══${RESET}"
        echo -e "Всего архивов: ${CYAN}$total_count${RESET}"
        echo ""
        
        local loop_limit=$show_limit
        [[ $loop_limit -gt $total_count ]] && loop_limit=$total_count
        
        for (( i=0; i<loop_limit; i++ )); do
            local archive="${sorted_archives[$i]}"
            local num=$((i + 1))
            
            # Определяем тип и статус защиты
            local type_icon="📦"
            local archive_type=$(detect_bedolaga_archive_type "$archive" 2>/dev/null || echo "unknown")
            if [[ "$archive_type" == "zip" ]]; then
                if is_archive_password_protected "$archive" 2>/dev/null; then
                    type_icon="🔒"
                fi
            fi
            
            if [[ "$show_filenames" == "true" ]]; then
                # Показываем полный путь
                local size=$(du -h "$archive" 2>/dev/null | cut -f1)
                if [[ $i -eq 0 ]]; then
                    echo -e "  ${GREEN}$num. $type_icon $archive${RESET}"
                    echo -e "     ${GREEN}($size) ← РЕКОМЕНДУЕТСЯ${RESET}"
                else
                    echo "  $num. $type_icon $archive ($size)"
                fi
            else
                # Показываем читаемый формат
                local name=$(basename "$archive")
                local size=$(du -h "$archive" 2>/dev/null | cut -f1)
                local mtime=$(stat -c '%y' "$archive" 2>/dev/null | cut -d'.' -f1)
                
                # Парсим дату из имени файла backup_YYYYMMDD_HHMMSS
                local date_str=""
                if [[ "$name" =~ backup_([0-9]{4})([0-9]{2})([0-9]{2})_([0-9]{2})([0-9]{2})([0-9]{2}) ]]; then
                    date_str="${BASH_REMATCH[1]}-${BASH_REMATCH[2]}-${BASH_REMATCH[3]} ${BASH_REMATCH[4]}:${BASH_REMATCH[5]}"
                else
                    date_str="$mtime"
                fi
                
                if [[ $i -eq 0 ]]; then
                    echo -e "  ${GREEN}$num. $type_icon $date_str${RESET} ($size) ${GREEN}← РЕКОМЕНДУЕТСЯ${RESET}"
                else
                    echo "  $num. $type_icon $date_str ($size)"
                fi
            fi
        done
        
        echo ""
        if [[ $show_limit -lt $total_count ]]; then
            echo -e " 888. ${GRAY}Показать все ($total_count шт)${RESET}"
        else
            echo -e " 888. ${GRAY}Показать топ-5${RESET}"
        fi
        if [[ "$show_filenames" == "false" ]]; then
            echo -e " 999. ${GRAY}Показать полные пути${RESET}"
        else
            echo -e " 999. ${GRAY}Показать даты${RESET}"
        fi
        echo ""
        echo "   0. Ввести путь вручную"
        echo ""
        echo -e "  ${GRAY}🔒 = защищён паролем${RESET}"
        echo ""
        read -erp "Номер файла или команда (Enter - Назад): " choice
        
        # Обработка выхода
        [[ -z "$choice" || "$choice" == "q" || "$choice" == "Q" ]] && return 1
        
        case "$choice" in
            888)
                if [[ $show_limit -lt $total_count ]]; then
                    show_limit=$total_count
                else
                    show_limit=5
                fi
                continue
                ;;
            999)
                if [[ "$show_filenames" == "false" ]]; then
                    show_filenames=true
                else
                    show_filenames=false
                fi
                continue
                ;;
            0)
                read -erp "Путь к архиву: " manual_path
                if [[ -f "$manual_path" ]]; then
                    _migration_set_archive "$manual_path"
                    return 0
                else
                    print_message "ERROR" "Файл не найден"
                fi
                ;;
            *)
                if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= total_count )); then
                    local idx=$((choice - 1))
                    _migration_set_archive "${sorted_archives[$idx]}"
                    return 0
                else
                    print_message "ERROR" "Неверный выбор"
                    sleep 1
                fi
                ;;
        esac
    done
}

# --- Вспомогательная: Установить архив и запросить пароль если нужно ---
_migration_set_archive() {
    local archive_path="$1"
    
    MIGRATION_SOURCE_BACKUP="$archive_path"
    MIGRATION_SOURCE_TYPE="archive"
    MIGRATION_DATA_ANALYSIS=""  # Сбросить кэш анализа
    BEDOLAGA_BACKUP_PASSWORD=""  # Сбросить пароль
    
    # Проверяем, требуется ли пароль
    local archive_type=$(detect_bedolaga_archive_type "$archive_path" 2>/dev/null || echo "unknown")
    local is_aes=false
    
    # Проверяем AES шифрование
    if [[ "$archive_type" == "zip" ]] && is_zip_aes_encrypted "$archive_path"; then
        is_aes=true
        debug_log "MIGRATE" "Archive uses AES encryption, will use 7z"
    fi
    
    if [[ "$archive_type" == "zip" ]] && is_archive_password_protected "$archive_path" 2>/dev/null; then
        echo ""
        if [[ "$is_aes" == "true" ]]; then
            print_message "INFO" "🔒 Архив защищён паролем (AES-256 шифрование)"
        else
            print_message "INFO" "🔒 Архив защищён паролем"
        fi
        read -ersp "Введите пароль: " BEDOLAGA_BACKUP_PASSWORD
        echo ""
        
        # Проверяем правильность пароля
        if [[ -n "$BEDOLAGA_BACKUP_PASSWORD" ]]; then
            local temp_dir=$(mktemp -d)
            TEMP_DIRS+=("$temp_dir")
            local password_ok=false
            
            if [[ "$is_aes" == "true" ]]; then
                # AES шифрование — нужен 7z
                if ! ensure_7z_installed; then
                    print_message "ERROR" "Для AES-зашифрованных архивов требуется 7z (p7zip)"
                    print_message "INFO" "Установите: apt install p7zip-full"
                    rm -rf "$temp_dir"
                    BEDOLAGA_BACKUP_PASSWORD=""
                    return 1
                fi
                
                local cmd_7z=$(get_7z_command)
                debug_log "MIGRATE" "Using 7z command: $cmd_7z"
                
                # Распаковываем с помощью 7z
                if $cmd_7z x -p"$BEDOLAGA_BACKUP_PASSWORD" -o"$temp_dir" "$archive_path" -y &>/dev/null; then
                    # Проверяем что распаковалось
                    if find "$temp_dir" -name "database.json" 2>/dev/null | grep -q .; then
                        password_ok=true
                    else
                        # Ищем внутренний tar.gz
                        local inner=$(find "$temp_dir" -type f \( -name "*.tar.gz" -o -name "*.gz" \) 2>/dev/null | head -1)
                        if [[ -n "$inner" ]] && tar -tzf "$inner" &>/dev/null; then
                            password_ok=true
                        fi
                    fi
                fi
            else
                # ZipCrypto — используем unzip
                ensure_unzip_installed 2>/dev/null
                
                if unzip -P "$BEDOLAGA_BACKUP_PASSWORD" -o -q "$archive_path" -d "$temp_dir" 2>/dev/null; then
                    if find "$temp_dir" -name "database.json" 2>/dev/null | grep -q .; then
                        password_ok=true
                    else
                        local inner=$(find "$temp_dir" -type f \( -name "*.tar.gz" -o -name "*.gz" \) 2>/dev/null | head -1)
                        if [[ -n "$inner" ]] && tar -tzf "$inner" &>/dev/null; then
                            password_ok=true
                        fi
                    fi
                fi
            fi
            
            if [[ "$password_ok" == "true" ]]; then
                print_message "SUCCESS" "✅ Пароль верный"
            else
                print_message "ERROR" "❌ Неверный пароль"
                BEDOLAGA_BACKUP_PASSWORD=""
            fi
            
            rm -rf "$temp_dir"
        fi
    fi
    
    print_message "SUCCESS" "Архив выбран: $(basename "$archive_path")"
    
    # Пытаемся получить анализ данных
    if [[ "$archive_type" != "zip" ]] || [[ -n "$BEDOLAGA_BACKUP_PASSWORD" ]]; then
        MIGRATION_DATA_ANALYSIS=$(migration_quick_analyze "$archive_path" 2>/dev/null)
    fi
}

