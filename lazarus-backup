# Отладочное сообщение
# Использование: debug_log "message" или debug_log "CATEGORY" "message"
debug_log() {
    # КРИТИЧНО: debug_log пишет в stderr (>&2), НЕ в stdout. Иначе любой вызов
    # `result=$(some_func_with_debug_log)` захватывает debug-строку в result.
    # Прошлый bug: get_db_user → read_bot_env → debug_log в stdout → ACTUAL_DB_USER
    # становился многострочным "[DEBUG] ...\npostgres", pg_isready ломался.
    if [[ "$DEBUG_MODE" == true ]]; then
        local ts=$(date '+%H:%M:%S.%3N')
        if [[ $# -eq 1 ]]; then
            echo -e "${MAGENTA}[$ts DEBUG]${RESET} $1" >&2
        else
            local category="$1"
            shift
            echo -e "${MAGENTA}[$ts DEBUG]${RESET} ${CYAN}[$category]${RESET} $*" >&2
        fi
    fi
}

