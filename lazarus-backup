# --- Функция: Автоматическая миграция (пошаговая с подтверждениями) ---
migration_run_automatic() {
    clear_screen
    echo -e "${GREEN}${BOLD}┌────────────────────────────────────────────────────────────────────┐${RESET}"
    echo -e "${GREEN}${BOLD}│  🚀 АВТОМАТИЧЕСКАЯ МИГРАЦИЯ                                        │${RESET}"
    echo -e "${GREEN}${BOLD}└────────────────────────────────────────────────────────────────────┘${RESET}"
