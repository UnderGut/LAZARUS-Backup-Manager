    fi
    
    local messages_count=0
    [[ -s "$ticket_messages_file" ]] && messages_count=$(($(wc -l < "$ticket_messages_file") - 1))
    print_message "SUCCESS" "Экспортировано сообщений тикетов: $messages_count"
    
    # Экспорт истории рассылок (broadcast_history → broadcast)
