setup_cron_task() {
    local TASK_TYPE="$1"; local JOB_CMD=""; local JOB_ID=""
    if [[ "$TASK_TYPE" == "db" ]]; then JOB_CMD="$SYMLINK_PATH backup_db"; JOB_ID="# LAZARUS-JOB-DB"
    elif [[ "$TASK_TYPE" == "files" ]]; then if ! ensure_bot_path; then return; fi; JOB_CMD="$SYMLINK_PATH backup_files"; JOB_ID="# LAZARUS-JOB-FILES"
    elif [[ "$TASK_TYPE" == "full" ]]; then if ! ensure_bot_path; then return; fi; JOB_CMD="$SYMLINK_PATH backup_full"; JOB_ID="# LAZARUS-JOB-FULL"; fi

    # Получаем текущий статус
    local CURRENT_STATUS=$(get_cron_status "$TASK_TYPE")
    local STATUS_COLOR="$GRAY"; [[ "$CURRENT_STATUS" != "Выкл" ]] && STATUS_COLOR="$YELLOW"
    
    # Человекочитаемое название типа
    local TYPE_NAME=""
    case "$TASK_TYPE" in
        "full") TYPE_NAME="Полный бэкап" ;;
        "db") TYPE_NAME="Только БД" ;;
        "files") TYPE_NAME="Только Файлы" ;;
    esac

    clear_screen
    echo -e "${GREEN}${BOLD}Настройка расписания: ${TYPE_NAME}${RESET}"
    echo -e "Текущий статус: [${STATUS_COLOR}${CURRENT_STATUS}${RESET}]"
    echo ""
    echo -e " 1. Ежечасно          ${GRAY}[в :00]${RESET}"
    echo -e " 2. Ежедневно         ${GRAY}[в 04:00]${RESET}"
    echo -e " 3. Еженедельно       ${GRAY}[Пн в 04:00]${RESET}"
    echo -e " 4. Своё время        ${GRAY}[ЧЧ:ММ]${RESET}"
    echo -e " 5. Каждые N минут    ${GRAY}[1-59]${RESET}"
    echo ""
    if [[ "$CURRENT_STATUS" != "Выкл" ]]; then
        echo -e " ${RED}0. Отключить${RESET}"
    else
        echo " 0. Назад"
    fi
    echo ""
    read -erp "Выбор (Enter - Назад): " c
    [[ -z "$c" ]] && return
    
    local NEW_CRON_LINES=""; local DISPLAY_TIME=""

    case $c in
        1) NEW_CRON_LINES="0 * * * * $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"; DISPLAY_TIME="Ежечасно" ;;
        2) NEW_CRON_LINES="0 4 * * * $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"; DISPLAY_TIME="Ежедневно 04:00" ;;
        3) NEW_CRON_LINES="0 4 * * 1 $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"; DISPLAY_TIME="Еженедельно" ;;
        4) 
           echo ""
           echo "Введите время (ЧЧ:ММ), можно несколько через пробел:"
           echo -e "${GRAY}Пример: 09:00 18:30${RESET}"
           read -erp "> " times_input
           if [[ -z "$times_input" ]]; then print_message "ERROR" "Время не введено!"; sleep 1; return; fi
           for t in $times_input; do 
               if [[ "$t" =~ ^([0-9]{1,2}):([0-9]{1,2})$ ]]; then 
                   h=$((10#${BASH_REMATCH[1]})); m=$((10#${BASH_REMATCH[2]}))
                   NEW_CRON_LINES+="$m $h * * * $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"$'\n'
               fi
           done
           DISPLAY_TIME="Свое: $times_input" ;;
        5) 
           echo ""
           echo "Введите интервал в минутах (1-59):"
           read -erp "> " interval
           if [[ "$interval" =~ ^[0-9]+$ ]] && [ "$interval" -gt 0 ] && [ "$interval" -lt 60 ]; then
               NEW_CRON_LINES="*/$interval * * * * $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"
               DISPLAY_TIME="Каждые $interval мин"
           else print_message "ERROR" "Введите число от 1 до 59."; sleep 1; return; fi ;;
        0) 
           if [[ "$CURRENT_STATUS" != "Выкл" ]]; then
               DISPLAY_TIME="Выкл"
           else
               return
           fi ;;
        *) return ;;
    esac

    local CURRENT_CRON=$(crontab -l 2> "$SILENT_LOG" | grep -v "$JOB_ID")
    if [[ "$DISPLAY_TIME" != "Выкл" && -n "$NEW_CRON_LINES" ]]; then echo -e "$CURRENT_CRON\n$NEW_CRON_LINES" | crontab -
    else echo "$CURRENT_CRON" | crontab -; fi

    # Синхронизируем настройки с реальным состоянием cron
    sync_cron_with_config
    
    log_message "INFO" "Cron task updated: $TASK_TYPE -> $DISPLAY_TIME"
    print_message "SUCCESS" "Расписание обновлено!"; sleep 1
}

