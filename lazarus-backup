rotate_backups_by_count() {
    local PREFIX="$1"
    local LABEL="$2"
    local PERFORM_DELETE="$3" 
    
    debug_log "ROTATION" "=== rotate_backups_by_count($PREFIX, $LABEL, delete=$PERFORM_DELETE) ==="
    debug_log "ROTATION" "MAX_BACKUPS_COUNT=$MAX_BACKUPS_COUNT"
    
    # СТРОГИЙ ПОИСК (Только архивы), сортировка по времени (старые в начале)
    # Используем ls -1tr для сортировки по времени и while read для безопасности имен с пробелами
    local files=()
    while IFS= read -r f; do
        files+=("$f")
    done < <(ls -1tr "$BACKUP_DIR"/${PREFIX}_*.tar.gz "$BACKUP_DIR"/${PREFIX}_*.tar.gz.enc 2> "$SILENT_LOG")
    
    local count=${#files[@]}
    local diff=$((count - MAX_BACKUPS_COUNT))
    debug_log "ROTATION" "Found $count files, limit=$MAX_BACKUPS_COUNT, to_delete=$diff"
    
    if [[ $diff -gt 0 ]]; then
        if [[ "$PERFORM_DELETE" == "true" ]]; then
            if [[ "$DRY_RUN" == "true" ]]; then
                debug_log "ROTATION" "[DRY-RUN] Would delete $diff files"
                echo -e "${YELLOW}[DRY-RUN] Категория '$LABEL': было бы удалено $diff старых файлов (лимит $MAX_BACKUPS_COUNT).${RESET}"
                log_message "INFO" "[DRY_RUN] Would delete $diff files (count-based rotation, prefix=$PREFIX, limit=$MAX_BACKUPS_COUNT)"
                echo "$diff"
                return 0
            fi
            echo -e "${YELLOW}Очистка категории '$LABEL' (удаление $diff старых файлов):${RESET}"
            for (( i=0; i<diff; i++ )); do
                local file_to_del="${files[$i]}"
                if [[ -f "$file_to_del" ]]; then
                    debug_log "ROTATION" "Deleting: $file_to_del"
                    rm -f "$file_to_del"
                    rm -f "$file_to_del.version"
                    echo "  🗑 Удален: $(basename "$file_to_del")"
                    log_message "INFO" "Deleted $file_to_del (count-based rotation, prefix=$PREFIX)"
                fi
            done
            debug_log "ROTATION" "Deleted $diff files"
            echo "$diff"
            return 0
        else
            echo -e " $LABEL: Найдено $count (Лимит $MAX_BACKUPS_COUNT) -> ${RED}Кандидаты на удаление: $diff шт.${RESET}"
            echo "$diff"
        fi
    else
        debug_log "ROTATION" "No files to delete (count=$count <= limit=$MAX_BACKUPS_COUNT)"
        if [[ "$PERFORM_DELETE" != "true" ]]; then
            echo -e " $LABEL: Найдено $count (Лимит $MAX_BACKUPS_COUNT) -> ${GREEN}OK${RESET}"
        fi
        echo "0"
        return 0
    fi
}

rotate_backups_by_age() {
    local PREFIX="$1"
    local LABEL="$2"
    local DAYS="$3"
    local PERFORM_DELETE="$4"

    debug_log "ROTATION" "=== rotate_backups_by_age($PREFIX, $LABEL, days=$DAYS, delete=$PERFORM_DELETE) ==="

    # Найдём файлы старше DAYS дней
    local files=()
    # find -mtime +N означает "строго больше N дней". Чтобы RETENTION_DAYS=N означал
    # "удалять файлы старше N дней", используем -mtime +$((N-1)). Для N==0 — будем
    # удалять все подходящие файлы.
    # Собираем аргументы find без eval
    local find_args=("$BACKUP_DIR" -maxdepth 1 \( -name "${PREFIX}_*.tar.gz" -o -name "${PREFIX}_*.tar.gz.enc" \) -type f)
    if [[ "$DAYS" -le 0 ]]; then
        # Если 0 или меньше - не удаляем ничего (защита от полной очистки)
        debug_log "ROTATION" "Days <= 0, skipping rotation"
        return 0
    else
        local nd=$((DAYS - 1))
        find_args+=( -mtime +"$nd" )
        debug_log "ROTATION" "Find mtime: +$nd (files older than $DAYS days)"
    fi
    find_args+=( -print0 )
    while IFS= read -r -d $'\0' f; do files+=("$f"); done < <(find "${find_args[@]}" 2> "$SILENT_LOG")

    local count=${#files[@]}
    debug_log "ROTATION" "Found $count files older than $DAYS days"

    if [[ $count -gt 0 ]]; then
        if [[ "$PERFORM_DELETE" == "true" ]]; then
            if [[ "$DRY_RUN" == "true" ]]; then
                debug_log "ROTATION" "[DRY-RUN] Would delete $count files"
                echo -e "${YELLOW}[DRY-RUN] Категория '$LABEL': было бы удалено $count файлов старше $DAYS дней.${RESET}"
                log_message "INFO" "[DRY_RUN] Would delete $count files (age-based rotation, prefix=$PREFIX, days=$DAYS)"
                echo "$count"
                return 0
            fi
            echo -e "${YELLOW}Очистка категории '$LABEL' (удаление $count файлов старше $DAYS дней):${RESET}"
            for f in "${files[@]}"; do
                if [[ -f "$f" ]]; then
                    debug_log "ROTATION" "Deleting: $f"
                    rm -f "$f"
                    rm -f "$f.version"
                    echo "  🗑 Удален: $(basename "$f")"
                    log_message "INFO" "Deleted $f (age-based rotation, prefix=$PREFIX, days=$DAYS)"
                fi
            done
            debug_log "ROTATION" "Deleted $count files"
            echo "$count"
            return 0
        else
            echo -e " $LABEL: Найдено $count файлов старше $DAYS дней -> ${RED}Кандидаты на удаление: $count шт.${RESET}"
            echo "$count"
        fi
    else
        debug_log "ROTATION" "No files to delete"
        if [[ "$PERFORM_DELETE" != "true" ]]; then
            echo -e " $LABEL: Нет файлов старше $DAYS дней -> ${GREEN}OK${RESET}"
        fi
        echo "0"
        return 0
    fi
}

# Ротация по размеру - удаляет старые бэкапы пока общий размер не станет <= лимита
# Использование: rotate_backups_by_size "true" для удаления, без аргумента - только проверка
rotate_backups_by_size() {
    local PERFORM_DELETE="$1"
    
    debug_log "SIZE" "=== rotate_backups_by_size(delete=$PERFORM_DELETE) ==="
    
    # Если лимит 0 или не задан - ничего не делаем
    if [[ -z "$MAX_BACKUP_SIZE_MB" || "$MAX_BACKUP_SIZE_MB" == "0" ]]; then
        debug_log "SIZE" "Size limit disabled (MAX_BACKUP_SIZE_MB=$MAX_BACKUP_SIZE_MB)"
        return 0
    fi
    
    local limit_mb="$MAX_BACKUP_SIZE_MB"
    local limit_bytes=$((limit_mb * 1024 * 1024))
    debug_log "SIZE" "Limit: $limit_mb MB ($limit_bytes bytes)"
    
    # Получаем текущий размер папки бэкапов в байтах
    local current_size_bytes=$(du -sb "$BACKUP_DIR" 2> "$SILENT_LOG" | awk '{print $1}')
    local current_size_mb=$((current_size_bytes / 1024 / 1024))
    debug_log "SIZE" "Current size: $current_size_mb MB ($current_size_bytes bytes)"
    
    # Форматирование для отображения
    local limit_display=""
    local current_display=""
    if [[ $limit_mb -ge 1024 ]]; then
        limit_display="$(echo "scale=1; $limit_mb / 1024" | bc) GB"
    else
        limit_display="$limit_mb MB"
    fi
    if [[ $current_size_mb -ge 1024 ]]; then
        current_display="$(echo "scale=1; $current_size_mb / 1024" | bc) GB"
    else
        current_display="$current_size_mb MB"
    fi
    
    debug_log "SIZE" "Current: $current_size_bytes bytes ($current_display), Limit: $limit_bytes bytes ($limit_display)"
    
    # Если размер в пределах лимита - всё ок
    if [[ $current_size_bytes -le $limit_bytes ]]; then
        if [[ "$PERFORM_DELETE" != "true" ]]; then
            echo -e " Размер бэкапов: ${GREEN}$current_display${RESET} / $limit_display -> ${GREEN}OK${RESET}"
        fi
        return 0
    fi
    
    # Нужно удалить файлы
    local excess_mb=$((current_size_mb - limit_mb))
    local excess_display=""
    if [[ $excess_mb -ge 1024 ]]; then
        excess_display="$(echo "scale=1; $excess_mb / 1024" | bc) GB"
    else
        excess_display="$excess_mb MB"
    fi
    debug_log "SIZE" "Excess: $excess_mb MB ($excess_display)"
    
    if [[ "$PERFORM_DELETE" != "true" ]]; then
        echo -e " Размер бэкапов: ${RED}$current_display${RESET} / $limit_display -> ${RED}Превышение: $excess_display${RESET}"
        return 0
    fi
    
    # Режим удаления
    if [[ "$DRY_RUN" == "true" ]]; then
        debug_log "SIZE" "[DRY-RUN] Would delete files to free $excess_display"
        echo -e "${YELLOW}[DRY-RUN] Превышение лимита на $excess_display. Старые файлы были бы удалены.${RESET}"
        log_message "INFO" "[DRY_RUN] Size rotation: current=$current_display, limit=$limit_display, excess=$excess_display"
        return 0
    fi
    
    debug_log "SIZE" "Starting deletion loop..."
    echo -e "${YELLOW}Очистка по лимиту размера (текущий: $current_display, лимит: $limit_display):${RESET}"
    
    # Получаем список всех бэкапов отсортированный по времени (старые первыми)
    local files=()
    while IFS= read -r -d $'\0' f; do 
        files+=("$f")
    done < <(find "$BACKUP_DIR" -maxdepth 1 -type f \( -name "lazarus_*.tar.gz" -o -name "lazarus_*.tar.gz.enc" \) -printf '%T@ %p\0' 2> "$SILENT_LOG" | sort -zn | cut -z -d' ' -f2-)
    
    debug_log "SIZE" "Found ${#files[@]} backup files to process"
    
    local deleted_count=0
    local deleted_size=0
    
    for file in "${files[@]}"; do
        # Пересчитываем текущий размер
        current_size_bytes=$(du -sb "$BACKUP_DIR" 2> "$SILENT_LOG" | awk '{print $1}')
        debug_log "SIZE" "Current: $current_size_bytes bytes, limit: $limit_bytes bytes"
        
        if [[ $current_size_bytes -le $limit_bytes ]]; then
            debug_log "SIZE" "Size now within limit, stopping"
            break
        fi
        
        if [[ -f "$file" ]]; then
            local file_size=$(stat -c%s "$file" 2> "$SILENT_LOG" || echo 0)
            debug_log "SIZE" "Deleting: $file (size=$file_size bytes)"
            rm -f "$file"
            rm -f "$file.version"
            echo "  🗑 Удален: $(basename "$file")"
            log_message "INFO" "Deleted $file (size-based rotation)"
            ((deleted_count++))
            ((deleted_size += file_size))
        fi
    done
    
    local deleted_display=""
    local deleted_mb=$((deleted_size / 1024 / 1024))
    if [[ $deleted_mb -ge 1024 ]]; then
        deleted_display="$(echo "scale=1; $deleted_mb / 1024" | bc) GB"
    else
        deleted_display="$deleted_mb MB"
    fi
    
    if [[ $deleted_count -gt 0 ]]; then
        print_message "SUCCESS" "Удалено $deleted_count файлов ($deleted_display)"
        log_message "SUCCESS" "Size-based rotation: deleted $deleted_count files ($deleted_display)"
    fi
    
    return 0
}

# Вспомогательная функция для форматирования размера
format_size_mb() {
    local size_mb="$1"
    if [[ -z "$size_mb" || "$size_mb" == "0" ]]; then
        echo "Без лимита"
    elif [[ $size_mb -ge 1024 ]]; then
        echo "$(echo "scale=1; $size_mb / 1024" | bc) GB"
    else
        echo "$size_mb MB"
    fi
}

# =============================================================================
# _split_exclude_dirs: разбивает EXCLUDE_DIRS-строку на массив, поддерживая
# пути с пробелами через `,` или `;` как первичный разделитель.
# =============================================================================
# Раньше split шёл через `IFS=' '` — пути типа `my dir/cache` ломались на
# два «my» + «dir/cache». Новая логика:
#   - Если в строке есть `,` или `;` — используем их как primary separator,
#     trim'им trailing/leading whitespace вокруг каждого элемента.
#   - Иначе fallback на space-split (backward-compat для существующих configs).
#
# Аргументы:
#   $1 — EXCLUDE_DIRS значение
#   $2 — имя выходного array (передаётся по reference через `eval`)
#
# Пример:
#   _split_exclude_dirs "node_modules, .git, my data/cache" ARR
#   # ARR=( "node_modules" ".git" "my data/cache" )
# =============================================================================
_split_exclude_dirs() {
    local _input="$1"
    local _out_name="$2"
    # Очистка target array через nameref (bash 4.3+, есть везде где есть GNU bash).
    eval "$_out_name=()"
    [[ -z "$_input" ]] && return 0

    # Detect comma/semicolon как разделитель — если есть, парсим по ним.
    if [[ "$_input" == *,* || "$_input" == *\;* ]]; then
        # Нормализуем `;` → `,` для одного парсинга.
        local _norm="${_input//;/,}"
        local _old_ifs="$IFS"
        IFS=','
        # shellcheck disable=SC2206
        local _raw=( $_norm )
        IFS="$_old_ifs"
        local _item
        for _item in "${_raw[@]}"; do
            # Trim leading/trailing whitespace
            _item="${_item#"${_item%%[![:space:]]*}"}"
            _item="${_item%"${_item##*[![:space:]]}"}"
            [[ -n "$_item" ]] && eval "$_out_name+=( \"\$_item\" )"
        done
    else
        # Backward-compat: space-split. Не поддерживает пути с пробелами,
        # но не ломает existing configs.
        local _old_ifs="$IFS"
        IFS=' '
        # shellcheck disable=SC2206
        local _raw=( $_input )
        IFS="$_old_ifs"
        local _item
        for _item in "${_raw[@]}"; do
            [[ -n "$_item" ]] && eval "$_out_name+=( \"\$_item\" )"
        done
    fi
}

# build_skipped_report: сканирует BOT_PATH и записывает в output_file список
# файлов, которые НЕ попадут в архив, с причиной. Формат строки (TSV):
#     SIZE_BYTES \t RELATIVE_PATH \t REASON
# Категории причин (порядок важен — первое совпадение):
#   1) size > MAX_FILE_SIZE_MB MB
#   2) .git directory
#   3) backups/ directory
#   4) bot image .tar (private-remnawave-*.tar / rwp_shop*.tar / telegram-shop*.tar)
#   5) log file (если BACKUP_LOG_FILES != "true")
#   6) EXCLUDE_DIRS: <pattern>
# Возвращает в stdout: общее число пропущенных файлов.
build_skipped_report() {
    local bot_path="$1"
    local output_file="$2"

    [[ -z "$bot_path" || ! -d "$bot_path" ]] && return 1
    if ! find /dev/null -printf '' 2>/dev/null; then
        return 1  # нет GNU find -printf
    fi

    : > "$output_file"
    local max_bytes=0
    if [[ "$MAX_FILE_SIZE_MB" =~ ^[0-9]+$ ]] && [[ "$MAX_FILE_SIZE_MB" -gt 0 ]]; then
        max_bytes=$((MAX_FILE_SIZE_MB * 1048576))
    fi

    local EXCL_ARR=()
    _split_exclude_dirs "$EXCLUDE_DIRS" EXCL_ARR

    local skip_logs="true"
    [[ "$BACKUP_LOG_FILES" == "true" ]] && skip_logs="false"

    local count=0
    # extglob: сохраняем текущее состояние и восстанавливаем при выходе из функции
    # через trap RETURN. Иначе при ошибочном early-return extglob утечёт в parent,
    # ломая последующие ${var//pattern/} c `(`/`)` в шаблоне (например, CAPTION_ESC).
    local _eg_prev
    _eg_prev=$(shopt -p extglob)
    shopt -s extglob
    # shellcheck disable=SC2064
    trap "$_eg_prev" RETURN

    # NB: используем NUL-разделитель (`-printf '%s\t%P\0'` + `read -d ''`) —
    # защита от файлов с tab/newline в именах. Атакующий с write-доступом к
    # BOT_PATH мог создать файл `evil\nname.log` чтобы log-pattern matcher
    # не сработал (newline ломает читаемые «строки»). С NUL — каждая запись
    # доезжает целиком, имя сохраняется как есть.
    while IFS=$'\t' read -r -d '' size rel_path; do
        [[ -z "$rel_path" ]] && continue
        local reason=""

        if [[ $max_bytes -gt 0 && -n "$size" && $size -gt $max_bytes ]]; then
            # Унифицированная причина без конкретного размера — чтобы все большие файлы
            # попадали в ОДНУ группу при группировке по reason в show_skipped_report.
            reason="size > MAX_FILE_SIZE_MB=${MAX_FILE_SIZE_MB}MB"
        elif [[ "$rel_path" == .git || "$rel_path" == .git/* || "$rel_path" == */.git/* ]]; then
            reason=".git directory"
        elif [[ "$rel_path" == backups || "$rel_path" == backups/* || "$rel_path" == */backups/* ]]; then
            reason="backups/ directory"
        elif [[ "$rel_path" == *private-remnawave-*.tar || "$rel_path" == *rwp_shop*.tar || "$rel_path" == *telegram-shop*.tar ]]; then
            reason="bot image .tar"
        elif [[ "$skip_logs" == "true" ]] && \
             { [[ "$rel_path" == *.log ]] || [[ "$rel_path" == *.log.+([0-9]) ]] || \
               [[ "$rel_path" == *.log.+([0-9]).gz ]] || [[ "$rel_path" == *.log-+([0-9]) ]] || \
               [[ "$rel_path" == *.log-+([0-9]).gz ]] || [[ "$rel_path" == logs/* ]] || \
               [[ "$rel_path" == */logs/* ]]; }; then
            reason="log file (BACKUP_LOG_FILES=$BACKUP_LOG_FILES)"
        else
            for ex in "${EXCL_ARR[@]}"; do
                [[ -z "$ex" ]] && continue
                if [[ "$rel_path" == "$ex" || "$rel_path" == "$ex"/* || "$rel_path" == */"$ex"/* ]]; then
                    reason="EXCLUDE_DIRS: $ex"
                    break
                fi
            done
        fi

        if [[ -n "$reason" ]]; then
            # NB: rel_path может содержать tab/newline → в TSV выводе они ломают
            # парсинг в show_skipped_report. Заменяем на видимые маркеры (не теряем
            # имя для diagnostics, но строка остаётся одна и парсится корректно).
            local _safe_path="${rel_path//$'\t'/<TAB>}"
            _safe_path="${_safe_path//$'\n'/<NL>}"
            printf '%s\t%s\t%s\n' "${size:-0}" "$_safe_path" "$reason" >> "$output_file"
            count=$((count + 1))
        fi
    done < <(cd "$bot_path" 2>/dev/null && find . -type f -printf '%s\t%P\0' 2> "$SILENT_LOG")

    # extglob восстанавливается через trap RETURN (см. выше)
    echo "$count"
}

# get_top_files_in_archive: возвращает топ-N крупных файлов в BOT_PATH,
# которые попадут в архив (фильтр по MAX_FILE_SIZE_MB + EXCLUDE_DIRS).
# Используется в TG pre-flight уведомлении когда архив >50 MB —
# чтобы пользователь понял, что раздувает бэкап.
# Аргументы: $1=bot_path  $2=max_size_mb  $3=exclude_dirs_str  $4=limit (default 5)
# Вывод (stdout, по одной строке): "  • SIZE — relative/path"
get_top_files_in_archive() {
    local bot_path="$1"
    local max_size_mb="${2:-0}"
    local exclude_dirs_str="$3"
    local limit="${4:-5}"

    [[ -z "$bot_path" || ! -d "$bot_path" ]] && return 1

    # Проверка наличия GNU find -printf (BusyBox не поддерживает)
    if ! find /dev/null -printf '' 2>/dev/null; then
        debug_log "TG" "get_top_files_in_archive: GNU find -printf не поддерживается, пропуск"
        return 1
    fi

    local FIND_ARGS=(".")
    if [[ -n "$exclude_dirs_str" ]]; then
        local EXCL_ARR=()
        _split_exclude_dirs "$exclude_dirs_str" EXCL_ARR
        for ex in "${EXCL_ARR[@]}"; do
            # Whitelist: разрешаем пробелы внутри (нужно для путей типа "my dir/cache").
            if [[ -n "$ex" && "$ex" =~ ^[a-zA-Z0-9_./\ -]+$ ]]; then
                FIND_ARGS+=("-path" "./$ex" "-prune" "-o")
            fi
        done
    fi
    FIND_ARGS+=("-type" "f")
    # Фильтр по max_size_mb (исключаем то что и так пропущено)
    if [[ "$max_size_mb" =~ ^[0-9]+$ ]] && [[ "$max_size_mb" -gt 0 ]]; then
        FIND_ARGS+=("!" "-size" "+${max_size_mb}M")
    fi
    # NUL-delim формат (`%s\t%P\0`) — защита от файлов с tab/newline в именах.
    # awk -F'\t' читает поля; запись с control char внутри пути ломала формат
    # «size TAB path NEWLINE» и приводила к partial parsing. С NUL-разделителем
    # каждая запись доезжает целиком, control'ы заменяем в awk на «?».
    FIND_ARGS+=("-printf" "%s\t%P\0")

    (cd "$bot_path" 2>/dev/null && find "${FIND_ARGS[@]}" 2>/dev/null) \
        | tr '\0' '\n' \
        | sort -rn \
        | head -n "$limit" \
        | awk -F'\t' '{
            sz=$1; path=$2;
            h=sz; u="B";
            if (h>=1024) { h/=1024; u="K" }
            if (h>=1024) { h/=1024; u="M" }
            if (h>=1024) { h/=1024; u="G" }
            # Очистка контрол-символов (на случай если в имени файла остался NUL/tab внутри)
            gsub(/[\001-\037\177]/, "?", path)
            # Обрезаем длинные пути до 60 символов для красоты в TG
            if (length(path) > 60) path = "..." substr(path, length(path)-57);
            printf "  • %.1f%s — %s\n", h, u, path
        }'
}

uninstall_script() {
    if [[ "$EUID" -ne 0 ]]; then
        print_message "ERROR" "Uninstall requires root (sudo)."
        return 1
    fi
    echo ""
    print_message "WARN" "Удаление скрипта и данных установки будет выполнено.";
    read -erp "Продолжить? (y/N): " ans
    if [[ ! "$ans" =~ ^[Yy]$ ]]; then print_message "INFO" "Отменено."; return 0; fi

    # remove symlink
    if [[ -L "$SYMLINK_PATH" ]]; then
        rm -f "$SYMLINK_PATH" && log_message "INFO" "Removed symlink $SYMLINK_PATH"
    fi
    # remove installed script
    if [[ -f "$INSTALL_DIR/$SCRIPT_NAME" ]]; then
        rm -f "$INSTALL_DIR/$SCRIPT_NAME" && log_message "INFO" "Removed $INSTALL_DIR/$SCRIPT_NAME"
    fi
    # remove config and backups (ask)
    if [[ -d "$INSTALL_DIR" ]]; then
        read -erp "Удалить папку $INSTALL_DIR и все бэкапы? (y/N): " r2
        if [[ "$r2" =~ ^[Yy]$ ]]; then
            rm -rf "$INSTALL_DIR" && log_message "INFO" "Removed $INSTALL_DIR"
        else
            log_message "INFO" "Preserved $INSTALL_DIR"
        fi
    fi
    # try to remove cron entries
    crontab -l 2> "$SILENT_LOG" | grep -v "# LAZARUS-JOB-" | crontab - 2> "$SILENT_LOG" || true
    log_message "INFO" "Attempted to remove cron entries for lazarus"
    print_message "SUCCESS" "Uninstall finished."
}

# --- ПРОВЕРКА CRON ЗАДАЧ ---

# Проверяет реальное состояние cron-задач и возвращает статус
get_cron_status() {
    local JOB_TYPE="$1"  # full, db, files
    local JOB_ID="# LAZARUS-JOB-${JOB_TYPE^^}"
    
    local cron_line=$(crontab -l 2> "$SILENT_LOG" | grep "$JOB_ID")
    
    if [[ -z "$cron_line" ]]; then
        echo "Выкл"
        return
    fi
    
    # Парсим cron-строку для отображения расписания
    local minute=$(echo "$cron_line" | awk '{print $1}')
    local hour=$(echo "$cron_line" | awk '{print $2}')
    local day_month=$(echo "$cron_line" | awk '{print $3}')
    local day_week=$(echo "$cron_line" | awk '{print $5}')
    
    # Определяем тип расписания
    if [[ "$minute" == "0" && "$hour" == "*" ]]; then
        echo "Ежечасно"
    elif [[ "$minute" =~ ^\*/([0-9]+)$ ]]; then
        echo "Каждые ${BASH_REMATCH[1]} мин"
    elif [[ "$minute" == "0" && "$hour" == "4" && "$day_week" == "1" ]]; then
        echo "Еженедельно"
    elif [[ "$minute" == "0" && "$hour" =~ ^[0-9]+$ && "$day_month" == "*" ]]; then
        printf "Ежедневно %02d:00" "$hour"
    elif [[ "$hour" =~ ^[0-9]+$ && "$minute" =~ ^[0-9]+$ ]]; then
        printf "Ежедневно %02d:%02d" "$hour" "$minute"
    else
        echo "Активно"
    fi
}

# Синхронизирует настройки скрипта с реальным состоянием cron
sync_cron_with_config() {
    local CRON_FULL=$(get_cron_status "full")
    local CRON_DB=$(get_cron_status "db")
    local CRON_FILES=$(get_cron_status "files")
    
    local needs_save=false
    
    # Обновляем переменные если они отличаются от реального cron
    if [[ "$SCHEDULE_FULL" != "$CRON_FULL" ]]; then
        SCHEDULE_FULL="$CRON_FULL"
        needs_save=true
    fi
    if [[ "$SCHEDULE_DB" != "$CRON_DB" ]]; then
        SCHEDULE_DB="$CRON_DB"
        needs_save=true
    fi
    if [[ "$SCHEDULE_FILES" != "$CRON_FILES" ]]; then
        SCHEDULE_FILES="$CRON_FILES"
        needs_save=true
    fi
    
    if [[ "$needs_save" == "true" ]]; then
        save_config
    fi
}

# Проверяет несоответствие между настройками и cron, предлагает исправить
check_cron_mismatch() {
    [[ "$IS_INTERACTIVE" != "true" ]] && return 0
    
    local CRON_FULL=$(get_cron_status "full")
    local CRON_DB=$(get_cron_status "db")
    local CRON_FILES=$(get_cron_status "files")
    
    local mismatches=()
    
    # Проверяем: в настройках включено, но в cron нет
    if [[ "$SCHEDULE_FULL" != "Выкл" && "$CRON_FULL" == "Выкл" ]]; then
        mismatches+=("Full: настройка='$SCHEDULE_FULL', cron=отсутствует")
    fi
    if [[ "$SCHEDULE_DB" != "Выкл" && "$CRON_DB" == "Выкл" ]]; then
        mismatches+=("DB: настройка='$SCHEDULE_DB', cron=отсутствует")
    fi
    if [[ "$SCHEDULE_FILES" != "Выкл" && "$CRON_FILES" == "Выкл" ]]; then
        mismatches+=("Files: настройка='$SCHEDULE_FILES', cron=отсутствует")
    fi
    
    if [[ ${#mismatches[@]} -eq 0 ]]; then
        return 0
    fi
    
    clear_screen
    echo -e "${YELLOW}${BOLD}⚠️ Обнаружено несоответствие настроек и cron-задач${RESET}"
    echo ""
    echo "В настройках скрипта указаны задачи автоматического бэкапа,"
    echo "но соответствующие cron-задачи не найдены в системе."
    echo ""
    echo -e "${CYAN}Несоответствия:${RESET}"
    for m in "${mismatches[@]}"; do
        echo -e " • $m"
    done
    echo ""
    echo "Возможно, cron-задачи были удалены вручную."
    echo ""
    echo " 1. Создать недостающие cron-задачи (восстановить)"
    echo " 2. Синхронизировать настройки с cron (сбросить в 'Выкл')"
    echo " 0. Пропустить (оставить как есть)"
    echo ""
    read -erp "Ваш выбор: " choice
    
    case $choice in
        1)
            # Восстанавливаем cron-задачи из настроек
            if [[ "$SCHEDULE_FULL" != "Выкл" && "$CRON_FULL" == "Выкл" ]]; then
                recreate_cron_from_schedule "full" "$SCHEDULE_FULL"
            fi
            if [[ "$SCHEDULE_DB" != "Выкл" && "$CRON_DB" == "Выкл" ]]; then
                recreate_cron_from_schedule "db" "$SCHEDULE_DB"
            fi
            if [[ "$SCHEDULE_FILES" != "Выкл" && "$CRON_FILES" == "Выкл" ]]; then
                recreate_cron_from_schedule "files" "$SCHEDULE_FILES"
            fi
            print_message "SUCCESS" "Cron-задачи восстановлены."
            sleep 1
            ;;
        2)
            # Синхронизируем настройки с реальным cron
            sync_cron_with_config
            print_message "SUCCESS" "Настройки синхронизированы с cron."
            sleep 1
            ;;
        *)
            print_message "INFO" "Пропущено."
            sleep 0.5
            ;;
    esac
}

# Воссоздаёт cron-задачу из сохранённого расписания
recreate_cron_from_schedule() {
    local TASK_TYPE="$1"
    local SCHEDULE="$2"
    
    local JOB_CMD="$SYMLINK_PATH backup_$TASK_TYPE"
    [[ "$TASK_TYPE" == "db" ]] && JOB_CMD="$SYMLINK_PATH backup_db"
    [[ "$TASK_TYPE" == "files" ]] && JOB_CMD="$SYMLINK_PATH backup_files"
    [[ "$TASK_TYPE" == "full" ]] && JOB_CMD="$SYMLINK_PATH backup_full"
    
    local JOB_ID="# LAZARUS-JOB-${TASK_TYPE^^}"
    local NEW_CRON_LINE=""
    
    # Парсим расписание и создаём cron-строку
    case "$SCHEDULE" in
        "Ежечасно")
            NEW_CRON_LINE="0 * * * * $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"
            ;;
        "Еженедельно")
            NEW_CRON_LINE="0 4 * * 1 $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"
            ;;
        Ежедневно\ *)
            # Парсим время из "Ежедневно HH:MM" или "Ежедневно HH:00"
            local time_part="${SCHEDULE#Ежедневно }"
            local hour="${time_part%%:*}"
            local minute="${time_part##*:}"
            hour=$((10#$hour))  # Убираем ведущий ноль
            minute=$((10#$minute))
            NEW_CRON_LINE="$minute $hour * * * $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"
            ;;
        Каждые\ *\ мин)
            local interval="${SCHEDULE#Каждые }"
            interval="${interval% мин}"
            NEW_CRON_LINE="*/$interval * * * * $JOB_CMD >> /var/log/lazarus_backup.log 2>&1 $JOB_ID"
            ;;
        *)
            # Неизвестный формат — пропускаем
            print_message "WARN" "Не удалось распознать расписание: $SCHEDULE"
            return 1
            ;;
    esac
    
    if [[ -n "$NEW_CRON_LINE" ]]; then
        local CURRENT_CRON=$(crontab -l 2> "$SILENT_LOG" | grep -v "$JOB_ID")
        echo -e "$CURRENT_CRON\n$NEW_CRON_LINE" | crontab -
        log_message "INFO" "Recreated cron job for $TASK_TYPE: $SCHEDULE"
    fi
}

# --- БЭКАП ---

create_backup() {
    local TYPE="$1"
    debug_log "BACKUP" "=== Starting backup: type=$TYPE ==="
    debug_log "BACKUP" "BOT_PATH=$BOT_PATH"
    debug_log "BACKUP" "BOT_CONTAINER=$BOT_CONTAINER_NAME, DB_CONTAINER=$DB_CONTAINER_NAME"
    debug_log "BACKUP" "IS_INTERACTIVE=$IS_INTERACTIVE"
    
    # Блокировка от параллельного запуска (только в non-interactive режиме)
    local LOCK_ACQUIRED="false"
    if [[ "$IS_INTERACTIVE" == "false" ]]; then
        debug_log "LOCK" "Attempting to acquire lock..."
        if ! acquire_lock; then
            local owner_pid=$(check_lock_owner)
            debug_log "LOCK" "Lock failed! Owner PID: $owner_pid"
            log_message "WARN" "Backup skipped: another instance is running (PID: $owner_pid)"
            print_message "WARN" "Другой процесс бэкапа уже запущен (PID: $owner_pid)"
            return 1
        fi
        debug_log "LOCK" "Lock acquired successfully"
        LOCK_ACQUIRED="true"
    fi
    
    # === ПРОВЕРКА ДИСКА ===
    # Два слоя защиты:
    #   1) Процентный (DISK_WARN_PERCENT / DISK_CRITICAL_PERCENT) — нужно для больших дисков
    #   2) Абсолютный (MIN_SPACE_MB=1024) — fallback для маленьких дисков (1 GB обязательно)
    local MIN_SPACE_MB=1024
    local free_space_kb=$(df -P "$BACKUP_DIR" 2> "$SILENT_LOG" | tail -1 | awk '{print $4}')
    local free_space_mb=$((free_space_kb / 1024))
    local free_space_human=$(df -h "$BACKUP_DIR" 2> "$SILENT_LOG" | tail -1 | awk '{print $4}')
    local disk_used_percent=$(df -P "$BACKUP_DIR" 2> "$SILENT_LOG" | tail -1 | awk '{print $5}' | tr -d '%')
    local disk_mount=$(df -P "$BACKUP_DIR" 2> "$SILENT_LOG" | tail -1 | awk '{print $6}')
    debug_log "DISK" "Used: ${disk_used_percent}% (mount=${disk_mount}, free=${free_space_human}), thresholds: WARN=${DISK_WARN_PERCENT}% CRIT=${DISK_CRITICAL_PERCENT}% MIN_ABS=${MIN_SPACE_MB}MB"

    # 1) CRITICAL: >= 95% — отменяем бэкап
    # Валидация: на NFS/FUSE/stale mount df может вернуть "?" — пропускаем процентные проверки.
    if ! [[ "$disk_used_percent" =~ ^[0-9]+$ ]]; then
        debug_log "DISK" "disk_used_percent not numeric ('$disk_used_percent'), skip percent checks"
        disk_used_percent=""
    fi

    if [[ -n "$disk_used_percent" && "$disk_used_percent" -ge "$DISK_CRITICAL_PERCENT" ]]; then
        print_message "ERROR" "Диск заполнен на ${disk_used_percent}% (порог CRITICAL=${DISK_CRITICAL_PERCENT}%). Бэкап отменён."
        log_message "ERROR" "Backup aborted: disk ${disk_used_percent}% >= CRITICAL ${DISK_CRITICAL_PERCENT}% on ${disk_mount}"
        local _crit_body="📊 ${disk_used_percent}% / порог ${DISK_CRITICAL_PERCENT}%
💾 Свободно: ${free_space_human} (${disk_mount})
🛑 Бэкап ОТМЕНЁН"
        local _crit_actions="<code>lazarus cleanup</code>
<code>lazarus s3 upload <файл></code>"
        send_telegram_alert "CRITICAL" "Диск переполнен" "$_crit_body" "$_crit_actions"
        [[ "$LOCK_ACQUIRED" == "true" ]] && release_lock
        return 1
    fi

    # 2) WARN: >= 90% — уведомление, продолжаем
    if [[ -n "$disk_used_percent" && "$disk_used_percent" -ge "$DISK_WARN_PERCENT" ]]; then
        print_message "WARN" "Диск заполнен на ${disk_used_percent}% (порог WARN=${DISK_WARN_PERCENT}%). Рекомендуется cleanup."
        log_message "WARN" "Disk usage ${disk_used_percent}% >= WARN ${DISK_WARN_PERCENT}% on ${disk_mount}"
        local _warn_body="📊 ${disk_used_percent}% / порог ${DISK_WARN_PERCENT}%
💾 Свободно: ${free_space_human} (${disk_mount})
✅ Бэкап продолжается. При ${DISK_CRITICAL_PERCENT}% — будет отменён."
        local _warn_actions="<code>lazarus cleanup</code>"
        send_telegram_alert "WARN" "Диск заполняется" "$_warn_body" "$_warn_actions"
    fi
    
    if [[ $free_space_mb -lt $MIN_SPACE_MB ]]; then
        print_message "ERROR" "Недостаточно места на диске! Свободно: ${free_space_human} (нужно минимум 1GB)"
        log_message "ERROR" "Backup aborted: insufficient disk space (free=${free_space_human}, required=1GB)"
        if [[ "$IS_INTERACTIVE" == "true" ]]; then
            echo ""
            echo -e "${YELLOW}Рекомендации:${RESET}"
            echo " • Удалите старые бэкапы (меню 5)"
            echo " • Освободите место на диске"
            echo ""
            read -erp "Всё равно продолжить? (y/N): " force_continue
            if [[ ! "$force_continue" =~ ^[Yy]$ ]]; then
                return 1
            fi
            print_message "WARN" "Продолжаем на свой риск..."
        else
            # В non-interactive режиме (cron) отправляем уведомление и прерываем
            send_telegram_alert "CRITICAL" "Нет места на диске" \
                "💾 Свободно: ${free_space_human} (${disk_mount})
🛑 Минимум для бэкапа: 1 GB
🛑 Бэкап ОТМЕНЁН (cron)" \
                "<code>lazarus cleanup</code>
<code>df -h</code>"
            [[ "$LOCK_ACQUIRED" == "true" ]] && release_lock
            return 1
        fi
    fi
    
    # Health-check контейнеров перед бэкапом
    if [[ "$TYPE" == "full" || "$TYPE" == "db_only" ]]; then
        debug_log "HEALTH" "Checking DB container health..."
        if [[ -n "$DB_CONTAINER_NAME" ]]; then
            local db_running=$(docker container inspect -f '{{.State.Running}}' "$DB_CONTAINER_NAME" 2> "$SILENT_LOG")
            debug_log "HEALTH" "Container $DB_CONTAINER_NAME running=$db_running"
            if [[ "$db_running" != "true" ]]; then
                print_message "ERROR" "Контейнер БД ($DB_CONTAINER_NAME) не запущен!"
                log_message "ERROR" "Backup aborted: DB container not running ($DB_CONTAINER_NAME)"
                if [[ "$IS_INTERACTIVE" != "true" ]]; then
                    send_telegram_alert "CRITICAL" "Контейнер БД не запущен" \
                        "🐳 <code>$DB_CONTAINER_NAME</code>
📦 Тип: $TYPE
🛑 Бэкап ОТМЕНЁН" \
                        "<code>docker start $DB_CONTAINER_NAME</code>
<code>docker ps -a</code>"
                fi
                [[ "$LOCK_ACQUIRED" == "true" ]] && release_lock
                return 1
            fi
            
            # Проверяем health status если есть
            local db_health=$(docker container inspect -f '{{.State.Health.Status}}' "$DB_CONTAINER_NAME" 2> "$SILENT_LOG")
            debug_log "HEALTH" "Container health status: $db_health"
            if [[ "$db_health" == "unhealthy" ]]; then
                print_message "WARN" "Контейнер БД в состоянии 'unhealthy'!"
                log_message "WARN" "DB container health status: unhealthy ($DB_CONTAINER_NAME)"
                if [[ "$IS_INTERACTIVE" == "true" ]]; then
                    read -erp "Продолжить несмотря на предупреждение? (y/N): " cont_unhealthy
                    if [[ ! "$cont_unhealthy" =~ ^[Yy]$ ]]; then
                        return 1
                    fi
                fi
                # В cron-режиме продолжаем, но логируем предупреждение
            fi
        fi
    fi
    
    if [[ -z "$BACKUP_PASSWORD" && "$IS_INTERACTIVE" == "true" ]]; then
        clear_screen
        echo -e "${RED}${BOLD}⚠️ ВНИМАНИЕ: Пароль шифрования не установлен!${RESET}"
        echo "Файл бэкапа не будет зашифрован. Данные могут быть доступны третьим лицам."
        echo ""
        echo " 1. Продолжить без шифрования"
        echo " 2. Установить пароль сейчас"
        echo " 0. Отмена"
        echo ""
        safe_read -erp "Ваш выбор: " enc_choice
        case $enc_choice in
            1) ;;
            2)
                # Двойной ввод с подтверждением + явный feedback.
                safe_read -s -erp "Введите пароль шифрования: " np
                echo ""
                if [[ -z "$np" ]]; then
                    print_message "ERROR" "✗ Пустой пароль. Бэкап отменён."
                    safe_read -rp "Enter — закрыть " _dummy
                    return
                fi
                safe_read -s -erp "Повторите пароль для подтверждения: " np_confirm
                echo ""
                if [[ "$np" != "$np_confirm" ]]; then
                    print_message "ERROR" "✗ Пароли НЕ совпадают. Бэкап отменён."
                    safe_read -rp "Enter — закрыть " _dummy
                    return
                fi
                # write_password_file валидирует путь/newline/chmod — отказ означает,
                # что пароль НЕ сохранён, БД-бэкап без шифрования не должен идти,
                # если пользователь его явно запросил.
                if ! write_password_file "$np"; then
                    print_message "ERROR" "Не удалось сохранить пароль. Бэкап отменён."
                    safe_read -rp "Enter — закрыть " _dummy
                    return
                fi
                BACKUP_PASSWORD="$np"
                save_config
                print_message "SUCCESS" "✓ Пароль установлен (${#np} символов). Продолжаем бэкап..."
                ;;
            *) print_message "INFO" "Бэкап отменён."; return ;;
        esac
    fi

    # === ВОПРОС ПРО ЛОГИ (если ещё не настроено и есть файловая часть бэкапа) ===
    # Спрашиваем только при interactive ручном бэкапе и только при типах с файлами.
    # Ответ сохраняется в config — повторно не спросим.
    if [[ "$IS_INTERACTIVE" == "true" && "$TYPE" != "db_only" && "$BACKUP_LOG_FILES" == "ask" ]]; then
        clear_screen
        echo -e "${CYAN}${BOLD}━━━ Бэкапить ли файлы логов? ━━━${RESET}"
        echo ""
        echo "В папке бота могут быть файлы вроде:"
        echo -e "  ${GRAY}access.log, access.log.1, access.log.2.gz, access.log-20260510.gz${RESET}"
        echo -e "  ${GRAY}error.log, error.log.1, error.log.5.gz${RESET}"
        echo ""
        echo "Обычно они не нужны для восстановления бота и только раздувают архив."
        echo ""
        echo -e " ${GREEN}1. Нет, не бэкапить логи${RESET} ${GRAY}(рекомендуется, экономит место)${RESET}"
        echo -e " ${YELLOW}2. Да, включить логи в архив${RESET}"
        echo ""
        safe_read -erp "Выбор (Enter = 1): " log_choice
        case "$log_choice" in
            2) BACKUP_LOG_FILES="true";  print_message "INFO" "Логи будут включены в архив (запомнено)" ;;
            *) BACKUP_LOG_FILES="false"; print_message "INFO" "Логи будут исключены из архива (запомнено)" ;;
        esac
        save_config
    fi

    local TIMESTAMP=$(date +%Y-%m-%d"_"%H_%M_%S)
    local FILE_DB="db_${TIMESTAMP}.sql.gz"
    local FILE_DIR="dir_${TIMESTAMP}.tar.gz"
    local FILE_VERSION="bot_version.txt"
    local FILE_FINAL=""
    local HAS_ERROR=0
    local SKIP_INFO=""
    local SKIP_FILE="$BACKUP_DIR/skipped_files.txt"

    if [[ "$TYPE" != "db_only" ]]; then if ! ensure_bot_path; then return; fi; fi
    if [[ "$TYPE" == "db_only" || "$TYPE" == "full" ]]; then
        if [[ -z "$DB_CONTAINER_NAME" ]]; then ensure_bot_path; fi
    fi

    local CURRENT_VER=$(get_raw_bot_version)
    echo "${CURRENT_VER:-Unknown}" > "$BACKUP_DIR/$FILE_VERSION"
    debug_log "BACKUP" "Bot version saved: ${CURRENT_VER:-Unknown}"

    # Версионный суффикс для имени архива — чтобы не плодить .version файлы-спутники.
    # Безопасно: оставляем только [A-Za-z0-9.-_], остальное заменяем на '-'.
    local VER_SUFFIX=""
    if [[ -n "$CURRENT_VER" && "$CURRENT_VER" != "Unknown" ]]; then
        local _safe_ver
        _safe_ver=$(printf '%s' "$CURRENT_VER" | tr -c 'A-Za-z0-9._-' '-' | sed 's/-\+/-/g; s/^-//; s/-$//')
        [[ -n "$_safe_ver" ]] && VER_SUFFIX="__v${_safe_ver}"
    fi
    debug_log "BACKUP" "Version suffix for filename: '${VER_SUFFIX}'"

    if [[ "$TYPE" == "full" || "$TYPE" == "db_only" ]]; then
        # Получаем параметры БД из .env бота (согласно официальной документации)
        local ACTUAL_DB_USER=$(get_db_user)
        local ACTUAL_DB_NAME=$(get_db_name)
        debug_log "DB" "DB params: user=$ACTUAL_DB_USER, db=$ACTUAL_DB_NAME"
        
        # Проверяем готовность БД через pg_isready с retry.
        # pg_isready может возвращать transient not-ready при высокой нагрузке,
        # short-lived lock, или race с healthcheck — 3 попытки спасают от false-fail.
        print_message "INFO" "Проверка готовности БД..."
        debug_log "DB" "Running: docker exec $DB_CONTAINER_NAME pg_isready -U $ACTUAL_DB_USER -d $ACTUAL_DB_NAME"
        local _pg_ready=false
        local _pg_attempt
        for _pg_attempt in 1 2 3; do
            # timeout 10 защищает от висящего docker exec (контейнер заблокирован,
            # OOM-killer убил BD-процесс, network issue с docker daemon).
            # Если docker сам не отвечает 10 сек — переходим к retry, не виснем навсегда.
            if timeout 10 docker exec "$DB_CONTAINER_NAME" pg_isready -U "$ACTUAL_DB_USER" -d "$ACTUAL_DB_NAME" > "$SILENT_LOG" 2>&1; then
                _pg_ready=true
                debug_log "DB" "pg_isready: OK (attempt $_pg_attempt)"
                break
            fi
            debug_log "DB" "pg_isready failed/timeout (attempt $_pg_attempt/3) — retry in 2s"
            [[ $_pg_attempt -lt 3 ]] && sleep 2
        done

        if [[ "$_pg_ready" != "true" ]]; then
            print_message "ERROR" "База данных не готова! (pg_isready failed 3x)"
            log_message "ERROR" "Backup aborted: pg_isready failed 3 times for $DB_CONTAINER_NAME"
            if [[ "$IS_INTERACTIVE" != "true" ]]; then
                send_telegram_alert "CRITICAL" "БД не отвечает (pg_isready × 3)" \
                    "🐳 <code>$DB_CONTAINER_NAME</code>
📦 Тип: $TYPE
🛑 Бэкап ОТМЕНЁН" \
                    "<code>docker logs $DB_CONTAINER_NAME --tail 50</code>
<code>docker inspect $DB_CONTAINER_NAME -f '{{.State.Health.Status}}'</code>"
            fi
            [[ "$LOCK_ACQUIRED" == "true" ]] && release_lock
            return 1
        fi
        
        print_message "INFO" "Дамп базы данных ($DB_CONTAINER_NAME, user=$ACTUAL_DB_USER, db=$ACTUAL_DB_NAME)..."
        debug_log "DB" "Running: docker exec $DB_CONTAINER_NAME pg_dump -U $ACTUAL_DB_USER $ACTUAL_DB_NAME | gzip -9 > $BACKUP_DIR/$FILE_DB"
        
        # Используем pg_dump вместо pg_dumpall (согласно официальной документации).
        # КРИТИЧНО: проверяем PIPESTATUS обоих звеньев, иначе при падении pg_dump
        # gzip успешно создаст пустой архив и backup пройдёт как SUCCESS → silent data loss.
        # Timeout-обёртка: при stuck-БД (lock на длинной транзакции) cron мог висеть
        # часами без сигнала. PG_DUMP_TIMEOUT_SEC=0 → отключить (для гигантских БД).
        _run_pipe_with_timeout "$PG_DUMP_TIMEOUT_SEC" "pg_dump" \
            'docker exec "$1" pg_dump -U "$2" "$3" 2> "$4" | gzip -9 > "$5"' \
            "$DB_CONTAINER_NAME" "$ACTUAL_DB_USER" "$ACTUAL_DB_NAME" "$SILENT_LOG" "$BACKUP_DIR/$FILE_DB"
        local _pipe_rc=$?
        # _run_pipe_with_timeout запускает pipe с set -o pipefail, поэтому
        # rc отражает первую упавшую команду в pipe или 124/137 при timeout.
        # Для backward-compat сохраняем legacy PIPESTATUS-style логирование:
        # если timeout — _pg_rc=$_pipe_rc, _gz_rc=0 (логика "первая команда упала").
        local _pg_rc=$_pipe_rc _gz_rc=0
        if [[ $_pipe_rc -ne 0 ]]; then
            print_message "ERROR" "Ошибка дампа БД (rc=$_pipe_rc)."
            debug_log "DB" "pg_dump FAILED: rc=$_pipe_rc (timeout=124, killed=137)"
            log_message "ERROR" "pg_dump failed: rc=$_pipe_rc (timeout=${PG_DUMP_TIMEOUT_SEC}s)"
            HAS_ERROR=1
        else
            local db_size=$(du -h "$BACKUP_DIR/$FILE_DB" 2>/dev/null | cut -f1)
            local db_bytes=$(stat -c%s "$BACKUP_DIR/$FILE_DB" 2>/dev/null || echo 0)
            # Sanity check: minimal valid gzipped pg_dump > 100 bytes (заголовок + CREATE/INSERT).
            # Пустой gzip ~20 байт — явный признак повреждённого дампа.
            if [[ "$db_bytes" -lt 100 ]]; then
                print_message "ERROR" "Дамп БД подозрительно мал (${db_bytes}b) — возможно pg_dump упал."
                log_message "ERROR" "Suspicious DB dump size: ${db_bytes}b (file: $FILE_DB)"
                HAS_ERROR=1
            else
                debug_log "DB" "pg_dump SUCCESS, file size: $db_size ($db_bytes bytes)"
            fi
        fi
    fi

    if [[ $HAS_ERROR -eq 1 ]]; then 
        rm -f "$BACKUP_DIR/$FILE_DB" "$BACKUP_DIR/$FILE_VERSION"
        [[ "$LOCK_ACQUIRED" == "true" ]] && release_lock
        return 1
    fi

    local -a EXCLUDE_ARRAY=() EXCLUDE_FLAGS=()
    # Используем _split_exclude_dirs — поддерживает `,`/`;` как разделитель
    # для путей с пробелами (`my dir/cache, .git, node_modules`).
    _split_exclude_dirs "$EXCLUDE_DIRS" EXCLUDE_ARRAY
    local ex
    for ex in "${EXCLUDE_ARRAY[@]}"; do if [[ -n "$ex" ]]; then EXCLUDE_FLAGS+=(--exclude="$ex"); fi; done
    # Базовые исключения (всегда):
    # - .git директория
    # - Docker образы бота (*.tar файлы)
    # - backups/ директория (локальные бэкапы пользователя)
    EXCLUDE_FLAGS+=(--exclude=".git" --exclude="backups")
    EXCLUDE_FLAGS+=(--exclude="private-remnawave-*.tar" --exclude="rwp_shop*.tar" --exclude="telegram-shop*.tar")

    # Логи: исключаем если BACKUP_LOG_FILES != "true".
    # Паттерны покрывают сырые и ротированные форматы:
    #   *.log              — access.log, error.log
    #   *.log.[0-9]*       — error.log.1, access.log.2
    #   *.log.[0-9]*.gz    — error.log.1.gz, access.log.2.gz
    #   *.log-[0-9]*       — access.log-20260510
    #   *.log-[0-9]*.gz    — access.log-20260510.gz
    #   logs/ logs.*       — папка logs/ и её варианты
    if [[ "$BACKUP_LOG_FILES" != "true" ]]; then
        EXCLUDE_FLAGS+=(--exclude="*.log")
        EXCLUDE_FLAGS+=(--exclude="*.log.[0-9]*")
        EXCLUDE_FLAGS+=(--exclude="*.log.[0-9]*.gz")
        EXCLUDE_FLAGS+=(--exclude="*.log-[0-9]*")
        EXCLUDE_FLAGS+=(--exclude="*.log-[0-9]*.gz")
        EXCLUDE_FLAGS+=(--exclude="logs")
        debug_log "TAR" "Logs excluded (BACKUP_LOG_FILES=$BACKUP_LOG_FILES)"
    else
        debug_log "TAR" "Logs INCLUDED in archive (BACKUP_LOG_FILES=true)"
    fi
    debug_log "TAR" "Exclude flags: ${EXCLUDE_FLAGS[*]}"

    # === Отчёт о пропущенных файлах (для меню 88 / lazarus skipped) ===
    # Сохраняем всегда (persistent, не плодит файлы — один общий .last_skipped.txt)
    local LAST_SKIPPED_FILE="$BACKUP_DIR/.last_skipped.txt"
    local LAST_SKIPPED_META="$BACKUP_DIR/.last_skipped.meta"
    if [[ "$TYPE" != "db_only" ]] && [[ -n "$BOT_PATH" && -d "$BOT_PATH" ]]; then
        local _skip_count
        _skip_count=$(build_skipped_report "$BOT_PATH" "$LAST_SKIPPED_FILE" 2> "$SILENT_LOG" || echo "0")
        debug_log "TAR" "Skipped report: $_skip_count entries → $LAST_SKIPPED_FILE"
        # Метаданные: timestamp, bot path, размер архива (заполнится позже)
        printf 'archive=%s\nbot_path=%s\ncount=%s\ntimestamp=%s\n' \
            "(в процессе)" "$BOT_PATH" "$_skip_count" "$(date '+%Y-%m-%d %H:%M:%S')" \
            > "$LAST_SKIPPED_META"
    else
        # db_only — сбрасываем отчёт (файлы не архивируются)
        : > "$LAST_SKIPPED_FILE"
        printf 'archive=%s\nbot_path=%s\ncount=0\ntimestamp=%s\nnote=db_only — файлы не архивируются\n' \
            "(db_only)" "${BOT_PATH:-?}" "$(date '+%Y-%m-%d %H:%M:%S')" \
            > "$LAST_SKIPPED_META"
    fi

    if [[ "$TYPE" != "db_only" ]]; then
        : > "$SKIP_FILE"
        local BOT_DIRNAME=$(basename "$BOT_PATH")
        debug_log "TAR" "BOT_DIRNAME=$BOT_DIRNAME, MAX_FILE_SIZE_MB=$MAX_FILE_SIZE_MB"
        # Построение массива аргументов find без eval (защита от инъекций через EXCLUDE_DIRS)
        local FIND_ARGS=(".")
        for ex in "${EXCLUDE_ARRAY[@]}"; do
            if [[ -n "$ex" ]]; then
                # Валидация: допускаем буквы/цифры/_./- + пробелы (для путей с пробелами).
                # Защита от shell-injection через EXCLUDE_DIRS: запрещаем `;`, `|`, `&`,
                # `$()`, backticks, `\n` — всё что bash может интерпретировать.
                if [[ "$ex" =~ ^[a-zA-Z0-9_./\ -]+$ ]]; then
                    FIND_ARGS+=("-path" "./$ex" "-prune" "-o")
                else
                    debug_log "TAR" "SKIP unsafe exclude pattern: $ex"
                fi
            fi
        done
        FIND_ARGS+=("-type" "f" "-size" "+${MAX_FILE_SIZE_MB}M" "-print0")
        debug_log "TAR" "Find args: ${FIND_ARGS[*]}"
        # Subshell: cd не утечёт в parent (cwd используется в других местах create_backup).
        # Если cd упал — find работает в текущей cwd → BACKUP_DIR обходим, что неправильно.
        # NUL-delim (`-print0` + `read -d ''`) — защита от файлов с newline/tab
        # в именах. tar --exclude-from понимает только line-based input, поэтому
        # сразу перед записью заменяем NUL на newline, а tab в имени файла на
        # видимый маркер (tar патерны не должны содержать настоящие tab/newline).
        ( cd "$BOT_PATH" && find "${FIND_ARGS[@]}" ) | while IFS= read -r -d '' f; do
            # Преобразуем ./path/file в BOT_DIRNAME/path/file для корректной работы --exclude-from.
            # Чистка контролов: tab/newline → видимые маркеры (защита от шенаниганов в именах).
            local _clean="${f//$'\t'/_TAB_}"
            _clean="${_clean//$'\n'/_NL_}"
            echo "${BOT_DIRNAME}${_clean#.}"
        done > "$SKIP_FILE"
        local SKIP_COUNT=$(wc -l < "$SKIP_FILE")
        debug_log "TAR" "Large files to skip: $SKIP_COUNT"
        if [[ "$SKIP_COUNT" -gt 0 ]]; then
            # NUL-delim для du --files0-from — единственный safe способ передать
            # пути с любыми символами. find -print0 даёт прямо нужный формат.
            local SKIP_SIZE
            SKIP_SIZE=$(cd "$BOT_PATH" && find "${FIND_ARGS[@]}" | du -ch --files0-from=- 2>/dev/null | tail -1 | cut -f1)
            print_message "WARN" "Пропущено больших файлов (>${MAX_FILE_SIZE_MB}MB): $SKIP_COUNT (общий вес: $SKIP_SIZE)"
            debug_log "TAR" "Skipped files content:"
            if [[ "$DEBUG_MODE" == true ]]; then cat "$SKIP_FILE"; fi
            EXCLUDE_FLAGS+=(--exclude-from="$SKIP_FILE")
            SKIP_INFO=$'\n⚠️ Skip: '"$SKIP_COUNT"$' (>'"$MAX_FILE_SIZE_MB"$'MB)'
        fi
    fi

    # tar exit codes:
    #   0  = OK
    #   1  = some files differ/changed during read (warning, archive OK)
    #   2+ = serious error (поломанный архив)
    # stderr → SILENT_LOG чтобы не спамить console «Cannot stat» от файлов,
    # которые бот пишет/удаляет в собственной директории (race). Запишем в log_message.
    local _tar_rc=0 _tar_err
    _tar_err=$(mktemp 2> "$SILENT_LOG") || _tar_err="/tmp/lazarus_tar_err.$$"

    # Progress-индикатор: tar --checkpoint=N печатает точку каждые N records
    # (1 record = 512 байт, checkpoint=2000 ≈ 1 MB). Активен только в interactive
    # режиме И не в debug (там и так много вывода). Cron / non-tty — без точек,
    # чтобы log не загромождать.
    local _tar_progress=()
    if [[ "$IS_INTERACTIVE" == "true" && "$DEBUG_MODE" != "true" ]]; then
        # `--checkpoint-action=dot` → "." в stdout каждые `--checkpoint=N` records.
        # `--checkpoint-action=ttyout='...'` для красивых индикаторов недоступен на
        # старых GNU tar, поэтому используем простые точки + новая строка после.
        _tar_progress=(--checkpoint=2000 --checkpoint-action=dot)
    fi
    if [[ "$TYPE" == "db_only" ]]; then
        FILE_FINAL="lazarus_db_${TIMESTAMP}${VER_SUFFIX}.tar.gz"
        debug_log "TAR" "Creating DB archive: $FILE_FINAL"
        # DB archive — это просто 2 маленьких файла, timeout мизерный, но
        # обёртка стандартизирует поведение и логирование.
        _run_with_timeout "$TAR_TIMEOUT_SEC" "tar-db" \
            tar -czf "$BACKUP_DIR/$FILE_FINAL" -C "$BACKUP_DIR" "$FILE_VERSION" "$FILE_DB" 2> "$_tar_err"
        _tar_rc=$?
        rm -f "$BACKUP_DIR/$FILE_DB"
    elif [[ "$TYPE" == "files_only" ]]; then
        FILE_FINAL="lazarus_files_${TIMESTAMP}${VER_SUFFIX}.tar.gz"
        local FILE_DIR="bot_files_${TIMESTAMP}.tar.gz"
        print_message "INFO" "Архивация файлов (это может занять время)..."
        [[ ${#_tar_progress[@]} -gt 0 ]] && printf "  ${GRAY}["
        debug_log "TAR" "Creating files archive: $FILE_FINAL"
        debug_log "TAR" "Running: tar -czf $BACKUP_DIR/$FILE_DIR ${EXCLUDE_FLAGS[*]} -C $(dirname "$BOT_PATH") $(basename "$BOT_PATH")"
        # Сначала архивируем файлы бота с исключениями
        _run_with_timeout "$TAR_TIMEOUT_SEC" "tar-files" \
            tar -czf "$BACKUP_DIR/$FILE_DIR" "${_tar_progress[@]}" "${EXCLUDE_FLAGS[@]}" -C "$(dirname "$BOT_PATH")" "$(basename "$BOT_PATH")" 2> "$_tar_err"
        _tar_rc=$?
        [[ ${#_tar_progress[@]} -gt 0 ]] && echo "]${RESET}"
        # NB: rc=1 = warning «файл изменился во время чтения» — архив OK,
        # combine можно делать (то же что и в `full` ниже).
        [[ $_tar_rc -le 1 ]] && {
            local _first_rc=$_tar_rc
            _run_with_timeout "$TAR_TIMEOUT_SEC" "tar-files-combine" \
                tar -czf "$BACKUP_DIR/$FILE_FINAL" -C "$BACKUP_DIR" "$FILE_VERSION" "$FILE_DIR" 2>> "$_tar_err"
            _tar_rc=$?
            # Если combine OK (0) но первый tar был warning (1) — финальный статус = warning.
            [[ $_tar_rc -eq 0 && $_first_rc -eq 1 ]] && _tar_rc=1
        }
        rm -f "$BACKUP_DIR/$FILE_DIR"
    else
        FILE_FINAL="lazarus_full_${TIMESTAMP}${VER_SUFFIX}.tar.gz"
        print_message "INFO" "Архивация файлов (это может занять время)..."
        [[ ${#_tar_progress[@]} -gt 0 ]] && printf "  ${GRAY}["
        debug_log "TAR" "Creating full archive: $FILE_FINAL"
        _run_with_timeout "$TAR_TIMEOUT_SEC" "tar-full" \
            tar -czf "$BACKUP_DIR/$FILE_DIR" "${_tar_progress[@]}" "${EXCLUDE_FLAGS[@]}" -C "$(dirname "$BOT_PATH")" "$(basename "$BOT_PATH")" 2> "$_tar_err"
        _tar_rc=$?
        [[ ${#_tar_progress[@]} -gt 0 ]] && echo "]${RESET}"
        # rc=1 = warning (файл изменился во время чтения), archive валиден → combine OK.
        [[ $_tar_rc -le 1 ]] && {
            local _first_rc=$_tar_rc
            _run_with_timeout "$TAR_TIMEOUT_SEC" "tar-full-combine" \
                tar -czf "$BACKUP_DIR/$FILE_FINAL" -C "$BACKUP_DIR" "$FILE_VERSION" "$FILE_DB" "$FILE_DIR" 2>> "$_tar_err"
            _tar_rc=$?
            # Sticky warning: если первый tar дал rc=1 (warning), а combine — 0,
            # финальный статус остаётся 1, чтобы пользователь увидел WARN в логе.
            [[ $_tar_rc -eq 0 && $_first_rc -eq 1 ]] && _tar_rc=1
        }
        rm -f "$BACKUP_DIR/$FILE_DB" "$BACKUP_DIR/$FILE_DIR"
    fi

    # Анализ tar exit code:
    # rc=1: некритично (файл бота изменился во время чтения, race). Логируем WARN.
    # rc>=2: серьёзная ошибка. HAS_ERROR=1.
    if [[ $_tar_rc -eq 1 ]]; then
        local _tar_err_head
        _tar_err_head=$(head -3 "$_tar_err" 2>/dev/null | tr '\n' '|')
        print_message "WARN" "tar предупреждение (некритично, архив создан): ${_tar_err_head}"
        log_message "WARN" "tar warning (rc=1) during $TYPE backup: $(cat "$_tar_err" 2>/dev/null | head -5 | tr '\n' ' ')"
    elif [[ $_tar_rc -ge 2 ]]; then
        print_message "ERROR" "tar упал (rc=$_tar_rc) — архив возможно повреждён"
        log_message "ERROR" "tar failed (rc=$_tar_rc) during $TYPE backup: $(cat "$_tar_err" 2>/dev/null | head -5 | tr '\n' ' ')"
        HAS_ERROR=1
    fi
    rm -f "$_tar_err"

    if [[ $HAS_ERROR -eq 1 ]]; then
        rm -f "$BACKUP_DIR/$FILE_DB" "$BACKUP_DIR/$FILE_VERSION" "$BACKUP_DIR/$FILE_FINAL"
        [[ "$LOCK_ACQUIRED" == "true" ]] && release_lock
        return 1
    fi

    rm -f "$SKIP_FILE"

    local ENC_STATUS="🔓 Unencrypted"
    if [[ -z "$BACKUP_PASSWORD" && "$IS_INTERACTIVE" == "false" ]]; then ENC_STATUS="⚠️ NO PASSWORD"; fi

    if [[ -n "$BACKUP_PASSWORD" ]]; then
        print_message "INFO" "Шифрование архива (это может занять время)..."
        # v2 envelope: AES-256-CBC + PBKDF2 100k + HMAC-SHA256 (encrypt-then-MAC).
        # HMAC защищает от targeted ciphertext-tampering (важно для backup'ов в
        # public S3 / FTP). Wrong-password detect ДО decrypt через MAC pre-check.
        # Старые v1 архивы (без MAC) остаются совместимыми при restore.
        _hmac_envelope_create \
            "$BACKUP_DIR/$FILE_FINAL" \
            "$BACKUP_DIR/${FILE_FINAL}.enc" \
            "$BACKUP_PASSWORD"
        local enc_res=$?
        
        if [[ $enc_res -eq 0 ]]; then
            rm "$BACKUP_DIR/$FILE_FINAL"
            FILE_FINAL="${FILE_FINAL}.enc"
            ENC_STATUS="🔒 Encrypted"
            print_message "SUCCESS" "Архив зашифрован."
            debug_log "ENC" "Encryption successful: $FILE_FINAL"
        else
            print_message "ERROR" "Ошибка шифрования! Отправка незашифрованного файла."
            debug_log "ENC" "Encryption FAILED!"
        fi
    fi

    # Версия зашита в имя файла как __vX.Y.Z — отдельный .version файл-спутник
    # больше не создаём (раньше получалось 2 файла на каждый бэкап).
    # bot_version.txt внутри tar остаётся (нужен при restore).
    rm -f "$BACKUP_DIR/$FILE_VERSION"
    debug_log "BACKUP" "Version encoded in filename: ${VER_SUFFIX:-<none>}"
    
    # --- VERIFY ARCHIVE ---
    print_message "INFO" "Проверка целостности архива..."
    debug_log "VERIFY" "Verifying archive integrity..."
    local VERIFY_OK="false"
    if [[ "$FILE_FINAL" == *".enc" ]]; then
        # Verify v2 envelope: HMAC pre-check + decrypt → gzip -t.
        # MAC проверяется ДО decrypt, gadget-protected.
        debug_log "VERIFY" "Running: _hmac_envelope_verify + decrypt | gzip -t"
        local _verify_decrypted
        _verify_decrypted=$(mktemp "${TMPDIR:-/tmp}/lazarus_verify.XXXXXX") || _verify_decrypted=""
        if [[ -n "$_verify_decrypted" ]]; then
            register_sensitive_tmp "$_verify_decrypted"
            if _hmac_envelope_decrypt "$BACKUP_DIR/$FILE_FINAL" "$_verify_decrypted" "$BACKUP_PASSWORD" \
                && gzip -t "$_verify_decrypted" 2> "$SILENT_LOG"; then
                VERIFY_OK="true"
            fi
            rm -f "$_verify_decrypted"
            unregister_sensitive_tmp "$_verify_decrypted"
        fi
    else
        debug_log "VERIFY" "Running: gzip -t $BACKUP_DIR/$FILE_FINAL"
        if gzip -t "$BACKUP_DIR/$FILE_FINAL" 2> "$SILENT_LOG"; then
             VERIFY_OK="true"
        fi
    fi
    debug_log "VERIFY" "Result: $VERIFY_OK"

    if [[ "$VERIFY_OK" == "true" ]]; then
        print_message "SUCCESS" "Архив валиден."
    else
        print_message "ERROR" "Архив поврежден! (Verification failed)"
        # We do not delete it, just warn
    fi

    local SIZE=$(du -h "$BACKUP_DIR/$FILE_FINAL" | awk '{print $1}')
    print_message "SUCCESS" "Бэкап создан: $FILE_FINAL ($SIZE)"
    log_message "SUCCESS" "Backup created: $FILE_FINAL (type=$TYPE, size=$SIZE, enc_status=$ENC_STATUS, verify=$VERIFY_OK)"
    debug_log "BACKUP" "Final file: $FILE_FINAL, size: $SIZE"

    # === Терминальный вывод: контроль содержимого + S3-рекомендация ===
    # Архив >50 MB: топ-5 крупных файлов + красный баннер если remote off
    # Архив ≤50 MB: ненавязчивая подсказка про S3 если remote off
    local _backup_bytes
    _backup_bytes=$(stat -c%s "$BACKUP_DIR/$FILE_FINAL" 2> "$SILENT_LOG" || echo 0)
    local _TG_LIMIT=52428800   # 50 MB
    local _backup_mb=$((_backup_bytes / 1048576))

    # Обновляем мета финальным именем архива (если файл существует)
    if [[ -f "$LAST_SKIPPED_META" ]]; then
        sed -i "s|^archive=.*|archive=$FILE_FINAL|" "$LAST_SKIPPED_META" 2> "$SILENT_LOG" || true
    fi

    # === Короткий статус (без больших блоков) ===
    # Топ-5 / красный баннер показываем только по запросу через post-backup меню (77/88/99).
    local _skipped_count=0
    if [[ -f "$LAST_SKIPPED_FILE" && -s "$LAST_SKIPPED_FILE" ]]; then
        _skipped_count=$(wc -l < "$LAST_SKIPPED_FILE" | tr -d ' ')
    fi

    if [[ $_backup_bytes -ge $_TG_LIMIT && "$REMOTE_STORAGE_TYPE" == "off" ]]; then
        echo ""
        echo -e "${RED}${BOLD}🔴 Архив ${_backup_mb} MB > лимит Telegram (50 MB) — настройте S3/FTP (99 в меню)${RESET}"
    elif [[ "$REMOTE_STORAGE_TYPE" == "off" ]]; then
        echo ""
        echo -e "${YELLOW}💡 Удалённое хранилище не настроено — бэкап только в Telegram (99 в меню)${RESET}"
    fi

    if [[ "$_skipped_count" -gt 0 ]]; then
        echo -e "${GRAY}ℹ Пропущено файлов: ${_skipped_count} (детали — пункт 88 в меню ниже)${RESET}"
    fi

    debug_log "UPLOAD" "Starting remote upload..."
    local _UPLOAD_REMOTE_OK="false"
    local _UPLOAD_TG_OK="false"
    upload_to_remote "$BACKUP_DIR/$FILE_FINAL"
    local _remote_rc=$?
    if [[ "$REMOTE_STORAGE_TYPE" != "off" && "$SEND_TO_REMOTE" == "true" && $_remote_rc -eq 0 ]]; then
        _UPLOAD_REMOTE_OK="true"
    fi
    debug_log "UPLOAD" "Remote upload complete (rc=$_remote_rc, ok=$_UPLOAD_REMOTE_OK)"

    local DISPLAY_DATE=$(date "+%d.%m.%Y %H:%M:%S")
    local HASHTAG=""; local TYPE_NAME=""; local ROTATION_KEY=""

    case "$TYPE" in
        "full") HASHTAG="💾 #full_backup"; TYPE_NAME="📦 Полный бэкап"; ROTATION_KEY="Полные бэкапы" ;;
        "db_only") HASHTAG="💾 #db_only"; TYPE_NAME="🗄 Дамп базы данных"; ROTATION_KEY="Базы данных" ;;
        "files_only") HASHTAG="💾 #files_only"; TYPE_NAME="📂 Файлы бота"; ROTATION_KEY="Архивы файлов" ;;
    esac

    # 📏 (размер) → 📊 в Premium через EMO_STATS
    # 🏷 (версия) → ✅ бейдж с галочкой в Premium через EMO_BADGE
    local VER_MSG=""; [[ -n "$CURRENT_VER" ]] && VER_MSG=" | 🏷 v${CURRENT_VER}"
    local CAPTION="${HASHTAG}
📅 ${DISPLAY_DATE}
${TYPE_NAME}
📏 ${SIZE}${VER_MSG}
${ENC_STATUS}${REMOTE_UPLOAD_STATUS_TEXT}${SKIP_INFO}"

    # Premium emoji в caption: escape MarkdownV2 целиком, затем заменяем
    # Unicode emoji на Premium-обёрнутый MarkdownV2-литерал (после escape).
    # ВАЖНО: Premium emoji видны ТОЛЬКО у получателей с Telegram Premium.
    # Не-Premium клиенты увидят fallback Unicode (что и есть в [...] часть).
    # Замены делаем ТОЛЬКО для verified ID (см. audit 2026-05-25).
    local CAPTION_ESC
    CAPTION_ESC=$(escape_markdown_v2 "$CAPTION")
    debug_log "TG" "CAPTION_ESC before premium replace: $CAPTION_ESC"
    CAPTION_ESC="${CAPTION_ESC//📂/$(tg_emoji "📂" "$EMO_FOLDER")}"
    CAPTION_ESC="${CAPTION_ESC//📅/$(tg_emoji "📅" "$EMO_CALENDAR")}"
    CAPTION_ESC="${CAPTION_ESC//🔒/$(tg_emoji "🔒" "$EMO_LOCK")}"
    CAPTION_ESC="${CAPTION_ESC//⚠️/$(tg_emoji "⚠️" "$EMO_WARN")}"
    CAPTION_ESC="${CAPTION_ESC//🏷/$(tg_emoji "🏷" "$EMO_BADGE")}"
    # 💾, 📦, 🗄, 📏, ☁️ — Unicode-only (verified ID mismatch).
    debug_log "TG" "CAPTION_ESC after premium replace: $CAPTION_ESC"

    send_telegram_document "$BACKUP_DIR/$FILE_FINAL" "$CAPTION_ESC" "pre-escaped"
    local _tg_rc=$?
    # TG success — только rc=0 (sendDocument 200 OK). rc=2 (>50MB) — НЕ считаем доставленным.
    if [[ "$SEND_TO_TELEGRAM" == "true" && "$TG_SEND_FILE" == "true" && $_tg_rc -eq 0 ]]; then
        _UPLOAD_TG_OK="true"
    fi
    debug_log "UPLOAD" "TG send complete (rc=$_tg_rc, ok=$_UPLOAD_TG_OK)"

    # === УДАЛЕНИЕ ЛОКАЛЬНОГО ФАЙЛА ПОСЛЕ УСПЕШНОЙ ОТПРАВКИ ===
    # Режимы:
    #   false       — не удалять (default)
    #   any         — удалить если хотя бы один канал доставил
    #   all         — удалить только если ВСЕ настроенные каналы доставили
    #   remote_only — удалить если remote (S3/FTP/WebDAV/Rclone) доставил, TG не учитываем
    if [[ "$DELETE_LOCAL_AFTER_REMOTE_UPLOAD" != "false" && -n "$DELETE_LOCAL_AFTER_REMOTE_UPLOAD" ]]; then
        local _can_delete="false"
        local _delete_reason=""
        case "$DELETE_LOCAL_AFTER_REMOTE_UPLOAD" in
            any)
                if [[ "$_UPLOAD_TG_OK" == "true" || "$_UPLOAD_REMOTE_OK" == "true" ]]; then
                    _can_delete="true"
                    _delete_reason="any: tg=$_UPLOAD_TG_OK remote=$_UPLOAD_REMOTE_OK"
                else
                    _delete_reason="any: оба канала провалились"
                fi
                ;;
            all)
                local _tg_required="false" _remote_required="false"
                [[ "$SEND_TO_TELEGRAM" == "true" && "$TG_SEND_FILE" == "true" && -n "$BOT_TOKEN" && -n "$CHAT_ID" ]] && _tg_required="true"
                [[ "$REMOTE_STORAGE_TYPE" != "off" && "$SEND_TO_REMOTE" == "true" ]] && _remote_required="true"
                if [[ "$_tg_required" == "false" && "$_remote_required" == "false" ]]; then
                    _delete_reason="all: ни один канал не настроен, удаление пропущено"
                elif [[ ( "$_tg_required" != "true" || "$_UPLOAD_TG_OK" == "true" ) \
                     && ( "$_remote_required" != "true" || "$_UPLOAD_REMOTE_OK" == "true" ) ]]; then
                    _can_delete="true"
                    _delete_reason="all: tg_req=$_tg_required tg_ok=$_UPLOAD_TG_OK remote_req=$_remote_required remote_ok=$_UPLOAD_REMOTE_OK"
                else
                    _delete_reason="all: не все каналы доставили"
                fi
                ;;
            remote_only)
                if [[ "$REMOTE_STORAGE_TYPE" == "off" || "$SEND_TO_REMOTE" != "true" ]]; then
                    _delete_reason="remote_only: remote не настроен, удаление пропущено"
                elif [[ "$_UPLOAD_REMOTE_OK" == "true" ]]; then
                    _can_delete="true"
                    _delete_reason="remote_only: remote=$_UPLOAD_REMOTE_OK"
                else
                    _delete_reason="remote_only: remote upload провален"
                fi
                ;;
            *)
                _delete_reason="неизвестный режим: $DELETE_LOCAL_AFTER_REMOTE_UPLOAD"
                ;;
        esac

        if [[ "$_can_delete" == "true" ]]; then
            print_message "INFO" "Локальный бэкап удалён после отправки (${DELETE_LOCAL_AFTER_REMOTE_UPLOAD}): $_delete_reason"
            log_message "INFO" "Local backup deleted after upload: $FILE_FINAL ($_delete_reason)"
            debug_log "BACKUP" "Deleting local: $BACKUP_DIR/$FILE_FINAL"
            # $FINAL_VERSION_FILE убран — мы больше не создаём .version файлы-спутники
            # (версия в имени архива). Legacy .version рядом удалит rotate_*.
            rm -f "$BACKUP_DIR/$FILE_FINAL"
        else
            print_message "WARN" "Локальный бэкап СОХРАНЁН (доставка не подтверждена): $_delete_reason"
            log_message "WARN" "Local backup kept: $FILE_FINAL ($_delete_reason)"
            # TG-уведомление о том что delete пропущен — только если опция была включена
            if [[ "$SEND_TO_TELEGRAM" == "true" && -n "$BOT_TOKEN" && -n "$CHAT_ID" ]]; then
                send_telegram_alert "WARN" "Локальный бэкап сохранён" \
                    "⚙️ Режим: <code>${DELETE_LOCAL_AFTER_REMOTE_UPLOAD}</code>
🔍 Причина: $_delete_reason
✅ Файл остался локально" \
                    ""
            fi
        fi
    fi

    # Автоматическая ротация бэкапов после создания (подавляем вывод счётчиков)
    local ROTATION_PREFIX="lazarus_$TYPE"
    if [[ "$TYPE" == "db_only" ]]; then ROTATION_PREFIX="lazarus_db"; fi
    if [[ "$TYPE" == "files_only" ]]; then ROTATION_PREFIX="lazarus_files"; fi

    # Ротация в зависимости от настроек DELETE_MODE
    if [[ "$DELETE_MODE" == "count" ]]; then
        rotate_backups_by_count "$ROTATION_PREFIX" "$ROTATION_KEY" "true" > /dev/null
    else
        rotate_backups_by_age "$ROTATION_PREFIX" "$ROTATION_KEY" "$RETENTION_DAYS" "true" > /dev/null
    fi
    
    # Ротация по размеру (если настроен лимит)
    rotate_backups_by_size "true" > /dev/null
    
    # Освобождаем блокировку
    [[ "$LOCK_ACQUIRED" == "true" ]] && release_lock
    
    return 0
}

