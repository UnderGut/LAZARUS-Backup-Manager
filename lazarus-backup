    fi
}

# Проверка и добавление machine-id volume в compose файл (требуется с версии 3.25.5+ для лицензии)
ensure_machine_id_volume() {
    local compose_file="$1"
    
    if [[ ! -f "$compose_file" ]]; then
        debug_log "MACHINE_ID" "Compose file not found: $compose_file"
        return 1
    fi
    
    # Проверяем есть ли уже machine-id volume
    if grep -q "/etc/machine-id" "$compose_file"; then
        debug_log "MACHINE_ID" "machine-id volume already exists in compose"
        return 0
    fi
    
    # Очищаем экран чтобы рамка была вверху (в debug режиме показывает разделитель)
    clear_screen
    
    # Короткие алиасы
    local B="${RED}${BOLD}"
    local R="${RESET}"
    local C="${CYAN}"
    local Y="${YELLOW}"
    
    echo -e "${B}╔══════════════════════════════════════════════════════════════╗${R}"
    echo -e "${B}║${R}          [!] ОТСУТСТВУЕТ VOLUME ДЛЯ ЛИЦЕНЗИИ                 ${B}║${R}"
    echo -e "${B}╠══════════════════════════════════════════════════════════════╣${R}"
    echo -e "${B}║${R}                                                              ${B}║${R}"
    echo -e "${B}║${R}  В compose файле не найден обязательный volume:              ${B}║${R}"
    echo -e "${B}║${R}  ${C}/etc/machine-id:/etc/machine-id:ro${R}                          ${B}║${R}"
    echo -e "${B}║${R}                                                              ${B}║${R}"
    echo -e "${B}║${R}  Этот volume необходим для привязки лицензии к серверу.      ${B}║${R}"
    echo -e "${B}║${R}  ${Y}Без него бот не сможет проверить лицензию!${R}                  ${B}║${R}"
    echo -e "${B}║${R}                                                              ${B}║${R}"
    echo -e "${B}╠══════════════════════════════════════════════════════════════╣${R}"
    echo -e "${B}║${R}  Нужно добавить в секцию volumes сервиса bot:                ${B}║${R}"
    echo -e "${B}║${R}  ${C}volumes:${R}                                                    ${B}║${R}"
    echo -e "${B}║${R}  ${C}  - /etc/machine-id:/etc/machine-id:ro${R}                      ${B}║${R}"
    echo -e "${B}╚══════════════════════════════════════════════════════════════╝${R}"
    echo ""
    
    local confirm=""
    while [[ ! "$confirm" =~ ^[YyNn]$ ]]; do
        read -erp "Добавить автоматически? (y/n): " confirm
        if [[ ! "$confirm" =~ ^[YyNn]$ ]]; then
            echo -e "${YELLOW}Введите 'y' для да или 'n' для нет${RESET}"
        fi
    done
    
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        # Создаём бэкап
        cp "$compose_file" "${compose_file}.bak.machine-id"
        
        # Ищем секцию volumes в сервисе bot и добавляем machine-id
        # Используем sed для добавления после строки с volumes: в секции bot
        
        # Сначала проверяем есть ли уже секция volumes у bot
        if grep -A 20 "^\s*bot:" "$compose_file" | grep -q "^\s*volumes:"; then
            # Есть секция volumes - добавляем после неё
            # Ищем первую строку volumes: после bot: и добавляем после неё
            local in_bot=false
            local volumes_found=false
            local temp_file=$(mktemp)
            
            while IFS= read -r line; do
                echo "$line" >> "$temp_file"
                
                # Определяем что мы в секции bot
                if [[ "$line" =~ ^[[:space:]]*bot: ]]; then
                    in_bot=true
                    volumes_found=false
                fi
                
                # Выходим из секции bot если встретили другой сервис
                if [[ "$in_bot" == true && "$line" =~ ^[[:space:]]{2}[a-z] && ! "$line" =~ ^[[:space:]]*bot: && ! "$line" =~ ^[[:space:]]{4} ]]; then
                    in_bot=false
                fi
                
                # Если мы в bot и нашли volumes: - добавляем machine-id
                if [[ "$in_bot" == true && "$volumes_found" == false && "$line" =~ ^[[:space:]]*volumes: ]]; then
                    volumes_found=true
                    echo "      - /etc/machine-id:/etc/machine-id:ro" >> "$temp_file"
                fi
            done < "$compose_file"
            
            mv "$temp_file" "$compose_file"
            print_message "SUCCESS" "Volume /etc/machine-id добавлен в compose файл"
            print_message "INFO" "Бэкап сохранён: ${compose_file}.bak.machine-id"
            echo ""
            read -erp "Нажмите Enter для продолжения..." dummy
        else
            # Нет секции volumes - нужно добавить вручную
            print_message "ERROR" "Секция volumes не найдена в сервисе bot"
            print_message "INFO" "Добавьте вручную в docker-compose.yml:"
            echo ""
            echo -e "${CYAN}services:"
            echo -e "  bot:"
            echo -e "    volumes:"
            echo -e "      - /etc/machine-id:/etc/machine-id:ro${RESET}"
            read -erp "Нажмите Enter для продолжения..." dummy
            return 1
        fi
        return 0
    else
        print_message "WARN" "Volume не добавлен. Лицензия может не работать!"
        print_message "INFO" "Добавьте вручную: /etc/machine-id:/etc/machine-id:ro"
        read -erp "Нажмите Enter для продолжения..." dummy
        return 1
    fi
}

# Обновление image версии в docker-compose файле
# Поддерживает все варианты именования image
update_compose_image_version() {
    local compose_file="$1"
    local new_version="$2"
    local new_image_name="$3"  # Опционально: имя нового image
    
    debug_log "COMPOSE" "=== update_compose_image_version() ==="
    debug_log "COMPOSE" "  compose_file=$compose_file"
    debug_log "COMPOSE" "  new_version=$new_version"
    debug_log "COMPOSE" "  new_image_name=$new_image_name"
    
    if [[ ! -f "$compose_file" ]]; then
        debug_log "COMPOSE" "Compose file not found: $compose_file"
        print_message "ERROR" "Compose файл не найден: $compose_file"
        return 1
    fi
    
    # Если новое имя image не указано, используем rwp_shop (официальное)
    [[ -z "$new_image_name" ]] && new_image_name="rwp_shop"
    debug_log "COMPOSE" "Target image name: $new_image_name"
    
    # Список всех возможных имён image бота
    local image_patterns=(
        "rwp_shop"
        "private-remnawave-telegram-shop-bot"
        "telegram-shop"
        "shopbot"
    )
    
    local found=false
    for pattern in "${image_patterns[@]}"; do
        debug_log "COMPOSE" "Checking for pattern: $pattern"
        if grep -qE "image:\s*['\"]?${pattern}:" "$compose_file"; then
            debug_log "COMPOSE" "Pattern matched: $pattern"
            # Заменяем на новое имя и версию
            sed -i -E "s|(image:\s*['\"]?)${pattern}:[0-9]+(\.[0-9]+){1,3}|\1${new_image_name}:${new_version}|g" "$compose_file"
            found=true
            debug_log "COMPOSE" "Sed replacement done: ${pattern} -> ${new_image_name}:${new_version}"
            print_message "SUCCESS" "Image обновлён: ${pattern} → ${new_image_name}:${new_version}"
            break
        fi
    done
    
    if [[ "$found" == "false" ]]; then
        debug_log "COMPOSE" "No matching image pattern found in compose file"
        print_message "ERROR" "Не найден image бота в compose файле"
        print_message "INFO" "Искали паттерны: ${image_patterns[*]}"
        return 1
    fi
    
    debug_log "COMPOSE" "update_compose_image_version() completed successfully"
    return 0
}

# --- ПРОВЕРКА ЗДОРОВЬЯ КОНТЕЙНЕРОВ ---

# Проверка здоровья БД
check_db_health() {
    local db_container="$1"
    local max_attempts="${2:-30}"
    local attempt=1
    
    debug_log "HEALTH" "check_db_health($db_container, max=$max_attempts)"
    
    while [[ $attempt -le $max_attempts ]]; do
        local health=$(docker inspect -f '{{.State.Health.Status}}' "$db_container" 2> "$SILENT_LOG")
        debug_log "HEALTH" "  attempt $attempt: health=$health"
        
        if [[ "$health" == "healthy" ]]; then
            debug_log "HEALTH" "DB healthy via docker healthcheck"
            return 0
        fi
        
        # Альтернативная проверка через pg_isready
        if docker exec "$db_container" pg_isready -U "$DB_USER" > "$SILENT_LOG" 2>&1; then
            debug_log "HEALTH" "DB healthy via pg_isready"
            return 0
        fi
        
        echo -ne "\r  Ожидание БД... ($attempt/$max_attempts)"
        sleep 1
        ((attempt++))
    done
    
    debug_log "HEALTH" "DB health check failed after $max_attempts attempts"
    echo ""
    return 1
}

# Проверка что контейнер бота запустился и работает
check_bot_health() {
    local bot_container="$1"
    local max_attempts="${2:-20}"
    local attempt=1
    
    debug_log "HEALTH" "check_bot_health($bot_container, max=$max_attempts)"
    
    while [[ $attempt -le $max_attempts ]]; do
        local status=$(docker inspect -f '{{.State.Status}}' "$bot_container" 2> "$SILENT_LOG")
        local running=$(docker inspect -f '{{.State.Running}}' "$bot_container" 2> "$SILENT_LOG")
        debug_log "HEALTH" "  attempt $attempt: status=$status, running=$running"
        
        if [[ "$status" == "running" && "$running" == "true" ]]; then
            # Проверяем что контейнер не рестартует
            sleep 2
            local status2=$(docker inspect -f '{{.State.Status}}' "$bot_container" 2> "$SILENT_LOG")
            debug_log "HEALTH" "  stability check: status2=$status2"
            if [[ "$status2" == "running" ]]; then
                debug_log "HEALTH" "Bot healthy and stable"
                return 0
            fi
        fi
        
        echo -ne "\r  Ожидание бота... ($attempt/$max_attempts)"
        sleep 1
        ((attempt++))
    done
    
    debug_log "HEALTH" "Bot health check failed after $max_attempts attempts"
    echo ""
    return 1
}

# Получить последний бэкап БД для возможного rollback
get_latest_db_backup() {
