        echo -e "${YELLOW}=== КОНТЕЙНЕР БД RWP-Shop ===${RESET}"
        
        local detected_db=""
        for pattern in "rwp_shop_db" "telegram-shop-db" "telegram-shop_db"; do
            detected_db=$(docker ps --format '{{.Names}}' 2>/dev/null | grep -iE "^${pattern}$" | head -1)
            [[ -n "$detected_db" ]] && break
        done
        
        if [[ -n "$detected_db" ]]; then
            echo -e "✅ Найден контейнер: ${GREEN}$detected_db${RESET}"
            read -erp "Использовать его? (Y/n): " use_db
            if [[ ! "$use_db" =~ ^[Nn]$ ]]; then
                MIGRATION_TARGET_CONTAINER="$detected_db"
                MIGRATION_TARGET_DB="${MIGRATION_TARGET_DB:-postgres}"
                MIGRATION_TARGET_USER="${MIGRATION_TARGET_USER:-postgres}"
            fi
        else
            echo -e "${YELLOW}⚠️  Контейнер БД не найден${RESET}"
        fi
    fi
    
    # === ИТОГОВАЯ КОНФИГУРАЦИЯ ===
    echo ""
    print_message "SUCCESS" "Настройка путей завершена"
    echo ""
    echo -e "┌────────────────────────────────────────────────────────┐"
    echo -e "│ ${BOLD}ИТОГОВАЯ КОНФИГУРАЦИЯ${RESET}                                  │"
    echo -e "├────────────────────────────────────────────────────────┤"
    if [[ -n "$MIGRATION_SOURCE_BACKUP_FILE" ]]; then
        echo -e "│ Архив:  ${GREEN}$(basename "$MIGRATION_SOURCE_BACKUP_FILE")${RESET}"
    else
        echo -e "│ Архив:  ${YELLOW}Не указан${RESET}"
    fi
    if [[ -n "$MIGRATION_SOURCE_ENV_FILE" ]]; then
        echo -e "│ .env:   ${GREEN}$MIGRATION_SOURCE_ENV_FILE${RESET}"
    else
        echo -e "│ .env:   ${YELLOW}Не указан${RESET}"
    fi
    echo -e "├────────────────────────────────────────────────────────┤"
    echo -e "│ Приёмник .env: ${GREEN}$MIGRATION_TARGET_ENV_FILE${RESET}"
    if [[ -n "$MIGRATION_TARGET_CONTAINER" ]]; then
        echo -e "│ Контейнер БД:  ${GREEN}$MIGRATION_TARGET_CONTAINER${RESET}"
    else
        echo -e "│ Контейнер БД:  ${YELLOW}Не настроен${RESET}"
    fi
    echo -e "└────────────────────────────────────────────────────────┘"
    
    read -erp "Enter..." dummy
    return 0
}

# --- Функция: Анализ настроек для миграции ---
migrate_settings_analyze() {
    debug_log "MIGRATE" "Analyzing settings for migration"
    
    # Проверяем наличие хотя бы одного источника
    if [[ -z "$MIGRATION_SOURCE_ENV_FILE" && -z "$MIGRATION_SOURCE_BACKUP_FILE" ]]; then
        print_message "ERROR" "Источник не настроен (ни .env, ни архив)"
        return 1
    fi
    
    # Читаем настройки из доступных источников
    declare -A source_settings
    declare -A backup_settings
    local source_desc=""
    
    # 1) Из .env файла Bedolaga
    if [[ -n "$MIGRATION_SOURCE_ENV_FILE" && -f "$MIGRATION_SOURCE_ENV_FILE" ]]; then
        read_env_file "$MIGRATION_SOURCE_ENV_FILE" source_settings
        source_desc=".env: $MIGRATION_SOURCE_ENV_FILE"
    fi
    
    # 2) Из архива бэкапа (system_settings)
    if [[ -n "$MIGRATION_SOURCE_BACKUP_FILE" && -f "$MIGRATION_SOURCE_BACKUP_FILE" ]]; then
        if extract_bedolaga_backup "$MIGRATION_SOURCE_BACKUP_FILE" 2>/dev/null; then
            read_all_bedolaga_settings backup_settings
            [[ -n "$source_desc" ]] && source_desc+="\n"
            source_desc+="Архив: $(basename "$MIGRATION_SOURCE_BACKUP_FILE") (${#backup_settings[@]} настроек из БД)"
        fi
    fi
    
    local total_source=${#source_settings[@]}
    local total_backup=${#backup_settings[@]}
    local can_migrate_env=0
    local can_migrate_db=0
    local can_migrate_from_backup=0
    local no_mapping=0
    
    # Подсчёт переменных из .env с маппингом
    for key in "${!source_settings[@]}"; do
        if [[ -n "${SETTINGS_ENV_TO_ENV[$key]}" ]]; then
            ((can_migrate_env++))
        elif [[ -n "${SETTINGS_ENV_TO_DB[$key]}" ]]; then
            ((can_migrate_db++))
        else
            ((no_mapping++))
        fi
    done
    
    # Подсчёт настроек из архива с маппингом
    for key in "${!backup_settings[@]}"; do
        if [[ -n "${BEDOLAGA_BACKUP_TO_RWP[$key]}" ]]; then
            ((can_migrate_from_backup++))
        fi
    done
    
    echo ""
    echo -e "${CYAN}${BOLD}═══ АНАЛИЗ НАСТРОЕК ═══${RESET}"
    echo ""
    echo -e "Источники:\n${GREEN}$source_desc${RESET}"
    echo ""
    echo "┌──────────────────────────────────────────────────┐"
    if [[ $total_source -gt 0 ]]; then
        printf "│  Найдено в .env Bedolaga:            %7s   │\n" "$total_source"
        printf "│    -> Перенос в .env:                %7s   │\n" "$can_migrate_env"
        printf "│    -> Перенос в settings DB:         %7s   │\n" "$can_migrate_db"
        printf "│    -> Без аналога:                   %7s   │\n" "$no_mapping"
    fi
    if [[ $total_backup -gt 0 ]]; then
        printf "│  Найдено в архиве:                   %7s   │\n" "$total_backup"
        printf "│    -> Перенос в settings DB:         %7s   │\n" "$can_migrate_from_backup"
    fi
    echo "└──────────────────────────────────────────────────┘"
    echo ""
    
    return 0
}

# --- Функция: Просмотр маппинга .env → .env ---
migrate_settings_show_env_mapping() {
    # Если используется архив - показываем маппинг из архива
    if [[ -n "$MIGRATION_SOURCE_BACKUP_FILE" && -f "$MIGRATION_SOURCE_BACKUP_FILE" ]]; then
        clear_screen
        echo -e "${CYAN}${BOLD}═══ МАППИНГ НАСТРОЕК ИЗ АРХИВА ═══${RESET}"
        echo ""
        echo -e "${GRAY}Источник: $(basename "$MIGRATION_SOURCE_BACKUP_FILE")${RESET}"
        echo ""
        
        # Распаковываем архив если нужно
        if [[ -z "$MIGRATION_EXTRACTED_DIR" || ! -f "$MIGRATION_EXTRACTED_DIR/database.json" ]]; then
            if ! extract_bedolaga_backup "$MIGRATION_SOURCE_BACKUP_FILE" 2>/dev/null; then
                print_message "ERROR" "Не удалось распаковать архив"
                read -erp "Enter..." dummy
                return 1
            fi
        fi
        
        # Показываем настройки из архива
        if [[ -n "$MIGRATION_EXTRACTED_DIR" && -f "$MIGRATION_EXTRACTED_DIR/database.json" ]]; then
            # Читаем настройки из архива
            declare -A backup_settings
            read_all_bedolaga_settings backup_settings
            
            echo -e "${GREEN}=== Настройки из system_settings → RWP-Shop ===${RESET}"
            echo ""
            printf "%-35s │ %-30s │ %s\n" "Bedolaga (backup)" "RWP-Shop" "Value"
            echo "────────────────────────────────────┼────────────────────────────────┼────────────────────────"
            
            local found_count=0
            local mapped_count=0
            local output_lines=()
            
            # Итерируем по реально найденным настройкам из архива
            for bedolaga_key in "${!backup_settings[@]}"; do
                local rwp_key="${BEDOLAGA_BACKUP_TO_RWP[$bedolaga_key]:-}"
                local value="${backup_settings[$bedolaga_key]}"
                
                # Ограничиваем длину значения
                [[ ${#value} -gt 20 ]] && value="${value:0:17}..."
                
                ((found_count++))
                if [[ -n "$rwp_key" ]]; then
                    output_lines+=("$(printf "%-35s │ ${GREEN}%-30s${RESET} │ %s" "$bedolaga_key" "$rwp_key" "$value")")
                    ((mapped_count++))
                else
                    output_lines+=("$(printf "%-35s │ ${GRAY}%-30s${RESET} │ %s" "$bedolaga_key" "(no mapping)" "$value")")
                fi
            done
            
            # Сортируем и выводим
            printf '%s\n' "${output_lines[@]}" | sort
            
            echo ""
            echo -e "Found in archive: ${GREEN}$found_count${RESET} settings"
            echo -e "With RWP-Shop mapping: ${GREEN}$mapped_count${RESET}"
        else
            print_message "WARN" "Архив не распакован или database.json не найден"
        fi
        
        echo ""
        read -erp "Enter..." dummy
        return 0
    fi
    
    # Если .env не указан - показываем подсказку
    if [[ -z "$MIGRATION_SOURCE_ENV_FILE" || ! -f "$MIGRATION_SOURCE_ENV_FILE" ]]; then
        print_message "WARN" ".env файл Bedolaga не указан"
        echo ""
        echo "Для просмотра маппинга .env → .env необходимо указать путь к .env файлу Bedolaga."
        echo "Используйте пункт 1 (Настройка путей) для указания источника."
        echo ""
        echo -e "${GRAY}Подсказка: Если вы используете архив - настройки уже загружены из system_settings.${RESET}"
        echo -e "${GRAY}Архив содержит настройки из админ-панели Bedolaga, а не из .env файла.${RESET}"
        echo ""
        read -erp "Enter..." dummy
        return 1
    fi
    
    declare -A source_settings
    read_env_file "$MIGRATION_SOURCE_ENV_FILE" source_settings
    
    clear_screen
    echo -e "${CYAN}${BOLD}═══ МАППИНГ .env → .env (критические настройки) ═══${RESET}"
    echo ""
    printf "%-30s │ %-30s │ %s\n" "Bedolaga" "RWP-Shop" "Значение"
    echo "───────────────────────────────┼────────────────────────────────┼────────────────────────"
    
    for bedolaga_key in "${!SETTINGS_ENV_TO_ENV[@]}"; do
        local rwp_key="${SETTINGS_ENV_TO_ENV[$bedolaga_key]}"
        local value="${source_settings[$bedolaga_key]:-<не задано>}"
        
        # Маскируем чувствительные данные
        if [[ "$bedolaga_key" =~ TOKEN|SECRET|PASSWORD|KEY ]]; then
            if [[ -n "${source_settings[$bedolaga_key]}" ]]; then
                local masked="${value:0:6}***${value: -3}"
                value="$masked"
            fi
        fi
        
        # Ограничиваем длину значения
        [[ ${#value} -gt 25 ]] && value="${value:0:22}..."
        
        printf "%-30s │ %-30s │ %s\n" "$bedolaga_key" "$rwp_key" "$value"
    done
    
    echo ""
    read -erp "Enter..." dummy
}

