# Отключение всех cron-задач LAZARUS
disable_all_cron_tasks() {
    echo ""
    print_message "WARN" "Вы уверены, что хотите отключить ВСЕ авто-бэкапы?"
    read -erp "Подтвердить? (y/n): " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        # Удаляем все cron-задачи LAZARUS
        local current_cron
        current_cron=$(crontab -l 2> "$SILENT_LOG" || echo "")
        local new_cron
        new_cron=$(echo "$current_cron" | grep -v "# LAZARUS-JOB-")
        
        if [[ -z "$new_cron" ]]; then
            crontab -r 2> "$SILENT_LOG" || true
        else
            echo "$new_cron" | crontab -
        fi
        
        # Обновляем конфиг
        SCHEDULE_FULL="Выкл"
        SCHEDULE_DB="Выкл"
        SCHEDULE_FILES="Выкл"
        save_config
        
        print_message "SUCCESS" "Все авто-бэкапы отключены"
        log_message "INFO" "All LAZARUS cron tasks disabled by user"
        sleep 1.5
    else
        print_message "INFO" "Отменено"
        sleep 1
    fi
}

