    fi
    
    # Healthcheck CSV после экспорта
    print_message "INFO" "       Проверка экспортированных данных..."
    if ! migration_healthcheck_csv "$MIGRATION_WORK_DIR/export" "false"; then
        print_message "WARN" "Предупреждения при проверке CSV"
    fi
    
    # [5/10] Балансы
    print_message "INFO" "[5/10] Анализ балансов пользователей..."
    # Автоматически выбираем export_csv для сохранения
    BALANCE_HANDLING_MODE="export_csv"
    if ! migrate_handle_balances; then
        print_message "WARN" "Предупреждение при анализе балансов"
    fi
    
    # [6/10] Трансформация
    print_message "INFO" "[6/10] Трансформация данных..."
    if ! migrate_transform_data; then
        print_message "ERROR" "Ошибка трансформации!"
        return 1
    fi
    
    # Применяем обработку балансов
    migrate_apply_balance_handling 2>/dev/null
    
    # Healthcheck трансформированных CSV (директория import)
    print_message "INFO" "       Проверка трансформированных данных..."
    if ! migration_healthcheck_csv "$MIGRATION_WORK_DIR/import" "false"; then
        print_message "WARN" "Предупреждения при проверке трансформации"
    fi
    
    # [7/10] Импорт - требует подтверждения!
    migration_show_import_warning
    
    read -erp "Введите 'IMPORT' для подтверждения импорта: " import_confirm
    if [[ "$import_confirm" != "IMPORT" ]]; then
        print_message "INFO" "Импорт отменён. Данные экспортированы в: $MIGRATION_WORK_DIR"
        return 0
    fi
    
    print_message "INFO" "[7/10] Импорт в RWP-Shop..."
    if ! migrate_import_data; then
        print_message "ERROR" "Ошибка импорта!"
        echo ""
        echo -e "${YELLOW}Для отката используйте бэкап:${RESET}"
        echo "  docker exec -i $MIGRATION_TARGET_CONTAINER psql -U $MIGRATION_TARGET_USER $MIGRATION_TARGET_DB < $MIGRATION_AUTO_BACKUP"
        return 1
    fi
    
    # [8/10] Сохранение непереносимых данных
    print_message "INFO" "[8/10] Сохранение непереносимых данных..."
    migration_save_not_migrated_data
    
    # [9/10] Отчёт + Финальный healthcheck
    print_message "INFO" "[9/10] Генерация отчёта + Финальный healthcheck..."
    migrate_generate_report
    
    # Финальный healthcheck БД
    migration_healthcheck_db_post "true"
    
    # [10/10] Миграция настроек (опционально)
    echo ""
    print_message "INFO" "[10/10] Миграция настроек..."
    echo ""
    echo -e "${CYAN}Хотите перенести настройки из Bedolaga в RWP-Shop?${RESET}"
    echo "  • Будут перенесены: токен бота, каналы, тарифы, тексты и др."
    echo "  • Существующие настройки в .env будут заменены"
    echo ""
    read -erp "Мигрировать настройки? (y/n): " migrate_settings_confirm
    if [[ "$migrate_settings_confirm" == "y" || "$migrate_settings_confirm" == "Y" ]]; then
        if migrate_settings_execute; then
            print_message "SUCCESS" "Настройки успешно мигрированы"
        else
            print_message "WARN" "Миграция настроек завершена с предупреждениями"
        fi
    else
        print_message "INFO" "Миграция настроек пропущена"
    fi
    
    local end_time=$(date +%s)
    local duration=$((end_time - start_time))
    
    echo ""
    echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
    echo -e "${GREEN}${BOLD}  ✅ МИГРАЦИЯ ЗАВЕРШЕНА!                                            ${RESET}"
    echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
    echo ""
    echo "  Время выполнения: ${duration}с"
    echo "  Рабочая папка: $MIGRATION_WORK_DIR"
    [[ -d "$MIGRATION_NOT_MIGRATED_DIR" ]] && echo "  Непереносимые данные: $MIGRATION_NOT_MIGRATED_DIR"
    echo ""
    echo -e "${YELLOW}⚠️  Не забудьте:${RESET}"
    echo "  • Проверить работу бота"
    echo "  • Перезапустить бота: docker compose restart"
    echo ""
    
    log_message "SUCCESS" "Migration completed in ${duration}s: Bedolaga → RWP-Shop"
    
    return 0
}

# --- Главное меню миграции ---
menu_migration() {
    # Показываем disclaimer один раз
    migration_show_disclaimer
    
    # Автопоиск архива при первом входе
    if [[ -z "$MIGRATION_SOURCE_BACKUP" ]]; then
        local auto_archive
        auto_archive=$(migration_auto_find_archive)
        if [[ -n "$auto_archive" ]]; then
            MIGRATION_SOURCE_BACKUP="$auto_archive"
            MIGRATION_SOURCE_TYPE="archive"
            # Получаем анализ
            MIGRATION_DATA_ANALYSIS=$(migration_quick_analyze "$auto_archive" 2>/dev/null)
        fi
    fi
    
    # Автопоиск приёмника
    if [[ -z "$MIGRATION_TARGET_CONTAINER" ]]; then
        for pattern in "rwp_shop_db" "telegram-shop-db"; do
            MIGRATION_TARGET_CONTAINER=$(docker ps --format '{{.Names}}' 2>/dev/null | grep -iE "^$pattern$" | head -1)
            [[ -n "$MIGRATION_TARGET_CONTAINER" ]] && break
        done
        MIGRATION_TARGET_DB="${MIGRATION_TARGET_DB:-postgres}"
        MIGRATION_TARGET_USER="${MIGRATION_TARGET_USER:-postgres}"
    fi
    
    # Определяем путь к RWP-Shop и инициализируем рабочую директорию
    migration_detect_target_path
    if [[ -z "$MIGRATION_WORK_DIR" || ! -d "$MIGRATION_WORK_DIR" ]]; then
        migration_init_work_dir
    fi
    
    while true; do
        clear_screen
        echo -e "${MAGENTA}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
        echo -e "${MAGENTA}${BOLD}       🔄 МИГРАЦИЯ: Bedolaga → RWP-Shop Private                    ${RESET}"
        echo -e "${MAGENTA}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
        echo ""
        
        # Показываем статус
        migration_show_status
        echo ""
        
        # Меню
        echo -e " ${GREEN}─── БЫСТРЫЙ СТАРТ ───${RESET}"
        echo -e " ${GREEN}${BOLD} 1. 🚀 АВТОМАТИЧЕСКАЯ МИГРАЦИЯ${RESET} (рекомендуется)"
        echo -e "    ${GRAY}Перенесёт все данные с подтверждением на каждом этапе${RESET}"
        echo ""
        
        echo " ─── ПОШАГОВЫЙ РЕЖИМ ───"
        echo " 2. 📥 Выбрать архив Bedolaga"
        echo " 3. 🎯 Настроить приёмник (RWP-Shop)"
        echo " 4. 📊 Анализ данных (превью миграции)"
        echo -e " 5. 🏥 ${CYAN}Healthcheck${RESET} (проверить архив и БД)"
        echo ""
        
        echo " ─── РУЧНОЕ УПРАВЛЕНИЕ ───"
        echo " 6. ▶️  Только экспорт данных"
        echo " 7. 🔄 Только трансформация"
        echo " 8. 📥 Только импорт в БД"
        echo " 9. 💰 Анализ балансов пользователей"
        echo ""
        
        echo -e " ─── НАСТРОЙКИ ───"
        echo -e " ${CYAN}10. ⚙️  Миграция настроек бота${RESET}"
        echo ""
        
        echo " ─── ПОСЛЕ МИГРАЦИИ ───"
        echo " 11. 📋 Посмотреть последний отчёт"
        echo " 12. 📁 Открыть папку NOT_MIGRATED"
        echo ""
        
        echo " 0. ← Назад в главное меню"
        echo ""
        read -erp "Выбор (Enter - Назад): " opt
        [[ -z "$opt" || "$opt" == "q" || "$opt" == "Q" ]] && return
        
        case "$opt" in
            1)
                # Автоматическая миграция
                migration_run_automatic
                read -erp "Нажмите Enter..." dummy
                ;;
            2)
                # Выбор архива (возвращает 0 при выборе, 1 при отмене)
                migration_select_archive
                ;;
            3)
                # Настройка приёмника
                migrate_configure_target
                ;;
            4)
                # Анализ данных
                migration_show_detailed_analysis
                read -erp "Нажмите Enter..." dummy
                ;;
            5)
                # Healthcheck
                migration_healthcheck_full "true"
                read -erp "Нажмите Enter..." dummy
                ;;
            6)
                # Только экспорт
                if [[ -z "$MIGRATION_SOURCE_TYPE" ]]; then
                    print_message "ERROR" "Сначала выберите архив (пункт 2)"
                    read -erp "Enter..." dummy
                    continue
                fi
                # Инициализируем рабочую папку если не задана
                if [[ -z "$MIGRATION_WORK_DIR" || ! -d "$MIGRATION_WORK_DIR" ]]; then
                    migration_init_work_dir
                fi
                
                echo ""
                echo -e "${CYAN}${BOLD}═══ ШАГ 1/3: ЭКСПОРТ ДАННЫХ ═══${RESET}"
                echo -e "${GRAY}Извлекаем данные из архива Bedolaga в CSV файлы${RESET}"
                echo ""
                
                migrate_export_data
                
                # Показываем healthcheck CSV после экспорта
                migration_healthcheck_csv "$MIGRATION_WORK_DIR/export" "true"
                
                # Показываем итог
                echo ""
                echo -e "${GREEN}${BOLD}═══ ЭКСПОРТ ЗАВЕРШЁН ═══${RESET}"
                echo ""
                echo -e "  📁 Файлы сохранены в:"
                echo -e "     ${CYAN}$MIGRATION_WORK_DIR/export/${RESET}"
                echo ""
                echo -e "  📋 Следующий шаг:"
                echo -e "     ${YELLOW}Пункт 7${RESET} → Трансформация (конвертация форматов)"
                echo ""
                read -erp "Нажмите Enter..." dummy
                ;;
            7)
                # Только трансформация
                if [[ -z "$MIGRATION_WORK_DIR" || ! -d "$MIGRATION_WORK_DIR/export" ]]; then
                    print_message "ERROR" "Сначала выполните экспорт (пункт 6)"
                    if [[ -n "$MIGRATION_WORK_DIR" ]]; then
                        debug_log "MIGRATE" "Export dir not found: $MIGRATION_WORK_DIR/export"
                    fi
                    read -erp "Enter..." dummy
                    continue
                fi
                
                echo ""
                echo -e "${CYAN}${BOLD}═══ ШАГ 2/3: ТРАНСФОРМАЦИЯ ═══${RESET}"
                echo -e "${GRAY}Конвертируем форматы Bedolaga → RWP-Shop${RESET}"
                echo ""
                
                migrate_transform_data
                
                # Показываем healthcheck CSV после трансформации (директория import)
                migration_healthcheck_csv "$MIGRATION_WORK_DIR/import" "true"
                
                # Показываем итог
                echo ""
                echo -e "${GREEN}${BOLD}═══ ТРАНСФОРМАЦИЯ ЗАВЕРШЕНА ═══${RESET}"
                echo ""
                echo -e "  📁 Файлы для импорта:"
                echo -e "     ${CYAN}$MIGRATION_WORK_DIR/import/${RESET}"
                echo ""
                echo -e "  📋 Следующий шаг:"
                echo -e "     ${YELLOW}Пункт 8${RESET} → Импорт в БД RWP-Shop"
                echo ""
                read -erp "Нажмите Enter..." dummy
                ;;
            8)
                # Только импорт
                if [[ -z "$MIGRATION_WORK_DIR" || ! -d "$MIGRATION_WORK_DIR/import" ]]; then
                    print_message "ERROR" "Сначала выполните трансформацию (пункт 7)"
                    read -erp "Enter..." dummy
                    continue
                fi
                if [[ -z "$MIGRATION_TARGET_CONTAINER" ]]; then
                    print_message "ERROR" "Сначала настройте приёмник (пункт 3)"
                    read -erp "Enter..." dummy
                    continue
                fi
                
                echo ""
                echo -e "${CYAN}${BOLD}═══ ШАГ 3/3: ИМПОРТ В БД ═══${RESET}"
                echo -e "${GRAY}Загружаем данные в PostgreSQL RWP-Shop${RESET}"
                echo ""
                
                # Healthcheck БД перед импортом
                migration_healthcheck_db_pre "true"
                
                # Создаём бэкап перед импортом
                migration_backup_target_db
                migration_show_import_warning
                
                read -erp "Введите 'IMPORT' для подтверждения: " confirm
                if [[ "$confirm" == "IMPORT" ]]; then
                    migrate_import_data
                    # Healthcheck БД после импорта
                    migration_healthcheck_db_post "true"
                    
                    # Показываем итог
                    echo ""
                    echo -e "${GREEN}${BOLD}═══ МИГРАЦИЯ ЗАВЕРШЕНА ═══${RESET}"
                    echo ""
                    echo -e "  ✅ Данные успешно импортированы в RWP-Shop"
                    echo ""
                    echo -e "  📋 Рекомендуется:"
                    echo -e "     • Проверить работу бота"
                    echo -e "     • Просмотреть пункт ${YELLOW}12${RESET} (NOT_MIGRATED) для несовместимых данных"
                    echo ""
                else
                    print_message "INFO" "Импорт отменён"
                fi
                read -erp "Нажмите Enter..." dummy
                ;;
            9)
                # Анализ балансов
                if [[ -z "$MIGRATION_SOURCE_TYPE" ]]; then
                    print_message "ERROR" "Сначала выберите архив (пункт 2)"
                    read -erp "Enter..." dummy
                    continue
                fi
                # Инициализируем рабочую папку если не задана
                if [[ -z "$MIGRATION_WORK_DIR" || ! -d "$MIGRATION_WORK_DIR" ]]; then
                    migration_init_work_dir
                fi
                # Распаковываем архив если ещё не распакован
                if [[ "$MIGRATION_SOURCE_TYPE" == "archive" ]]; then
                    if [[ -z "$MIGRATION_EXTRACTED_DIR" || ! -f "$MIGRATION_EXTRACTED_DIR/database.json" ]]; then
                        if ! extract_bedolaga_backup "$MIGRATION_SOURCE_BACKUP"; then
                            print_message "ERROR" "Не удалось распаковать архив"
                            read -erp "Enter..." dummy
                            continue
                        fi
                    fi
                fi
                if migrate_handle_balances; then
                    # Пользователь выбрал действие, применяем
                    if [[ -n "$BALANCE_HANDLING_MODE" && "$BALANCE_HANDLING_MODE" != "none" ]]; then
                        migrate_apply_balance_handling
                    fi
                    read -erp "Нажмите Enter..." dummy
                fi
                # Если return 1 (назад) — просто продолжаем цикл меню
                ;;
            10)
                # Миграция настроек
                menu_migrate_settings
                ;;
            11)
                # Последний отчёт
                local report_file="$MIGRATION_WORK_DIR/migration_report.txt"
                if [[ -f "$report_file" ]]; then
                    clear_screen
                    cat "$report_file"
                else
                    # Ищем последний отчёт
                    local latest_report=$(find "$BACKUP_DIR" -name "migration_report.txt" -type f 2>/dev/null | head -1)
                    if [[ -n "$latest_report" ]]; then
                        clear_screen
                        cat "$latest_report"
                    else
                        print_message "WARN" "Отчёт не найден. Сначала выполните миграцию."
                    fi
                fi
                read -erp "Нажмите Enter..." dummy
                ;;
            12)
                # Открыть папку NOT_MIGRATED
                local not_migrated_dir="$MIGRATION_WORK_DIR/NOT_MIGRATED"
                if [[ -d "$not_migrated_dir" ]]; then
                    echo ""
                    echo "Содержимое папки NOT_MIGRATED:"
                    echo ""
                    ls -la "$not_migrated_dir"
                    echo ""
                    echo "Путь: $not_migrated_dir"
                else
                    # Ищем последнюю папку
                    local latest_dir=$(find "$BACKUP_DIR" -name "NOT_MIGRATED" -type d 2>/dev/null | head -1)
                    if [[ -n "$latest_dir" ]]; then
                        echo ""
                        echo "Содержимое папки NOT_MIGRATED:"
                        echo ""
                        ls -la "$latest_dir"
                        echo ""
                        echo "Путь: $latest_dir"
                    else
                        print_message "WARN" "Папка NOT_MIGRATED не найдена."
                        echo "Она создаётся автоматически при миграции."
                    fi
                fi
                read -erp "Нажмите Enter..." dummy
                ;;
            0) return ;;
        esac
    done
}
