# --- Функция: Чтение .env файла в ассоциативный массив ---
read_env_file() {
    local env_file="$1"
    local -n result_map=$2
    
    if [[ ! -f "$env_file" ]]; then
        debug_log "MIGRATE" "ENV file not found: $env_file"
        return 1
    fi
    
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Пропускаем комментарии и пустые строки
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// }" ]] && continue
        
        # Извлекаем KEY=VALUE
        if [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
            local key="${BASH_REMATCH[1]}"
            local value="${BASH_REMATCH[2]}"
            
            # Убираем кавычки если есть
            value="${value#\"}"
            value="${value%\"}"
            value="${value#\'}"
            value="${value%\'}"
            
            result_map["$key"]="$value"
        fi
    done < "$env_file"
    
    debug_log "MIGRATE" "Read ${#result_map[@]} variables from $env_file"
    return 0
}

# --- Функция: Получить значение с дефолтом из Bedolaga ---
# Использование: get_bedolaga_value source_settings "KEY"
get_bedolaga_value() {
    local -n _source_map=$1
    local key="$2"
    local value="${_source_map[$key]:-}"
    
    # Если значение пустое — берём дефолт
    if [[ -z "$value" ]]; then
        value="${BEDOLAGA_DEFAULTS[$key]:-}"
    fi
    
    echo "$value"
}

# --- Функция: Получить дефолт RWP-Shop ---
get_rwp_default() {
    local key="$1"
    echo "${RWP_SHOP_DEFAULTS[$key]:-}"
}

# --- Функция: Запись переменной в .env файл ---
write_env_variable() {
    local env_file="$1"
    local key="$2"
    local value="$3"
    
    # Экранируем спецсимволы для sed
    local escaped_value="${value//\\/\\\\}"
    escaped_value="${escaped_value//&/\\&}"
    
    if grep -q "^${key}=" "$env_file" 2>/dev/null; then
        # Обновляем существующую переменную
        sed -i "s|^${key}=.*|${key}=\"${escaped_value}\"|" "$env_file"
    else
        # Добавляем новую переменную
        echo "${key}=\"${value}\"" >> "$env_file"
    fi
}

