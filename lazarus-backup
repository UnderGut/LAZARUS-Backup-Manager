# --- УДАЛЁННОЕ ХРАНИЛИЩЕ И S3 ---

validate_remote_connection() {
    local type="$1"; local url="$2"; local user="$3"; local pass="$4"
    
    debug_log "REMOTE" "=== validate_remote_connection($type) ==="
    debug_log "REMOTE" "URL: $url"
    debug_log "REMOTE" "User: ${user:-<empty>}"
    
    print_message "INFO" "Тестирование подключения ($type)..."
    
    local base_url="${url%/}"
    
    if [[ "$type" == "ftp" ]]; then
        debug_log "REMOTE" "Testing FTP connection..."
        # FTP: проверяем листинг директории
        local curl_cmd=(curl $CURL_SILENT -m 15 --ftp-pasv --list-only)
        [[ -n "$user" ]] && curl_cmd+=(--user "$user:$pass")
        
        # Поддержка FTPS (implicit и explicit)
        if [[ "$base_url" == ftps://* ]]; then
            debug_log "REMOTE" "Using FTPS (implicit TLS)"
            curl_cmd+=(--ssl-reqd --insecure)
        elif [[ "$base_url" == ftp://* ]]; then
            debug_log "REMOTE" "Using FTP with optional TLS"
            # Попробуем explicit TLS если доступен
            curl_cmd+=(--ssl --insecure)
        fi
        
        debug_log "REMOTE" "Running: ${curl_cmd[*]} $base_url/"
        if "${curl_cmd[@]}" "$base_url/" > "$SILENT_LOG" 2>&1; then 
            debug_log "REMOTE" "FTP connection SUCCESS"
            return 0
        else 
            debug_log "REMOTE" "FTP with TLS failed, trying without TLS..."
            # Повторная попытка без TLS для обычного FTP
            if [[ "$base_url" == ftp://* ]]; then
                curl_cmd=(curl $CURL_SILENT -m 15 --ftp-pasv --list-only)
                [[ -n "$user" ]] && curl_cmd+=(--user "$user:$pass")
                if "${curl_cmd[@]}" "$base_url/" > "$SILENT_LOG" 2>&1; then
                    debug_log "REMOTE" "FTP without TLS SUCCESS"
                    return 0
                fi
            fi
            debug_log "REMOTE" "FTP connection FAILED"
            return 1
        fi
        
    elif [[ "$type" == "webdav" ]]; then
        debug_log "REMOTE" "Testing WebDAV connection..."
        # WebDAV: PROPFIND с Depth: 0
        local curl_cmd=(curl $CURL_SILENT -m 15 -L)
        [[ -n "$user" ]] && curl_cmd+=(--user "$user:$pass")
        
        # Поддержка самоподписанных сертификатов
        [[ "$base_url" == https://* ]] && curl_cmd+=(--insecure)
        
        local http_code
        debug_log "REMOTE" "Sending PROPFIND request..."
        http_code=$("${curl_cmd[@]}" -o "$SILENT_LOG" -w "%{http_code}" -X PROPFIND -H "Depth: 0" "$base_url/" 2> "$SILENT_LOG")
        debug_log "REMOTE" "PROPFIND HTTP code: $http_code"
        
        # 207 Multi-Status — стандартный успешный ответ WebDAV
        # 200 OK — некоторые серверы отвечают так
        # 301/302 — редирект (curl -L обработает)
        if [[ "$http_code" =~ ^(200|207)$ ]]; then 
            debug_log "REMOTE" "WebDAV connection SUCCESS"
            return 0
        else 
            debug_log "REMOTE" "PROPFIND failed, trying GET fallback..."
            # Fallback: попробуем простой GET
            http_code=$("${curl_cmd[@]}" -o "$SILENT_LOG" -w "%{http_code}" "$base_url/" 2> "$SILENT_LOG")
            debug_log "REMOTE" "GET HTTP code: $http_code"
            if [[ "$http_code" =~ ^(200|207|401)$ ]]; then
                # 401 означает что сервер отвечает, но нужна авторизация
                debug_log "REMOTE" "WebDAV connection SUCCESS (via GET)"
                return 0
            fi
            debug_log "REMOTE" "WebDAV connection FAILED"
            return 1
        fi
        
    elif [[ "$type" == "rclone" ]]; then
        debug_log "REMOTE" "Testing rclone connection..."
        if ! command -v rclone > "$SILENT_LOG" 2>&1; then
            debug_log "REMOTE" "rclone not installed!"
            print_message "ERROR" "Rclone не установлен!"
            return 1
        fi
        # Проверяем доступность remote
        local remote_name="${url%%:*}"
        debug_log "REMOTE" "Remote name: $remote_name"
        if rclone listremotes 2> "$SILENT_LOG" | grep -q "^${remote_name}:$"; then
            debug_log "REMOTE" "Remote exists, testing lsd..."
            # Remote существует, проверяем доступность
            if rclone lsd "$url" > "$SILENT_LOG" 2>&1; then 
                debug_log "REMOTE" "Rclone connection SUCCESS"
                return 0
            fi
        else
            debug_log "REMOTE" "Remote '$remote_name' not found in rclone config"
        fi
        debug_log "REMOTE" "Rclone connection FAILED"
        return 1

    elif [[ "$type" == "s3" ]]; then
        debug_log "REMOTE" "Testing S3 connection..."
        if ! command -v aws > "$SILENT_LOG" 2>&1; then
            print_message "ERROR" "AWS CLI не установлен!"
            return 1
        fi
        if [[ -z "$S3_BUCKET" ]]; then
            print_message "ERROR" "S3_BUCKET не задан в конфиге."
            return 1
        fi
        local _s3_validate_opts=()
        [[ -n "$S3_ENDPOINT" ]] && _s3_validate_opts+=(--endpoint-url "$S3_ENDPOINT")
        [[ -n "$S3_REGION"   ]] && _s3_validate_opts+=(--region "$S3_REGION")
        if _s3_aws_run s3 ls "s3://${S3_BUCKET}/" "${_s3_validate_opts[@]}" --max-items 1 > "$SILENT_LOG" 2>&1; then
            debug_log "REMOTE" "S3 connection SUCCESS"
            return 0
        fi
        debug_log "REMOTE" "S3 connection FAILED"
        return 1
    fi
    
    debug_log "REMOTE" "Unknown storage type: $type"
    return 1
}

# =============================================================================
# _s3_aws_run: вызов aws CLI с приватным credentials-файлом
# =============================================================================
# Записывает временный файл ~/aws/credentials с правами 0600 и подключает его
# через AWS_SHARED_CREDENTIALS_FILE + AWS_PROFILE=lazarus, а не через
# `export AWS_ACCESS_KEY_ID`/`AWS_SECRET_ACCESS_KEY` в окружение текущего
# shell-процесса. После завершения файл затирается (shred / rm).
#
# Преимущества:
#   - переменные не утекают в дочерние процессы, не запущенные через aws;
#   - нет race-window между export и unset, в котором креды видны другим;
#   - повторные параллельные вызовы не конфликтуют между собой.
#
# Использование:
#   _s3_aws_run s3 cp file.tgz s3://bucket/path/
#   _s3_aws_run s3 ls "s3://bucket/" --max-items 1
# Override (для wizard-режима, когда S3_* ещё не сохранены):
#   _S3_AWS_KEY_OVERRIDE="<key>" _S3_AWS_SECRET_OVERRIDE="<secret>" \
#       _s3_aws_run s3 ls ...
# =============================================================================
_s3_aws_run() {
    local _ak="${_S3_AWS_KEY_OVERRIDE:-$S3_ACCESS_KEY}"
    local _sk="${_S3_AWS_SECRET_OVERRIDE:-$S3_SECRET_KEY}"
    if [[ -z "$_ak" || -z "$_sk" ]]; then
        debug_log "S3" "_s3_aws_run: пустые credentials, fallback на default chain"
        aws "$@"
        return $?
    fi
    local _creds_file
    _creds_file=$(mktemp 2> "$SILENT_LOG") || {
        print_message "ERROR" "_s3_aws_run: mktemp failed, выполняем aws без приватного файла" >&2
        aws "$@"
        return $?
    }
    chmod 600 "$_creds_file" 2> "$SILENT_LOG" || true
    {
        printf '[lazarus]\n'
        printf 'aws_access_key_id = %s\n' "$_ak"
        printf 'aws_secret_access_key = %s\n' "$_sk"
    } > "$_creds_file"
    AWS_SHARED_CREDENTIALS_FILE="$_creds_file" AWS_PROFILE="lazarus" aws "$@"
    local _rc=$?
    if command -v shred > "$SILENT_LOG" 2>&1; then
        shred -u "$_creds_file" 2> "$SILENT_LOG" || rm -f "$_creds_file"
    else
        rm -f "$_creds_file"
    fi
    return $_rc
}

upload_to_remote() {
    if [[ "$SEND_TO_REMOTE" != "true" ]]; then 
        debug_log "REMOTE" "Remote upload disabled (SEND_TO_REMOTE=$SEND_TO_REMOTE)"
        return 0
    fi
    local file_path="$1"
    local filename=$(basename "$file_path")
    local file_size=$(stat -c%s "$file_path" 2> "$SILENT_LOG" || echo "0")
    REMOTE_UPLOAD_STATUS_TEXT="" 
    
    debug_log "REMOTE" "=== upload_to_remote ==="
    debug_log "REMOTE" "File: $file_path"
    debug_log "REMOTE" "Size: $file_size bytes"
    debug_log "REMOTE" "Type: $REMOTE_STORAGE_TYPE"
    debug_log "REMOTE" "URL: $REMOTE_STORAGE_URL"

    if [[ "$REMOTE_STORAGE_TYPE" == "off" || -z "$REMOTE_STORAGE_URL" ]]; then 
        debug_log "REMOTE" "Remote storage disabled or URL empty"
        return 0
    fi
    
    if [[ ! -f "$file_path" ]]; then
        print_message "ERROR" "Файл для загрузки не найден: $file_path" >&2
        log_message "ERROR" "Upload failed: file not found $file_path"
        debug_log "REMOTE" "ERROR: File not found!"
        return 1
    fi

    print_message "INFO" "Загрузка на $REMOTE_STORAGE_TYPE ($(numfmt --to=iec $file_size 2> "$SILENT_LOG" || echo "${file_size}B"))..." >&2

    # === RCLONE ===
    if [[ "$REMOTE_STORAGE_TYPE" == "rclone" ]]; then
        debug_log "REMOTE" "Using rclone..."
        if ! command -v rclone > "$SILENT_LOG" 2>&1; then
            print_message "ERROR" "Rclone не установлен!"
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ Rclone: Не установлен'
            return 1
        fi
        local dest="${REMOTE_STORAGE_URL%/}"
        local rclone_opts=(--progress --retries 3 --low-level-retries 10)
        [[ "$IS_INTERACTIVE" != "true" ]] && rclone_opts=(--quiet --retries 3 --low-level-retries 10)
        debug_log "REMOTE" "Running: rclone copy $file_path $dest ${rclone_opts[*]}"
        
        if rclone copy "$file_path" "$dest" "${rclone_opts[@]}" 2>&1; then
            print_message "SUCCESS" "Файл загружен (rclone)." >&2
            debug_log "REMOTE" "Rclone upload SUCCESS"
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ Rclone: OK'
            log_message "SUCCESS" "Uploaded $filename to rclone:$dest"
            return 0
        else
            print_message "ERROR" "Ошибка загрузки rclone." >&2
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ Rclone: Ошибка'
            log_message "ERROR" "Failed upload $filename to rclone:$dest"
            return 1
        fi
    fi

    # === S3 (AWS, MinIO, RustFS, Yandex Cloud, etc.) ===
    if [[ "$REMOTE_STORAGE_TYPE" == "s3" ]]; then
        debug_log "REMOTE" "Using S3..."
        
        # Проверяем AWS CLI
        if ! command -v aws > "$SILENT_LOG" 2>&1; then
            print_message "ERROR" "AWS CLI не установлен!" >&2
            echo -e "Установка: ${GRAY}curl \"https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip\" -o awscliv2.zip && unzip awscliv2.zip && sudo ./aws/install${RESET}" >&2
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ S3: AWS CLI не установлен'
            return 1
        fi
        
        # Проверяем настройки
        if [[ -z "$S3_BUCKET" ]]; then
            print_message "ERROR" "S3 bucket не настроен!" >&2
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ S3: Bucket не настроен'
            return 1
        fi
        
        # Формируем путь в bucket
        local s3_path="${S3_PATH%/}"
        [[ -n "$s3_path" ]] && s3_path="${s3_path}/"
        local s3_dest="s3://${S3_BUCKET}/${s3_path}${filename}"
        
        debug_log "REMOTE" "S3 Endpoint: $S3_ENDPOINT"
        debug_log "REMOTE" "S3 Bucket: $S3_BUCKET"
        debug_log "REMOTE" "S3 Region: $S3_REGION"
        debug_log "REMOTE" "S3 Destination: $s3_dest"
        
        # Формируем команду
        local aws_opts=()
        [[ -n "$S3_ENDPOINT" ]] && aws_opts+=(--endpoint-url "$S3_ENDPOINT")
        [[ -n "$S3_REGION" ]] && aws_opts+=(--region "$S3_REGION")

        # Credentials передаются через _s3_aws_run без export
        debug_log "REMOTE" "Running: _s3_aws_run s3 cp $file_path $s3_dest ${aws_opts[*]}"
        local s3_output
        if [[ "$IS_INTERACTIVE" == "true" ]]; then
            s3_output=$(_s3_aws_run s3 cp "$file_path" "$s3_dest" "${aws_opts[@]}" --only-show-errors 2>&1)
        else
            s3_output=$(_s3_aws_run s3 cp "$file_path" "$s3_dest" "${aws_opts[@]}" --quiet 2>&1)
        fi
        local s3_result=$?

        if [[ $s3_result -eq 0 ]]; then
            print_message "SUCCESS" "Файл загружен в S3." >&2
            debug_log "REMOTE" "S3 upload SUCCESS"
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ S3: OK'
            log_message "SUCCESS" "Uploaded $filename to S3 ($s3_dest)"
            return 0
        else
            print_message "ERROR" "Ошибка загрузки в S3: $s3_output" >&2
            debug_log "REMOTE" "S3 upload FAILED: $s3_output"
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ S3: Ошибка'
            log_message "ERROR" "Failed upload $filename to S3: $s3_output"
            return 1
        fi
    fi

    # === FTP / WEBDAV ===
    local upload_url="${REMOTE_STORAGE_URL%/}/$filename"
    local max_retries=3
    local retry_delay=5
    local attempt=1
    local http_code=""
    local upload_success=false
    
    # Расчёт таймаута на основе размера файла (минимум 120 сек, +60 сек на каждые 50MB)
    local timeout=$((120 + (file_size / 50000000) * 60))
    [[ $timeout -gt 1800 ]] && timeout=1800  # Максимум 30 минут
    debug_log "UPLOAD" "Upload URL: $upload_url"
    debug_log "UPLOAD" "Timeout: ${timeout}s, Max retries: $max_retries"
    
    while [[ $attempt -le $max_retries ]]; do
        debug_log "UPLOAD" "Attempt $attempt/$max_retries"
        [[ $attempt -gt 1 ]] && print_message "INFO" "Повторная попытка $attempt/$max_retries..." >&2
        
        # Базовые опции curl
        local curl_opts=(-o "$SILENT_LOG" -w "%{http_code}" -m "$timeout" -T "$file_path")
        
        # Прогресс-бар или тихий режим
        if [[ "$IS_INTERACTIVE" == "true" ]]; then
            curl_opts+=(-#)
        else
            curl_opts+=(-s)
        fi
        
        # Аутентификация
        [[ -n "$REMOTE_STORAGE_USER" ]] && curl_opts+=(--user "$REMOTE_STORAGE_USER:$REMOTE_STORAGE_PASS")
        
        if [[ "$REMOTE_STORAGE_TYPE" == "ftp" ]]; then
            # FTP специфичные опции
            curl_opts+=(--ftp-pasv)              # Passive mode (работает за NAT)
            curl_opts+=(--ftp-create-dirs)       # Создать директории если нужно
            debug_log "UPLOAD" "FTP mode: passive, create-dirs"
            
            # Поддержка FTPS
            if [[ "$upload_url" == ftps://* ]]; then
                curl_opts+=(--ssl-reqd --insecure)
                debug_log "UPLOAD" "FTPS: SSL required"
            elif [[ "$upload_url" == ftp://* ]]; then
                curl_opts+=(--ssl --insecure)    # Попробовать TLS если доступен
                debug_log "UPLOAD" "FTP: Try TLS if available"
            fi
            
            curl_opts+=("$upload_url")
            debug_log "UPLOAD" "Executing FTP upload..."
            http_code=$(curl "${curl_opts[@]}" 2> "$SILENT_LOG") || http_code="000"
            debug_log "UPLOAD" "FTP response code: $http_code"
            
            # FTP коды успеха: 226 (Transfer complete), 250 (Requested file action okay)
            if [[ "$http_code" =~ ^(226|250|200)$ ]]; then
                upload_success=true
                debug_log "UPLOAD" "FTP upload SUCCESS"
                break
            fi
            
        elif [[ "$REMOTE_STORAGE_TYPE" == "webdav" ]]; then
            # WebDAV специфичные опции
            curl_opts+=(-L)                      # Следовать редиректам
            curl_opts+=(--retry 2)               # Встроенный retry curl
            curl_opts+=(--retry-delay 3)
            debug_log "UPLOAD" "WebDAV mode: follow redirects, retry 2"
            
            # Поддержка HTTPS с самоподписанными сертификатами
            if [[ "$upload_url" == https://* ]]; then
                curl_opts+=(--insecure)
                debug_log "UPLOAD" "WebDAV: HTTPS with insecure"
            fi
            
            curl_opts+=("$upload_url")
            debug_log "UPLOAD" "Executing WebDAV upload..."
            http_code=$(curl "${curl_opts[@]}" 2> "$SILENT_LOG") || http_code="000"
            debug_log "UPLOAD" "WebDAV response code: $http_code"
            
            # WebDAV коды успеха: 200 OK, 201 Created, 204 No Content
            if [[ "$http_code" =~ ^(200|201|204)$ ]]; then
                upload_success=true
                debug_log "UPLOAD" "WebDAV upload SUCCESS"
                break
            fi
        fi
        
        # Логируем неудачную попытку
        debug_log "UPLOAD" "Attempt $attempt FAILED with HTTP $http_code"
        log_message "WARN" "Upload attempt $attempt failed: HTTP $http_code for $upload_url"
        
        ((attempt++))
        [[ $attempt -le $max_retries ]] && sleep $retry_delay
    done
    
    if [[ "$upload_success" == true ]]; then
        print_message "SUCCESS" "Файл загружен в хранилище." >&2
        if [[ "$REMOTE_STORAGE_TYPE" == "ftp" ]]; then 
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ FTP: OK'
        else 
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ WebDAV: OK'
        fi
        log_message "SUCCESS" "Uploaded $filename to $REMOTE_STORAGE_TYPE ($upload_url) HTTP=$http_code"
        return 0
    else
        print_message "ERROR" "Ошибка загрузки после $max_retries попыток (Код: $http_code)" >&2
        if [[ "$REMOTE_STORAGE_TYPE" == "ftp" ]]; then 
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ FTP: Ошибка'
        else 
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ WebDAV: Ошибка'
        fi
        log_message "ERROR" "Failed upload $filename to $REMOTE_STORAGE_TYPE after $max_retries attempts. Last HTTP=$http_code"
        return 1
    fi
}

configure_remote_storage() {
    while true; do
        clear_screen
        echo -e "${GREEN}${BOLD}Настройка удалённого хранилища${RESET}"
        echo ""
        
        # Показываем текущий статус
        if [[ "$REMOTE_STORAGE_TYPE" == "s3" && -n "$S3_BUCKET" ]]; then
