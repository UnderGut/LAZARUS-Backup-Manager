# =============================================================================
# HMAC ENVELOPE для зашифрованных бэкапов (encrypt-then-MAC)
# =============================================================================
# AES-256-CBC сам по себе НЕ аутентифицирован — атакующий с write-доступом к .enc
# может подменить ciphertext, decrypt пройдёт. Защита: HMAC-SHA256 над всем
# ciphertext'ом, проверяется ПЕРЕД decrypt (constant-time compare, gadget-protected).
#
# Формат v2 envelope:
#   bytes 0-3:   magic "LAZ2"
#   bytes 4-N:   ciphertext (openssl enc -aes-256-cbc -salt -pbkdf2 output)
#                — структура: "Salted__" + salt(8) + ciphertext
#   bytes N-N+32: HMAC-SHA256 over bytes [4..N) (только ciphertext, без magic)
#
# Legacy v1 (без HMAC): просто openssl output без magic, обрабатывается как fallback.
#
# K_mac derivation: HMAC-SHA256(BACKUP_PASSWORD, "lazarus-hmac-key-v1").
# Это deterministic и быстрый (без PBKDF2) — достаточно для encrypt-then-MAC:
#   - Атакующий без BACKUP_PASSWORD не вычислит K_mac.
#   - K_enc (PBKDF2 100k) и K_mac (fast HMAC) семантически разделены.
#   - Подбор пароля через MAC — теоретически быстрее, чем через PBKDF2, НО
#     attacker всё равно вынужден проверить через PBKDF2 для финального decrypt.

# Hex-кодирование байт из stdin. Использует `od` (доступен везде, в отличие от `xxd`).
_to_hex() {
    od -An -vtx1 | tr -d ' \n'
}

# K_mac = HMAC-SHA256(password, "lazarus-hmac-key-v1") → hex 64 символа
_derive_hmac_key() {
    local password="$1"
    printf '%s' "$password" | openssl dgst -sha256 -hmac "lazarus-hmac-key-v1" -binary | _to_hex
}

# Создаёт v2 envelope: openssl enc → LAZ2 + ciphertext + HMAC
# Возвращает 0 при успехе, 1 при ошибке. Перезаписывает $2.
_hmac_envelope_create() {
    local infile="$1" outfile="$2" password="$3"
    local cipher_tmp
    cipher_tmp=$(mktemp "${TMPDIR:-/tmp}/lazarus_enc.XXXXXX") || return 1
    register_sensitive_tmp "$cipher_tmp"

    # Step 1: encrypt через openssl (как раньше).
    # Timeout-обёртка: PBKDF2 + AES для очень больших архивов (>5 GB) может
    # затянуться на slow CPU/IO; ENCRYPT_TIMEOUT_SEC=0 → отключить.
    # Используем _run_pipe_with_timeout с heredoc через FD3 — pipefail сохраняем.
    if ! _run_pipe_with_timeout "${ENCRYPT_TIMEOUT_SEC:-1800}" "encrypt-aes" \
            'openssl enc -aes-256-cbc -salt -pbkdf2 -iter 100000 -in "$1" -out "$2" -pass fd:3 3<<<"$3" 2> "$4"' \
            "$infile" "$cipher_tmp" "$password" "$SILENT_LOG"; then
        rm -f "$cipher_tmp"; unregister_sensitive_tmp "$cipher_tmp"
        return 1
    fi

    # Step 2: derive K_mac
    local k_mac
    k_mac=$(_derive_hmac_key "$password")
    if [[ -z "$k_mac" ]]; then
        rm -f "$cipher_tmp"; unregister_sensitive_tmp "$cipher_tmp"
        return 1
    fi

    # Step 3: write LAZ2 + ciphertext + HMAC
    {
        printf 'LAZ2'
        cat "$cipher_tmp"
        openssl dgst -sha256 -mac HMAC -macopt "hexkey:$k_mac" -binary "$cipher_tmp"
    } > "$outfile"

    rm -f "$cipher_tmp"
    unregister_sensitive_tmp "$cipher_tmp"
    return 0
}

# Проверка MAC v2 envelope БЕЗ decrypt.
# Returns: 0 = MAC OK, 1 = MAC mismatch / not v2 / file too small.
# stdout: тип формата ("v2" | "v1" | "unknown") для caller decision.
_hmac_envelope_verify() {
    local file="$1" password="$2"
    local size
    size=$(stat -c%s "$file" 2>/dev/null || echo 0)

    # Минимальный v2: 4 (LAZ2) + 16 (Salted__ + salt) + 16 (1 AES block) + 32 (MAC) = 68
    if [[ $size -lt 68 ]]; then
        # Проверим v1 (просто Salted__ + salt + 1 block = 24)
        local v1_magic
        v1_magic=$(head -c 8 "$file" 2>/dev/null)
        if [[ "$v1_magic" == "Salted__" && $size -ge 24 ]]; then
            echo "v1"
            return 1   # v1 не имеет MAC — caller решает (warning)
        fi
        echo "unknown"
        return 1
    fi

    local magic
    magic=$(head -c 4 "$file" 2>/dev/null)
    if [[ "$magic" != "LAZ2" ]]; then
        # Legacy v1 path
        local v1_magic
        v1_magic=$(head -c 8 "$file" 2>/dev/null)
        if [[ "$v1_magic" == "Salted__" ]]; then
            echo "v1"
            return 1
        fi
        echo "unknown"
        return 1
    fi

    # v2 path: vы verify MAC
    local k_mac
    k_mac=$(_derive_hmac_key "$password")
    [[ -z "$k_mac" ]] && { echo "v2"; return 1; }

    local cipher_len=$((size - 4 - 32))
    local cipher_tmp
    cipher_tmp=$(mktemp "${TMPDIR:-/tmp}/lazarus_mac.XXXXXX") || { echo "v2"; return 1; }
    register_sensitive_tmp "$cipher_tmp"

    # Извлекаем ciphertext (без LAZ2 и без последних 32 байт MAC).
    # ВНИМАНИЕ: `dd bs=1` КАТАСТРОФИЧЕСКИ медленный (31 сек на 35 МБ → 15 мин на 1 GB).
    # `tail -c +N | head -c M` использует buffered I/O, для 35 МБ ~ 0.1 сек.
    # +N в `tail -c` это 1-based: пропустить 4 байта = начать с +5.
    tail -c +5 "$file" 2>/dev/null | head -c "$cipher_len" > "$cipher_tmp" 2> "$SILENT_LOG"

    local computed
    computed=$(openssl dgst -sha256 -mac HMAC -macopt "hexkey:$k_mac" -binary "$cipher_tmp" | _to_hex)
    local stored
    stored=$(tail -c 32 "$file" | _to_hex)

    rm -f "$cipher_tmp"
    unregister_sensitive_tmp "$cipher_tmp"

    # Сравнение через bash [[ == ]] — не constant-time, но для нашей threat model
    # (атакующий без пароля не знает correct MAC) — adequate.
    if [[ "$computed" == "$stored" && -n "$computed" ]]; then
        echo "v2"
        return 0
    fi
    echo "v2"
    return 1
}

# Verify + decrypt v2 envelope. Принимает outfile для decrypted plaintext.
# Returns: 0 — OK; 1 — MAC mismatch / unknown format; 2 — decrypt failed (после MAC OK).
# umask 077 + сразу chmod 600 на outfile (для restore-сценария где outfile в /tmp).
#
# OPTIMIZATION: extract ciphertext ОДИН РАЗ (не вызываем _hmac_envelope_verify, который
# делал свой extract). Single-pass = ~0.5 сек экономии на 1 GB файла.
_hmac_envelope_decrypt() {
    local infile="$1" outfile="$2" password="$3"

    # Fast format detection через magic (4-8 байт). Без полного extract.
    local _magic4 _magic8
    _magic4=$(head -c 4 "$infile" 2>/dev/null)
    _magic8=$(head -c 8 "$infile" 2>/dev/null)

    if [[ "$_magic4" == "LAZ2" ]]; then
        # === v2 path: single extract + MAC + decrypt ===
        local size cipher_len cipher_tmp k_mac
        size=$(stat -c%s "$infile")
        # Минимальный v2: LAZ2(4) + Salted__(8) + salt(8) + 1 AES block(16) + MAC(32) = 68
        if [[ $size -lt 68 ]]; then
            debug_log "HMAC" "v2 file too small ($size bytes)"
            return 1
        fi
        cipher_len=$((size - 4 - 32))

        cipher_tmp=$(mktemp "${TMPDIR:-/tmp}/lazarus_dec.XXXXXX") || return 2
        register_sensitive_tmp "$cipher_tmp"
        # Один read: ciphertext в tmp файл (тот же используется для MAC compute и openssl decrypt)
        tail -c +5 "$infile" 2>/dev/null | head -c "$cipher_len" > "$cipher_tmp" 2> "$SILENT_LOG"

        # Compute MAC over extracted ciphertext
        k_mac=$(_derive_hmac_key "$password")
        if [[ -z "$k_mac" ]]; then
            rm -f "$cipher_tmp"; unregister_sensitive_tmp "$cipher_tmp"
            return 1
        fi
        local computed stored
        computed=$(openssl dgst -sha256 -mac HMAC -macopt "hexkey:$k_mac" -binary "$cipher_tmp" | _to_hex)
        stored=$(tail -c 32 "$infile" | _to_hex)

        if [[ "$computed" != "$stored" || -z "$computed" ]]; then
            debug_log "HMAC" "v2 MAC mismatch"
            rm -f "$cipher_tmp"; unregister_sensitive_tmp "$cipher_tmp"
            return 1
        fi

        # MAC OK → decrypt тот же cipher_tmp (не extract ещё раз)
        ( umask 077 && openssl enc -d -aes-256-cbc -pbkdf2 -iter 100000 \
            -in "$cipher_tmp" -out "$outfile" \
            -pass fd:3 3<<<"$password" ) 2> "$SILENT_LOG"
        local drc=$?
        rm -f "$cipher_tmp"
        unregister_sensitive_tmp "$cipher_tmp"
        chmod 600 "$outfile" 2> "$SILENT_LOG" || true
        [[ $drc -eq 0 ]] && return 0 || return 2

    elif [[ "$_magic8" == "Salted__" ]]; then
        # === v1 legacy path: нет MAC, decrypt напрямую ===
        ( umask 077 && openssl enc -d -aes-256-cbc -pbkdf2 -iter 100000 \
            -in "$infile" -out "$outfile" \
            -pass fd:3 3<<<"$password" ) 2> "$SILENT_LOG"
        local drc=$?
        chmod 600 "$outfile" 2> "$SILENT_LOG" || true
        [[ $drc -eq 0 ]] && return 0 || return 2
    fi
    return 1   # unknown format
}

# =============================================================================
# _run_with_timeout: запускает команду с hard-limit таймаутом + понятным логом
# =============================================================================
# Защищает cron от вечно висящего pg_dump/tar/openssl при stuck-БД, медленном
# диске, или сетевом hang на docker exec. Без таймаута процесс висит часами,
# никто не узнаёт пока админ руками не убьёт.
#
# Аргументы:
#   $1 — таймаут в секундах. 0 → запуск БЕЗ таймаута (для очень больших БД).
#   $2 — короткий label для логов ("pg_dump", "tar-archive", "encrypt").
#   $3+ — команда + её аргументы.
#
# Return:
#   exit code команды напрямую;
#   124 — таймаут (от GNU coreutils `timeout`), мы логируем как ERROR + TG.
#
# NB: не работает для pipe-цепочек (timeout даёт по SIGTERM только первому
# процессу). Для pipe pg_dump|gzip используем отдельный subshell-wrapper
# (см. _run_pipe_with_timeout ниже).
# =============================================================================
_run_with_timeout() {
    local _timeout="$1"
    local _label="$2"
    shift 2

    # 0 или пусто → без timeout (для очень больших БД / power-users).
    if [[ -z "$_timeout" || "$_timeout" == "0" ]]; then
        debug_log "TIMEOUT" "$_label: no timeout (disabled by config)"
        "$@"
        return $?
    fi

    # GNU timeout есть везде где есть coreutils (Debian, Ubuntu, CentOS).
    # На BSD/macOS он может отсутствовать — fallback запускаем без timeout.
    if ! command -v timeout > "$SILENT_LOG" 2>&1; then
        debug_log "TIMEOUT" "$_label: 'timeout' not found, running without limit"
        "$@"
        return $?
    fi

    debug_log "TIMEOUT" "$_label: running with ${_timeout}s limit: $*"
    # --kill-after 30: если SIGTERM не убил процесс за 30 сек — SIGKILL.
    # Защищает от zombie процессов которые игнорируют TERM.
    timeout --kill-after=30 "$_timeout" "$@"
    local _rc=$?
    if [[ $_rc -eq 124 || $_rc -eq 137 ]]; then
        # 124 — SIGTERM от timeout, 137 — SIGKILL (через --kill-after).
        print_message "ERROR" "$_label: операция прервана по таймауту (${_timeout}с)" >&2
        log_message "ERROR" "$_label TIMEOUT (limit=${_timeout}s, rc=$_rc): $*"
        debug_log "TIMEOUT" "$_label HARD-KILLED at ${_timeout}s"
    fi
    return $_rc
}

# Pipe-вариант: для конструкций вроде `pg_dump | gzip > file`.
# Запускает всё через `timeout bash -c '...'` потому что обычный timeout
# не передаёт SIGTERM компонентам pipe.
# Использует переменные через -- exporting:
#   _run_pipe_with_timeout 1800 "pg_dump+gzip" \
#       'docker exec "$1" pg_dump -U "$2" "$3" | gzip > "$4"' \
#       "$DB_CONTAINER" "$DB_USER" "$DB_NAME" "$OUT_FILE"
# Внутри bash -c доступен "$1", "$2", ... — обычная positional передача.
# Return: exit code последней команды pipe (через `set -o pipefail`).
_run_pipe_with_timeout() {
    local _timeout="$1"
    local _label="$2"
    local _pipe_cmd="$3"
    shift 3

    if [[ -z "$_timeout" || "$_timeout" == "0" ]]; then
        debug_log "TIMEOUT" "$_label: no timeout (disabled by config)"
        bash -c "set -o pipefail; $_pipe_cmd" _ "$@"
        return $?
    fi
    if ! command -v timeout > "$SILENT_LOG" 2>&1; then
        bash -c "set -o pipefail; $_pipe_cmd" _ "$@"
        return $?
    fi

    debug_log "TIMEOUT" "$_label (pipe): running with ${_timeout}s limit"
    timeout --kill-after=30 "$_timeout" bash -c "set -o pipefail; $_pipe_cmd" _ "$@"
    local _rc=$?
    if [[ $_rc -eq 124 || $_rc -eq 137 ]]; then
        print_message "ERROR" "$_label: операция прервана по таймауту (${_timeout}с)" >&2
        log_message "ERROR" "$_label TIMEOUT (limit=${_timeout}s, rc=$_rc, pipe)"
        debug_log "TIMEOUT" "$_label HARD-KILLED at ${_timeout}s (pipe)"
    fi
    return $_rc
}

# =============================================================================
# v1 → v2 envelope migration (для users которые обновились с pre-HMAC версии)
# =============================================================================
# v1 = openssl enc output без HMAC (magic "Salted__")
# v2 = LAZ2 + ciphertext + HMAC-SHA256 (encrypt-then-MAC, auth)
#
# Конверсия: decrypt v1 → re-encrypt v2 → atomic rename → удалить v1.
# Гарантия rollback: v1 файл удаляется ТОЛЬКО после успешного v2 verify.
# =============================================================================

# Сканирует BACKUP_DIR и возвращает (через stdout, по одному файлу на строку)
# полный путь ко всем v1-encrypted backup'ам (`Salted__` magic).
# Skip'ает: v2 (LAZ2), unencrypted (.tar.gz без .enc), unknown.
_detect_v1_backups() {
    local _dir="${1:-$BACKUP_DIR}"
    [[ ! -d "$_dir" ]] && return 0
    local _file _magic4 _magic8
    while IFS= read -r -d '' _file; do
        [[ ! -f "$_file" ]] && continue
        _magic4=$(head -c 4 "$_file" 2>/dev/null)
        [[ "$_magic4" == "LAZ2" ]] && continue   # уже v2
        _magic8=$(head -c 8 "$_file" 2>/dev/null)
        [[ "$_magic8" == "Salted__" ]] && echo "$_file"
    done < <(find "$_dir" -maxdepth 1 -name '*.enc' -type f -print0 2>/dev/null)
}

# Конвертирует один файл v1 → v2. Атомарно: пишет в tmp, verify, replace.
# Аргументы: $1 = path to v1 .enc, $2 = password
# Return: 0 — OK (v1 файл заменён v2), 1 — fail (оригинал не тронут).
_convert_v1_to_v2() {
    local _v1file="$1"
    local _password="$2"
    [[ ! -f "$_v1file" ]] && return 1
    [[ -z "$_password" ]] && {
        debug_log "MIGRATE" "Empty password for $_v1file"
        return 1
    }

    local _plain_tmp _v2_tmp
    _plain_tmp=$(mktemp "${TMPDIR:-/tmp}/lazarus_mig_plain.XXXXXX") || return 1
    register_sensitive_tmp "$_plain_tmp"
    _v2_tmp=$(mktemp "${TMPDIR:-/tmp}/lazarus_mig_v2.XXXXXX") || {
        rm -f "$_plain_tmp"; unregister_sensitive_tmp "$_plain_tmp"
        return 1
    }
    register_sensitive_tmp "$_v2_tmp"

    # Step 1: decrypt v1 → plain
    if ! _hmac_envelope_decrypt "$_v1file" "$_plain_tmp" "$_password"; then
        debug_log "MIGRATE" "decrypt FAIL for $_v1file"
        rm -f "$_plain_tmp" "$_v2_tmp"
        unregister_sensitive_tmp "$_plain_tmp"; unregister_sensitive_tmp "$_v2_tmp"
        return 1
    fi

    # Step 2: encrypt plain → v2
    if ! _hmac_envelope_create "$_plain_tmp" "$_v2_tmp" "$_password"; then
        debug_log "MIGRATE" "encrypt FAIL for $_v1file"
        rm -f "$_plain_tmp" "$_v2_tmp"
        unregister_sensitive_tmp "$_plain_tmp"; unregister_sensitive_tmp "$_v2_tmp"
        return 1
    fi

    # Step 3: verify v2 (MAC pre-check)
    local _verify_fmt
    _verify_fmt=$(_hmac_envelope_verify "$_v2_tmp" "$_password")
    if [[ "$_verify_fmt" != "v2" ]]; then
        debug_log "MIGRATE" "v2 verify FAIL for $_v1file (got format: $_verify_fmt)"
        rm -f "$_plain_tmp" "$_v2_tmp"
        unregister_sensitive_tmp "$_plain_tmp"; unregister_sensitive_tmp "$_v2_tmp"
        return 1
    fi

    # Step 4: atomic replace (v2 → original path)
    # mv в той же ФС атомарен; v1 файл существует до самого конца только на случай
    # если mv упадёт из-за нехватки места.
    if ! mv -f "$_v2_tmp" "$_v1file"; then
        debug_log "MIGRATE" "atomic mv FAIL for $_v1file"
        rm -f "$_plain_tmp" "$_v2_tmp"
        unregister_sensitive_tmp "$_plain_tmp"; unregister_sensitive_tmp "$_v2_tmp"
        return 1
    fi
    chmod 644 "$_v1file" 2> "$SILENT_LOG" || true

    # Step 5: shred plain (содержит расшифрованный SQL/файлы)
    shred -u "$_plain_tmp" 2> "$SILENT_LOG" || rm -f "$_plain_tmp"
    unregister_sensitive_tmp "$_plain_tmp"
    unregister_sensitive_tmp "$_v2_tmp"
    return 0
}

# Sentinel для cron-режима: если есть v1 backup'ы и режим non-interactive,
# создаём файл-маркер, чтобы при следующем интерактивном запуске показать prompt.
_v2_migration_sentinel() {
    local _sentinel="$INSTALL_DIR/.v2_migration_pending"
    local _v1_count
    _v1_count=$(_detect_v1_backups | wc -l)
    if [[ $_v1_count -gt 0 ]]; then
        echo "$_v1_count" > "$_sentinel" 2> "$SILENT_LOG" || true
        debug_log "MIGRATE" "Sentinel created: $_v1_count v1 backup(s) pending migration"
        log_message "WARN" "Найдено $_v1_count backup'ов в формате v1 (без HMAC). Запустите 'lazarus migrate-v2' для конверсии."
    else
        [[ -f "$_sentinel" ]] && rm -f "$_sentinel"
    fi
}

# Главная функция миграции — interactive prompt + batch convert.
# Возвращает 0 если всё OK или нет v1 файлов, 1 при ошибке любой конверсии.
migrate_v1_backups() {
    local _v1_files=()
    while IFS= read -r f; do _v1_files+=("$f"); done < <(_detect_v1_backups)
    local _v1_count=${#_v1_files[@]}

    if [[ $_v1_count -eq 0 ]]; then
        print_message "INFO" "Нет v1 backup'ов для конверсии."
        rm -f "$INSTALL_DIR/.v2_migration_pending"
        return 0
    fi

    if [[ -z "$BACKUP_PASSWORD" ]]; then
        print_message "ERROR" "BACKUP_PASSWORD не задан — миграция невозможна (нужен пароль от старых архивов)."
        return 1
    fi

    echo ""
    echo -e "${YELLOW}═══════════════════════════════════════════════════${RESET}"
    echo -e "${YELLOW}  МИГРАЦИЯ v1 → v2 envelope (добавление HMAC)${RESET}"
    echo -e "${YELLOW}═══════════════════════════════════════════════════${RESET}"
    echo ""
    echo -e "Найдено ${BOLD}${_v1_count}${RESET} backup'ов в формате v1 (без HMAC integrity):"
    for f in "${_v1_files[@]:0:5}"; do
        local _sz; _sz=$(stat -c%s "$f" 2> "$SILENT_LOG" | numfmt --to=iec 2> "$SILENT_LOG" || echo "?")
        echo "  • $(basename "$f") (${_sz})"
    done
    [[ $_v1_count -gt 5 ]] && echo "  ... и ещё $((_v1_count - 5))"
    echo ""
    echo "v2 envelope добавляет HMAC-SHA256 проверку целостности (защита от targeted"
    echo "ciphertext-подмены) и быструю проверку пароля ДО decrypt (gadget protection)."
    echo ""
    echo "Конверсия: decrypt → re-encrypt → atomic rename. Безопасна, оригинал"
    echo "удаляется ТОЛЬКО после успешной верификации v2."
    echo ""

    # Non-interactive (cron, no auto-yes) — не спрашиваем, только sentinel.
    # Если передан --yes (`_MIGRATE_AUTO_YES=true`) — продолжаем БЕЗ prompt.
    if [[ "$IS_INTERACTIVE" != "true" && "${_MIGRATE_AUTO_YES:-false}" != "true" ]]; then
        _v2_migration_sentinel
        print_message "WARN" "Non-interactive mode — миграция отложена. Запустите 'lazarus migrate-v2 --yes' для автоматической конверсии."
        return 0
    fi

    if [[ "${_MIGRATE_AUTO_YES:-false}" == "true" ]]; then
        print_message "INFO" "Auto-yes — пропускаем prompt."
    else
        read -erp "Конвертировать в v2? [Y/n]: " _ans
        if [[ "$_ans" =~ ^[Nn]$ ]]; then
            print_message "INFO" "Миграция отменена. Sentinel остаётся — спросим в следующий раз."
            _v2_migration_sentinel
            return 0
        fi
    fi

    echo ""
    local _ok=0 _fail=0 _i=0
    for f in "${_v1_files[@]}"; do
        _i=$((_i + 1))
        local _base; _base=$(basename "$f")
        printf "[%d/%d] %s ... " "$_i" "$_v1_count" "$_base"
        if _convert_v1_to_v2 "$f" "$BACKUP_PASSWORD"; then
            echo -e "${GREEN}OK${RESET}"
            _ok=$((_ok + 1))
            log_message "INFO" "Migrated v1→v2: $_base"
        else
            echo -e "${RED}FAIL${RESET}"
            _fail=$((_fail + 1))
            log_message "ERROR" "Migration FAIL v1→v2: $_base"
        fi
    done

    echo ""
    echo -e "${GREEN}Успешно конвертировано: $_ok${RESET}"
    [[ $_fail -gt 0 ]] && echo -e "${RED}Ошибок: $_fail${RESET}"

    if [[ $_fail -eq 0 ]]; then
        rm -f "$INSTALL_DIR/.v2_migration_pending"
        return 0
    else
        _v2_migration_sentinel  # обновить counter
        return 1
    fi
}

escape_markdown_v2() {
    echo "$1" | sed -e 's/\\/\\\\/g' -e 's/_/\\_/g' -e 's/\[/\\[/g' -e 's/\]/\\]/g' \
        -e 's/(/\\(/g' -e 's/)/\\)/g' -e 's/~/\~/g' -e 's/`/\\`/g' -e 's/>/\\>/g' \
        -e 's/#/\\#/g' -e 's/+/\\+/g' -e 's/-/\\-/g' -e 's/=/\\=/g' -e 's/|/\\|/g' \
        -e 's/{/\\{/g' -e 's/}/\\}/g' -e 's/\./\\./g' -e 's/!/\\!/g'
}

send_telegram_notification() {
    # Backward-compat wrapper: print_message ERROR → автоматически вызывает это.
    # Переключаемся на новый красивый alert через send_telegram_alert.
    # NB: send_telegram_alert определена ниже по тексту — на этом этапе bash
    # ещё не parse'ил её body, но на момент вызова функция в global scope
    # будет доступна (определения функций в bash lazy-resolve'ятся при вызове).
    local msg="$1"
    debug_log "TG" "=== send_telegram_notification ==="
    debug_log "TG" "SEND_TO_TELEGRAM=$SEND_TO_TELEGRAM"
    [[ "$SEND_TO_TELEGRAM" == "true" && -n "$BOT_TOKEN" && -n "$CHAT_ID" ]] || {
        debug_log "TG" "Notifications disabled or credentials missing"
        return 0
    }
    if ! command -v curl > "$SILENT_LOG" 2>&1; then
        debug_log "TG" "curl not available, skipping notification"
        return 0
    fi
    # Используем новый формат — title="Lazarus Error", body=msg.
    # send_telegram_alert сама делает escape и форматирование.
    send_telegram_alert "ERROR" "Lazarus" "$msg" ""
}

print_message() {
    local type="$1"; local message="$2"; local color_code="$RESET"
    case "$type" in
        "INFO") color_code="$GRAY" ;;
        "SUCCESS") color_code="$GREEN" ;;
        "WARN") color_code="$YELLOW" ;;
        "ERROR") color_code="$RED" ;;
        "ACTION") color_code="$CYAN" ;;
    esac
    echo -e "${color_code}[$type]${RESET} $message"

    if [[ "$type" == "ERROR" ]]; then
        send_telegram_notification "$message"
    fi
}

log_message() {
    # Level, Message
    local level="$1"; local message="$2"
    # Ensure log dir exists and file is writable
    local logdir
    logdir=$(dirname "$LOG_FILE")
    if [[ ! -d "$logdir" ]]; then mkdir -p "$logdir" 2> "$SILENT_LOG" || true; fi
    if [[ ! -f "$LOG_FILE" ]]; then touch "$LOG_FILE" 2> "$SILENT_LOG" || true; fi
    local ts
    ts=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$ts] [$level] $message" >> "$LOG_FILE" 2> "$SILENT_LOG" || true
}

rotate_internal_log() {
    # Rotate log if > 10MB
    local MAX_LOG_SIZE=$((10 * 1024 * 1024))
    if [[ -f "$LOG_FILE" ]]; then
        local size
        size=$(stat -c%s "$LOG_FILE" 2> "$SILENT_LOG" || echo 0)
        if [[ "$size" -gt "$MAX_LOG_SIZE" ]]; then
            mv "$LOG_FILE" "${LOG_FILE}.old"
            echo "Log rotated on $(date)" > "$LOG_FILE"
        fi
    fi
}

# --- БЛОКИРОВКА ОТ ПАРАЛЛЕЛЬНОГО ЗАПУСКА ---

acquire_lock() {
    # Пытаемся получить эксклюзивную блокировку
    # Используется для предотвращения параллельного запуска из cron
    # Возвращает 0 если блокировка получена, 1 если занято
    debug_log "LOCK" "=== acquire_lock ==="
    debug_log "LOCK" "Lock file: $LOCK_FILE"
    
    # Создаём директорию для lock-файла если не существует
    local lock_dir=$(dirname "$LOCK_FILE")
    if [[ ! -d "$lock_dir" ]]; then
        debug_log "LOCK" "Creating lock directory: $lock_dir"
        mkdir -p "$lock_dir" 2> "$SILENT_LOG" || true
    fi
    
    # Открываем файл на дескриптор LOCK_FD
    debug_log "LOCK" "Opening lock file on FD $LOCK_FD"
    eval "exec $LOCK_FD>\"$LOCK_FILE\""
    
    # Пытаемся получить неблокирующую эксклюзивную блокировку
    debug_log "LOCK" "Attempting flock..."
    if ! flock -n "$LOCK_FD" 2> "$SILENT_LOG"; then
        debug_log "LOCK" "FAILED - lock already held by another process"
        return 1  # Блокировка уже занята другим процессом
    fi
    
    # Записываем PID в lock-файл для отладки
    echo "$$" >&$LOCK_FD
    debug_log "LOCK" "Lock acquired, PID=$$ written to lock file"
    
    return 0
}

release_lock() {
    # Освобождаем блокировку
    debug_log "LOCK" "=== release_lock ==="
    debug_log "LOCK" "Releasing FD $LOCK_FD"
    flock -u "$LOCK_FD" 2> "$SILENT_LOG" || true
    eval "exec $LOCK_FD>&-" 2> "$SILENT_LOG" || true
    rm -f "$LOCK_FILE" 2> "$SILENT_LOG" || true
    debug_log "LOCK" "Lock released and file removed"
}

check_lock_owner() {
    # Возвращает PID процесса, владеющего блокировкой
    debug_log "LOCK" "Checking lock owner..."
    if [[ -f "$LOCK_FILE" ]]; then
        local owner
        owner=$(cat "$LOCK_FILE" 2> "$SILENT_LOG" || echo "unknown")
        debug_log "LOCK" "Lock owner PID: $owner"
        echo "$owner"
    else
        debug_log "LOCK" "No lock file found"
        echo "none"
    fi
}

check_dependencies() {
    # Required at startup. Without these the script cannot work at all.
    local required=("tar" "gzip" "openssl" "docker" "find" "du" "date")
    # Optional: needed only for specific features. Missing -> warn, do not exit.
    #   rsync -> needed only for rsync-mode restore (folder sync).
    local optional=("rsync")
    local missing=()
    local missing_optional=()

    # Check for curl OR wget (required for self-update / network ops)
    if ! command -v curl > "$SILENT_LOG" 2>&1 && ! command -v wget > "$SILENT_LOG" 2>&1; then
        missing+=("curl (or wget)")
    fi

    for cmd in "${required[@]}"; do
        if ! command -v "$cmd" > "$SILENT_LOG" 2>&1; then
            missing+=("$cmd")
        fi
    done

    for cmd in "${optional[@]}"; do
        if ! command -v "$cmd" > "$SILENT_LOG" 2>&1; then
            missing_optional+=("$cmd")
        fi
    done

    # Check for docker compose (v2)
    if command -v docker > "$SILENT_LOG" 2>&1; then
        if ! docker compose version > "$SILENT_LOG" 2>&1; then
             echo -e "${RED}[ERROR]${RESET} 'docker compose' plugin is required but not found."
             echo -e "${CYAN}[ACTION]${RESET} Please install docker-compose-plugin (v2)."
             exit 1
        fi
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${RED}[ERROR]${RESET} Missing dependencies: ${missing[*]}"
        echo -e "${CYAN}[ACTION]${RESET} Please install them (e.g., apt install ${missing[*]})"
        exit 1
    fi

    if [[ ${#missing_optional[@]} -gt 0 ]]; then
        echo -e "${YELLOW}[WARN]${RESET} Optional tools not found: ${missing_optional[*]}"
        echo -e "${CYAN}[HINT]${RESET} Install only if you need rsync-mode restore: apt install ${missing_optional[*]}"
    fi
}

# --- СТАТИСТИКА БЭКАПОВ ---

get_backup_stats() {
    # Подсчёт файлов по категориям
    local n_full=$(find "$BACKUP_DIR" -maxdepth 1 -type f \( -name "lazarus_full_*.tar.gz" -o -name "lazarus_full_*.tar.gz.enc" \) 2> "$SILENT_LOG" | wc -l)
    local n_db=$(find "$BACKUP_DIR" -maxdepth 1 -type f \( -name "lazarus_db_*.tar.gz" -o -name "lazarus_db_*.tar.gz.enc" \) 2> "$SILENT_LOG" | wc -l)
    local n_files=$(find "$BACKUP_DIR" -maxdepth 1 -type f \( -name "lazarus_files_*.tar.gz" -o -name "lazarus_files_*.tar.gz.enc" \) 2> "$SILENT_LOG" | wc -l)
    
    # Общий размер папки бэкапов
    local total_size="0B"
    if [[ -d "$BACKUP_DIR" ]]; then
        total_size=$(du -sh "$BACKUP_DIR" 2> "$SILENT_LOG" | awk '{print $1}')
    fi
    
    # Последний бэкап (любой тип)
    local last_backup=""
    local last_backup_ago=""
    local latest_file=$(find "$BACKUP_DIR" -maxdepth 1 -type f \( -name "lazarus_*.tar.gz" -o -name "lazarus_*.tar.gz.enc" \) -printf '%T@ %p\n' 2> "$SILENT_LOG" | sort -rn | head -1 | awk '{print $2}')
    
    if [[ -n "$latest_file" && -f "$latest_file" ]]; then
        local filename=$(basename "$latest_file")
        # Извлекаем дату из имени файла: lazarus_type_YYYY-MM-DD_HH_MM_SS.tar.gz
        if [[ $filename =~ _([0-9]{4})-([0-9]{2})-([0-9]{2})_([0-9]{2})_([0-9]{2}) ]]; then
            local file_date="${BASH_REMATCH[3]}.${BASH_REMATCH[2]} ${BASH_REMATCH[4]}:${BASH_REMATCH[5]}"
            last_backup="$file_date"
            
            # Вычисляем "сколько времени назад"
            local file_ts=$(stat -c %Y "$latest_file" 2> "$SILENT_LOG")
            local now_ts=$(date +%s)
            if [[ -n "$file_ts" ]]; then
                local diff_sec=$((now_ts - file_ts))
                if [[ $diff_sec -lt 60 ]]; then
                    last_backup_ago="только что"
                elif [[ $diff_sec -lt 3600 ]]; then
                    local mins=$((diff_sec / 60))
                    last_backup_ago="${mins} мин назад"
                elif [[ $diff_sec -lt 86400 ]]; then
                    local hours=$((diff_sec / 3600))
                    last_backup_ago="${hours} ч назад"
                else
                    local days=$((diff_sec / 86400))
                    last_backup_ago="${days} дн назад"
                fi
            fi
        fi
    fi
    
    # Возвращаем через глобальные переменные (bash не умеет возвращать несколько значений)
    STATS_FULL="$n_full"
    STATS_DB="$n_db"
    STATS_FILES="$n_files"
    STATS_SIZE="$total_size"
    STATS_LAST="$last_backup"
    STATS_LAST_AGO="$last_backup_ago"
}

# --- СИСТЕМА ОБНОВЛЕНИЯ ---

check_for_updates() {
    clear_screen
    echo -e "${CYAN}Проверка обновлений...${RESET}"
    
    local MAX_RETRIES=2
    local TIMEOUT=15
    local CACHE_BUSTER="?t=$(date +%s)"
    
    # Собираем версии со всех источников и берём максимальную
    local BEST_VERSION=""
    local BEST_CONTENT=""
    local BEST_URL=""
    
    for url in "${REMOTE_URLS[@]}"; do
        local FETCH_URL="${url}${CACHE_BUSTER}"
        echo -e "${GRAY}Проверяю: ${url}...${RESET}"
        
        local REMOTE_CONTENT=""
        for attempt in $(seq 1 $MAX_RETRIES); do
            if command -v curl > "$SILENT_LOG" 2>&1; then
                REMOTE_CONTENT=$(curl $CURL_SILENT -L --connect-timeout $TIMEOUT --max-time 30 "$FETCH_URL" 2> "$SILENT_LOG")
            elif command -v wget > "$SILENT_LOG" 2>&1; then
                REMOTE_CONTENT=$(wget $WGET_SILENT -O- --timeout=$TIMEOUT "$FETCH_URL" 2> "$SILENT_LOG")
            else
                print_message "ERROR" "Нет curl или wget для проверки обновлений."
                read -erp "Enter..." dummy; return
            fi
            
            # Проверяем что получили валидный скрипт
            if [[ -n "$REMOTE_CONTENT" ]] && echo "$REMOTE_CONTENT" | head -1 | grep -q "^#!/bin/bash"; then
                break
            fi
            REMOTE_CONTENT=""
            [[ $attempt -lt $MAX_RETRIES ]] && sleep 1
        done
        
        if [[ -z "$REMOTE_CONTENT" ]]; then
            echo -e "${YELLOW}  ✗ Недоступен${RESET}"
            continue
        fi
        
        local THIS_VERSION=$(echo "$REMOTE_CONTENT" | grep '^VERSION=' | head -1 | cut -d'"' -f2)
        if [[ -z "$THIS_VERSION" ]]; then
            echo -e "${YELLOW}  ✗ VERSION не найден${RESET}"
            continue
        fi
        
        echo -e "${GREEN}  ✓ v${THIS_VERSION}${RESET}"
        
        # Сравниваем с лучшей найденной версией
        if [[ -z "$BEST_VERSION" ]]; then
            BEST_VERSION="$THIS_VERSION"
            BEST_CONTENT="$REMOTE_CONTENT"
            BEST_URL="$url"
        else
            # Берём максимальную версию
            local V_BEST=$(echo "$BEST_VERSION" | cut -d'-' -f1)
            local V_THIS=$(echo "$THIS_VERSION" | cut -d'-' -f1)
            if [[ "$(printf '%s\n' "$V_BEST" "$V_THIS" | sort -V | tail -n1)" == "$V_THIS" && "$V_THIS" != "$V_BEST" ]]; then
                BEST_VERSION="$THIS_VERSION"
                BEST_CONTENT="$REMOTE_CONTENT"
                BEST_URL="$url"
            fi
        fi
    done
    
    if [[ -z "$BEST_VERSION" ]]; then
        print_message "ERROR" "Не удалось получить информацию о версии ни с одного источника."
        read -erp "Enter..." dummy; return
    fi
    
    echo ""
    echo -e "${GREEN}Лучший источник: ${BEST_URL}${RESET}"
    echo ""

    local V_LOCAL=$(echo "$VERSION" | cut -d'-' -f1)
    local V_REMOTE=$(echo "$BEST_VERSION" | cut -d'-' -f1)
    local SUFFIX_LOCAL=$(echo "$VERSION" | grep -oE '\-.*$' || echo "")
    local SUFFIX_REMOTE=$(echo "$BEST_VERSION" | grep -oE '\-.*$' || echo "")

    echo -e "Текущая версия: ${BOLD}$VERSION${RESET}"
    echo -e "Актуальная версия: ${BOLD}$BEST_VERSION${RESET}"
    echo ""

    if [[ "$VERSION" == "$BEST_VERSION" ]]; then
        print_message "SUCCESS" "У вас установлена последняя версия."
        read -erp "Enter..." dummy
        return
    fi

    local IS_UPGRADE=false
    # Сначала сравниваем основную версию (X.Y.Z)
    if [[ "$(printf '%s\n' "$V_LOCAL" "$V_REMOTE" | sort -V | head -n1)" == "$V_LOCAL" && "$V_LOCAL" != "$V_REMOTE" ]]; then
        IS_UPGRADE=true
    # Если основные версии равны, но есть разница в суффиксах — это тоже обновление
    elif [[ "$V_LOCAL" == "$V_REMOTE" && "$SUFFIX_LOCAL" != "$SUFFIX_REMOTE" ]]; then
        IS_UPGRADE=true
    fi

    if [[ "$IS_UPGRADE" == "true" ]]; then
        print_message "WARN" "Доступно обновление!"
        read -erp "Обновить скрипт сейчас? (y/N): " choice
        if [[ "$choice" =~ ^[Yy]$ ]]; then
            perform_update "$BEST_CONTENT"
        else
            print_message "INFO" "Обновление отменено."
            read -erp "Enter..." dummy
        fi
    else
        echo -e "${YELLOW}⚠️ Внимание: Версия на сервере старее или такая же.${RESET}"
        read -erp "Все равно загрузить версию с сервера? (y/N): " choice
        if [[ "$choice" =~ ^[Yy]$ ]]; then
            perform_update "$BEST_CONTENT"
        else
            print_message "INFO" "Отменено."
            read -erp "Enter..." dummy
        fi
    fi
}

# Тихая проверка обновлений при старте (не блокирует)
# Результат сохраняется в UPDATE_AVAILABLE и UPDATE_REMOTE_VERSION
# Проверяет все источники и берёт максимальную версию
check_updates_silent() {
    UPDATE_AVAILABLE=""
    UPDATE_REMOTE_VERSION=""
    
    local TIMEOUT=5
    local CACHE_BUSTER="?t=$(date +%s)"
    local BEST_VERSION=""
    
    # Проверяем все источники и берём максимальную версию
    for url in "${REMOTE_URLS[@]}"; do
        local FETCH_URL="${url}${CACHE_BUSTER}"
        local REMOTE_CONTENT=""
        
        if command -v curl &>/dev/null; then
            REMOTE_CONTENT=$(curl -sL --connect-timeout $TIMEOUT --max-time 10 "$FETCH_URL" 2>/dev/null | head -20)
        elif command -v wget &>/dev/null; then
            REMOTE_CONTENT=$(wget -qO- --timeout=$TIMEOUT "$FETCH_URL" 2>/dev/null | head -20)
        else
            continue
        fi
        
        # Проверяем что получили валидный скрипт
        if [[ -n "$REMOTE_CONTENT" ]] && echo "$REMOTE_CONTENT" | head -1 | grep -q "^#!/bin/bash"; then
            local THIS_VERSION=$(echo "$REMOTE_CONTENT" | grep '^VERSION=' | head -1 | cut -d'"' -f2)
            if [[ -n "$THIS_VERSION" ]]; then
                # Сравниваем с лучшей найденной версией
                if [[ -z "$BEST_VERSION" ]]; then
                    BEST_VERSION="$THIS_VERSION"
                else
                    local V_BEST=$(echo "$BEST_VERSION" | cut -d'-' -f1)
                    local V_THIS=$(echo "$THIS_VERSION" | cut -d'-' -f1)
                    if [[ "$(printf '%s\n' "$V_BEST" "$V_THIS" | sort -V | tail -n1)" == "$V_THIS" && "$V_THIS" != "$V_BEST" ]]; then
                        BEST_VERSION="$THIS_VERSION"
                    fi
                fi
            fi
        fi
    done
    
    [[ -z "$BEST_VERSION" ]] && return 1
    
    # Сравниваем версии
    local V_LOCAL=$(echo "$VERSION" | cut -d'-' -f1)
    local V_REMOTE=$(echo "$BEST_VERSION" | cut -d'-' -f1)
    local SUFFIX_LOCAL=$(echo "$VERSION" | grep -oE '\-.*$' || echo "")
    local SUFFIX_REMOTE=$(echo "$BEST_VERSION" | grep -oE '\-.*$' || echo "")
    
    # Проверяем есть ли обновление
    local IS_UPGRADE=false
    if [[ "$(printf '%s\n' "$V_LOCAL" "$V_REMOTE" | sort -V | head -n1)" == "$V_LOCAL" && "$V_LOCAL" != "$V_REMOTE" ]]; then
        IS_UPGRADE=true
    elif [[ "$V_LOCAL" == "$V_REMOTE" && "$SUFFIX_LOCAL" != "$SUFFIX_REMOTE" && -n "$SUFFIX_LOCAL" && -z "$SUFFIX_REMOTE" ]]; then
        # dev -> stable это тоже обновление
        IS_UPGRADE=true
    fi
    
    if [[ "$IS_UPGRADE" == "true" ]]; then
        UPDATE_AVAILABLE="true"
        UPDATE_REMOTE_VERSION="$BEST_VERSION"
    fi
    
    return 0
}

perform_update() {
    local CONTENT="$1"
    local SCRIPT_PATH="$INSTALL_DIR/$SCRIPT_NAME"
    local BACKUP_PATH="$INSTALL_DIR/${SCRIPT_NAME}.backup"
    
    # Проверяем валидность содержимого
    if ! echo "$CONTENT" | head -n 1 | grep -q "^#!/bin/bash"; then
        print_message "ERROR" "Ошибка: загруженный файл не является bash-скриптом."
        read -erp "Enter..." dummy
        return 1
    fi
    
    # Проверяем минимальный размер (защита от обрезанных файлов)
    local CONTENT_SIZE=${#CONTENT}
    if [[ $CONTENT_SIZE -lt 10000 ]]; then
        print_message "ERROR" "Ошибка: загруженный файл слишком мал ($CONTENT_SIZE байт)."
        print_message "ERROR" "Возможно, файл был повреждён при загрузке."
        read -erp "Enter..." dummy
        return 1
    fi
    
    # Создаём резервную копию текущей версии
    if [[ -f "$SCRIPT_PATH" ]]; then
        cp "$SCRIPT_PATH" "$BACKUP_PATH"
        print_message "INFO" "Создана резервная копия: ${SCRIPT_NAME}.backup"
    fi
    
    # Записываем новую версию
    if echo "$CONTENT" > "$SCRIPT_PATH"; then
        chmod +x "$SCRIPT_PATH"
        print_message "SUCCESS" "Обновление завершено!"
        log_message "SUCCESS" "Script updated to new version"
        echo ""
        echo -e "${CYAN}Перезапуск скрипта...${RESET}"
        sleep 1
        exec "$SCRIPT_PATH"
    else
        print_message "ERROR" "Не удалось записать файл обновления!"
        # Восстанавливаем из бэкапа
        if [[ -f "$BACKUP_PATH" ]]; then
            mv "$BACKUP_PATH" "$SCRIPT_PATH"
            print_message "WARN" "Восстановлена предыдущая версия из бэкапа."
        fi
        read -erp "Enter..." dummy
        return 1
    fi
}

# --- СИСТЕМА УСТАНОВКИ ---

install_script() {
    if [[ "$EUID" -ne 0 ]]; then
        echo -e "${RED}Ошибка: Запустите скрипт с правами root (sudo)!${RESET}"
        exit 1
    fi

    local CURRENT_SCRIPT_PATH=$(realpath "$0" 2> "$SILENT_LOG")
    local INSTALLED_SCRIPT_PATH="$INSTALL_DIR/$SCRIPT_NAME"

    # === CLEANUP: удаляем legacy `lazarus-migrator` плагин ===
    # Bedolaga→RWP-Shop миграция убрана из проекта (deprecated). Если у пользователя
    # остался файл плагина от старой версии — чистим, чтобы не было путаницы.
    if [[ -f "$INSTALL_DIR/lazarus-migrator" ]]; then
        rm -f "$INSTALL_DIR/lazarus-migrator"
        echo -e "${GRAY}Cleanup: удалён устаревший плагин $INSTALL_DIR/lazarus-migrator${RESET}"
    fi

    # === MIGRATION: старая установка с именем "lazarus" → "lazarus-backup" ===
    # Раньше SCRIPT_NAME было "lazarus" → файл /opt/lazarus-backup/lazarus.
    # Теперь SCRIPT_NAME="lazarus-backup" для согласованности с именем в репо
    # и raw.githubusercontent URL. CLI symlink остался "lazarus" — пользователь
    # продолжает набирать `lazarus`, cron-задачи через $SYMLINK_PATH работают.
    local LEGACY_PATH="$INSTALL_DIR/lazarus"
    if [[ -f "$LEGACY_PATH" && ! -L "$LEGACY_PATH" && "$LEGACY_PATH" != "$INSTALLED_SCRIPT_PATH" ]]; then
        if [[ -f "$INSTALLED_SCRIPT_PATH" ]]; then
            # Уже есть новый файл — удаляем legacy
            rm -f "$LEGACY_PATH"
            echo -e "${GRAY}Migration: удалена старая копия $LEGACY_PATH${RESET}"
        else
            # Переименовываем legacy → новое имя
            mv "$LEGACY_PATH" "$INSTALLED_SCRIPT_PATH"
            chmod +x "$INSTALLED_SCRIPT_PATH" 2> "$SILENT_LOG" || true
            echo -e "${GREEN}Migration: $LEGACY_PATH → $INSTALLED_SCRIPT_PATH${RESET}"
        fi
        # Пересоздаём symlink на новый target
        if [[ -L "$SYMLINK_PATH" || -f "$SYMLINK_PATH" ]]; then rm -f "$SYMLINK_PATH"; fi
        ln -s "$INSTALLED_SCRIPT_PATH" "$SYMLINK_PATH"
        # CURRENT_SCRIPT_PATH мог указывать на legacy — обновим
        if [[ "$CURRENT_SCRIPT_PATH" == "$LEGACY_PATH" ]]; then
            CURRENT_SCRIPT_PATH="$INSTALLED_SCRIPT_PATH"
        fi
    fi

    if [[ "$CURRENT_SCRIPT_PATH" == "$INSTALLED_SCRIPT_PATH" ]]; then
        return
    fi

    echo -e "${CYAN}--- УСТАНОВКА LAZARUS BACKUP ---${RESET}"
    if [[ ! -d "$INSTALL_DIR" ]]; then
        mkdir -p "$INSTALL_DIR"
        print_message "SUCCESS" "Создана папка: $INSTALL_DIR"
    fi

    local DOWNLOAD_SUCCESS=false
    local TEMP_FILE="/tmp/lazarus_install_tmp"

    if [[ -f "$0" && "$0" != "bash" && "$0" != "/dev/fd/"* ]]; then
        cp "$(realpath "$0")" "$INSTALLED_SCRIPT_PATH"
        DOWNLOAD_SUCCESS=true
    else
        print_message "INFO" "Загрузка последней версии..."
        # Добавляем timestamp для обхода кэша GitHub
        local FETCH_URL="${REMOTE_URL}?t=$(date +%s)"
        if command -v curl > "$SILENT_LOG" 2>&1; then
            curl $CURL_SILENT -L --connect-timeout 15 --max-time 60 "$FETCH_URL" -o "$TEMP_FILE"
        elif command -v wget > "$SILENT_LOG" 2>&1; then
            wget $WGET_SILENT -O "$TEMP_FILE" --timeout=15 "$FETCH_URL"
        else
            print_message "ERROR" "Для установки нужен curl или wget!"
            exit 1
        fi

        if [[ -f "$TEMP_FILE" ]]; then
            # Проверяем что это bash-скрипт
            if head -n 1 "$TEMP_FILE" | grep -q "^#!/bin/bash"; then
                # Проверяем минимальный размер
                local FILE_SIZE=$(stat -c%s "$TEMP_FILE" 2> "$SILENT_LOG" || stat -f%z "$TEMP_FILE" 2> "$SILENT_LOG" || echo "0")
                if [[ $FILE_SIZE -lt 10000 ]]; then
                    print_message "ERROR" "Загруженный файл слишком мал ($FILE_SIZE байт)."
                    rm -f "$TEMP_FILE"
                    exit 1
                fi
                mv "$TEMP_FILE" "$INSTALLED_SCRIPT_PATH"
                DOWNLOAD_SUCCESS=true
            else
                print_message "ERROR" "Ошибка загрузки! Сервер вернул неверный файл."
                rm -f "$TEMP_FILE"
                exit 1
            fi
        else
            print_message "ERROR" "Не удалось скачать файл."
            exit 1
        fi
    fi

    if [[ "$DOWNLOAD_SUCCESS" == "true" ]]; then
        chmod +x "$INSTALLED_SCRIPT_PATH"
        if [[ -L "$SYMLINK_PATH" || -f "$SYMLINK_PATH" ]]; then rm -f "$SYMLINK_PATH"; fi
        ln -s "$INSTALLED_SCRIPT_PATH" "$SYMLINK_PATH"
        
        print_message "SUCCESS" "Установка завершена. Запуск..."
        echo ""
        exec "$INSTALLED_SCRIPT_PATH"
        exit 0
    fi
}

# --- ЯДРО ИНТЕЛЛЕКТУАЛЬНОГО ПОИСКА ---

add_candidate() {
    local path="$1"
    local bot="$2"
    [[ -z "$path" ]] && return
    for p in "${FOUND_PATHS[@]}"; do
        [[ "$p" == "$path" ]] && return
    done
    FOUND_PATHS+=("$path")
    FOUND_BOTS+=("$bot")
}

scan_system_for_bot() {
    FOUND_PATH=""; FOUND_BOT=""; FOUND_DB=""
    FOUND_PATHS=(); FOUND_BOTS=()
    debug_log "SCAN" "=== scan_system_for_bot ==="
    local running_containers=$(docker ps --format '{{.Names}}|{{.Image}}')
    debug_log "SCAN" "Running containers: $(echo "$running_containers" | wc -l)"
    
    # Список контейнеров панели управления (ИСКЛЮЧАЕМ из поиска)
    local PANEL_CONTAINERS=(
        "remnawave"              # Основной контейнер панели
        "remnawave-db"           # БД панели
        "remnawave-redis"        # Redis панели
        "remnawave-nginx"        # Nginx панели
        "remnawave-subscription-page"   # Страница подписок панели
        "remnawave-telegram-mini-app"   # Mini App панели
        "certwardenclient"       # Cert Warden
    )
    
    for container in $running_containers; do
        local c_name=$(echo "$container" | cut -d'|' -f1)
        local c_image=$(echo "$container" | cut -d'|' -f2)
        debug_log "SCAN" "Checking: $c_name ($c_image)"
        
        # Проверяем что это не контейнер панели
        local is_panel=false
        for panel_c in "${PANEL_CONTAINERS[@]}"; do
            if [[ "$c_name" == "$panel_c" ]]; then
                is_panel=true
                debug_log "SCAN" "  -> Skip (panel container: $panel_c)"
                break
            fi
        done
        
        # Исключаем контейнеры панели по image
        if [[ "$c_image" == *"remnawave/backend"* ]]; then is_panel=true; debug_log "SCAN" "  -> Skip (remnawave/backend)"; fi
        if [[ "$c_image" == *"remnawave/subscription-page"* ]]; then is_panel=true; debug_log "SCAN" "  -> Skip (subscription-page)"; fi
        if [[ "$c_image" == *"remnawave-telegram-sub-mini-app"* ]]; then is_panel=true; fi
        if [[ "$c_image" == *"certwarden-client"* ]]; then is_panel=true; fi
        if [[ "$c_image" == "nginx"* || "$c_image" == "postgres"* || "$c_image" == "redis"* ]]; then
            # Пропускаем только если имя контейнера содержит "remnawave" БЕЗ "shop"/"bot"
            if [[ "$c_name" == *"remnawave"* && "$c_name" != *"shop"* && "$c_name" != *"bot"* ]]; then
                is_panel=true
                debug_log "SCAN" "  -> Skip (panel infra)"
            fi
        fi
        
        if [[ "$is_panel" == true ]]; then continue; fi

        # Ищем контейнер БОТА по ключевым словам
        for key in "${KEYWORDS[@]}"; do
            if [[ "$c_image" == *"$key"* || "$c_name" == *"$key"* ]]; then
                debug_log "SCAN" "  -> MATCH! keyword=$key"
                local work_dir=$(docker inspect --format '{{ index .Config.Labels "com.docker.compose.project.working_dir" }}' "$c_name")
                debug_log "SCAN" "  -> working_dir=$work_dir"
                if [[ -n "$work_dir" && -d "$work_dir" && "$work_dir" != "/opt" ]]; then
                    add_candidate "$work_dir" "$c_name"
                fi
                break
            fi
        done
    done
    
    if [[ ${#FOUND_PATHS[@]} -gt 0 ]]; then
        FOUND_PATH="${FOUND_PATHS[0]}"
        FOUND_BOT="${FOUND_BOTS[0]}"
    fi
    debug_log "SCAN" "After container scan: FOUND_BOT=$FOUND_BOT, FOUND_PATH=$FOUND_PATH"

    # Если не нашли через контейнеры — ищем по файлам docker-compose
    if [[ -z "$FOUND_PATH" ]]; then
        debug_log "SCAN" "No containers found, searching compose files..."
        local search_dirs=("/opt" "/home" "/root")
        local compose_files=$(find "${search_dirs[@]}" -maxdepth 4 -name "docker-compose.yml" -o -name "compose.yaml" 2> "$SILENT_LOG")
        for file in $compose_files; do
            # Пропускаем compose файлы панели управления
            if grep -q "remnawave/backend" "$file"; then continue; fi
            if grep -q "remnawave/subscription-page" "$file"; then continue; fi
            
            # Ищем по ключевым словам БОТА
            if grep -qE "image:.*($(IFS="|"; echo "${KEYWORDS[*]}"))" "$file" || grep -qE "container_name:.*($(IFS="|"; echo "${KEYWORDS[*]}"))" "$file"; then
                local candidate_path
                candidate_path=$(dirname "$file")
                [[ "$candidate_path" == "/opt" ]] && continue
                # Сначала пытаемся найти container_name
                local candidate_bot
                candidate_bot=$(grep -E "container_name:" "$file" | grep -E "($(IFS="|"; echo "${KEYWORDS[*]}"))" | head -1 | awk '{print $2}' | tr -d '"' | tr -d "'")
                
                # Если container_name не найден, используем docker compose для получения имени контейнера
                # subshell: cd локален и не оставляет побочных эффектов в вызывающем shell
                if [[ -z "$candidate_bot" && -d "$candidate_path" ]]; then
                    candidate_bot=$(
                        cd "$candidate_path" 2> "$SILENT_LOG" || exit 0
                        # Ищем service который использует наш image
                        for key in "${KEYWORDS[@]}"; do
                            local _svc
                            _svc=$(grep -B 2 "image:.*$key" "$file" | grep "^[a-z]" | head -1 | awk '{print $1}' | tr -d ':')
                            if [[ -n "$_svc" ]]; then
                                # Получаем реальное имя контейнера через docker compose
                                local _name
                                _name=$(docker compose ps -a --format '{{.Name}}' "$_svc" 2> "$SILENT_LOG" | head -1)
                                if [[ -n "$_name" ]]; then
                                    echo "$_name"
                                    break
                                fi
                            fi
                        done
                    )
                fi
                add_candidate "$candidate_path" "$candidate_bot"
            fi
        done
    fi

    # Поиск контейнера БД
    # subshell: cd локален, результат передаётся через stdout
    if [[ -n "$FOUND_PATH" ]]; then
        local _found_db
        _found_db=$(
            cd "$FOUND_PATH" 2> "$SILENT_LOG" || exit 0
            local db_services=("db" "postgres" "database" "postgresql")
            for svc in "${db_services[@]}"; do
                local db_c
                db_c=$(docker compose ps -a --format '{{.Name}}' "$svc" 2> "$SILENT_LOG")
                # Исключаем БД панели
                if [[ -n "$db_c" && "$db_c" != "remnawave-db" && "$db_c" != *"remnawave_"* ]]; then
                    echo "$db_c"
                    break
                fi
            done
        )
        [[ -n "$_found_db" ]] && FOUND_DB="$_found_db"
    fi
}

# --- ФУНКЦИИ ВЕРСИИ И ПОИСКА ---

get_raw_bot_version() {
    if [[ -n "$BOT_CONTAINER_NAME" ]] && docker container inspect -f '{{.State.Running}}' "$BOT_CONTAINER_NAME" > /dev/null 2> "$SILENT_LOG"; then
        local full_image=$(docker inspect -f '{{.Config.Image}}' "$BOT_CONTAINER_NAME")
        local ver="${full_image##*:}"
        echo "${ver:-Unknown}"
    else
        echo ""
    fi
}

get_bot_version_display() {
    local ver=$(get_raw_bot_version)
    if [[ -n "$ver" ]]; then echo "$ver"; else echo "N/A"; fi
}

# Получение статуса контейнера бота
get_container_status() {
    if [[ -z "$BOT_CONTAINER_NAME" ]]; then
        echo "N/A"
        return
    fi
    
    local status
    status=$(docker inspect -f '{{.State.Status}}' "$BOT_CONTAINER_NAME" 2> "$SILENT_LOG")
    
    case "$status" in
        "running") echo "Online" ;;
        "exited"|"dead") echo "Offline" ;;
        "paused") echo "Paused" ;;
        "restarting") echo "Restarting" ;;
        *) echo "N/A" ;;
    esac
}

# Автоматическое определение DB volume
get_db_volume_name() {
    debug_log "DB" "=== get_db_volume_name ==="
    debug_log "DB" "DB_CONTAINER_NAME=$DB_CONTAINER_NAME"
    
    if [[ -z "$DB_CONTAINER_NAME" ]]; then
        debug_log "DB" "ERROR: DB_CONTAINER_NAME is empty"
        echo ""
        return 1
    fi
    
    # Извлекаем имя volume из docker inspect
    debug_log "DB" "Trying docker inspect..."
    local volume=$(docker inspect -f '{{range .Mounts}}{{if eq .Type "volume"}}{{.Name}}{{end}}{{end}}' "$DB_CONTAINER_NAME" 2> "$SILENT_LOG")
    
    if [[ -n "$volume" ]]; then
        debug_log "DB" "Volume found via docker inspect: $volume"
        echo "$volume"
        return 0
    fi
    debug_log "DB" "No volume from docker inspect, trying compose fallback"
    
    # Fallback: пытаемся определить из docker-compose.yml
    if [[ -n "$BOT_PATH" && -d "$BOT_PATH" ]]; then
        local compose_file=""
        [[ -f "$BOT_PATH/compose.yaml" ]] && compose_file="$BOT_PATH/compose.yaml"
        [[ -f "$BOT_PATH/docker-compose.yml" ]] && compose_file="$BOT_PATH/docker-compose.yml"
        debug_log "DB" "Compose file: $compose_file"
        
        if [[ -n "$compose_file" ]]; then
            # Ищем volume в секции volumes БД (поддержка обоих путей)
            # Новая документация: /var/lib/postgresql/data
            # Старые установки: /var/lib/postgresql
            local vol=$(grep -A 10 "^\s*$DB_SERVICE_NAME:" "$compose_file" | grep -E "volumes:" -A 5 | grep -oE "[a-zA-Z0-9_-]+:/var/lib/postgresql(/data)?" | cut -d':' -f1 | head -1)
            debug_log "DB" "Parsed volume name from compose: '$vol'"
            if [[ -n "$vol" ]]; then
                # Проверяем есть ли такой volume
                if docker volume inspect "$vol" > /dev/null 2> "$SILENT_LOG"; then
                    debug_log "DB" "Volume exists: $vol"
                    echo "$vol"
                    return 0
                else
                    debug_log "DB" "Volume '$vol' does not exist in docker"
                fi
            fi
        fi
    fi
    
    # Если всё равно не нашли — возвращаем пустую строку
    debug_log "DB" "No volume found, returning empty"
    echo ""
    return 1
}

# Чтение переменных из .env файла бота
# Использование: read_bot_env "POSTGRES_USER" → возвращает значение
read_bot_env() {
    local var_name="$1"
    local env_file=""
    
    if [[ -n "$BOT_PATH" && -d "$BOT_PATH" ]]; then
        [[ -f "$BOT_PATH/.env" ]] && env_file="$BOT_PATH/.env"
    fi
    
    if [[ -z "$env_file" ]]; then
        debug_log "DB" "read_bot_env: no .env file found for '$var_name'"
        echo ""
        return 1
    fi
    
    # Читаем значение переменной из .env (поддержка форматов KEY=value и KEY="value")
    local value=$(grep -E "^${var_name}=" "$env_file" 2>/dev/null | head -1 | cut -d'=' -f2- | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//")
    debug_log "DB" "read_bot_env: $var_name='$value' from $env_file"
    echo "$value"
}

# Получение имени пользователя БД из .env бота или fallback на глобальную настройку
get_db_user() {
    local env_user=$(read_bot_env "POSTGRES_USER")
    if [[ -n "$env_user" ]]; then
        debug_log "DB" "get_db_user: using env POSTGRES_USER=$env_user"
        echo "$env_user"
    else
        debug_log "DB" "get_db_user: using global DB_USER=$DB_USER"
        echo "$DB_USER"
    fi
}

# Получение имени базы данных из .env бота или fallback на postgres
get_db_name() {
    local env_db=$(read_bot_env "POSTGRES_DB")
    if [[ -n "$env_db" ]]; then
        debug_log "DB" "get_db_name: using env POSTGRES_DB=$env_db"
        echo "$env_db"
    else
        debug_log "DB" "get_db_name: using default 'postgres'"
        echo "postgres"
    fi
}

# --- ФУНКЦИЯ ОБНОВЛЕНИЯ БОТА ---

# Извлечение версии из имени файла (rwp_shop-3.23.0-amd64.tar → 3.23.0)
extract_version_from_filename() {
    local filename="$1"
    # Поддержка форматов:
    # - rwp_shop-3.23.0-amd64.tar (новый)
    # - rwp_shop-3.23.0.tar
    # - private-remnawave-telegram-shop-bot-3.21.2-amd64.tar (старый)
    # - telegram-shop-2.0.0.tar
    echo "$filename" | grep -oE '[0-9]+(\.[0-9]+){1,3}' | head -1
}

# Нормализация версии: оставляем только цифры и точки, берём первые 4 числовые
# компоненты (major.minor.patch.build). Защищает от тегов вида "6.3.1.2",
# "6.3.1-rc1", "v6.3.1+build". Build (4-я) используется как tie-breaker.
_normalize_version_parts() {
    local raw="$1"
    # Оставляем только [0-9.] — отрезаем суффиксы вроде -rc1, +build, префикс v
    local clean="${raw//[^0-9.]/}"
    local -a parts
    IFS='.' read -ra parts <<< "$clean"
    # Возвращаем четыре компоненты через пробел; пустые → 0
    printf '%s %s %s %s' \
        "${parts[0]:-0}" \
        "${parts[1]:-0}" \
        "${parts[2]:-0}" \
        "${parts[3]:-0}"
}

# Сравнение версий (возвращает 0 если $1 > $2)
version_gt() {
    local v1="$1" v2="$2"
    local v1_major v1_minor v1_patch v1_build v2_major v2_minor v2_patch v2_build
    read -r v1_major v1_minor v1_patch v1_build <<< "$(_normalize_version_parts "$v1")"
    read -r v2_major v2_minor v2_patch v2_build <<< "$(_normalize_version_parts "$v2")"

    # Приводим к числам (убираем ведущие нули)
    v1_major=$((10#${v1_major:-0})); v1_minor=$((10#${v1_minor:-0})); v1_patch=$((10#${v1_patch:-0})); v1_build=$((10#${v1_build:-0}))
    v2_major=$((10#${v2_major:-0})); v2_minor=$((10#${v2_minor:-0})); v2_patch=$((10#${v2_patch:-0})); v2_build=$((10#${v2_build:-0}))

    if [[ $v1_major -gt $v2_major ]]; then return 0; fi
    if [[ $v1_major -lt $v2_major ]]; then return 1; fi
    if [[ $v1_minor -gt $v2_minor ]]; then return 0; fi
    if [[ $v1_minor -lt $v2_minor ]]; then return 1; fi
    if [[ $v1_patch -gt $v2_patch ]]; then return 0; fi
    if [[ $v1_patch -lt $v2_patch ]]; then return 1; fi
    if [[ $v1_build -gt $v2_build ]]; then return 0; fi
    return 1
}

# Сравнение версий (возвращает 0 если $1 >= $2)
version_gte() {
    local v1="$1" v2="$2"
    
    # Если версии равны - true
    [[ "$v1" == "$v2" ]] && return 0
    
    # Иначе проверяем >
    version_gt "$v1" "$v2"
}

# Поиск файлов образа во всех стандартных путях + BOT_PATH
# Возвращает список файлов, отсортированный по версии (новые первыми)
find_all_bot_image_files() {
    debug_log "SCAN" "=== find_all_bot_image_files() start ==="
    local search_paths=()
    
    # Собираем все пути для поиска
    # 1. Путь к боту (если настроен)
    [[ -n "$BOT_PATH" && -d "$BOT_PATH" ]] && search_paths+=("$BOT_PATH")
    
    # 2. Стандартные пути
    [[ -d "/opt" ]] && search_paths+=("/opt")
    [[ -d "/root" ]] && search_paths+=("/root")
    
    # 3. Путь по умолчанию (если отличается от BOT_PATH)
    if [[ -d "$DEFAULT_BOT_PATH" && "$DEFAULT_BOT_PATH" != "$BOT_PATH" ]]; then
        search_paths+=("$DEFAULT_BOT_PATH")
    fi
    
    debug_log "SCAN" "Search paths: ${search_paths[*]}"
    
    local all_files=""
    local seen_files=()
    
    for search_path in "${search_paths[@]}"; do
        debug_log "SCAN" "Searching in: $search_path (maxdepth=3)"
        # Рекурсивный поиск (maxdepth 3 для разумной глубины)
        while IFS= read -r file; do
            [[ -z "$file" ]] && continue
            
            # Проверка на дубликаты (по имени файла)
            local fname=$(basename "$file")
            local is_dup=false
            for seen in "${seen_files[@]}"; do
                [[ "$seen" == "$fname" ]] && is_dup=true && break
            done
            
            if [[ "$is_dup" == "false" ]]; then
                debug_log "SCAN" "  Found: $file"
                seen_files+=("$fname")
                all_files+="$file"$'\n'
            else
                debug_log "SCAN" "  Duplicate skipped: $fname"
            fi
        done < <(find "$search_path" -maxdepth 3 -type f \( \
            -name "rwp_shop*.tar" -o \
            -name "private-remnawave-telegram-shop-bot*.tar" -o \
            -name "telegram-shop*.tar" \
        \) 2> "$SILENT_LOG")
    done
    
    # Удаляем последний перенос строки
    all_files="${all_files%$'\n'}"
    
    if [[ -z "$all_files" ]]; then
        debug_log "SCAN" "No image files found"
        echo ""
        return 1
    fi
    
    debug_log "SCAN" "Total unique files found: $(echo "$all_files" | wc -l)"
    
    # Сортировка по версии (извлекаем версию, сортируем, выводим)
    # Новые версии первыми (sort -Vr)
    echo "$all_files" | while IFS= read -r file; do
        local version=$(extract_version_from_filename "$(basename "$file")")
        echo "$version|$file"
    done | sort -t'|' -k1 -Vr | cut -d'|' -f2
}

# Определение имени image из загруженного tar файла
get_image_name_from_tar() {
    local tar_file="$1"
    # После docker load выводит что-то типа "Loaded image: rwp_shop:3.23.5"
    # Но мы можем определить по имени файла
    local filename=$(basename "$tar_file")
    
    if [[ "$filename" == rwp_shop* ]]; then
        echo "rwp_shop"
    elif [[ "$filename" == private-remnawave-telegram-shop-bot* ]]; then
        echo "private-remnawave-telegram-shop-bot"
    elif [[ "$filename" == telegram-shop* ]]; then
        echo "telegram-shop"
    else
        echo "rwp_shop"  # По умолчанию новый формат
    fi
}

# Проверка, загружен ли образ с указанной версией в Docker
# Возвращает: 0 если загружен, 1 если нет
is_image_loaded_in_docker() {
    local image_name="$1"
    local version="$2"
    
    [[ -z "$image_name" || -z "$version" ]] && return 1
    
    # Проверяем наличие образа в docker images
    if docker images --format "{{.Repository}}:{{.Tag}}" 2>/dev/null | grep -qE "^${image_name}:${version}$"; then
        return 0
    fi
    
    return 1
}

# Быстрая проверка наличия LICENSE_KEY в .env (без интерактива)
# Возвращает: 0 если ключ есть и не пустой, 1 если нет
has_license_key() {
    local env_file="${BOT_PATH}/.env"
    [[ ! -f "$env_file" ]] && return 1
    
    local key=$(grep "^LICENSE_KEY=" "$env_file" 2>/dev/null | cut -d'=' -f2-)
    [[ -n "$key" && "$key" =~ ^[0-9a-f]{64}$ ]] && return 0
    return 1
}

# Быстрая проверка наличия machine-id volume в compose (без интерактива)
# Возвращает: 0 если volume есть, 1 если нет
has_machine_id_volume() {
    local compose_file=""
    [[ -f "$BOT_PATH/compose.yaml" ]] && compose_file="$BOT_PATH/compose.yaml"
    [[ -f "$BOT_PATH/docker-compose.yml" ]] && compose_file="$BOT_PATH/docker-compose.yml"
    [[ -z "$compose_file" ]] && return 1
    
    grep -q "/etc/machine-id" "$compose_file" 2>/dev/null && return 0
    return 1
}

# Получение версии image из docker-compose файла
# Возвращает: "image_name:version" или пустую строку
get_compose_image_version() {
    local compose_file="$1"
    
    if [[ ! -f "$compose_file" ]]; then
        echo ""
        return 1
    fi
    
    # Ищем image бота в compose файле
    local image_patterns=("rwp_shop" "private-remnawave-telegram-shop-bot" "telegram-shop" "shopbot")
    
    for pattern in "${image_patterns[@]}"; do
        local match=$(grep -oE "image:\s*['\"]?${pattern}:[0-9]+(\.[0-9]+){1,3}" "$compose_file" | head -1)
        if [[ -n "$match" ]]; then
            # Извлекаем image:version (убираем "image:" и пробелы/кавычки)
            local image_ver=$(echo "$match" | sed -E "s/image:\s*['\"]?//g" | tr -d "'" | tr -d '"')
            echo "$image_ver"
            return 0
        fi
    done
    
    echo ""
    return 1
}

# Получение версии загруженного Docker image
# Возвращает: версию (например "3.27.0") или пустую строку
get_loaded_image_version() {
    local image_name="$1"
    
    [[ -z "$image_name" ]] && image_name="rwp_shop"
    
    # Получаем последнюю версию image из docker images
    local version=$(docker images --format "{{.Tag}}" "$image_name" 2>/dev/null | grep -E "^[0-9]+\.[0-9]+\.[0-9]+" | sort -V | tail -1)
    
    if [[ -n "$version" ]]; then
        echo "$version"
        return 0
    fi
    
    echo ""
    return 1
}

# Получение текущей версии бота из compose файла или запущенного контейнера
# Возвращает: версию (например "3.27.0") или пустую строку
get_current_bot_version() {
    # Сначала пробуем из запущенного контейнера
    local ver=$(get_raw_bot_version)
    if [[ -n "$ver" && "$ver" != "Unknown" ]]; then
        echo "$ver"
        return 0
    fi
    
    # Затем из compose файла
    local compose_file=""
    [[ -f "$BOT_PATH/compose.yaml" ]] && compose_file="$BOT_PATH/compose.yaml"
    [[ -f "$BOT_PATH/docker-compose.yml" ]] && compose_file="$BOT_PATH/docker-compose.yml"
    
    if [[ -n "$compose_file" ]]; then
        local compose_ver=$(get_compose_image_version "$compose_file")
        if [[ -n "$compose_ver" ]]; then
            # Извлекаем версию из "image:version"
            echo "${compose_ver##*:}"
            return 0
        fi
    fi
    
    echo ""
    return 1
}

# Получение списка загруженных образов бота в Docker
# Возвращает: строки "image_name|version" (например "rwp_shop|3.27.0")
get_loaded_bot_images() {
    local result=""
    local image_names=("rwp_shop" "private-remnawave-telegram-shop-bot")
    
    for img in "${image_names[@]}"; do
        local versions=$(docker images --format "{{.Tag}}" "$img" 2>/dev/null | grep -E "^[0-9]+\.[0-9]+\.[0-9]+")
        while IFS= read -r ver; do
            [[ -z "$ver" ]] && continue
            result+="${img}|${ver}"$'\n'
        done <<< "$versions"
    done
    
    echo -n "$result" | sed '/^$/d'
}

# Проверка соответствия версии в compose и загруженного image
# Возвращает: 0 если совпадают, 1 если не совпадают, 2 если ошибка
check_image_version_match() {
    debug_log "VERSION" "=== check_image_version_match() ==="
    
    # Определяем compose файл
    local compose_file=""
    if [[ -n "$BOT_PATH" && -d "$BOT_PATH" ]]; then
        [[ -f "$BOT_PATH/compose.yaml" ]] && compose_file="$BOT_PATH/compose.yaml"
        [[ -f "$BOT_PATH/docker-compose.yml" ]] && compose_file="$BOT_PATH/docker-compose.yml"
    fi
    
    if [[ -z "$compose_file" ]]; then
        debug_log "VERSION" "Compose file not found"
        return 2
    fi
    
    debug_log "VERSION" "Compose file: $compose_file"
    
    # Получаем версию из compose
    local compose_image=$(get_compose_image_version "$compose_file")
    debug_log "VERSION" "Compose image: $compose_image"
    
    if [[ -z "$compose_image" ]]; then
        debug_log "VERSION" "Could not get image from compose"
        return 2
    fi
    
    # Разделяем на имя и версию
    local compose_name="${compose_image%%:*}"
    local compose_version="${compose_image##*:}"
    debug_log "VERSION" "Compose: name=$compose_name version=$compose_version"
    
    # Получаем загруженную версию image
    local loaded_version=$(get_loaded_image_version "$compose_name")
    debug_log "VERSION" "Loaded image version: $loaded_version"

    # Сканируем локальные .tar файлы (для случая, когда image ещё не выполнен docker load)
    local latest_tar_version=""
    local latest_tar_file=""
    local _tar_list
    _tar_list=$(find_all_bot_image_files 2>/dev/null)
    if [[ -n "$_tar_list" ]]; then
        local _tf _tv
        while IFS= read -r _tf; do
            [[ -z "$_tf" ]] && continue
            _tv=$(extract_version_from_filename "$(basename "$_tf")")
            [[ -z "$_tv" ]] && continue
            if [[ -z "$latest_tar_version" ]] || version_gt "$_tv" "$latest_tar_version"; then
                latest_tar_version="$_tv"
                latest_tar_file="$_tf"
            fi
        done <<< "$_tar_list"
    fi
    debug_log "VERSION" "Latest tar: version=$latest_tar_version file=$latest_tar_file"

    # Нет ни загруженного image, ни локального .tar
    if [[ -z "$loaded_version" && -z "$latest_tar_version" ]]; then
        debug_log "VERSION" "No loaded image and no tar found for $compose_name"
        echo "NOT_FOUND"
        return 1
    fi

    # Image не загружен — есть только локальный .tar
    if [[ -z "$loaded_version" ]]; then
        if version_gt "$latest_tar_version" "$compose_version"; then
            debug_log "VERSION" "TAR_NEW (no loaded): tar=$latest_tar_version > compose=$compose_version"
            echo "TAR_NEW:$compose_version:$latest_tar_version:$compose_name:$latest_tar_file"
        elif [[ "$latest_tar_version" == "$compose_version" ]]; then
            debug_log "VERSION" "TAR_MATCH (no loaded): tar=$latest_tar_version == compose"
            echo "TAR_MATCH:$compose_version:$latest_tar_version:$compose_name:$latest_tar_file"
        else
            debug_log "VERSION" "Only older tar present, image not loaded"
            echo "NOT_FOUND"
        fi
        return 1
    fi

    # Loaded image есть, но локальный .tar новее (и compose, и loaded) — это TAR_NEW с приоритетом
    if [[ -n "$latest_tar_version" ]] \
       && version_gt "$latest_tar_version" "$loaded_version" \
       && version_gt "$latest_tar_version" "$compose_version"; then
        debug_log "VERSION" "TAR_NEW (with loaded): tar=$latest_tar_version > loaded=$loaded_version, compose=$compose_version"
        echo "TAR_NEW:$compose_version:$latest_tar_version:$compose_name:$latest_tar_file"
        return 1
    fi

    # Сравниваем версии (compose vs загруженный image)
    if [[ "$compose_version" == "$loaded_version" ]]; then
        debug_log "VERSION" "Versions match: $compose_version"
        echo "MATCH:$compose_version"
        return 0
    else
        debug_log "VERSION" "Version MISMATCH: compose=$compose_version loaded=$loaded_version"

        # Определяем какая версия выше
        if version_gt "$loaded_version" "$compose_version"; then
            echo "UPGRADE:$compose_version:$loaded_version:$compose_name"
        else
            echo "DOWNGRADE:$compose_version:$loaded_version:$compose_name"
        fi
        return 1
    fi
}

