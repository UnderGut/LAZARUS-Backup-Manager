# Проверка соответствия версий Docker image
check_and_warn_version_mismatch() {
    local result=$(check_image_version_match 2>/dev/null)
    local status=$?
    
    debug_log "VERSION" "Version check result: $result (status=$status)"
    
    case "$result" in
        MATCH:*)
            # Версии совпадают - всё ок
            debug_log "VERSION" "Versions match"
            ;;
        UPGRADE:*)
            # Загруженная версия ВЫШЕ чем в compose - предложить обновить
            local compose_ver=$(echo "$result" | cut -d: -f2)
            local loaded_ver=$(echo "$result" | cut -d: -f3)
            local image_name=$(echo "$result" | cut -d: -f4)
            # Очищаем экран чтобы предупреждение было вверху
            clear_screen
            show_version_mismatch_warning "$compose_ver" "$loaded_ver" "true" "$image_name"
            if [[ "$IS_INTERACTIVE" == true ]]; then
                offer_compose_update "$compose_ver" "$loaded_ver" "$image_name"
            fi
            ;;
        DOWNGRADE:*)
            # Загруженная версия НИЖЕ чем в compose - предупреждение
            local compose_ver=$(echo "$result" | cut -d: -f2)
            local loaded_ver=$(echo "$result" | cut -d: -f3)
            local image_name=$(echo "$result" | cut -d: -f4)
            # Очищаем экран чтобы предупреждение было вверху
            clear_screen
            show_version_mismatch_warning "$compose_ver" "$loaded_ver" "false" "$image_name"
            if [[ "$IS_INTERACTIVE" == true ]]; then
                read -erp "Нажмите Enter для продолжения..." dummy
            fi
            ;;
        NOT_FOUND)
            # Image не найден - критическая ошибка
            echo ""
            print_message "ERROR" "Docker image бота не найден!"
            print_message "INFO" "Загрузите image командой: curl + docker load"
            echo ""
            ;;
        *)
            # Не удалось определить - игнорируем (возможно бот не настроен)
            debug_log "VERSION" "Could not determine version match (bot not configured?)"
            ;;
    esac
}

