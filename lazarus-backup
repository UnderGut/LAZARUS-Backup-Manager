    if [[ -z "$MIGRATION_TARGET_CONTAINER" ]]; then
        for pattern in "rwp_shop_db" "telegram-shop-db"; do
            MIGRATION_TARGET_CONTAINER=$(docker ps --format '{{.Names}}' 2>/dev/null | grep -iE "^$pattern$" | head -1)
