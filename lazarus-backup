# SENSITIVE_TMP_PATHS — массив путей с sensitive данными (decrypted backups,
# S3 credentials), которые ОБЯЗАТЕЛЬНО надо удалить при exit/SIGKILL.
# Регистрируется через `register_sensitive_tmp`.
declare -a SENSITIVE_TMP_PATHS=()

register_sensitive_tmp() {
    # Аргумент — путь к файлу или каталогу с sensitive данными.
    [[ -n "$1" ]] && SENSITIVE_TMP_PATHS+=("$1")
}

unregister_sensitive_tmp() {
    # Удалить из списка после явной успешной очистки (предотвращает double-rm).
    local target="$1"
    local i new=()
    for i in "${SENSITIVE_TMP_PATHS[@]}"; do
        [[ "$i" != "$target" ]] && new+=("$i")
    done
    SENSITIVE_TMP_PATHS=("${new[@]}")
}

# Trap для очистки при завершении: lock + sensitive tmp пути
cleanup_on_exit() {
    # Освобождаем блокировку если была получена
    # NOTE: debug_log может не работать здесь если вызывается после закрытия stdout
    if [[ -n "$LOCK_FD" ]]; then
        flock -u "$LOCK_FD" 2>/dev/null || true
        eval "exec $LOCK_FD>&-" 2>/dev/null || true
    fi
    rm -f "$LOCK_FILE" 2>/dev/null || true

    # КРИТИЧНО: удаляем sensitive temp paths (decrypted backups, S3 creds).
    # Если скрипт умер по SIGKILL — этот trap не сработает, но при normal exit,
    # ctrl+C-trap exit, double-confirm exit — сработает.
    if [[ ${#SENSITIVE_TMP_PATHS[@]} -gt 0 ]]; then
        local p
        for p in "${SENSITIVE_TMP_PATHS[@]}"; do
            [[ -n "$p" && -e "$p" ]] && rm -rf "$p" 2>/dev/null || true
        done
    fi
}
# EXIT: всегда чистим (lock, temp dirs).
# INT/TERM: double-confirm — первый Ctrl+C просит подтверждение, второй в течение
# DOUBLE_CTRLC_WINDOW секунд завершает скрипт через exit 130 (128 + SIGINT).
# Это спасает от случайных одиночных нажатий в меню. Внутри уже запущенных команд
# (pg_dump/tar/curl) первый Ctrl+C всё равно убивает child process — это поведение
# kernel/bash, наш trap не успевает защитить child. Для полной блокировки нужны
# setsid-обёртки на каждый critical-call (отдельная задача).
_INT_FLAG=0
_INT_LAST_TS=0
DOUBLE_CTRLC_WINDOW=3   # сек.

_lazarus_int_handler() {
    local _now
    _now=$(date +%s)
    if [[ $_INT_FLAG -eq 1 && $((_now - _INT_LAST_TS)) -le $DOUBLE_CTRLC_WINDOW ]]; then
        # Второй Ctrl+C в окне → реально выходим
        printf '\n\033[31m\033[1m[INFO] Повторный Ctrl+C — прерываем скрипт\033[0m\n'
        exit 130
    fi
    _INT_FLAG=1
    _INT_LAST_TS=$_now
    printf '\n\033[33m\033[1m[WARN] Получен Ctrl+C — нажмите ещё раз в течение %s сек для выхода\033[0m\n' "$DOUBLE_CTRLC_WINDOW"
    printf '\033[90m       (если этого не сделать, операция продолжится)\033[0m\n'
}

trap cleanup_on_exit EXIT
trap _lazarus_int_handler INT TERM

# safe_read: обёртка над builtin read. При SIGINT (rc=130) повторяет prompt —
# полезно в меню, где Ctrl+C во время read не должен интерпретироваться
# как пустой ответ → отмена. EOF (Ctrl+D) и прочие ошибки пропускаются дальше.
# Использовать ВМЕСТО `read` в местах где пустой ввод имеет деструктивный смысл.
safe_read() {
    while true; do
        builtin read "$@"
        local _rc=$?
        if [[ $_rc -eq 0 ]]; then return 0; fi
        if [[ $_rc -eq 130 ]]; then
            # Первый Ctrl+C — handler уже отработал WARN; перечитываем prompt
            continue
        fi
        return $_rc
    done
}

# Цвета
if [[ -t 0 ]]; then
