#!/bin/bash
# lazarus-migrator -- Bedolaga -> RWP-Shop migration plugin
# Part of LAZARUS-Backup-Manager. Sourced by main script lazarus-backup.
# NOT a standalone script -- depends on functions and globals from main.
# Repo: https://github.com/UnderGut/LAZARUS-Backup-Manager

# Guard against direct execution
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "ERROR: lazarus-migrator is a plugin, not a standalone script." >&2
    echo "It must be sourced from /opt/lazarus-backup/lazarus-backup" >&2
    exit 1
fi

# Plugin version (synchronized with main lazarus-backup)
LAZARUS_MIGRATOR_VERSION="5.0.0-dev"

# =============================================================================
# МИГРАЦИЯ МЕЖДУ БОТАМИ (Bedolaga → RWP-Shop (Private))
# =============================================================================

# Массив для хранения временных директорий (для очистки при выходе)
declare -a TEMP_DIRS=()

# Конфигурация миграции
MIGRATION_SOURCE_TYPE=""        # archive | docker | postgresql
MIGRATION_SOURCE_BACKUP=""      # Путь к архиву бэкапа (.tar.gz)
MIGRATION_SOURCE_HOST=""
MIGRATION_SOURCE_PORT="5432"
MIGRATION_SOURCE_DB=""
MIGRATION_SOURCE_USER=""
MIGRATION_SOURCE_PASS=""
MIGRATION_SOURCE_CONTAINER=""   # Docker контейнер БД Bedolaga
MIGRATION_TARGET_CONTAINER=""
MIGRATION_TARGET_DB=""
MIGRATION_TARGET_USER=""
MIGRATION_TARGET_PATH=""            # Путь к папке RWP-Shop (где docker-compose)
MIGRATION_WORK_DIR=""
MIGRATION_EXTRACTED_DIR=""      # Временная папка с распакованным архивом

# Маппинг payment_method (Bedolaga) → invoice_type (RWP-Shop)
# 
# Bedolaga поддерживает: telegram_stars, tribute, yookassa, cryptobot, 
#                        heleket, mulenpay, pal24, wata, platega, cloudpayments, manual
#
# RWP-Shop поддерживает: yookassa, crypto, telegram, severpay_cards, 
#                               severpay_sbp, wata, platega, stripe
#
# ⚠️ Методы без аналога в Remnawave: tribute, heleket, mulenpay, pal24, cloudpayments
#    Они будут замаппены на "unknown" и потребуют ручной обработки
declare -A PAYMENT_METHOD_MAP=(
    # Прямые совпадения (публичная + приватная версия)
    ["yookassa"]="yookassa"
    ["tribute"]="tribute"
    ["wata"]="wata"
    
    # Требуют преобразования
    ["telegram_stars"]="telegram"
    ["cryptobot"]="crypto"
    
    # Platega в Bedolaga → platega_cards в Remnawave (приватная версия)
    # Доступные варианты: platega_cards, platega_sbp, platega_crypto, platega_acquiring, platega_worldwide
    ["platega"]="platega_cards"
    
    # Нет аналога в RWP-Shop - помечаем как unknown
    ["manual"]="unknown"
    ["heleket"]="unknown"
    ["mulenpay"]="unknown"
    ["pal24"]="unknown"
    ["cloudpayments"]="unknown"
)

# --- Функция: Анализ структуры источника ---
migrate_analyze_source() {
    debug_log "MIGRATE" "Starting source analysis"
    print_message "INFO" "Анализ источника данных..."
    
    # Для режима archive — проверяем JSON-файл
    if [[ "$MIGRATION_SOURCE_TYPE" == "archive" ]]; then
        local db_json="$MIGRATION_EXTRACTED_DIR/database.json"
        debug_log "MIGRATE" "Archive mode: checking $db_json"
        
        if [[ ! -f "$db_json" ]]; then
            print_message "ERROR" "Файл database.json не найден в архиве"
            return 1
        fi
        
        # Подсчёт таблиц в JSON через Python
        local python_cmd=""
        if command -v python3 &>/dev/null; then python_cmd="python3"
        elif command -v python &>/dev/null; then python_cmd="python"
        fi
        
        if [[ -n "$python_cmd" ]]; then
            local table_count=$($python_cmd - "$db_json" << 'PYEOF'
import sys, json
with open(sys.argv[1], 'r', encoding='utf-8') as f:
    data = json.load(f)
tables = data.get('data', {})
print(len(tables))
PYEOF
)
            print_message "SUCCESS" "Найдено таблиц в архиве: $table_count"
            debug_log "MIGRATE" "Archive contains $table_count tables"
        else
            print_message "WARN" "Python не найден, пропускаем подсчёт таблиц"
        fi
        return 0
    fi
    
    # Для режимов docker/postgresql — проверяем PostgreSQL
    local source_info=""
    
    if [[ -n "$MIGRATION_SOURCE_CONTAINER" ]]; then
        debug_log "MIGRATE" "Using Docker container: $MIGRATION_SOURCE_CONTAINER"
        source_info=$(docker exec "$MIGRATION_SOURCE_CONTAINER" psql -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -t -c "
            SELECT 'tables:' || count(*) FROM information_schema.tables WHERE table_schema='public';
        " 2>&1)
    else
        debug_log "MIGRATE" "Using direct connection: $MIGRATION_SOURCE_HOST:$MIGRATION_SOURCE_PORT"
        export PGPASSWORD="$MIGRATION_SOURCE_PASS"
        source_info=$(psql -h "$MIGRATION_SOURCE_HOST" -p "$MIGRATION_SOURCE_PORT" -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -t -c "
            SELECT 'tables:' || count(*) FROM information_schema.tables WHERE table_schema='public';
        " 2>&1)
        unset PGPASSWORD
    fi
    
    if [[ $? -ne 0 ]]; then
        print_message "ERROR" "Не удалось подключиться к БД источника"
        debug_log "MIGRATE" "Connection failed: $source_info"
        return 1
    fi
    
    echo "$source_info"
    debug_log "MIGRATE" "Source info: $source_info"
}

# --- Функция: Проверка совместимости ---
migrate_check_compatibility() {
    debug_log "MIGRATE" "Checking source compatibility"
    print_message "INFO" "Проверка совместимости источника..."
    
    local required_tables=("users" "transactions" "promocodes")
    local missing_tables=()
    
    # Для архива - проверяем наличие таблиц в database.json
    if [[ "$MIGRATION_SOURCE_TYPE" == "archive" ]]; then
        local db_json="$MIGRATION_EXTRACTED_DIR/database.json"
        
        if [[ ! -f "$db_json" ]]; then
            print_message "ERROR" "Файл database.json не найден"
            return 1
        fi
        
        for table in "${required_tables[@]}"; do
            # Проверяем наличие таблицы в JSON
            if ! grep -q "\"$table\":" "$db_json"; then
                missing_tables+=("$table")
            fi
        done
    else
        # Для PostgreSQL - проверяем через psql
        for table in "${required_tables[@]}"; do
            local exists=""
            if [[ -n "$MIGRATION_SOURCE_CONTAINER" ]]; then
                exists=$(docker exec "$MIGRATION_SOURCE_CONTAINER" psql -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -t -c "
                    SELECT 1 FROM information_schema.tables WHERE table_schema='public' AND table_name='$table' LIMIT 1;
                " 2>/dev/null | tr -d ' ')
            else
                export PGPASSWORD="$MIGRATION_SOURCE_PASS"
                exists=$(psql -h "$MIGRATION_SOURCE_HOST" -p "$MIGRATION_SOURCE_PORT" -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -t -c "
                    SELECT 1 FROM information_schema.tables WHERE table_schema='public' AND table_name='$table' LIMIT 1;
                " 2>/dev/null | tr -d ' ')
                unset PGPASSWORD
            fi
            
            if [[ "$exists" != "1" ]]; then
                missing_tables+=("$table")
            fi
        done
    fi
    
    if [[ ${#missing_tables[@]} -gt 0 ]]; then
        print_message "ERROR" "Отсутствуют обязательные таблицы: ${missing_tables[*]}"
        debug_log "MIGRATE" "Missing tables: ${missing_tables[*]}"
        return 1
    fi
    
    print_message "SUCCESS" "Источник совместим (Bedolaga format)"
    return 0
}

# --- Переменные для хранения настроек обработки баланса ---
BALANCE_HANDLING_MODE=""      # ignore, export_csv, convert_days, convert_partner
BALANCE_CONVERSION_PRICE=""   # Стоимость месяца в рублях (для convert_days)
BALANCE_CONVERSION_DAYS=""    # Количество дней в месяце (для convert_days)

# --- Функция: Анализ и обработка балансов пользователей ---
migrate_handle_balances() {
    debug_log "MIGRATE" "Analyzing user balances"
    print_message "INFO" "Анализ балансов пользователей..."
    
    local export_dir="$MIGRATION_WORK_DIR/export"
    mkdir -p "$export_dir"
    local balances_file="$export_dir/user_balances.csv"
    
    local balance_data=""
    
    # Для архива - читаем из database.json через Python
    if [[ "$MIGRATION_SOURCE_TYPE" == "archive" ]]; then
        local db_json="$MIGRATION_EXTRACTED_DIR/database.json"
        
        # Используем Python для извлечения пользователей с балансом > 0
        local python_cmd=""
        if command -v python3 &>/dev/null; then
            python_cmd="python3"
        elif command -v python &>/dev/null; then
            python_cmd="python"
        fi
        
        if [[ -n "$python_cmd" ]]; then
            balance_data=$($python_cmd - "$db_json" << 'PYEOF'
import sys
import json

with open(sys.argv[1], 'r', encoding='utf-8') as f:
    data = json.load(f)

users = data.get('data', {}).get('users', [])
for u in users:
    # Проверяем разные варианты имён полей
    # balance_kopeks - копейки (старый формат)
    # balance - рубли (новый формат)
    balance_kop = u.get('balance_kopeks', 0) or 0
    balance_rub_direct = u.get('balance', 0) or 0
    
    # Если есть balance в рублях - конвертируем в копейки
    if balance_rub_direct > 0 and balance_kop == 0:
        balance_kop = int(balance_rub_direct * 100)
    
    if balance_kop > 0:
        tg_id = u.get('telegram_id', '')
        username = u.get('username', '') or ''
        fname = u.get('first_name', '') or ''
        balance_rub = round(balance_kop / 100, 2)
        print(f"{tg_id},{username},{fname},{balance_kop},{balance_rub}")
PYEOF
)
        fi
    else
        # Для PostgreSQL - запрос через psql
        local balance_query="
            SELECT telegram_id, username, first_name, balance_kopeks, 
                   ROUND(balance_kopeks::numeric / 100, 2) as balance_rubles
            FROM users 
            WHERE balance_kopeks > 0 
            ORDER BY balance_kopeks DESC;
        "
        
        if [[ -n "$MIGRATION_SOURCE_CONTAINER" ]]; then
            balance_data=$(docker exec "$MIGRATION_SOURCE_CONTAINER" psql -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -t -A -F',' -c "$balance_query" 2>/dev/null)
        else
            export PGPASSWORD="$MIGRATION_SOURCE_PASS"
            balance_data=$(psql -h "$MIGRATION_SOURCE_HOST" -p "$MIGRATION_SOURCE_PORT" -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -t -A -F',' -c "$balance_query" 2>/dev/null)
            unset PGPASSWORD
        fi
    fi
    
    if [[ -z "$balance_data" ]]; then
        print_message "SUCCESS" "Пользователей с балансом > 0 не найдено"
        BALANCE_HANDLING_MODE="none"
        return 0
    fi
    
    # Подсчёт статистики через Python (избегаем проблем с subshell в bash)
    local stats
    local python_cmd=""
    if command -v python3 &>/dev/null; then
        python_cmd="python3"
    elif command -v python &>/dev/null; then
        python_cmd="python"
    fi
    
    if [[ -n "$python_cmd" ]]; then
        stats=$(echo "$balance_data" | $python_cmd -c '
import sys

total_kop = 0
count = 0

for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    parts = line.split(",")
    if len(parts) >= 4:
        try:
            # 4-е поле - balance_kop (копейки)
            kop = float(parts[3])
            total_kop += int(kop)
            count += 1
        except:
            pass

total_rub = round(total_kop / 100, 2)
print(f"{count},{total_kop},{total_rub}")
')
    fi
    
    local users_with_balance=$(echo "$stats" | cut -d',' -f1)
    local total_balance_kopeks=$(echo "$stats" | cut -d',' -f2)
    local total_balance_rubles=$(echo "$stats" | cut -d',' -f3)
    
    # Fallback если Python не сработал
    if [[ -z "$users_with_balance" || "$users_with_balance" == "0" ]]; then
        users_with_balance=$(echo "$balance_data" | grep -c '^[0-9]' || echo "0")
        total_balance_rubles="?"
    fi
    
    # Сохраняем данные в файл
    echo "telegram_id,username,first_name,balance_kopeks,balance_rubles" > "$balances_file"
    echo "$balance_data" >> "$balances_file"
    
    # Показываем предупреждение
    echo ""
    echo -e "${RED}${BOLD}══════════════════════════════════════════════════════════════${RESET}"
    echo -e "${RED}${BOLD}  ⚠️  ОБНАРУЖЕНЫ ПОЛЬЗОВАТЕЛИ С НЕНУЛЕВЫМ БАЛАНСОМ!          ${RESET}"
    echo -e "${RED}${BOLD}══════════════════════════════════════════════════════════════${RESET}"
    echo ""
    echo -e "  ${YELLOW}Пользователей с балансом > 0:${RESET} ${WHITE}${BOLD}$users_with_balance${RESET}"
    echo -e "  ${YELLOW}Общая сумма балансов:${RESET}        ${WHITE}${BOLD}$total_balance_rubles ₽${RESET}"
    echo ""
    
    # Показываем топ-5 пользователей
    echo -e "${CYAN}  Топ-5 пользователей по балансу:${RESET}"
    local count=0
    while IFS=',' read -r tg_id username fname balance_kop balance_rub; do
        [[ -z "$tg_id" ]] && continue
        ((count++))
        [[ $count -gt 5 ]] && break
        local display_name="${username:-${fname:-ID:$tg_id}}"
        printf "    %d. %-20s %10s ₽\n" "$count" "$display_name" "$balance_rub"
    done <<< "$balance_data"
    
    if [[ $users_with_balance -gt 5 ]]; then
        echo -e "    ${GRAY}... и ещё $((users_with_balance - 5)) пользователей${RESET}"
    fi
    echo ""
    
    echo -e "${RED}${BOLD}══════════════════════════════════════════════════════════════${RESET}"
    echo -e "${YELLOW}  В RWP-Shop НЕТ внутреннего баланса пользователя!${RESET}"
    echo -e "${YELLOW}  Выберите как обработать эти данные:${RESET}"
    echo -e "${RED}${BOLD}══════════════════════════════════════════════════════════════${RESET}"
    echo ""
    echo -e "  ${GREEN}1.${RESET} Экспорт в CSV (рекомендуется)"
    echo "     → Сохранить список в файл для ручной обработки"
    echo "     → Вы сможете вернуть деньги или продлить подписки вручную"
    echo ""
    echo -e "  ${GREEN}2.${RESET} Конвертировать в дни подписки"
    echo "     → Баланс будет пересчитан в дни по вашему тарифу"
    echo "     → Дни добавятся к expire_at пользователя"
    echo ""
    echo -e "  ${YELLOW}3.${RESET} Создать партнёров и перенести баланс"
    echo "     → Создаёт записи партнёров в RWP-Shop"
    echo "     → Использует % комиссии из Bedolaga (или указать вручную)"
    echo "     → Устанавливает available_balance из баланса Bedolaga"
    echo ""
    echo -e "  ${RED}4.${RESET} Игнорировать (ПОТЕРЯ ДАННЫХ!)"
    echo "     → Балансы будут потеряны безвозвратно"
    echo ""
    echo -e "  ${CYAN}5.${RESET} Показать ВСЕХ пользователей с балансом"
    echo ""
    echo -e "  ${CYAN}0.${RESET} Назад"
    echo ""
    
    while true; do
        read -erp "Выберите вариант [0-5] (Enter - Назад): " choice
        case "$choice" in
            ""|0|q|Q)
                return 1
                ;;
            5)
                # Показать всех пользователей с балансом
                echo ""
                echo -e "${CYAN}══════════════════════════════════════════════════════════════${RESET}"
                echo -e "${CYAN}  ВСЕ ПОЛЬЗОВАТЕЛИ С БАЛАНСОМ ($users_with_balance чел.)${RESET}"
                echo -e "${CYAN}══════════════════════════════════════════════════════════════${RESET}"
                echo ""
                printf "  ${GRAY}%-4s %-20s %-15s %12s${RESET}\n" "№" "Username" "Telegram ID" "Баланс"
                echo "  ──────────────────────────────────────────────────────────"
                local num=0
                while IFS=',' read -r tg_id username fname balance_kop balance_rub; do
                    [[ -z "$tg_id" ]] && continue
                    ((num++))
                    local display_name="${username:-${fname:-—}}"
                    printf "  %-4d %-20s %-15s %10s ₽\n" "$num" "$display_name" "$tg_id" "$balance_rub"
                done <<< "$balance_data"
                echo ""
                echo -e "  ${YELLOW}Итого: $total_balance_rubles ₽${RESET}"
                echo ""
                read -erp "Нажмите Enter для продолжения..." dummy
                echo ""
                ;;
            1)
                BALANCE_HANDLING_MODE="export_csv"
                print_message "INFO" "Балансы будут сохранены в: $balances_file"
                break
                ;;
            2)
                echo ""
                echo -e "${CYAN}=== НАСТРОЙКА КОНВЕРТАЦИИ БАЛАНСА В ДНИ ===${RESET}"
                echo ""
                echo "Укажите параметры вашего тарифа:"
                echo ""
                
                # Стоимость месяца
                read -erp "Стоимость 1 месяца подписки в рублях [100]: " month_price
                month_price="${month_price:-100}"
                
                # Валидация числа
                if ! [[ "$month_price" =~ ^[0-9]+([.][0-9]+)?$ ]] || [[ $(echo "$month_price <= 0" | bc) -eq 1 ]]; then
                    print_message "ERROR" "Некорректная стоимость. Используется 100₽"
                    month_price="100"
                fi
                
                # Количество дней в месяце
                read -erp "Количество дней в 1 месяце подписки [30]: " days_per_month
                days_per_month="${days_per_month:-30}"
                
                # Валидация числа
                if ! [[ "$days_per_month" =~ ^[0-9]+$ ]] || [[ "$days_per_month" -le 0 ]]; then
                    print_message "ERROR" "Некорректное количество дней. Используется 30"
                    days_per_month="30"
                fi
                
                BALANCE_CONVERSION_PRICE="$month_price"
                BALANCE_CONVERSION_DAYS="$days_per_month"
                BALANCE_HANDLING_MODE="convert_days"
                
                echo ""
                echo -e "${CYAN}Формула расчёта:${RESET}"
                echo "  extra_days = (balance_rubles / $month_price) × $days_per_month"
                echo ""
                
                # Пример расчёта
                local example_balance="150"
                local example_days=$(echo "scale=0; ($example_balance / $month_price) * $days_per_month" | bc 2>/dev/null || echo "?")
                echo -e "  ${YELLOW}Пример:${RESET} баланс 150₽ → $example_days дней"
                echo ""
                
                print_message "SUCCESS" "Курс: $month_price ₽ = $days_per_month дней"
                break
                ;;
            3)
                BALANCE_HANDLING_MODE="convert_partner"
                print_message "INFO" "Балансы партнёров → partner.available_balance"
                break
                ;;
            4)
                echo ""
                echo -e "${RED}${BOLD}  ⚠️  ВНИМАНИЕ! ВЫ ПОТЕРЯЕТЕ $total_balance_rubles ₽!${RESET}"
                echo ""
                read -erp "Введите 'LOSE DATA' для подтверждения: " confirm
                if [[ "$confirm" == "LOSE DATA" ]]; then
                    BALANCE_HANDLING_MODE="ignore"
                    print_message "WARN" "Балансы будут проигнорированы (потеря данных)"
                    # Всё равно сохраняем в файл для истории
                    print_message "INFO" "Резервная копия балансов: $balances_file"
                    break
                else
                    print_message "INFO" "Отмена. Выберите другой вариант."
                fi
                ;;
            *)
                print_message "ERROR" "Неверный выбор"
                ;;
        esac
    done
    
    return 0
}

# --- Функция: Применение обработки балансов ---
migrate_apply_balance_handling() {
    debug_log "MIGRATE" "Applying balance handling: $BALANCE_HANDLING_MODE"
    
    local export_dir="$MIGRATION_WORK_DIR/export"
    local import_dir="$MIGRATION_WORK_DIR/import"
    local balances_file="$export_dir/user_balances.csv"
    local balance_report="$MIGRATION_WORK_DIR/balance_report.txt"
    
    case "$BALANCE_HANDLING_MODE" in
        "none")
            debug_log "MIGRATE" "No balances to process"
            return 0
            ;;
        "export_csv")
            # Уже сохранено в migrate_handle_balances
            print_message "SUCCESS" "Балансы экспортированы в: $balances_file"
            
            # Создаём отчёт
            {
                echo "═══════════════════════════════════════════════════════════"
                echo "  ОТЧЁТ О БАЛАНСАХ ПОЛЬЗОВАТЕЛЕЙ"
                echo "  Дата миграции: $(date '+%Y-%m-%d %H:%M:%S')"
                echo "═══════════════════════════════════════════════════════════"
                echo ""
                echo "Файл с балансами: $balances_file"
                echo ""
                echo "РЕКОМЕНДАЦИИ:"
                echo "1. Свяжитесь с пользователями и предложите возврат средств"
                echo "2. Или продлите им подписку на эквивалентный срок"
                echo "3. Используйте админ-панель Remnawave для ручных операций"
                echo ""
                echo "СПИСОК ПОЛЬЗОВАТЕЛЕЙ:"
                cat "$balances_file"
            } > "$balance_report"
            
            print_message "INFO" "Отчёт создан: $balance_report"
            ;;
            
        "convert_days")
            print_message "INFO" "Конвертация балансов в дни подписки..."
            
            # Создаём файл с доп. днями для каждого пользователя
            local days_file="$import_dir/balance_to_days.csv"
            echo "telegram_id,extra_days,balance_rubles,month_price,days_per_month" > "$days_file"
            
            local month_price="${BALANCE_CONVERSION_PRICE:-100}"
            local days_per_month="${BALANCE_CONVERSION_DAYS:-30}"
            
            tail -n +2 "$balances_file" | while IFS=',' read -r tg_id username fname balance_kop balance_rub; do
                [[ -z "$tg_id" ]] && continue
                # Расчёт дней: (balance_rub / month_price) * days_per_month
                local extra_days=$(echo "scale=0; ($balance_rub / $month_price) * $days_per_month" | bc 2>/dev/null || echo "0")
                [[ "$extra_days" -lt 1 ]] && extra_days=0
                echo "$tg_id,$extra_days,$balance_rub,$month_price,$days_per_month" >> "$days_file"
            done
            
            print_message "SUCCESS" "Файл конвертации создан: $days_file"
            
            # Отчёт
            {
                echo "═══════════════════════════════════════════════════════════"
                echo "  КОНВЕРТАЦИЯ БАЛАНСОВ В ДНИ ПОДПИСКИ"
                echo "  Тариф: $month_price ₽ = $days_per_month дней"
                echo "  Формула: extra_days = (balance / $month_price) × $days_per_month"
                echo "═══════════════════════════════════════════════════════════"
                echo ""
                echo "telegram_id,extra_days,balance_rubles"
                tail -n +2 "$days_file" | cut -d',' -f1-3
            } > "$balance_report"
            ;;
            
        "convert_partner")
            print_message "INFO" "Конвертация балансов в партнёрские (с созданием записей)..."
            
            # Файл для создания партнёров
            local partner_create_file="$import_dir/partners_to_create.csv"
            echo "telegram_id,available_balance,percent" > "$partner_create_file"
            
            # Получаем глобальный процент комиссии из настроек Bedolaga
            local default_percent="10"  # fallback
            
            # Пробуем получить из распакованного архива
            if [[ -n "$MIGRATION_EXTRACTED_DIR" && -f "$MIGRATION_EXTRACTED_DIR/database.json" ]]; then
                local db_json="$MIGRATION_EXTRACTED_DIR/database.json"
                
                # Извлекаем REFERRAL_COMMISSION_PERCENT из system_settings
                local extracted_percent=$(grep -o '"REFERRAL_COMMISSION_PERCENT"[^}]*"value"[^"]*"[^"]*"' "$db_json" 2>/dev/null | grep -o '"value"[^"]*"[^"]*"' | grep -o '[0-9]\+' | head -1)
                if [[ -n "$extracted_percent" ]]; then
                    default_percent="$extracted_percent"
                    debug_log "MIGRATE" "Found REFERRAL_COMMISSION_PERCENT in backup: $default_percent"
                fi
                
                # Также проверяем REFERRAL_BONUS_PERCENT (другое название)
                if [[ "$default_percent" == "10" ]]; then
                    extracted_percent=$(grep -o '"REFERRAL_BONUS_PERCENT"[^}]*"value"[^"]*"[^"]*"' "$db_json" 2>/dev/null | grep -o '"value"[^"]*"[^"]*"' | grep -o '[0-9]\+' | head -1)
                    if [[ -n "$extracted_percent" ]]; then
                        default_percent="$extracted_percent"
                        debug_log "MIGRATE" "Found REFERRAL_BONUS_PERCENT in backup: $default_percent"
                    fi
                fi
            fi
            
            echo ""
            echo -e "${CYAN}=== НАСТРОЙКА ПАРТНЁРСКОГО ПРОЦЕНТА ===${RESET}"
            echo ""
            echo -e "В настройках Bedolaga найден процент комиссии: ${GREEN}$default_percent%${RESET}"
            echo ""
            echo "Выберите какой процент использовать для новых партнёров:"
            echo "  1. Использовать из Bedolaga: ${default_percent}%"
            echo "  2. Указать другой процент"
            echo ""
            read -erp "Выбор [1]: " percent_choice
            percent_choice="${percent_choice:-1}"
            
            local partner_percent="$default_percent"
            if [[ "$percent_choice" == "2" ]]; then
                read -erp "Введите процент комиссии (1-100): " custom_percent
                if [[ "$custom_percent" =~ ^[0-9]+$ ]] && [[ "$custom_percent" -ge 1 ]] && [[ "$custom_percent" -le 100 ]]; then
                    partner_percent="$custom_percent"
                else
                    print_message "WARN" "Некорректное значение, используется $default_percent%"
                fi
            fi
            
            print_message "INFO" "Процент комиссии для партнёров: $partner_percent%"
            
            # Создаём записи партнёров для всех пользователей с балансом
            local created_count=0
            tail -n +2 "$balances_file" | while IFS=',' read -r tg_id username fname balance_kop balance_rub; do
                [[ -z "$tg_id" ]] && continue
                echo "$tg_id,$balance_rub,$partner_percent" >> "$partner_create_file"
                ((created_count++))
            done
            
            created_count=$(($(wc -l < "$partner_create_file") - 1))
            
            print_message "SUCCESS" "Подготовлено партнёров к созданию: $created_count"
            
            # Показываем превью
            echo ""
            echo -e "${CYAN}Превью (первые 5 записей):${RESET}"
            echo "telegram_id | баланс | процент"
            echo "------------|--------|--------"
            tail -n +2 "$partner_create_file" | head -5 | while IFS=',' read -r tid bal pct; do
                printf "%s | %s ₽ | %s%%\n" "$tid" "$bal" "$pct"
            done
            echo ""
            
            # Отчёт
            {
                echo "═══════════════════════════════════════════════════════════"
                echo "  СОЗДАНИЕ ПАРТНЁРОВ С БАЛАНСОМ"
                echo "═══════════════════════════════════════════════════════════"
                echo ""
                echo "Процент комиссии: $partner_percent%"
                echo "Источник процента: $([ "$partner_percent" == "$default_percent" ] && echo "Bedolaga" || echo "указан вручную")"
                echo ""
                echo "ПАРТНЁРЫ ДЛЯ СОЗДАНИЯ:"
                cat "$partner_create_file"
                echo ""
                echo "SQL для импорта (выполняется автоматически при импорте):"
                echo "INSERT INTO partner (telegram_id, available_balance, percent)"
                echo "VALUES (telegram_id, balance, percent)"
                echo "ON CONFLICT (telegram_id) DO UPDATE SET"
                echo "  available_balance = partner.available_balance + EXCLUDED.available_balance;"
            } > "$balance_report"
            ;;
            
        "ignore")
            print_message "WARN" "Балансы проигнорированы!"
            
            {
                echo "═══════════════════════════════════════════════════════════"
                echo "  ⚠️  БАЛАНСЫ БЫЛИ ПРОИГНОРИРОВАНЫ (ПОТЕРЯ ДАННЫХ)"
                echo "  Дата: $(date '+%Y-%m-%d %H:%M:%S')"
                echo "═══════════════════════════════════════════════════════════"
                echo ""
                echo "РЕЗЕРВНАЯ КОПИЯ ПОТЕРЯННЫХ БАЛАНСОВ:"
                cat "$balances_file"
            } > "$balance_report"
            ;;
    esac
    
    return 0
}

# --- Функция: Экспорт данных из JSON бэкапа Bedolaga ---
# Парсит database.json и создаёт CSV файлы для импорта
migrate_export_from_json() {
    debug_log "MIGRATE" "Starting JSON export from backup archive"
    print_message "INFO" "Экспорт данных из JSON бэкапа Bedolaga..."
    
    local db_json="$MIGRATION_EXTRACTED_DIR/database.json"
    
    if [[ ! -f "$db_json" ]]; then
        print_message "ERROR" "Файл database.json не найден в распакованном архиве"
        return 1
    fi
    
    local export_dir="$MIGRATION_WORK_DIR/export"
    mkdir -p "$export_dir"
    
    # P2: Список временных файлов для очистки при выходе
    local temp_files=()
    cleanup_temp_files() {
        for f in "${temp_files[@]}"; do
            [[ -f "$f" ]] && rm -f "$f"
        done
    }
    trap cleanup_temp_files RETURN
    
    # P2: Функция валидации CSV
    validate_csv() {
        local csv_file="$1"
        local expected_name="$2"
        
        if [[ ! -f "$csv_file" ]]; then
            debug_log "MIGRATE" "CSV validation: $expected_name - file not found"
            return 1
        fi
        
        local lines=$(wc -l < "$csv_file" 2>/dev/null)
        if [[ "$lines" -lt 1 ]]; then
            debug_log "MIGRATE" "CSV validation: $expected_name - empty file"
            return 1
        fi
        
        # Проверяем консистентность количества колонок (первые 5 строк)
        local expected_cols=$(head -1 "$csv_file" | awk -F',' '{print NF}')
        local inconsistent=$(head -5 "$csv_file" | awk -F',' -v e="$expected_cols" 'NF != e {print NR}' | head -1)
        
        if [[ -n "$inconsistent" ]]; then
            debug_log "MIGRATE" "CSV validation: $expected_name - inconsistent columns at line $inconsistent"
            return 1
        fi
        
        debug_log "MIGRATE" "CSV validation: $expected_name - OK ($lines lines, $expected_cols cols)"
        return 0
    }
    
    # Проверяем наличие Python для парсинга JSON
    local python_cmd=""
    if command -v python3 &>/dev/null; then
        python_cmd="python3"
    elif command -v python &>/dev/null; then
        python_cmd="python"
    fi
    
    if [[ -z "$python_cmd" ]]; then
        print_message "ERROR" "Python не найден. Установите python3 для парсинга JSON бэкапа"
        return 1
    fi
    
    debug_log "MIGRATE" "Using Python: $python_cmd"
    
    # Вспомогательная функция для парсинга JSON массива через Python
    # Использует встроенный модуль json, без зависимости от jq
    parse_json_table() {
        local json_file="$1"
        local table_name="$2"
        local fields="$3"  # Comma-separated list of fields
        
        debug_log "MIGRATE" "Parsing table: $table_name, fields: $fields"
        
        $python_cmd - "$json_file" "$table_name" "$fields" << 'PYTHON_SCRIPT'
import sys
import json
import csv

json_file = sys.argv[1]
table_name = sys.argv[2]
fields = [f.strip() for f in sys.argv[3].split(',')]

try:
    with open(json_file, 'r', encoding='utf-8') as f:
        data = json.load(f)
except Exception as e:
    sys.stderr.write(f"Error loading JSON: {e}\n")
    sys.exit(1)

# Получаем таблицу из data
table_data = data.get('data', {}).get(table_name, [])

if not table_data:
    # Пустая таблица - выводим только заголовок
    print(','.join(fields))
    sys.exit(0)

# Записываем CSV в stdout
writer = csv.writer(sys.stdout)
writer.writerow(fields)

for row in table_data:
    values = []
    for field in fields:
        val = row.get(field, '')
        if val is None:
            val = ''
        elif isinstance(val, bool):
            val = 't' if val else 'f'
        elif isinstance(val, (int, float)):
            val = str(val)
        values.append(val)
    writer.writerow(values)
PYTHON_SCRIPT
    }
    
    # --- Экспорт users ---
    print_message "INFO" "Экспорт users..."
    local users_raw_file="$export_dir/users_raw.csv"
    local users_file="$export_dir/users.csv"
    temp_files+=("$users_raw_file")  # P2: Добавляем в список для очистки
    
    # Сначала экспортируем все поля
    parse_json_table "$db_json" "users" "id,telegram_id,username,first_name,language,created_at,balance_kopeks,referral_balance,status,last_activity,referred_by_id" > "$users_raw_file"
    
    # --- Создание маппинга id → telegram_id для JOIN-ов ---
    # Сохраняем в ассоциативный файл для быстрого поиска
    local id_map_file="$export_dir/.id_to_telegram.map"
    # P0: Race Condition fix - используем атомарную запись через временный файл
    awk -F',' 'NR>1 && $1!="" && $2!="" {print $1 "=" $2}' "$users_raw_file" > "${id_map_file}.tmp" && \
        mv "${id_map_file}.tmp" "$id_map_file"
    debug_log "MIGRATE" "Created id→telegram_id map with $(wc -l < "$id_map_file") entries"
    
    # Конвертируем в формат совместимый с psql экспортом:
    # telegram_id,username,first_name,language,created_at,balance_kopeks,referral_balance,status
    echo "telegram_id,username,first_name,language,created_at,balance_kopeks,referral_balance,status" > "$users_file"
    awk -F',' 'NR > 1 {
        # Поля: id,telegram_id,username,first_name,language,created_at,balance_kopeks,referral_balance,status,...
        telegram_id = $2
        username = $3
        first_name = $4
        language = $5
        created_at = $6
        balance_kopeks = $7
        referral_balance = $8
        status = $9
        
        # Обработка пустых значений
        if (balance_kopeks == "") balance_kopeks = "0"
        if (referral_balance == "") referral_balance = "0"
        if (status == "") status = "active"
        
        print telegram_id "," username "," first_name "," language "," created_at "," balance_kopeks "," referral_balance "," status
    }' "$users_raw_file" >> "$users_file"
    
    local user_count=0
    [[ -s "$users_file" ]] && user_count=$(($(wc -l < "$users_file") - 1))
    print_message "SUCCESS" "Экспортировано пользователей: $user_count"
    debug_log "MIGRATE" "Users exported: $user_count"
    
    # --- Экспорт реферальных связей ---
    print_message "INFO" "Экспорт реферальных связей..."
    local referrals_file="$export_dir/referrals.csv"
    
    # Нужен JOIN: users.referred_by_id → users.id → telegram_id
    # Создаём CSV с telegram_id вместо internal id
    # Читаем из users_raw_file т.к. там есть referred_by_id (поле $11)
    echo "referee_telegram_id,referrer_telegram_id,created_at" > "$referrals_file"
    
    awk -F',' -v mapfile="$id_map_file" '
    BEGIN {
        while ((getline line < mapfile) > 0) {
            split(line, parts, "=")
            id_map[parts[1]] = parts[2]
        }
    }
    NR > 1 {
        # Формат users_raw: id,telegram_id,username,first_name,language,created_at,balance_kopeks,referral_balance,status,last_activity,referred_by_id
        telegram_id = $2
        referred_by_id = $11
        created_at = $6
        
        if (referred_by_id != "" && referred_by_id in id_map) {
            referrer_tg = id_map[referred_by_id]
            print telegram_id "," referrer_tg "," created_at
        }
    }
    ' "$users_raw_file" >> "$referrals_file"
    
    local referral_count=0
    [[ -s "$referrals_file" ]] && referral_count=$(($(wc -l < "$referrals_file") - 1))
    print_message "SUCCESS" "Экспортировано реферальных связей: $referral_count"
    
    # --- Экспорт subscriptions ---
    print_message "INFO" "Экспорт подписок..."
    local subscriptions_raw="$export_dir/subscriptions_raw.csv"
    local subscriptions_file="$export_dir/subscriptions.csv"
    
    parse_json_table "$db_json" "subscriptions" "id,user_id,end_date,subscription_url,is_trial,device_limit,autopay_enabled,status" > "$subscriptions_raw"
    
    # JOIN с users для получения telegram_id и фильтрация активных
    echo "telegram_id,expire_at,subscription_link,is_trial,device_limit,autopay_enabled" > "$subscriptions_file"
    
    awk -F',' -v mapfile="$id_map_file" '
    BEGIN {
        while ((getline line < mapfile) > 0) {
            split(line, parts, "=")
            id_map[parts[1]] = parts[2]
        }
        skipped = 0
    }
    NR > 1 {
        user_id = $2
        end_date = $3
        subscription_url = $4
        is_trial = $5
        device_limit = $6
        autopay = $7
        status = $8
        
        # P1: Логирование пустых user_id
        if (user_id == "") {
            skipped++
            next
        }
        
        # Только активные подписки
        if (status == "active" && user_id in id_map) {
            telegram_id = id_map[user_id]
            print telegram_id "," end_date "," subscription_url "," is_trial "," device_limit "," autopay
        }
    }
    END {
        if (skipped > 0) {
            print "WARN: Skipped " skipped " subscriptions with empty user_id" > "/dev/stderr"
        }
    }
    ' "$subscriptions_raw" >> "$subscriptions_file"
    
    local subs_count=0
    [[ -s "$subscriptions_file" ]] && subs_count=$(($(wc -l < "$subscriptions_file") - 1))
    print_message "SUCCESS" "Экспортировано активных подписок: $subs_count"
    
    # --- Экспорт transactions ---
    print_message "INFO" "Экспорт транзакций..."
    local transactions_raw="$export_dir/transactions_raw.csv"
    local transactions_file="$export_dir/transactions.csv"
    
    # В JSON поле is_completed (boolean), не status
    parse_json_table "$db_json" "transactions" "id,user_id,amount_kopeks,payment_method,is_completed,created_at" > "$transactions_raw"
    
    # JOIN с users и фильтрация по is_completed
    # Формат вывода для совместимости с transform: id,user_id,amount,payment_method,status,created_at,subscription_days
    echo "id,user_id,amount,payment_method,status,created_at,subscription_days" > "$transactions_file"
    
    awk -F',' -v mapfile="$id_map_file" '
    BEGIN {
        while ((getline line < mapfile) > 0) {
            split(line, parts, "=")
            id_map[parts[1]] = parts[2]
        }
        skipped = 0
    }
    NR > 1 {
        id = $1
        user_id = $2
        amount = $3
        payment_method = $4
        is_completed = $5  # "t" или "f"
        created_at = $6
        
        # P1: Логирование пустых user_id
        if (user_id == "") {
            skipped++
            next
        }
        
        # Только завершённые транзакции (is_completed = "t")
        if (is_completed == "t" && user_id in id_map) {
            telegram_id = id_map[user_id]
            # subscription_days отсутствует в JSON - ставим пустое значение
            print id "," telegram_id "," amount "," payment_method ",completed," created_at ","
        }
    }
    END {
        if (skipped > 0) {
            print "WARN: Skipped " skipped " transactions with empty user_id" > "/dev/stderr"
        }
    }
    ' "$transactions_raw" >> "$transactions_file"
    
    local tx_count=0
    [[ -s "$transactions_file" ]] && tx_count=$(($(wc -l < "$transactions_file") - 1))
    print_message "SUCCESS" "Экспортировано транзакций: $tx_count"
    
    # --- Экспорт promocodes ---
    # В Bedolaga промокоды могут давать:
    # 1) subscription_days > 0 — дни подписки (мигрируются)
    # 2) bonus_kopeks > 0 — деньги на баланс (НЕ мигрируются, сохраняются в NOT_MIGRATED)
    print_message "INFO" "Экспорт промокодов..."
    local promocodes_file="$export_dir/promocodes.csv"
    local promocodes_balance_file="$export_dir/promocodes_balance_type.csv"
    
    # Экспортируем с bonus_kopeks для разделения типов
    parse_json_table "$db_json" "promocodes" "code,subscription_days,bonus_kopeks,max_uses,current_uses,is_active,created_at" > "$export_dir/promocodes_full.csv"
    
    # Разделяем: дни → promocodes.csv, баланс → promocodes_balance_type.csv
    echo "code,subscription_days,max_uses,current_uses,is_active,created_at" > "$promocodes_file"
    echo "code,bonus_kopeks,bonus_rub,max_uses,current_uses,is_active,created_at" > "$promocodes_balance_file"
    
    local promo_days_count=0
    local promo_balance_count=0
    
    while IFS=',' read -r code sub_days bonus_kop max_uses cur_uses is_active created_at; do
        [[ -z "$code" || "$code" == "code" ]] && continue
        
        # Проверяем тип промокода
        local has_days=false
        local has_balance=false
        [[ -n "$sub_days" && "$sub_days" != "0" && "$sub_days" != "null" ]] && has_days=true
        [[ -n "$bonus_kop" && "$bonus_kop" != "0" && "$bonus_kop" != "null" ]] && has_balance=true
        
        if [[ "$has_days" == "true" ]]; then
            # Промокод на дни — мигрируется
            echo "$code,$sub_days,$max_uses,$cur_uses,$is_active,$created_at" >> "$promocodes_file"
            ((promo_days_count++))
        elif [[ "$has_balance" == "true" ]]; then
            # Промокод на баланс — НЕ мигрируется
            local bonus_rub=$(awk "BEGIN {printf \"%.2f\", ${bonus_kop:-0}/100}")
            echo "$code,$bonus_kop,$bonus_rub,$max_uses,$cur_uses,$is_active,$created_at" >> "$promocodes_balance_file"
            ((promo_balance_count++))
        fi
    done < "$export_dir/promocodes_full.csv"
    
    print_message "SUCCESS" "Экспортировано промокодов (дни): $promo_days_count"
    if [[ $promo_balance_count -gt 0 ]]; then
        print_message "WARN" "Промокодов на баланс (не мигрируются): $promo_balance_count"
        print_message "INFO" "Сохранены в: promocodes_balance_type.csv"
    fi
    
    # Удаляем временный файл
    rm -f "$export_dir/promocodes_full.csv"
    
    # --- Экспорт promocode_uses ---
    print_message "INFO" "Экспорт использований промокодов..."
    local promo_uses_raw="$export_dir/promocode_uses_raw.csv"
    local promo_uses_file="$export_dir/promocode_uses.csv"
    
    parse_json_table "$db_json" "promocode_uses" "user_id,promocode_id,used_at" > "$promo_uses_raw"
    
    # Создаём маппинг promocode_id → code
    local promo_map_file="$export_dir/.promo_id_to_code.map"
    
    # Нам нужен id из JSON, экспортируем с id
    parse_json_table "$db_json" "promocodes" "id,code" > "$export_dir/promocodes_with_id.csv"
    # P0: Race Condition fix - атомарная запись
    awk -F',' 'NR>1 && $1!="" && $2!="" {print $1 "=" $2}' "$export_dir/promocodes_with_id.csv" > "${promo_map_file}.tmp" && \
        mv "${promo_map_file}.tmp" "$promo_map_file"
    
    echo "customer_telegram_id,promo_code,used_at" > "$promo_uses_file"
    
    awk -F',' -v usermap="$id_map_file" -v promomap="$promo_map_file" '
    BEGIN {
        while ((getline line < usermap) > 0) {
            split(line, parts, "=")
            user_map[parts[1]] = parts[2]
        }
        while ((getline line < promomap) > 0) {
            split(line, parts, "=")
            promo_map[parts[1]] = parts[2]
        }
    }
    NR > 1 {
        user_id = $1
        promo_id = $2
        used_at = $3
        
        if (user_id in user_map && promo_id in promo_map) {
            print user_map[user_id] "," promo_map[promo_id] "," used_at
        }
    }
    ' "$promo_uses_raw" >> "$promo_uses_file"
    
    local promo_uses_count=0
    [[ -s "$promo_uses_file" ]] && promo_uses_count=$(($(wc -l < "$promo_uses_file") - 1))
    print_message "SUCCESS" "Экспортировано использований промокодов: $promo_uses_count"
    
    # --- Экспорт tickets ---
    print_message "INFO" "Экспорт тикетов..."
    local tickets_raw="$export_dir/tickets_raw.csv"
    local tickets_file="$export_dir/tickets.csv"
    
    parse_json_table "$db_json" "tickets" "id,user_id,title,status,created_at,updated_at,closed_at" > "$tickets_raw"
    
    echo "id,customer_telegram_id,subject,status,created_at,updated_at,closed_at" > "$tickets_file"
    
    awk -F',' -v mapfile="$id_map_file" '
    BEGIN {
        while ((getline line < mapfile) > 0) {
            split(line, parts, "=")
            id_map[parts[1]] = parts[2]
        }
    }
    NR > 1 {
        id = $1
        user_id = $2
        title = $3
        status = $4
        created_at = $5
        updated_at = $6
        closed_at = $7
        
        if (user_id in id_map) {
            telegram_id = id_map[user_id]
            print id "," telegram_id "," title "," status "," created_at "," updated_at "," closed_at
        }
    }
    ' "$tickets_raw" >> "$tickets_file"
    
    local tickets_count=0
    [[ -s "$tickets_file" ]] && tickets_count=$(($(wc -l < "$tickets_file") - 1))
    print_message "SUCCESS" "Экспортировано тикетов: $tickets_count"
    
    # --- Экспорт ticket_messages ---
    print_message "INFO" "Экспорт сообщений тикетов..."
    local messages_raw="$export_dir/ticket_messages_raw.csv"
    local messages_file="$export_dir/ticket_messages.csv"
    
    parse_json_table "$db_json" "ticket_messages" "id,ticket_id,user_id,message_text,is_from_admin,created_at" > "$messages_raw"
    
    echo "id,ticket_id,sender_type,sender_id,message,created_at" > "$messages_file"
    
    awk -F',' -v mapfile="$id_map_file" '
    BEGIN {
        while ((getline line < mapfile) > 0) {
            split(line, parts, "=")
            id_map[parts[1]] = parts[2]
        }
    }
    NR > 1 {
        id = $1
        ticket_id = $2
        user_id = $3
        message = $4
        is_admin = $5
        created_at = $6
        
        sender_type = (is_admin == "t" || is_admin == "true" || is_admin == "True") ? "admin" : "customer"
        
        if (user_id in id_map) {
            telegram_id = id_map[user_id]
            # P0: CSV Formula Injection protection - prefix with apostrophe if starts with =, +, -, @
            if (message ~ /^[=+\-@]/) {
                message = "'\''" message
            }
            # CSV-экранирование: удваиваем кавычки внутри, оборачиваем в кавычки если есть запятые/кавычки/переносы
            gsub(/"/, "\"\"", message)
            if (message ~ /[,"\n\r]/) {
                message = "\"" message "\""
            }
            print id "," ticket_id "," sender_type "," telegram_id "," message "," created_at
        }
    }
    ' "$messages_raw" >> "$messages_file"
    
    local messages_count=0
    [[ -s "$messages_file" ]] && messages_count=$(($(wc -l < "$messages_file") - 1))
    print_message "SUCCESS" "Экспортировано сообщений тикетов: $messages_count"
    
    # --- Экспорт broadcast_history ---
    print_message "INFO" "Экспорт истории рассылок..."
    local broadcast_file="$export_dir/broadcast.csv"
    
    parse_json_table "$db_json" "broadcast_history" "id,message_text,target_type,created_at,status,total_count,sent_count,failed_count" > "$export_dir/broadcast_raw.csv"
    
    # Добавляем заголовок с нужными полями
    echo "id,content,type,language,created_at,status,total_count,sent_count,failed_count" > "$broadcast_file"
    
    awk -F',' 'NR > 1 {
        id = $1
        content = $2
        type = $3
        created_at = $4
        status = $5
        total = $6
        sent = $7
        failed = $8
        
        # P0: CSV Formula Injection protection
        if (content ~ /^[=+\-@]/) {
            content = "'\''" content
        }
        # CSV-экранирование: удваиваем кавычки внутри, оборачиваем если есть спецсимволы
        gsub(/"/, "\"\"", content)
        if (content ~ /[,"\n\r]/) {
            content = "\"" content "\""
        }
        print id "," content "," type ",," created_at "," status "," total "," sent "," failed
    }' "$export_dir/broadcast_raw.csv" >> "$broadcast_file"
    
    local broadcast_count=0
    [[ -s "$broadcast_file" ]] && broadcast_count=$(($(wc -l < "$broadcast_file") - 1))
    print_message "SUCCESS" "Экспортировано рассылок: $broadcast_count"
    
    # --- Экспорт user_activity ---
    print_message "INFO" "Экспорт активности пользователей..."
    local activity_file="$export_dir/user_activity.csv"
    
    echo "telegram_id,last_activity" > "$activity_file"
    
    # Читаем из users_raw_file т.к. там есть last_activity (поле $10)
    # Формат users_raw: id,telegram_id,username,first_name,language,created_at,balance_kopeks,referral_balance,status,last_activity,referred_by_id
    awk -F',' 'NR > 1 {
        telegram_id = $2
        last_activity = $10
        
        if (telegram_id != "" && last_activity != "") {
            print telegram_id "," last_activity
        }
    }' "$users_raw_file" >> "$activity_file"
    
    local activity_count=0
    [[ -s "$activity_file" ]] && activity_count=$(($(wc -l < "$activity_file") - 1))
    print_message "SUCCESS" "Экспортировано записей активности: $activity_count"
    
    # --- Экспорт referral_earnings ---
    print_message "INFO" "Экспорт реферальных бонусов..."
    local ref_bonus_raw="$export_dir/referral_earnings_raw.csv"
    local ref_bonus_file="$export_dir/referral_bonus.csv"
    
    parse_json_table "$db_json" "referral_earnings" "id,user_id,referral_id,reason,amount_kopeks,created_at" > "$ref_bonus_raw"
    
    echo "id,referrer_telegram_id,referee_telegram_id,reason,amount_kopeks,created_at" > "$ref_bonus_file"
    
    awk -F',' -v mapfile="$id_map_file" '
    BEGIN {
        while ((getline line < mapfile) > 0) {
            split(line, parts, "=")
            id_map[parts[1]] = parts[2]
        }
    }
    NR > 1 {
        id = $1
        user_id = $2      # referrer (кто получил бонус)
        referral_id = $3  # referee (за кого получен бонус)
        reason = $4
        amount = $5
        created_at = $6
        
        if (user_id in id_map && referral_id in id_map) {
            referrer_tg = id_map[user_id]
            referee_tg = id_map[referral_id]
            print id "," referrer_tg "," referee_tg "," reason "," amount "," created_at
        }
    }
    ' "$ref_bonus_raw" >> "$ref_bonus_file"
    
    local ref_bonus_count=0
    [[ -s "$ref_bonus_file" ]] && ref_bonus_count=$(($(wc -l < "$ref_bonus_file") - 1))
    print_message "SUCCESS" "Экспортировано записей реферальных бонусов: $ref_bonus_count"
    
    # P2: Валидация основных CSV файлов
    local validation_errors=0
    for csv in "$users_file" "$transactions_file" "$promocodes_file"; do
        if [[ -f "$csv" ]] && ! validate_csv "$csv" "$(basename "$csv")"; then
            ((validation_errors++))
        fi
    done
    
    if [[ $validation_errors -gt 0 ]]; then
        print_message "WARN" "Обнаружены проблемы в $validation_errors CSV файлах (см. debug log)"
    fi
    
    # Очистка временных файлов
    rm -f "$export_dir"/*_raw.csv "$export_dir"/.*.map "$export_dir"/promocodes_with_id.csv 2>/dev/null
    
    debug_log "MIGRATE" "JSON export complete: users=$user_count, referrals=$referral_count, subs=$subs_count, tx=$tx_count, promo=$promo_count, tickets=$tickets_count, messages=$messages_count, broadcast=$broadcast_count"
    
    print_message "SUCCESS" "Экспорт из JSON завершён!"
    return 0
}

# --- Функция: Экспорт данных из источника ---
migrate_export_data() {
    debug_log "MIGRATE" "Starting data export"
    
    # Если источник - архив JSON, используем JSON-парсер
    if [[ "$MIGRATION_SOURCE_TYPE" == "archive" ]]; then
        debug_log "MIGRATE" "Source type is archive, using JSON export"
        
        # Проверяем что архив выбран
        if [[ -z "$MIGRATION_SOURCE_BACKUP" || ! -f "$MIGRATION_SOURCE_BACKUP" ]]; then
            print_message "ERROR" "Архив не выбран или не найден"
            return 1
        fi
        
        # Распаковываем архив если ещё не распакован
        if [[ -z "$MIGRATION_EXTRACTED_DIR" || ! -d "$MIGRATION_EXTRACTED_DIR" || ! -f "$MIGRATION_EXTRACTED_DIR/database.json" ]]; then
            debug_log "MIGRATE" "Extracting archive before export..."
            if ! extract_bedolaga_backup "$MIGRATION_SOURCE_BACKUP"; then
                print_message "ERROR" "Не удалось распаковать архив"
                return 1
            fi
        fi
        
        migrate_export_from_json
        return $?
    fi
    
    print_message "INFO" "Экспорт данных из Bedolaga (PostgreSQL)..."
    
    local export_dir="$MIGRATION_WORK_DIR/export"
    mkdir -p "$export_dir"
    
    local export_sql="
-- Export users
COPY (
    SELECT 
        telegram_id,
        tg_username,
        tg_first_name,
        language,
        created_at,
        balance,
        referral_balance,
        referrer_id
    FROM users
    ORDER BY telegram_id
) TO STDOUT WITH CSV HEADER;
"
    
    local users_file="$export_dir/users.csv"
    local referrals_file="$export_dir/referrals.csv"
    local transactions_file="$export_dir/transactions.csv"
    local promocodes_file="$export_dir/promocodes.csv"
    local promo_uses_file="$export_dir/promocode_uses.csv"
    
    # Экспорт users (без referrer_id - он идёт в отдельный файл)
    # Добавлено поле status для миграции is_blocked
    if [[ -n "$MIGRATION_SOURCE_CONTAINER" ]]; then
        docker exec "$MIGRATION_SOURCE_CONTAINER" psql -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (SELECT telegram_id, username, first_name, language, created_at, balance_kopeks, 0 as referral_balance, COALESCE(status, 'active') as status FROM users ORDER BY telegram_id) TO STDOUT WITH CSV HEADER;
        " > "$users_file" 2>/dev/null
    else
        export PGPASSWORD="$MIGRATION_SOURCE_PASS"
        psql -h "$MIGRATION_SOURCE_HOST" -p "$MIGRATION_SOURCE_PORT" -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (SELECT telegram_id, username, first_name, language, created_at, balance_kopeks, 0 as referral_balance, COALESCE(status, 'active') as status FROM users ORDER BY telegram_id) TO STDOUT WITH CSV HEADER;
        " > "$users_file" 2>/dev/null
        unset PGPASSWORD
    fi
    
    if [[ ! -s "$users_file" ]]; then
        print_message "ERROR" "Не удалось экспортировать пользователей"
        return 1
    fi
    
    local user_count=$(wc -l < "$users_file")
    user_count=$((user_count - 1))  # Минус заголовок
    print_message "SUCCESS" "Экспортировано пользователей: $user_count"
    
    # Экспорт реферальных связей (referee_telegram_id, referrer_telegram_id, created_at)
    # JOIN для преобразования referred_by_id (internal id) → telegram_id
    if [[ -n "$MIGRATION_SOURCE_CONTAINER" ]]; then
        docker exec "$MIGRATION_SOURCE_CONTAINER" psql -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (
                SELECT 
                    u.telegram_id as referee_telegram_id,
                    r.telegram_id as referrer_telegram_id,
                    u.created_at
                FROM users u
                INNER JOIN users r ON u.referred_by_id = r.id
                WHERE u.referred_by_id IS NOT NULL
                ORDER BY u.created_at
            ) TO STDOUT WITH CSV HEADER;
        " > "$referrals_file" 2>/dev/null
    else
        export PGPASSWORD="$MIGRATION_SOURCE_PASS"
        psql -h "$MIGRATION_SOURCE_HOST" -p "$MIGRATION_SOURCE_PORT" -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (
                SELECT 
                    u.telegram_id as referee_telegram_id,
                    r.telegram_id as referrer_telegram_id,
                    u.created_at
                FROM users u
                INNER JOIN users r ON u.referred_by_id = r.id
                WHERE u.referred_by_id IS NOT NULL
                ORDER BY u.created_at
            ) TO STDOUT WITH CSV HEADER;
        " > "$referrals_file" 2>/dev/null
        unset PGPASSWORD
    fi
    
    local referral_count=0
    [[ -s "$referrals_file" ]] && referral_count=$(($(wc -l < "$referrals_file") - 1))
    print_message "SUCCESS" "Экспортировано реферальных связей: $referral_count"
    
    # Экспорт transactions
    if [[ -n "$MIGRATION_SOURCE_CONTAINER" ]]; then
        docker exec "$MIGRATION_SOURCE_CONTAINER" psql -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (SELECT id, user_id, amount, payment_method, status, created_at, subscription_days FROM transactions WHERE status='completed' ORDER BY id) TO STDOUT WITH CSV HEADER;
        " > "$transactions_file" 2>/dev/null
    else
        export PGPASSWORD="$MIGRATION_SOURCE_PASS"
        psql -h "$MIGRATION_SOURCE_HOST" -p "$MIGRATION_SOURCE_PORT" -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (SELECT id, user_id, amount, payment_method, status, created_at, subscription_days FROM transactions WHERE status='completed' ORDER BY id) TO STDOUT WITH CSV HEADER;
        " > "$transactions_file" 2>/dev/null
        unset PGPASSWORD
    fi
    
    local tx_count=0
    [[ -s "$transactions_file" ]] && tx_count=$(($(wc -l < "$transactions_file") - 1))
    print_message "SUCCESS" "Экспортировано транзакций: $tx_count"
    
    # Экспорт promocodes
    if [[ -n "$MIGRATION_SOURCE_CONTAINER" ]]; then
        docker exec "$MIGRATION_SOURCE_CONTAINER" psql -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (SELECT code, bonus_days, max_uses, current_uses, is_active, created_at FROM promocodes ORDER BY code) TO STDOUT WITH CSV HEADER;
        " > "$promocodes_file" 2>/dev/null
    else
        export PGPASSWORD="$MIGRATION_SOURCE_PASS"
        psql -h "$MIGRATION_SOURCE_HOST" -p "$MIGRATION_SOURCE_PORT" -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (SELECT code, bonus_days, max_uses, current_uses, is_active, created_at FROM promocodes ORDER BY code) TO STDOUT WITH CSV HEADER;
        " > "$promocodes_file" 2>/dev/null
        unset PGPASSWORD
    fi
    
    local promo_count=0
    [[ -s "$promocodes_file" ]] && promo_count=$(($(wc -l < "$promocodes_file") - 1))
    print_message "SUCCESS" "Экспортировано промокодов: $promo_count"
    
    # Экспорт promocode_uses (история использования промокодов)
    # JOIN для преобразования user_id и promocode_id во внешние идентификаторы
    local promo_uses_file="$export_dir/promocode_uses.csv"
    if [[ -n "$MIGRATION_SOURCE_CONTAINER" ]]; then
        docker exec "$MIGRATION_SOURCE_CONTAINER" psql -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (
                SELECT 
                    u.telegram_id as customer_telegram_id,
                    p.code as promo_code,
                    pu.used_at
                FROM promocode_uses pu
                INNER JOIN users u ON pu.user_id = u.id
                INNER JOIN promocodes p ON pu.promocode_id = p.id
                ORDER BY pu.used_at
            ) TO STDOUT WITH CSV HEADER;
        " > "$promo_uses_file" 2>/dev/null
    else
        export PGPASSWORD="$MIGRATION_SOURCE_PASS"
        psql -h "$MIGRATION_SOURCE_HOST" -p "$MIGRATION_SOURCE_PORT" -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (
                SELECT 
                    u.telegram_id as customer_telegram_id,
                    p.code as promo_code,
                    pu.used_at
                FROM promocode_uses pu
                INNER JOIN users u ON pu.user_id = u.id
                INNER JOIN promocodes p ON pu.promocode_id = p.id
                ORDER BY pu.used_at
            ) TO STDOUT WITH CSV HEADER;
        " > "$promo_uses_file" 2>/dev/null
        unset PGPASSWORD
    fi
    
    local promo_uses_count=0
    [[ -s "$promo_uses_file" ]] && promo_uses_count=$(($(wc -l < "$promo_uses_file") - 1))
    print_message "SUCCESS" "Экспортировано использований промокодов: $promo_uses_count"
    
    # Экспорт подписок (subscription_url, end_date, is_trial, device_limit, autopay_enabled)
    # JOIN для преобразования user_id → telegram_id
    local subscriptions_file="$export_dir/subscriptions.csv"
    if [[ -n "$MIGRATION_SOURCE_CONTAINER" ]]; then
        docker exec "$MIGRATION_SOURCE_CONTAINER" psql -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (
                SELECT 
                    u.telegram_id,
                    s.end_date as expire_at,
                    s.subscription_url as subscription_link,
                    s.is_trial,
                    s.device_limit,
                    s.autopay_enabled,
                    s.autopay_days_before,
                    s.status
                FROM subscriptions s
                INNER JOIN users u ON s.user_id = u.id
                WHERE s.status = 'active' AND s.end_date > NOW()
                ORDER BY u.telegram_id
            ) TO STDOUT WITH CSV HEADER;
        " > "$subscriptions_file" 2>/dev/null
    else
        export PGPASSWORD="$MIGRATION_SOURCE_PASS"
        psql -h "$MIGRATION_SOURCE_HOST" -p "$MIGRATION_SOURCE_PORT" -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (
                SELECT 
                    u.telegram_id,
                    s.end_date as expire_at,
                    s.subscription_url as subscription_link,
                    s.is_trial,
                    s.device_limit,
                    s.autopay_enabled,
                    s.autopay_days_before,
                    s.status
                FROM subscriptions s
                INNER JOIN users u ON s.user_id = u.id
                WHERE s.status = 'active' AND s.end_date > NOW()
                ORDER BY u.telegram_id
            ) TO STDOUT WITH CSV HEADER;
        " > "$subscriptions_file" 2>/dev/null
        unset PGPASSWORD
    fi
    
    local subs_count=0
    [[ -s "$subscriptions_file" ]] && subs_count=$(($(wc -l < "$subscriptions_file") - 1))
    print_message "SUCCESS" "Экспортировано активных подписок: $subs_count"
    
    # Экспорт тикетов поддержки (tickets → support_ticket)
