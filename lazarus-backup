    # 1) Настройки из архива без маппинга
    if [[ -n "$MIGRATION_SOURCE_BACKUP_FILE" && -f "$MIGRATION_SOURCE_BACKUP_FILE" ]]; then
        echo -e "${GREEN}=== ИЗ АРХИВА (system_settings) ===${RESET}"
        echo ""
        
        # Читаем настройки из архива
        if [[ -n "$MIGRATION_EXTRACTED_DIR" && -f "$MIGRATION_EXTRACTED_DIR/database.json" ]]; then
            declare -A backup_settings
            read_all_bedolaga_settings backup_settings
            
            local archive_count=0
            local lines=()
            for key in "${!backup_settings[@]}"; do
                local rwp_key="${BEDOLAGA_BACKUP_TO_RWP[$key]:-}"
                # Показываем только те, у которых нет маппинга
                if [[ -z "$rwp_key" ]]; then
                    local value="${backup_settings[$key]}"
                    
                    # Маскируем чувствительные данные
                    if [[ "$key" =~ TOKEN|SECRET|PASSWORD|KEY ]]; then
                        [[ -n "$value" ]] && value="${value:0:6}***"
                    fi
                    
                    [[ ${#value} -gt 40 ]] && value="${value:0:37}..."
                    
                    lines+=("$(printf "  %-35s = %s" "$key" "$value")")
                    ((archive_count++))
                    ((count++))
                fi
            done
            
            # Сортируем и выводим
            printf '%s\n' "${lines[@]}" | sort
            
            echo ""
            echo "Без аналога в архиве: $archive_count"
        else
            print_message "WARN" "Архив не распакован"
        fi
        echo ""
    fi
    
    # 2) Настройки из .env без маппинга
    if [[ -n "$MIGRATION_SOURCE_ENV_FILE" && -f "$MIGRATION_SOURCE_ENV_FILE" ]]; then
        echo -e "${YELLOW}=== ИЗ .ENV ===${RESET}"
        echo ""
        
        declare -A source_settings
        read_env_file "$MIGRATION_SOURCE_ENV_FILE" source_settings
        
        local env_count=0
        local env_lines=()
        for key in "${!source_settings[@]}"; do
            # Проверяем есть ли маппинг
            if [[ -z "${SETTINGS_ENV_TO_ENV[$key]}" && -z "${SETTINGS_ENV_TO_DB[$key]}" ]]; then
                local value="${source_settings[$key]}"
                
                # Маскируем чувствительные данные
                if [[ "$key" =~ TOKEN|SECRET|PASSWORD|KEY ]]; then
                    [[ -n "$value" ]] && value="${value:0:6}***"
                fi
                
                [[ ${#value} -gt 40 ]] && value="${value:0:37}..."
                
                env_lines+=("$(printf "  %-35s = %s" "$key" "$value")")
                ((env_count++))
                ((count++))
            fi
        done
        
        # Сортируем и выводим
        printf '%s\n' "${env_lines[@]}" | sort
        
        echo ""
        echo "Без аналога в .env: $env_count"
    fi
    
    echo ""
    echo -e "${GRAY}Всего настроек без аналога: $count${RESET}"
    echo ""
    read -erp "Enter..." dummy
}

# --- Функция: Выполнение миграции настроек ---
migrate_settings_execute() {
    debug_log "MIGRATE" "Starting settings migration"
    
    # Проверки источника
    if [[ -z "$MIGRATION_SOURCE_BACKUP_FILE" && -z "$MIGRATION_SOURCE_ENV_FILE" ]]; then
        print_message "ERROR" "Не указан ни архив бэкапа, ни .env файл Bedolaga"
        return 1
    fi
    
    if [[ -z "$MIGRATION_TARGET_ENV_FILE" ]]; then
        print_message "ERROR" "Путь к приёмнику .env не настроен"
        return 1
    fi
    
    if [[ -z "$MIGRATION_TARGET_CONTAINER" ]]; then
        print_message "WARN" "Контейнер БД RWP-Shop не настроен — настройки в БД не будут перенесены"
    fi
    
    echo ""
    echo -e "${RED}${BOLD}══════════════════════════════════════════════════${RESET}"
    echo -e "${RED}${BOLD}  ⚠️  ВНИМАНИЕ! МИГРАЦИЯ НАСТРОЕК!               ${RESET}"
    echo -e "${RED}${BOLD}══════════════════════════════════════════════════${RESET}"
    echo ""
    echo "Источники:"
    [[ -n "$MIGRATION_SOURCE_BACKUP_FILE" ]] && echo " • Архив: $(basename "$MIGRATION_SOURCE_BACKUP_FILE")"
    [[ -n "$MIGRATION_SOURCE_ENV_FILE" ]] && echo " • .env:  $MIGRATION_SOURCE_ENV_FILE"
    echo ""
    echo "Будут изменены:"
    echo " • Файл .env: $MIGRATION_TARGET_ENV_FILE"
    [[ -n "$MIGRATION_TARGET_CONTAINER" ]] && echo " • База данных: $MIGRATION_TARGET_CONTAINER / $MIGRATION_TARGET_DB"
    echo ""
    echo -e "${YELLOW}Рекомендуется сделать бэкап RWP-Shop перед продолжением!${RESET}"
    echo ""
    read -erp "Введите 'SETTINGS' для подтверждения: " confirm
    
    if [[ "$confirm" != "SETTINGS" ]]; then
        print_message "INFO" "Миграция отменена"
        return 0
    fi
    
    local work_dir="$MIGRATION_WORK_DIR"
    [[ -z "$work_dir" ]] && work_dir="${BACKUP_DIR}/migration_settings_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$work_dir"
    
    # Бэкап целевого .env
    if [[ -f "$MIGRATION_TARGET_ENV_FILE" ]]; then
        cp "$MIGRATION_TARGET_ENV_FILE" "$work_dir/target_env_backup.env"
        print_message "INFO" "Бэкап .env: $work_dir/target_env_backup.env"
    fi
    
    local env_migrated=0
    local db_migrated=0
    local backup_settings_migrated=0
    local defaults_used=0
    local errors=0
    
    # === ЭТАП 1: Распаковка архива Bedolaga (если указан) ===
    declare -A backup_settings
    if [[ -n "$MIGRATION_SOURCE_BACKUP_FILE" && -f "$MIGRATION_SOURCE_BACKUP_FILE" ]]; then
        print_message "INFO" "[1/3] Распаковка архива Bedolaga..."
        
        if extract_bedolaga_backup "$MIGRATION_SOURCE_BACKUP_FILE"; then
            # Читаем system_settings из бэкапа
            read_all_bedolaga_settings backup_settings
            print_message "SUCCESS" "Прочитано настроек из бэкапа: ${#backup_settings[@]}"
        else
            print_message "WARN" "Не удалось распаковать архив, продолжаем без него"
        fi
    fi
    
    # Читаем .env Bedolaga (если указан)
    declare -A env_settings
    if [[ -n "$MIGRATION_SOURCE_ENV_FILE" && -f "$MIGRATION_SOURCE_ENV_FILE" ]]; then
        read_env_file "$MIGRATION_SOURCE_ENV_FILE" env_settings
    fi
    
    # === ЭТАП 2: Миграция критических настроек в .env ===
    print_message "INFO" "[2/3] Миграция критических настроек в .env..."
    
    for bedolaga_key in "${!SETTINGS_ENV_TO_ENV[@]}"; do
        local rwp_key="${SETTINGS_ENV_TO_ENV[$bedolaga_key]}"
        local value=""
        local is_default=false
        
        # Приоритет: 1) .env Bedolaga → 2) Дефолт Bedolaga → 3) Дефолт RWP-Shop
        value="${env_settings[$bedolaga_key]:-}"
        
        if [[ -z "$value" ]]; then
            value="${BEDOLAGA_DEFAULTS[$bedolaga_key]:-}"
            [[ -n "$value" ]] && is_default=true
        fi
        
        if [[ -z "$value" ]]; then
            value="${RWP_SHOP_DEFAULTS[$rwp_key]:-}"
            [[ -n "$value" ]] && is_default=true
        fi
        
        if [[ -n "$value" ]]; then
            write_env_variable "$MIGRATION_TARGET_ENV_FILE" "$rwp_key" "$value"
            if $is_default; then
                debug_log "MIGRATE" "ENV: $bedolaga_key → $rwp_key (DEFAULT: $value)"
                ((defaults_used++))
            else
                debug_log "MIGRATE" "ENV: $bedolaga_key → $rwp_key = $value"
            fi
            ((env_migrated++))
        fi
    done
    
    print_message "SUCCESS" "Перенесено в .env: $env_migrated переменных"
    [[ $defaults_used -gt 0 ]] && echo -e "   ${GRAY}(из них дефолтных: $defaults_used)${RESET}"
    
    # === ЭТАП 3: Миграция настроек в БД RWP-Shop ===
    if [[ -n "$MIGRATION_TARGET_CONTAINER" ]]; then
        print_message "INFO" "[3/3] Миграция настроек в таблицу settings..."
        defaults_used=0
        
        local sql_file="$work_dir/settings_import.sql"
        echo "-- Settings migration: Bedolaga → RWP-Shop" > "$sql_file"
        echo "-- Generated: $(date '+%Y-%m-%d %H:%M:%S')" >> "$sql_file"
        echo "-- Sources: backup=${MIGRATION_SOURCE_BACKUP_FILE:-none}, env=${MIGRATION_SOURCE_ENV_FILE:-none}" >> "$sql_file"
        echo "" >> "$sql_file"
        
        # 3a) Сначала переносим из архива бэкапа (system_settings → settings)
        if [[ ${#backup_settings[@]} -gt 0 ]]; then
            echo "-- From Bedolaga backup (system_settings):" >> "$sql_file"
            
            for backup_key in "${!backup_settings[@]}"; do
                local rwp_key="${BEDOLAGA_BACKUP_TO_RWP[$backup_key]:-}"
                
                # Пропускаем настройки без маппинга
                [[ -z "$rwp_key" ]] && continue
                
                local value="${backup_settings[$backup_key]}"
                
                # Экранируем одинарные кавычки для SQL
                local escaped_value="${value//\'/\'\'}"
                
                # Конвертируем булевы значения
                if [[ "$value" =~ ^(true|false|True|False|TRUE|FALSE|1|0)$ ]]; then
                    case "${value,,}" in
                        true|1) escaped_value="true" ;;
                        false|0) escaped_value="false" ;;
                    esac
                fi
                
                echo "INSERT INTO settings (key, value, created_at, updated_at) VALUES ('$rwp_key', '$escaped_value', NOW(), NOW())" >> "$sql_file"
                echo "ON CONFLICT (key) DO UPDATE SET value = EXCLUDED.value, updated_at = NOW();" >> "$sql_file"
                
                debug_log "MIGRATE" "BACKUP→DB: $backup_key → $rwp_key = $value"
                ((backup_settings_migrated++))
            done
        fi
        
        # 3b) Затем переносим из .env (SETTINGS_ENV_TO_DB)
        if [[ ${#env_settings[@]} -gt 0 || ${#BEDOLAGA_DEFAULTS[@]} -gt 0 ]]; then
            echo "" >> "$sql_file"
            echo "-- From Bedolaga .env (SETTINGS_ENV_TO_DB):" >> "$sql_file"
            
            for bedolaga_key in "${!SETTINGS_ENV_TO_DB[@]}"; do
                local db_key="${SETTINGS_ENV_TO_DB[$bedolaga_key]}"
                local value=""
                local is_default=false
                
                # Приоритет: 1) Уже есть в backup_settings → пропускаем
                # Проверяем, не было ли это уже перенесено из бэкапа
                local already_from_backup=false
                for bk in "${!BEDOLAGA_BACKUP_TO_RWP[@]}"; do
                    if [[ "${BEDOLAGA_BACKUP_TO_RWP[$bk]}" == "$db_key" && -n "${backup_settings[$bk]:-}" ]]; then
                        already_from_backup=true
                        break
                    fi
                done
                
                $already_from_backup && continue
                
                # 2) .env Bedolaga → 3) Дефолт Bedolaga → 4) Дефолт RWP-Shop
                value="${env_settings[$bedolaga_key]:-}"
                
                if [[ -z "$value" ]]; then
                    value="${BEDOLAGA_DEFAULTS[$bedolaga_key]:-}"
                    [[ -n "$value" ]] && is_default=true
                fi
                
                if [[ -z "$value" ]]; then
                    value="${RWP_SHOP_DEFAULTS[$db_key]:-}"
                    [[ -n "$value" ]] && is_default=true
                fi
                
                if [[ -n "$value" ]]; then
                    local escaped_value="${value//\'/\'\'}"
                    
                    if [[ "$value" =~ ^(true|false|True|False|TRUE|FALSE|1|0)$ ]]; then
                        case "${value,,}" in
                            true|1) escaped_value="true" ;;
                            false|0) escaped_value="false" ;;
                        esac
                    fi
                    
                    echo "INSERT INTO settings (key, value, created_at, updated_at) VALUES ('$db_key', '$escaped_value', NOW(), NOW())" >> "$sql_file"
                    echo "ON CONFLICT (key) DO UPDATE SET value = EXCLUDED.value, updated_at = NOW();" >> "$sql_file"
                    
                    if $is_default; then
                        debug_log "MIGRATE" "ENV→DB: $bedolaga_key → $db_key (DEFAULT: $value)"
                        ((defaults_used++))
                    else
                        debug_log "MIGRATE" "ENV→DB: $bedolaga_key → $db_key = $value"
                    fi
                    ((db_migrated++))
                fi
            done
        fi
        
        # Выполняем SQL
        docker cp "$sql_file" "${MIGRATION_TARGET_CONTAINER}:/tmp/settings_import.sql"
        
        local sql_result
        sql_result=$(docker exec "$MIGRATION_TARGET_CONTAINER" psql -U "$MIGRATION_TARGET_USER" -d "$MIGRATION_TARGET_DB" -f /tmp/settings_import.sql 2>&1)
        local sql_exit=$?
        
        docker exec "$MIGRATION_TARGET_CONTAINER" rm -f /tmp/settings_import.sql
        
        if [[ $sql_exit -ne 0 ]]; then
            print_message "ERROR" "Ошибка SQL: $sql_result"
            ((errors++))
        else
            local total_db=$((backup_settings_migrated + db_migrated))
            print_message "SUCCESS" "Перенесено в settings DB: $total_db настроек"
            [[ $backup_settings_migrated -gt 0 ]] && echo -e "   ${GRAY}(из архива: $backup_settings_migrated)${RESET}"
            [[ $defaults_used -gt 0 ]] && echo -e "   ${GRAY}(из них дефолтных: $defaults_used)${RESET}"
        fi
    else
        print_message "WARN" "Пропущен импорт в БД — контейнер не настроен"
    fi
    
    # === ОТЧЁТ ===
    local report_file="$work_dir/settings_migration_report.txt"
    {
        echo "╔════════════════════════════════════════════════════════╗"
        echo "║         ОТЧЁТ МИГРАЦИИ НАСТРОЕК                        ║"
        echo "╚════════════════════════════════════════════════════════╝"
        echo ""
        echo "Дата: $(date '+%Y-%m-%d %H:%M:%S')"
        echo ""
        echo "=== ИСТОЧНИКИ ==="
        echo "Архив бэкапа: ${MIGRATION_SOURCE_BACKUP_FILE:-не указан}"
        echo ".env файл:    ${MIGRATION_SOURCE_ENV_FILE:-не указан}"
        echo ""
        echo "=== ПРИЁМНИКИ ==="
        echo ".env:         $MIGRATION_TARGET_ENV_FILE"
        echo "БД:           ${MIGRATION_TARGET_CONTAINER:-не настроен} / ${MIGRATION_TARGET_DB:-}"
        echo ""
        echo "=== РЕЗУЛЬТАТЫ ==="
        echo "Перенесено в .env: $env_migrated"
        echo "Из архива бэкапа в БД: $backup_settings_migrated"
        echo "Из .env в БД: $db_migrated"
        echo "Ошибок: $errors"
        echo ""
        echo "=== ВАЖНО ==="
        echo "1. Перезапустите бота для применения настроек из .env"
        echo "2. Проверьте админ-панель RWP-Shop для проверки настроек из БД"
        echo "3. Некоторые настройки могут потребовать ручной корректировки"
        echo ""
        echo "=== НАСТРОЙКИ БЕЗ МИГРАЦИИ ==="
        echo "Некоторые настройки Bedolaga не имеют прямых аналогов в RWP-Shop:"
        echo "  - Цены и пакеты трафика (разная архитектура тарифов)"
        echo "  - Настройки бэкапа (у RWP-Shop нет встроенного бэкапа)"
        echo "  - Внешний админ токен (архитектура отличается)"
    } > "$report_file"
    
    local total_db=$((backup_settings_migrated + db_migrated))
    
    echo ""
    echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════${RESET}"
    echo -e "${GREEN}${BOLD}  ✅ МИГРАЦИЯ НАСТРОЕК ЗАВЕРШЕНА!                  ${RESET}"
    echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════${RESET}"
    echo ""
    echo "Результаты:"
    echo " • .env: $env_migrated переменных"
    [[ $backup_settings_migrated -gt 0 ]] && echo " • Из архива в БД: $backup_settings_migrated настроек"
    [[ $db_migrated -gt 0 ]] && echo " • Из .env в БД: $db_migrated настроек"
    echo " • Ошибок: $errors"
    echo ""
    echo "Отчёт: $report_file"
    echo ""
    
    if [[ $errors -eq 0 ]]; then
        print_message "WARN" "Перезапустите бота для применения изменений!"
        echo ""
        read -erp "Перезапустить бота сейчас? (y/N): " restart_bot
        if [[ "$restart_bot" =~ ^[Yy]$ ]]; then
            if [[ -n "$MIGRATION_TARGET_BOT_PATH" && -f "$MIGRATION_TARGET_BOT_PATH/compose.yaml" ]]; then
                print_message "INFO" "Перезапуск бота..."
                (cd "$MIGRATION_TARGET_BOT_PATH" && docker compose restart bot)
                print_message "SUCCESS" "Бот перезапущен"
            else
                print_message "WARN" "Путь к compose.yaml не найден. Перезапустите бота вручную."
            fi
        fi
    fi
    
    log_message "SUCCESS" "Settings migration completed: env=$env_migrated, db=$db_migrated, errors=$errors"
    
    read -erp "Enter..." dummy
    return 0
}

# --- Функция: Экспорт настроек в CSV ---
migrate_settings_export_csv() {
    if [[ -z "$MIGRATION_SOURCE_ENV_FILE" || ! -f "$MIGRATION_SOURCE_ENV_FILE" ]]; then
        print_message "ERROR" "Путь к источнику не настроен"
        read -erp "Enter..." dummy
        return 1
    fi
    
    declare -A source_settings
    read_env_file "$MIGRATION_SOURCE_ENV_FILE" source_settings
    
    local work_dir="${BACKUP_DIR}/settings_export_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$work_dir"
    
    local csv_file="$work_dir/bedolaga_settings.csv"
    
    echo "key,value,maps_to_env,maps_to_db,migration_status" > "$csv_file"
    
    for key in "${!source_settings[@]}"; do
        local value="${source_settings[$key]}"
        local env_target="${SETTINGS_ENV_TO_ENV[$key]:-}"
        local db_target="${SETTINGS_ENV_TO_DB[$key]:-}"
        local status="no_mapping"
        
        [[ -n "$env_target" ]] && status="env"
        [[ -n "$db_target" ]] && status="db"
        
        # Экранируем для CSV
        value="${value//\"/\"\"}"
        
        echo "\"$key\",\"$value\",\"$env_target\",\"$db_target\",\"$status\"" >> "$csv_file"
    done
    
    print_message "SUCCESS" "Настройки экспортированы: $csv_file"
    echo ""
    echo "Статистика:"
    echo " • Всего настроек: ${#source_settings[@]}"
    echo " • Маппинг на .env: $(grep -c ',env$' "$csv_file")"
    echo " • Маппинг на DB: $(grep -c ',db$' "$csv_file")"
    echo " • Без маппинга: $(grep -c ',no_mapping$' "$csv_file")"
    
    read -erp "Enter..." dummy
}

# --- Меню миграции настроек ---
menu_migrate_settings() {
    # === АВТОМАТИЧЕСКАЯ СИНХРОНИЗАЦИЯ ДАННЫХ ИЗ ОСНОВНОГО МЕНЮ МИГРАЦИИ ===
    
    # Источник: если в основном меню выбран архив, используем его
    if [[ -z "$MIGRATION_SOURCE_BACKUP_FILE" && -n "$MIGRATION_SOURCE_BACKUP" && -f "$MIGRATION_SOURCE_BACKUP" ]]; then
        MIGRATION_SOURCE_BACKUP_FILE="$MIGRATION_SOURCE_BACKUP"
        debug_log "SETTINGS" "Auto-synced source archive from main migration: $MIGRATION_SOURCE_BACKUP_FILE"
    fi
    
    # Приёмник: если в основном меню настроен контейнер, ищем .env рядом
    if [[ -z "$MIGRATION_TARGET_ENV_FILE" && -n "$MIGRATION_TARGET_CONTAINER" ]]; then
        # Метод 1: Через docker inspect (working_dir)
        local working_dir=$(docker inspect "$MIGRATION_TARGET_CONTAINER" --format '{{index .Config.Labels "com.docker.compose.project.working_dir"}}' 2>/dev/null)
        if [[ -n "$working_dir" && -d "$working_dir" ]]; then
            MIGRATION_TARGET_BOT_PATH="$working_dir"
            MIGRATION_TARGET_ENV_FILE="$working_dir/.env"
            debug_log "SETTINGS" "Auto-detected target .env from docker inspect: $MIGRATION_TARGET_ENV_FILE"
        fi
        
        # Метод 2: Через BOT_PATH из основного конфига
        if [[ -z "$MIGRATION_TARGET_ENV_FILE" && -n "$BOT_PATH" && -d "$BOT_PATH" ]]; then
            MIGRATION_TARGET_BOT_PATH="$BOT_PATH"
            MIGRATION_TARGET_ENV_FILE="$BOT_PATH/.env"
            debug_log "SETTINGS" "Auto-detected target .env from BOT_PATH: $MIGRATION_TARGET_ENV_FILE"
        fi
        
        # Метод 3: Автопоиск
        if [[ -z "$MIGRATION_TARGET_ENV_FILE" ]]; then
            local found_rwp=$(find_rwp_shop_env)
            if [[ -n "$found_rwp" && -d "$found_rwp" ]]; then
                MIGRATION_TARGET_BOT_PATH="$found_rwp"
                MIGRATION_TARGET_ENV_FILE="$found_rwp/.env"
                debug_log "SETTINGS" "Auto-detected target .env from find_rwp_shop_env: $MIGRATION_TARGET_ENV_FILE"
            fi
        fi
    fi
    
    while true; do
        clear_screen
        echo -e "${CYAN}${BOLD}══════════════════════════════════════════════════════════════${RESET}"
        echo -e "${CYAN}${BOLD}            🔧 МИГРАЦИЯ НАСТРОЕК BEDOLAGA → RWP-SHOP          ${RESET}"
        echo -e "${CYAN}${BOLD}══════════════════════════════════════════════════════════════${RESET}"
        echo ""
        
        # === СТАТУС (автоматически синхронизирован) ===
        echo -e "${YELLOW}=== ТЕКУЩИЙ СТАТУС ===${RESET}"
        
        # Источник: архив (из основного меню)
        local archive_needs_password=false
        if [[ -n "$MIGRATION_SOURCE_BACKUP_FILE" && -f "$MIGRATION_SOURCE_BACKUP_FILE" ]]; then
            local archive_name=$(basename "$MIGRATION_SOURCE_BACKUP_FILE")
            local archive_size=$(du -h "$MIGRATION_SOURCE_BACKUP_FILE" 2>/dev/null | cut -f1)
            
            # Проверяем, нужен ли пароль
            local archive_type=$(detect_bedolaga_archive_type "$MIGRATION_SOURCE_BACKUP_FILE" 2>/dev/null)
            if [[ "$archive_type" == "zip" ]] && is_archive_password_protected "$MIGRATION_SOURCE_BACKUP_FILE" 2>/dev/null; then
                if [[ -z "$BEDOLAGA_BACKUP_PASSWORD" ]]; then
                    archive_needs_password=true
                    echo -e "Источник архив: ${YELLOW}🔒 $archive_name${RESET} ($archive_size)"
                    echo -e "                ${RED}⚠️  Требуется пароль! Выберите архив заново (основное меню → пункт 2)${RESET}"
                else
