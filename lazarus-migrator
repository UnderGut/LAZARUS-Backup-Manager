    print_message "INFO" "Генерация отчёта миграции..."
    
    local report_file="$MIGRATION_WORK_DIR/migration_report_$(date +%Y%m%d_%H%M%S).txt"
    
    {
        echo "╔════════════════════════════════════════════════════════╗"
        echo "║         LAZARUS Migration Report                       ║"
        echo "║         Bedolaga → RWP-Shop (Private)                  ║"
        echo "╚════════════════════════════════════════════════════════╝"
