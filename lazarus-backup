        " > "$ticket_messages_file" 2>/dev/null
    else
        export PGPASSWORD="$MIGRATION_SOURCE_PASS"
        psql -h "$MIGRATION_SOURCE_HOST" -p "$MIGRATION_SOURCE_PORT" -U "$MIGRATION_SOURCE_USER" -d "$MIGRATION_SOURCE_DB" -c "
            COPY (
                SELECT 
