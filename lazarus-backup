validate_tar_safety() {
    local archive="$1"
    local list_file="$2"

    if ! tar -tzf "$archive" > "$list_file" 2> "$SILENT_LOG"; then
        print_message "ERROR" "Архив поврежден или не tar.gz: $archive"
        return 1
    fi

    if grep -Eq '(^/|^[A-Za-z]:|(^|/)\.\.(|/))' "$list_file"; then
        print_message "ERROR" "Архив содержит небезопасные пути: $archive"
        return 1
    fi

    if tar -tvf "$archive" 2> "$SILENT_LOG" | awk '{print substr($1,1,1)}' | grep -Eq '^[lh]'; then
        print_message "ERROR" "Архив содержит ссылки (symlink/hardlink), восстановление запрещено"
        return 1
    fi

    return 0
}

get_restore_stage_root() {
    local stage_dir="$1"
    local entries=("$stage_dir"/*)
    local count=0
    local root=""
    for entry in "${entries[@]}"; do
        [[ ! -e "$entry" ]] && continue
        count=$((count + 1))
        root="$entry"
    done
    if [[ $count -ne 1 || ! -d "$root" ]]; then
        print_message "ERROR" "Ожидалась одна корневая папка в архиве (найдено: $count)"
        return 1
    fi
    echo "$root"
}

restore_rsync_preview() {
    local src="$1"
    local dst="$2"
    local extra_excludes=()
    if [[ "$RESTORE_INCLUDE_ENV" != "true" ]]; then
        extra_excludes+=("--exclude" ".env")
        extra_excludes+=("--exclude" ".env.*")
    fi

    rsync -a --delete --safe-links --itemize-changes --dry-run "${extra_excludes[@]}" "$src/" "$dst/"
}

restore_rsync_apply() {
    local src="$1"
    local dst="$2"
    local extra_excludes=()
    if [[ "$RESTORE_INCLUDE_ENV" != "true" ]]; then
        extra_excludes+=("--exclude" ".env")
        extra_excludes+=("--exclude" ".env.*")
    fi

    rsync -a --delete --safe-links "${extra_excludes[@]}" "$src/" "$dst/"
}

assert_db_container_matches_bot() {
    if [[ -z "$DB_CONTAINER_NAME" ]]; then
        print_message "ERROR" "DB_CONTAINER_NAME не задан"
        return 1
    fi
    local work_dir
    work_dir=$(docker inspect -f '{{ index .Config.Labels "com.docker.compose.project.working_dir" }}' "$DB_CONTAINER_NAME" 2> "$SILENT_LOG")
    if [[ -z "$work_dir" ]]; then
        print_message "ERROR" "Не удалось определить working_dir контейнера БД"
        return 1
    fi
    local real_work
    local real_bot
    real_work=$(normalize_path "$work_dir")
    real_bot=$(normalize_path "$BOT_PATH")
    if [[ "$real_work" != "$real_bot" ]]; then
        print_message "ERROR" "Контейнер БД не принадлежит BOT_PATH (ожидался $real_bot, найден $real_work)"
        return 1
    fi
    return 0
}

# --- assert_safe_db_target: проверяет что БД контейнер соответствует целевому проекту ---
# Выполняет: 1) belongs to working_dir, 2) psql current_database() check, 3) показывает инфо
assert_safe_db_target() {
    local container="$1"
    local expected_user="$2"
    local expected_db="$3"

    if [[ -z "$container" ]]; then
        print_message "ERROR" "assert_safe_db_target: контейнер не задан"
        return 1
    fi

    # 1) Контейнер запущен
    if ! docker ps --format '{{.Names}}' | grep -q "^${container}$"; then
        print_message "ERROR" "Контейнер БД не запущен: $container"
        return 1
    fi

    # 2) Контейнер принадлежит BOT_PATH (уже проверено assert_db_container_matches_bot, но проверим ещё раз)
    local work_dir
    work_dir=$(docker inspect -f '{{ index .Config.Labels "com.docker.compose.project.working_dir" }}' "$container" 2> "$SILENT_LOG")
    if [[ -n "$work_dir" && -n "$BOT_PATH" ]]; then
        local real_work real_bot
        real_work=$(normalize_path "$work_dir")
        real_bot=$(normalize_path "$BOT_PATH")
        if [[ "$real_work" != "$real_bot" ]]; then
            print_message "ERROR" "Контейнер БД '$container' принадлежит проекту '$real_work', а не '$real_bot'"
            return 1
        fi
    fi

    # 3) PostgreSQL доступен и current_database совпадает
    local actual_db
    actual_db=$(docker exec "$container" psql -U "$expected_user" -tAc "SELECT current_database()" 2> "$SILENT_LOG")
    if [[ -z "$actual_db" ]]; then
        print_message "ERROR" "Не удалось подключиться к PostgreSQL в контейнере '$container'"
        return 1
    fi

    if [[ "$actual_db" != "$expected_db" ]]; then
        print_message "ERROR" "current_database()='$actual_db', ожидалось '$expected_db'"
        return 1
    fi

    debug_log "RESTORE" "assert_safe_db_target OK: container=$container, db=$actual_db, user=$expected_user"
    return 0
}

# --- confirm_drop_schema: подтверждение DROP SCHEMA с safety snapshot ---
# Безопасное по умолчанию: без флага --restore-drop-schema DROP SCHEMA не выполняется
confirm_drop_schema() {
    local db_container="$1"
    local db_user="$2"
    local db_name="$3"
    local backup_dir="$4"

    # === БЕЗОПАСНЫЙ СНАПШОТ ПЕРЕД DROP ===
    local snapshot_file="${backup_dir}/pre_restore_snapshot_$(date +%Y%m%d_%H%M%S).sql.gz"
    print_message "INFO" "Создание safety snapshot БД перед DROP SCHEMA..."
    if docker exec "$db_container" pg_dump -U "$db_user" "$db_name" 2> "$SILENT_LOG" | gzip > "$snapshot_file"; then
        local snap_size
        snap_size=$(du -h "$snapshot_file" 2>/dev/null | cut -f1)
        print_message "SUCCESS" "Safety snapshot: $snapshot_file ($snap_size)"
    else
        print_message "ERROR" "Не удалось создать safety snapshot! Восстановление прервано."
        rm -f "$snapshot_file"
        return 1
    fi

    # === ИНТЕРАКТИВНЫЙ РЕЖИМ ===
    if [[ "$IS_INTERACTIVE" == true ]]; then
        if [[ "$AUTO_CONFIRM" == "true" && "$RESTORE_FORCE" == "true" ]]; then
            print_message "WARN" "AUTO_CONFIRM+FORCE: DROP SCHEMA пропущен в интерактивном режиме без --restore-drop-schema"
            if [[ "$RESTORE_DROP_SCHEMA" != "true" ]]; then
                return 1
            fi
            return 0
        fi

        echo ""
        echo -e "${RED}${BOLD}══════════════════════════════════════════════════${RESET}"
        echo -e "${RED}${BOLD}  ⚠️  ОЧИСТКА СХЕМЫ БАЗЫ ДАННЫХ!                 ${RESET}"
        echo -e "${RED}${BOLD}══════════════════════════════════════════════════${RESET}"
        echo ""
        echo "Контейнер:  $db_container"
        echo "База данных: $db_name"
        echo "Пользователь: $db_user"
        echo ""
        echo "Будет выполнено: DROP SCHEMA public CASCADE; CREATE SCHEMA public;"
        echo "Это УНИЧТОЖИТ все таблицы, данные и индексы в схеме public."
        echo ""
        echo -e "Safety snapshot сохранён: ${GREEN}$snapshot_file${RESET}"
        echo ""
        local expected="DROP_SCHEMA_IN:${db_name}"
        echo -n "Введите для подтверждения: "
        echo -e "${CYAN}$expected${RESET}"
        read -r confirm
        if [[ "$confirm" != "$expected" ]]; then
            print_message "INFO" "DROP SCHEMA отменён пользователем."
            return 1
        fi
        return 0
    fi

    # === НЕ-ИНТЕРАКТИВНЫЙ РЕЖИМ ===
    if [[ "$RESTORE_DROP_SCHEMA" != "true" ]]; then
        print_message "ERROR" "DROP SCHEMA требует --restore-drop-schema в не-интерактивном режиме"
        return 1
    fi

    if [[ "$AUTO_CONFIRM" == "true" && "$RESTORE_FORCE" == "true" ]]; then
        return 0
    fi

    print_message "ERROR" "DROP SCHEMA требует --restore-drop-schema вместе с --yes и --i-know-what-i-am-doing"
    return 1
}

execute_restore() {
    local MODE="$1"; local FILE="$2"
    debug_log "RESTORE" "=== execute_restore ==="
    debug_log "RESTORE" "Mode: $MODE, File: $FILE"
    echo ""; print_message "WARN" "ВНИМАНИЕ: Текущие данные будут перезаписаны!"
    if [[ "$IS_INTERACTIVE" == true ]]; then
        read -erp "Продолжить? (y/n): " confirm; [[ "$confirm" != "y" ]] && return
    fi

    local TMP_DIR="$BACKUP_DIR/restore_tmp_$$"
    mkdir -p "$TMP_DIR"
    debug_log "RESTORE" "Temp dir: $TMP_DIR"

    local WORK_FILE="$FILE"
    if [[ "$FILE" == *".enc" ]]; then
        print_message "INFO" "Файл зашифрован. Требуется пароль."
        debug_log "RESTORE" "File is encrypted, requesting password..."
        read -s -erp "Пароль: " decrypt_pass; echo ""
        local DECRYPTED_FILE="$TMP_DIR/decrypted.tar.gz"

        debug_log "RESTORE" "Decrypting to: $DECRYPTED_FILE"
        export LAZARUS_DEC_PASS="$decrypt_pass"
        openssl enc -d -aes-256-cbc -pbkdf2 -iter 100000 -in "$FILE" -out "$DECRYPTED_FILE" -pass env:LAZARUS_DEC_PASS 2> "$SILENT_LOG"
        local dec_res=$?
        unset LAZARUS_DEC_PASS
        debug_log "RESTORE" "Decryption result: $dec_res"

        if [[ $dec_res -ne 0 ]]; then print_message "ERROR" "Неверный пароль или поврежденный файл!"; rm -rf "$TMP_DIR"; return; fi
        print_message "SUCCESS" "Пароль принят."
        WORK_FILE="$DECRYPTED_FILE"
    fi

    local DB_DUMP=""
    local DIR_ARC=""

    if [[ "$MODE" == "files_only" ]]; then
        DIR_ARC="$WORK_FILE"
    else
        local OUTER_LIST="$TMP_DIR/outer_list.txt"
        if ! validate_tar_safety "$WORK_FILE" "$OUTER_LIST"; then rm -rf "$TMP_DIR"; return; fi

        print_message "INFO" "Распаковка..."
        debug_log "RESTORE" "Extracting: tar -xzf $WORK_FILE -C $TMP_DIR"
        tar -xzf "$WORK_FILE" -C "$TMP_DIR" --no-same-owner --no-same-permissions
        debug_log "RESTORE" "Contents: $(ls -la "$TMP_DIR")"

        DB_DUMP=$(find "$TMP_DIR" -name "db_*.sql.gz" | head -1)
        DIR_ARC=$(find "$TMP_DIR" -name "dir_*.tar.gz" | head -1)
    fi

    debug_log "RESTORE" "DB_DUMP: $DB_DUMP"
    debug_log "RESTORE" "DIR_ARC: $DIR_ARC"

    if [[ "$MODE" == "full" || "$MODE" == "files_only" ]]; then
        if ! ensure_bot_path; then rm -rf "$TMP_DIR"; return; fi
        if ! assert_safe_bot_path "$BOT_PATH"; then rm -rf "$TMP_DIR"; return; fi
        if [[ -z "$DIR_ARC" || ! -f "$DIR_ARC" ]]; then
            print_message "ERROR" "Архив с файлами не найден."
            rm -rf "$TMP_DIR"
            return
        fi

        local DIR_LIST="$TMP_DIR/dir_list.txt"
        if ! validate_tar_safety "$DIR_ARC" "$DIR_LIST"; then rm -rf "$TMP_DIR"; return; fi

        local STAGE_DIR="$TMP_DIR/restore_stage"
        mkdir -p "$STAGE_DIR"
        tar -xzf "$DIR_ARC" -C "$STAGE_DIR" --no-same-owner --no-same-permissions

        local ROOT_DIR
        ROOT_DIR=$(get_restore_stage_root "$STAGE_DIR") || { rm -rf "$TMP_DIR"; return; }

        print_message "INFO" "План синхронизации (dry-run):"
        local PLAN_FILE="$TMP_DIR/restore_plan.txt"
        restore_rsync_preview "$ROOT_DIR" "$BOT_PATH" > "$PLAN_FILE" 2>&1 || true
        if [[ -s "$PLAN_FILE" ]]; then
            head -n 25 "$PLAN_FILE"
            if [[ $(wc -l < "$PLAN_FILE") -gt 25 ]]; then
                echo "..."
            fi
        else
            echo "(Изменений не обнаружено)"
        fi

        if ! confirm_restore_target; then rm -rf "$TMP_DIR"; return; fi

        if [[ "$DRY_RUN" == "true" ]]; then
            print_message "INFO" "DRY-RUN: восстановление пропущено"
            rm -rf "$TMP_DIR"
            return
        fi

        print_message "INFO" "Остановка контейнеров..."
        debug_log "RESTORE" "Stopping containers in $BOT_PATH"
        cd "$BOT_PATH" && docker compose down 2> "$SILENT_LOG"

        print_message "INFO" "Синхронизация файлов..."
        restore_rsync_apply "$ROOT_DIR" "$BOT_PATH"

        if [[ "$MODE" == "full" ]]; then
            if ! assert_db_container_matches_bot; then rm -rf "$TMP_DIR"; return; fi
            local volume_name
            volume_name=$(get_db_volume_name)
            debug_log "RESTORE" "DB Volume: $volume_name"
            if [[ -n "$volume_name" ]]; then
                if confirm_drop_volume "$volume_name"; then
                    print_message "INFO" "Удаление старого volume: $volume_name"
                    debug_log "RESTORE" "Running: docker volume rm $volume_name"
                    docker volume rm "$volume_name" 2> "$SILENT_LOG" || true
                else
                    print_message "INFO" "Пропускаем удаление volume БД."
                fi
            else
                print_message "WARN" "Volume БД не определён, пропускаем удаление."
            fi

            print_message "INFO" "Запуск БД..."
            debug_log "RESTORE" "Running: docker compose up -d $DB_SERVICE_NAME"
            docker compose up -d "$DB_SERVICE_NAME"
            sleep 5
        fi
    fi

    if [[ -n "$DB_DUMP" ]]; then
        print_message "INFO" "Импорт базы данных..."
        if ! ensure_bot_path; then rm -rf "$TMP_DIR"; return; fi
        if ! assert_safe_bot_path "$BOT_PATH"; then rm -rf "$TMP_DIR"; return; fi
        if ! assert_db_container_matches_bot; then rm -rf "$TMP_DIR"; return; fi

        local ACTUAL_DB_USER
        local ACTUAL_DB_NAME
        ACTUAL_DB_USER=$(get_db_user)
        ACTUAL_DB_NAME=$(get_db_name)
        debug_log "RESTORE" "DB params: user=$ACTUAL_DB_USER, db=$ACTUAL_DB_NAME"

        # Проверяем что целевая БД валидна
        if ! assert_safe_db_target "$DB_CONTAINER_NAME" "$ACTUAL_DB_USER" "$ACTUAL_DB_NAME"; then
            print_message "ERROR" "Целевая БД не прошла проверку безопасности. Восстановление прервано."
            rm -rf "$TMP_DIR"
            return
        fi

        # DROP SCHEMA требует явного подтверждения — safe by default
        if confirm_drop_schema "$DB_CONTAINER_NAME" "$ACTUAL_DB_USER" "$ACTUAL_DB_NAME" "$BACKUP_DIR"; then
            print_message "INFO" "Очистка схемы БД (DROP SCHEMA public CASCADE)..."
            debug_log "RESTORE" "Running: docker exec $DB_CONTAINER_NAME psql -U $ACTUAL_DB_USER -c 'DROP SCHEMA...'"
            docker exec -i "$DB_CONTAINER_NAME" psql -U "$ACTUAL_DB_USER" -c "DROP SCHEMA public CASCADE; CREATE SCHEMA public;" > "$SILENT_LOG" 2>&1
        else
            print_message "WARN" "DROP SCHEMA пропущен. Импорт может завершиться с ошибками из-за существующих таблиц."
        fi

        print_message "INFO" "Импорт данных (user=$ACTUAL_DB_USER, db=$ACTUAL_DB_NAME)..."
        debug_log "RESTORE" "Running: zcat $DB_DUMP | docker exec $DB_CONTAINER_NAME psql -U $ACTUAL_DB_USER $ACTUAL_DB_NAME"
        zcat "$DB_DUMP" | docker exec -i "$DB_CONTAINER_NAME" psql -U "$ACTUAL_DB_USER" "$ACTUAL_DB_NAME" > "$SILENT_LOG" 2>&1
        debug_log "RESTORE" "DB import complete"
    fi

    if [[ "$MODE" == "full" || "$MODE" == "files_only" ]]; then
        print_message "INFO" "Запуск всех контейнеров..."
        debug_log "RESTORE" "Running: docker compose up -d"
        cd "$BOT_PATH" && docker compose up -d
    fi

    rm -rf "$TMP_DIR"
    debug_log "RESTORE" "Temp dir cleaned up"
    print_message "SUCCESS" "Восстановление успешно завершено."
    log_message "SUCCESS" "Restore completed (mode=$MODE, file=$FILE)"
    if [[ "$IS_INTERACTIVE" == true ]]; then
        read -erp "Нажмите Enter..." dummy
    fi
}

