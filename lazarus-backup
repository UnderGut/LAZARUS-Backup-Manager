load_or_create_config() {
    debug_log "CONFIG" "=== load_or_create_config ==="
    debug_log "CONFIG" "Config file: $CONFIG_FILE"
    
    if [[ -f "$CONFIG_FILE" ]]; then 
        debug_log "CONFIG" "Config exists, loading safely..."
        load_config_file "$CONFIG_FILE"
        debug_log "CONFIG" "Config loaded successfully"
    else
        debug_log "CONFIG" "Config file not found, using defaults"
    fi
    if [[ -z "$MAX_BACKUPS_COUNT" ]]; then MAX_BACKUPS_COUNT=100; fi
    if [[ -z "$IGNORE_MISMATCH" ]]; then IGNORE_MISMATCH="false"; fi
    if [[ -z "$MAX_FILE_SIZE_MB" ]]; then MAX_FILE_SIZE_MB="1"; fi
    if [[ -z "$REMOTE_STORAGE_TYPE" ]]; then REMOTE_STORAGE_TYPE="off"; fi
    if [[ -z "$SEND_TO_TELEGRAM" ]]; then SEND_TO_TELEGRAM="true"; fi
    if [[ -z "$TG_SEND_FILE" ]]; then TG_SEND_FILE="true"; fi
    if [[ -z "$SEND_TO_REMOTE" ]]; then SEND_TO_REMOTE="true"; fi
    if [[ -z "$DELETE_MODE" ]]; then DELETE_MODE="time"; fi
    if [[ -z "$RETENTION_DAYS" ]]; then RETENTION_DAYS="7"; fi
    if [[ -z "$MAX_BACKUP_SIZE_MB" ]]; then MAX_BACKUP_SIZE_MB="0"; fi
    if [[ -z "$S3_REGION" ]]; then S3_REGION="us-east-1"; fi
    if [[ -z "$BACKUP_PASSWORD_FILE" ]]; then BACKUP_PASSWORD_FILE="$INSTALL_DIR/.password"; fi
    if [[ -z "$DISK_WARN_PERCENT" ]]; then DISK_WARN_PERCENT="90"; fi
    if [[ -z "$DISK_CRITICAL_PERCENT" ]]; then DISK_CRITICAL_PERCENT="95"; fi
    if [[ -z "$DELETE_LOCAL_AFTER_REMOTE_UPLOAD" ]]; then DELETE_LOCAL_AFTER_REMOTE_UPLOAD="false"; fi
    if [[ -z "$BACKUP_LOG_FILES" ]]; then BACKUP_LOG_FILES="ask"; fi
    debug_log "CONFIG" "Defaults applied: MAX_BACKUPS=$MAX_BACKUPS_COUNT, DELETE_MODE=$DELETE_MODE"
    debug_log "CONFIG" "Creating backup dir: $BACKUP_DIR"
    mkdir -p "$BACKUP_DIR"

    local updated=false
    
    # Telegram настройки опциональны - НЕ требуем их ввода при старте
    # Уведомление об отсутствии настроек будет показано в главном меню
    if [[ -z "$BOT_TOKEN" || -z "$CHAT_ID" ]]; then
        debug_log "CONFIG" "Telegram settings not configured (optional)"
    fi
    
    if [[ -z "$BOT_PATH" || -z "$BOT_CONTAINER_NAME" || -z "$DB_CONTAINER_NAME" ]]; then 
        debug_log "CONFIG" "Bot installation not configured, starting detection"
        detect_bot_installation
    fi

    # Миграция пароля из старого config.env в отдельный файл (chmod 600).
    # Если write провалится — оставляем BACKUP_PASSWORD в памяти как есть,
    # чтобы шифрование текущей сессии работало; в следующий запуск опять попробуем.
    if [[ -n "$BACKUP_PASSWORD" ]]; then
        debug_log "CONFIG" "Migrating BACKUP_PASSWORD to file"
        if write_password_file "$BACKUP_PASSWORD"; then
            BACKUP_PASSWORD=""
            updated=true
        else
            debug_log "CONFIG" "Migration failed — keeping BACKUP_PASSWORD in memory only"
        fi
    fi
    # Загружаем пароль из файла (если есть)
    if [[ -z "$BACKUP_PASSWORD" ]]; then
        read_password_file || true
    fi
    
    if $updated; then 
        debug_log "CONFIG" "Config updated, saving..."
        save_config
    fi
    debug_log "CONFIG" "=== load_or_create_config completed ==="
}

# --- TELEGRAM: ОТПРАВКА ФАЙЛОВ И СООБЩЕНИЙ ---

send_telegram_document() {
    local file_path="$1"; local caption="$2"; local caption_mode="${3:-plain}"
    # caption_mode: "plain" (default) — escape через escape_markdown_v2;
    #               "pre-escaped" — caller уже подготовил MarkdownV2-safe строку
    #               (нужно для Premium emoji литералов ![X](tg://emoji?id=N), которые
    #               escape сломал бы).
    debug_log "TG" "=== send_telegram_document ==="
    debug_log "TG" "File: $file_path"
    debug_log "TG" "SEND_TO_TELEGRAM=$SEND_TO_TELEGRAM, TG_SEND_FILE=$TG_SEND_FILE"
    [[ -z "$BOT_TOKEN" || -z "$CHAT_ID" ]] && { debug_log "TG" "Missing BOT_TOKEN or CHAT_ID"; return 1; }
    
    # Если уведомления полностью отключены
    if [[ "$SEND_TO_TELEGRAM" != "true" ]]; then
        print_message "INFO" "Уведомления Telegram отключены."
        debug_log "TG" "Notifications disabled, skipping"
        return 0
    fi
    
    # Если отправка файла отключена — отправляем только текстовое уведомление
    if [[ "$TG_SEND_FILE" != "true" ]]; then
        print_message "INFO" "Отправка файла в TG отключена, отправляем уведомление..."
        debug_log "TG" "File sending disabled, sending text only"
        local filename=$(basename "$file_path")
        # Экранируем для MarkdownV2
        local escaped_filename=$(escape_markdown_v2 "$filename")
        local escaped_caption
        if [[ "$caption_mode" == "pre-escaped" ]]; then
            escaped_caption="$caption"
        else
            escaped_caption=$(escape_markdown_v2 "$caption")
        fi
        # Формируем сообщение (уже экранированное)
        local notify_text="📦 *Бэкап создан*

${escaped_caption}

📁 Файл: \`${escaped_filename}\`
💡 _Отправка файла в Telegram отключена_"
        
        # Отправляем напрямую (текст уже экранирован)
        local thread_param=""
        [[ -n "$TG_MESSAGE_THREAD_ID" ]] && thread_param="-d message_thread_id=$TG_MESSAGE_THREAD_ID"
        
        local http_code
        http_code=$(curl $CURL_SILENT -o "$SILENT_LOG" -w "%{http_code}" -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
            -d chat_id="$CHAT_ID" \
            -d parse_mode="MarkdownV2" \
            --data-urlencode text="$notify_text" \
            $thread_param 2> "$SILENT_LOG")
        debug_log "TG" "Text-only notification HTTP code: $http_code"
        
        if [[ "$http_code" == "200" ]]; then
            print_message "SUCCESS" "Уведомление отправлено в Telegram."
            return 0
        else
            print_message "WARN" "Не удалось отправить уведомление (HTTP: $http_code)"
            log_message "WARN" "Telegram notification failed, HTTP code: $http_code"
            return 1
        fi
    fi
    
    local file_size_bytes=$(stat -c%s "$file_path" 2> "$SILENT_LOG" || echo 0)
    debug_log "TG" "File size: $file_size_bytes bytes ($(numfmt --to=iec $file_size_bytes 2>/dev/null || echo "$file_size_bytes"))"

    # === PRE-FLIGHT CHECK: Telegram Bot API лимит = 50 MB на sendDocument ===
    # Не пытаемся отправлять файлы >= 50 MB — сразу шлём text-уведомление с ❌,
    # путём и инструкцией. Это экономит ~minutes на upload + неминуемый 413.
    local TG_MAX_BYTES=52428800
    if [[ $file_size_bytes -ge $TG_MAX_BYTES ]]; then
        local size_mb=$((file_size_bytes / 1048576))
        debug_log "TG" "Pre-flight: file ${size_mb}MB >= 50MB, skipping upload, sending notice"
        print_message "WARN" "Файл ${size_mb}MB превышает лимит Telegram (50MB) — отправляем только уведомление"
        log_message "WARN" "TG file send skipped: ${size_mb}MB > 50MB. File kept locally: $file_path"

        local escaped_caption
        if [[ "$caption_mode" == "pre-escaped" ]]; then
            escaped_caption="$caption"
        else
            escaped_caption=$(escape_markdown_v2 "$caption")
        fi

        # Компактное уведомление: размер + одна подсказка.
        # Пути не выводим в TG (privacy). Детали (имя файла, путь, топ-5) — в терминале.
        local notice_text="$(tg_emoji "❌" "$EMO_ERROR") *Бэкап не отправлен в Telegram*

${escaped_caption}

${size_mb} MB \\> 50 MB \\(лимит Bot API\\)

$(tg_emoji "💡" "$EMO_INFO") Настройте S3/FTP/WebDAV для больших бэкапов"

        local thread_param=""
        [[ -n "$TG_MESSAGE_THREAD_ID" ]] && thread_param="-d message_thread_id=$TG_MESSAGE_THREAD_ID"

        curl $CURL_SILENT -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
            -d chat_id="$CHAT_ID" \
            -d parse_mode="MarkdownV2" \
            --data-urlencode text="$notice_text" \
            $thread_param > "$SILENT_LOG" 2>&1 || true
        return 2  # special code: file too big, sent notice only
    fi

    print_message "INFO" "Отправка в Telegram..."

    local _caption_final
    if [[ "$caption_mode" == "pre-escaped" ]]; then
        _caption_final="$caption"
    else
        _caption_final=$(escape_markdown_v2 "$caption")
    fi
    local form_params=(-F chat_id="$CHAT_ID" -F document=@"$file_path" -F parse_mode="MarkdownV2" -F caption="$_caption_final")
    [[ -n "$TG_MESSAGE_THREAD_ID" ]] && form_params+=(-F message_thread_id="$TG_MESSAGE_THREAD_ID")
    debug_log "TG" "Sending to: https://api.telegram.org/bot<TOKEN>/sendDocument"
    debug_log "TG" "Chat ID: $CHAT_ID, Thread ID: ${TG_MESSAGE_THREAD_ID:-none}"
    
    # Retry × 3 с exp backoff (5, 15, 45 сек). HTTP 000 = network/timeout, HTTP 5xx = TG-side issue.
    # Retry-able: 000, 408, 429, 500, 502, 503, 504. NOT retry-able: 400, 401, 403, 413 (наши проблемы).
    local _tg_max=3 _tg_attempt=1 _tg_delay=5
    local http_code=""
    while [[ $_tg_attempt -le $_tg_max ]]; do
        [[ $_tg_attempt -gt 1 ]] && print_message "INFO" "TG retry $_tg_attempt/$_tg_max через ${_tg_delay}с..."
        # --max-time 120 защищает от висящего соединения на конкретной попытке.
        http_code=$(curl $CURL_SILENT --max-time 120 -o "$SILENT_LOG" -w "%{http_code}" \
            -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendDocument" "${form_params[@]}")
        debug_log "TG" "Attempt $_tg_attempt/$_tg_max: HTTP $http_code"
        # Success или non-retryable client error → выходим из retry-loop.
        case "$http_code" in
            200) break ;;
            400|401|403|413) break ;;  # client-side errors, retry бесполезен
            *)
                # Retry-able: 000/timeout, 408, 429, 5xx, прочие
                if [[ $_tg_attempt -lt $_tg_max ]]; then
                    sleep "$_tg_delay"
                    _tg_delay=$((_tg_delay * 3))   # 5 → 15 → 45
                fi
                ;;
        esac
        _tg_attempt=$((_tg_attempt + 1))
    done

    if [[ "$http_code" == "200" ]]; then
        print_message "SUCCESS" "Успешно отправлено в Telegram."
        return 0
    fi

    # === FALLBACK (если pre-flight пропустил, например файл вырос между stat и curl) ===
    local file_size=$(stat -c%s "$file_path" 2> "$SILENT_LOG" || echo 0)
    debug_log "TG" "Send FAILED! File size: $file_size, HTTP=$http_code"

    if [[ $file_size -ge 52428800 ]]; then
        print_message "ERROR" "Файл >50MB. Telegram API отклонил отправку."
        debug_log "TG" "File exceeds 50MB limit (fallback)"
        local error_msg="⚠️ *Ошибка отправки бэкапа*

Файл \\> 50 МБ \\(лимит Telegram Bot API\\)\\.
Бэкап сохранён локально\\."

        local thread_param=""
        [[ -n "$TG_MESSAGE_THREAD_ID" ]] && thread_param="-d message_thread_id=$TG_MESSAGE_THREAD_ID"

        curl $CURL_SILENT -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
            -d chat_id="$CHAT_ID" \
            --data-urlencode text="$error_msg" \
            -d parse_mode="MarkdownV2" \
            $thread_param > "$SILENT_LOG"
        return 2
    fi

    print_message "ERROR" "Не удалось отправить в Telegram (HTTP код: $http_code)."
    return 1
}

send_telegram_text() {
    # send simple text message to configured chat (expects already escaped MarkdownV2 text)
    local text="$1"
    [[ -z "$BOT_TOKEN" || -z "$CHAT_ID" ]] && return 1
    [[ "$SEND_TO_TELEGRAM" != "true" ]] && return 0
    local thread_param=""
    [[ -n "$TG_MESSAGE_THREAD_ID" ]] && thread_param="-d message_thread_id=$TG_MESSAGE_THREAD_ID"
    curl $CURL_SILENT -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
        -d chat_id="$CHAT_ID" \
        --data-urlencode text="$text" \
        -d parse_mode="MarkdownV2" $thread_param > "$SILENT_LOG" 2>&1
}

# =============================================================================
# send_telegram_alert: стандартизированный заметный alert для критичных событий.
# =============================================================================
# Формат строится из 4 секций (любая может быть пустой):
#   1. Header: эмодзи-серия + severity + title (огромный жирный)
#   2. Metrics: список ключ→значение (метрики, контекст)
#   3. Actions: что делать пользователю (commands в `code`)
#   4. Footer: hashtags + hostname + timestamp
#
# Severity → визуальный регистр:
#   CRITICAL → 🔴🔴🔴 + BOLD + #alert #critical → срочное
#   ERROR    → ❌ + BOLD + #alert #error      → ошибка backup'а
#   WARN     → ⚠️ + #warning                  → продолжение работы
#   INFO     → ℹ️ + #info                     → событие (rotation, cleanup)
#
# Аргументы:
#   $1 — severity: CRITICAL | ERROR | WARN | INFO
#   $2 — title: короткое название события (для header)
#   $3 — body: текст (multi-line допустим, MarkdownV2 уже escaped или plain)
#   $4 — actions (опц.): что делать (multi-line, code-блоки через ` `)
#
# NB: body и actions передавать в PLAIN тексте — helper сам escape'ит MarkdownV2.
# Чтобы вставить inline code (бэктики) — используй `<code>...<code>`-маркер,
# helper заменит на `...` (с escape ` внутри).
# =============================================================================
send_telegram_alert() {
    local severity="$1"
    local title="$2"
    local body="${3:-}"
    local actions="${4:-}"

    [[ -z "$BOT_TOKEN" || -z "$CHAT_ID" ]] && return 1
    [[ "$SEND_TO_TELEGRAM" != "true" ]] && return 0

    # Визуальные элементы по severity. Компактный формат для мобильных:
    # одна emoji в начале + короткий label, без тройных баннеров.
    local _emoji="" _label="" _hashtags=""
    case "$severity" in
        CRITICAL)
            _emoji="🔴"
            _label="CRITICAL"
            _hashtags="#alert #critical"
            ;;
        ERROR)
            _emoji="❌"
            _label="ERROR"
            _hashtags="#alert #error"
            ;;
        WARN)
            _emoji="⚠️"
            _label="WARN"
            _hashtags="#warning"
            ;;
        INFO)
            _emoji="ℹ️"
            _label="INFO"
            _hashtags="#info"
            ;;
        *)
            _emoji="📌"
            _label="$severity"
            _hashtags="#alert"
            ;;
    esac

    # Hashtags вверху — для быстрого поиска в Telegram (#critical / #error / #warning / #info)
    local _tags_esc
    _tags_esc=$(escape_markdown_v2 "$_hashtags")
    local _tags_line="$_tags_esc"

    # Header — компактный: одна emoji + LABEL · title (одна строка на iPhone <420px)
    local _title_esc
    _title_esc=$(escape_markdown_v2 "$title")
    local _header="${_emoji} *${_label}* · ${_title_esc}"

    # Body (escape MarkdownV2, поддержка <code>X</code> для inline-code).
    # NB: escape_markdown_v2 экранирует `>` → `\>`, поэтому после escape маркеры
    # выглядят как `<code\>` и `</code\>`. Заменяем через sed — bash parameter
    # expansion патчинг literal backslash в pattern крайне ненадёжный.
    local _body_section=""
    if [[ -n "$body" ]]; then
        local _body_esc
        _body_esc=$(escape_markdown_v2 "$body")
        _body_esc=$(printf '%s' "$_body_esc" | sed -e 's|<code\\>|`|g' -e 's|</code\\>|`|g')
        _body_section=$'\n\n'"$_body_esc"
    fi

    # Actions section — компактно: "💡 *Действия:*" + multi-line c командами в code.
    local _actions_section=""
    if [[ -n "$actions" ]]; then
        local _actions_esc
        _actions_esc=$(escape_markdown_v2 "$actions")
        _actions_esc=$(printf '%s' "$_actions_esc" | sed -e 's|<code\\>|`|g' -e 's|</code\\>|`|g')
        _actions_section=$'\n\n'"💡 *Действия:* "$'\n'"$_actions_esc"
    fi

    # Footer: hostname + short timestamp (без часов-emoji, на одной строке).
    local _host _ts
    _host=$(hostname 2>/dev/null || echo "unknown")
    _ts=$(date '+%d.%m %H:%M' 2>/dev/null || echo "")
    local _footer_esc
    _footer_esc=$(escape_markdown_v2 "🖥 ${_host} · ${_ts}")
    local _footer=$'\n\n'"$_footer_esc"

    # Separator не используем — компактнее. Header уже выделен жирным и emoji.

    # Финальный текст. Hashtags на самом верху (1-я строка) — quick-scan и фильтр
    # в Telegram через #critical / #error / #warning / #info.
    local _full_text="${_tags_line}"$'\n'"${_header}${_body_section}${_actions_section}${_footer}"

    local thread_param=""
    [[ -n "$TG_MESSAGE_THREAD_ID" ]] && thread_param="-d message_thread_id=$TG_MESSAGE_THREAD_ID"

    # disable_notification=false (default) — звук для CRITICAL обязателен.
    # Для INFO можно тихо, но не делаем разделение чтобы пользователь точно увидел.
    curl $CURL_SILENT -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
        -d chat_id="$CHAT_ID" \
        --data-urlencode text="$_full_text" \
        -d parse_mode="MarkdownV2" \
        -d disable_web_page_preview="true" \
        $thread_param > "$SILENT_LOG" 2>&1
    debug_log "TG" "alert sent: severity=$severity title='$title'"
}

test_telegram_connection() {
    print_message "INFO" "Проверка связи с Telegram API..."
    local res=$(curl $CURL_SILENT "https://api.telegram.org/bot$BOT_TOKEN/getMe")
    if [[ "$res" == *'"ok":true'* ]]; then
        local bot_user=$(echo "$res" | grep -o '"username":"[^"]*"' | cut -d'"' -f4)
        print_message "SUCCESS" "Успех! Бот: @$bot_user"
    else
        print_message "ERROR" "Ошибка подключения. Проверьте токен."
    fi
    read -erp "Enter..." dummy
}

# --- УДАЛЁННОЕ ХРАНИЛИЩЕ И S3 ---

validate_remote_connection() {
    local type="$1"; local url="$2"; local user="$3"; local pass="$4"
    
    debug_log "REMOTE" "=== validate_remote_connection($type) ==="
    debug_log "REMOTE" "URL: $url"
    debug_log "REMOTE" "User: ${user:-<empty>}"
    
    print_message "INFO" "Тестирование подключения ($type)..."
    
    local base_url="${url%/}"
    
    if [[ "$type" == "ftp" ]]; then
        debug_log "REMOTE" "Testing FTP connection..."
        # FTP: проверяем листинг директории
        local curl_cmd=(curl $CURL_SILENT -m 15 --ftp-pasv --list-only)
        [[ -n "$user" ]] && curl_cmd+=(--user "$user:$pass")
        
        # Поддержка FTPS (implicit и explicit)
        if [[ "$base_url" == ftps://* ]]; then
            debug_log "REMOTE" "Using FTPS (implicit TLS)"
            curl_cmd+=(--ssl-reqd --insecure)
        elif [[ "$base_url" == ftp://* ]]; then
            debug_log "REMOTE" "Using FTP with optional TLS"
            # Попробуем explicit TLS если доступен
            curl_cmd+=(--ssl --insecure)
        fi
        
        debug_log "REMOTE" "Running: ${curl_cmd[*]} $base_url/"
        if "${curl_cmd[@]}" "$base_url/" > "$SILENT_LOG" 2>&1; then 
            debug_log "REMOTE" "FTP connection SUCCESS"
            return 0
        else 
            debug_log "REMOTE" "FTP with TLS failed, trying without TLS..."
            # Повторная попытка без TLS для обычного FTP
            if [[ "$base_url" == ftp://* ]]; then
                curl_cmd=(curl $CURL_SILENT -m 15 --ftp-pasv --list-only)
                [[ -n "$user" ]] && curl_cmd+=(--user "$user:$pass")
                if "${curl_cmd[@]}" "$base_url/" > "$SILENT_LOG" 2>&1; then
                    debug_log "REMOTE" "FTP without TLS SUCCESS"
                    return 0
                fi
            fi
            debug_log "REMOTE" "FTP connection FAILED"
            return 1
        fi
        
    elif [[ "$type" == "webdav" ]]; then
        debug_log "REMOTE" "Testing WebDAV connection..."
        # WebDAV: PROPFIND с Depth: 0
        local curl_cmd=(curl $CURL_SILENT -m 15 -L)
        [[ -n "$user" ]] && curl_cmd+=(--user "$user:$pass")
        
        # Поддержка самоподписанных сертификатов
        [[ "$base_url" == https://* ]] && curl_cmd+=(--insecure)
        
        local http_code
        debug_log "REMOTE" "Sending PROPFIND request..."
        http_code=$("${curl_cmd[@]}" -o "$SILENT_LOG" -w "%{http_code}" -X PROPFIND -H "Depth: 0" "$base_url/" 2> "$SILENT_LOG")
        debug_log "REMOTE" "PROPFIND HTTP code: $http_code"
        
        # 207 Multi-Status — стандартный успешный ответ WebDAV
        # 200 OK — некоторые серверы отвечают так
        # 301/302 — редирект (curl -L обработает)
        if [[ "$http_code" =~ ^(200|207)$ ]]; then 
            debug_log "REMOTE" "WebDAV connection SUCCESS"
            return 0
        else 
            debug_log "REMOTE" "PROPFIND failed, trying GET fallback..."
            # Fallback: попробуем простой GET
            http_code=$("${curl_cmd[@]}" -o "$SILENT_LOG" -w "%{http_code}" "$base_url/" 2> "$SILENT_LOG")
            debug_log "REMOTE" "GET HTTP code: $http_code"
            if [[ "$http_code" =~ ^(200|207|401)$ ]]; then
                # 401 означает что сервер отвечает, но нужна авторизация
                debug_log "REMOTE" "WebDAV connection SUCCESS (via GET)"
                return 0
            fi
            debug_log "REMOTE" "WebDAV connection FAILED"
            return 1
        fi
        
    elif [[ "$type" == "rclone" ]]; then
        debug_log "REMOTE" "Testing rclone connection..."
        if ! command -v rclone > "$SILENT_LOG" 2>&1; then
            debug_log "REMOTE" "rclone not installed!"
            print_message "ERROR" "Rclone не установлен!"
            return 1
        fi
        # Проверяем доступность remote
        local remote_name="${url%%:*}"
        debug_log "REMOTE" "Remote name: $remote_name"
        if rclone listremotes 2> "$SILENT_LOG" | grep -q "^${remote_name}:$"; then
            debug_log "REMOTE" "Remote exists, testing lsd..."
            # Remote существует, проверяем доступность
            if rclone lsd "$url" > "$SILENT_LOG" 2>&1; then 
                debug_log "REMOTE" "Rclone connection SUCCESS"
                return 0
            fi
        else
            debug_log "REMOTE" "Remote '$remote_name' not found in rclone config"
        fi
        debug_log "REMOTE" "Rclone connection FAILED"
        return 1

    elif [[ "$type" == "s3" ]]; then
        # NB: для S3 параметры $url/$user/$pass функции НЕ используются —
        # передавать креды через них небезопасно (попадут в process listing).
        # Wizard temporarily set'ит S3_* глобалы или передаёт через
        # _S3_AWS_KEY_OVERRIDE / _S3_AWS_SECRET_OVERRIDE в _s3_aws_run.
        debug_log "REMOTE" "Testing S3 connection..."
        if ! command -v aws > "$SILENT_LOG" 2>&1; then
            print_message "ERROR" "AWS CLI не установлен!"
            return 1
        fi
        if [[ -z "$S3_BUCKET" ]]; then
            print_message "ERROR" "S3_BUCKET не задан в конфиге."
            return 1
        fi
        local _s3_validate_opts=()
        [[ -n "$S3_ENDPOINT" ]] && _s3_validate_opts+=(--endpoint-url "$S3_ENDPOINT")
        [[ -n "$S3_REGION"   ]] && _s3_validate_opts+=(--region "$S3_REGION")
        # NB: используем s3api head-bucket (доступен в v1/v2) вместо `aws s3 ls --max-items`.
        # `--max-items` это аргумент `aws s3api list-objects-v2`, а не `aws s3 ls` —
        # на AWS CLI v2 даёт `Unknown options: --max-items`.
        if _s3_aws_run s3api head-bucket --bucket "$S3_BUCKET" "${_s3_validate_opts[@]}" > "$SILENT_LOG" 2>&1; then
            debug_log "REMOTE" "S3 connection SUCCESS"
            return 0
        fi
        debug_log "REMOTE" "S3 connection FAILED"
        return 1
    fi
    
    debug_log "REMOTE" "Unknown storage type: $type"
    return 1
}

# =============================================================================
# _s3_aws_run: вызов aws CLI с приватным credentials-файлом
# =============================================================================
# Записывает временный файл ~/aws/credentials с правами 0600 и подключает его
# через AWS_SHARED_CREDENTIALS_FILE + AWS_PROFILE=lazarus, а не через
# `export AWS_ACCESS_KEY_ID`/`AWS_SECRET_ACCESS_KEY` в окружение текущего
# shell-процесса. После завершения файл затирается (shred / rm).
#
# Преимущества:
#   - переменные не утекают в дочерние процессы, не запущенные через aws;
#   - нет race-window между export и unset, в котором креды видны другим;
#   - повторные параллельные вызовы не конфликтуют между собой.
#
# Использование:
#   _s3_aws_run s3 cp file.tgz s3://bucket/path/
#   _s3_aws_run s3api head-bucket --bucket NAME
# Override (для wizard-режима, когда S3_* ещё не сохранены):
#   _S3_AWS_KEY_OVERRIDE="<key>" _S3_AWS_SECRET_OVERRIDE="<secret>" \
#       _s3_aws_run s3 ls ...
# =============================================================================
_s3_aws_run() {
    local _ak="${_S3_AWS_KEY_OVERRIDE:-$S3_ACCESS_KEY}"
    local _sk="${_S3_AWS_SECRET_OVERRIDE:-$S3_SECRET_KEY}"
    if [[ -z "$_ak" || -z "$_sk" ]]; then
        debug_log "S3" "_s3_aws_run: пустые credentials — отказ (опаснее тихий fallback на default chain)"
        print_message "ERROR" "S3 credentials не заданы (S3_ACCESS_KEY / S3_SECRET_KEY)" >&2
        return 1
    fi
    local _creds_file
    # umask 077 + mktemp → файл создаётся сразу с 0600 (без race-окна между mktemp и chmod).
    _creds_file=$(umask 077 && mktemp "${TMPDIR:-/tmp}/lazarus_s3_creds.XXXXXX" 2> "$SILENT_LOG") || {
        print_message "ERROR" "_s3_aws_run: mktemp failed — невозможно создать creds-файл" >&2
        return 1
    }
    # Регистрируем в cleanup_on_exit — если скрипт умрёт между write и rm, креды
    # удалятся в trap EXIT. Защита от SIGKILL невозможна (kernel-level), но от
    # ctrl+c/panic/normal-exit — гарантия удаления.
    register_sensitive_tmp "$_creds_file"
    chmod 600 "$_creds_file" 2> "$SILENT_LOG" || true
    {
        printf '[lazarus]\n'
        printf 'aws_access_key_id = %s\n' "$_ak"
        printf 'aws_secret_access_key = %s\n' "$_sk"
    } > "$_creds_file"
    AWS_SHARED_CREDENTIALS_FILE="$_creds_file" AWS_PROFILE="lazarus" aws "$@"
    local _rc=$?
    # /tmp обычно tmpfs → shred бесполезен, rm достаточно. На /var/tmp (если TMPDIR) — shred оправдан.
    rm -f "$_creds_file"
    unregister_sensitive_tmp "$_creds_file"
    return $_rc
}

# =============================================================================
# _s3_mask_endpoint: маскирует credentials в URL для debug_log / TG-отчётов.
# =============================================================================
# Если кто-то задал S3_ENDPOINT="https://AKIA...:secret@s3.example.com" — голый
# echo в debug-лог утечёт ключ в /var/log и журналы Telegram. Маскируем юзера
# и пароль (если есть в URL) на <CREDS>. Сам endpoint не трогаем, только лог.
# =============================================================================
_s3_mask_endpoint() {
    local _ep="$1"
    [[ -z "$_ep" ]] && { echo ""; return 0; }
    # scheme://user:pass@host → scheme://<CREDS>@host (regex без extended bash для портабельности)
    if [[ "$_ep" =~ ^([a-zA-Z][a-zA-Z0-9+.-]*://)([^/@]+@)(.*)$ ]]; then
        echo "${BASH_REMATCH[1]}<CREDS>@${BASH_REMATCH[3]}"
    else
        echo "$_ep"
    fi
}

# =============================================================================
# _s3_aws_version: детектит major-версию AWS CLI один раз и кэширует в глобале.
# =============================================================================
# Возвращает "1", "2" или "unknown". v1 (`aws-cli/1.x`) НЕ поддерживает флаг
# `--quiet` у `aws s3 cp` — только `--only-show-errors`. v2 поддерживает оба.
# Кэш в _AWS_CLI_MAJOR_CACHED — пересчёт только если не задан.
# =============================================================================
_AWS_CLI_MAJOR_CACHED=""
_s3_aws_version() {
    if [[ -n "$_AWS_CLI_MAJOR_CACHED" ]]; then
        echo "$_AWS_CLI_MAJOR_CACHED"
        return 0
    fi
    if ! command -v aws > "$SILENT_LOG" 2>&1; then
        _AWS_CLI_MAJOR_CACHED="unknown"
        echo "unknown"
        return 1
    fi
    local _ver_out
    _ver_out=$(aws --version 2>&1 | head -1)
    # Формат: "aws-cli/2.x.y Python/... Linux/..." или "aws-cli/1.x.y ..."
    if [[ "$_ver_out" =~ aws-cli/([0-9]+) ]]; then
        _AWS_CLI_MAJOR_CACHED="${BASH_REMATCH[1]}"
    else
        _AWS_CLI_MAJOR_CACHED="unknown"
    fi
    echo "$_AWS_CLI_MAJOR_CACHED"
}

# =============================================================================
# _s3_quiet_flag: правильный «тихий» флаг для `aws s3 cp`.
# =============================================================================
# v2: --quiet (полностью молчит, даже errors)
# v1: --only-show-errors (только errors)
# Для non-TTY режима без debug — хотим только errors, не молчание полностью,
# поэтому всегда `--only-show-errors`. Это работает на обеих версиях.
# =============================================================================
_s3_quiet_flag() {
    echo "--only-show-errors"
}

# =============================================================================
# _s3_arch_suffix: возвращает суффикс архитектуры для AWS CLI installer.
# =============================================================================
# AWS CLI v2 поставляет два билда: linux-x86_64 и linux-aarch64. Скрипт
# install_aws_cli всегда грузил x86_64 — на ARM (Oracle Cloud Ampere, AWS
# Graviton, Raspberry Pi 4/5) это даёт `Exec format error`.
# =============================================================================
_s3_arch_suffix() {
    local _arch
    _arch=$(uname -m 2>/dev/null)
    case "$_arch" in
        x86_64|amd64) echo "x86_64" ;;
        aarch64|arm64) echo "aarch64" ;;
        *) echo "" ;;  # неподдерживаемая → caller покажет ошибку
    esac
}

# =============================================================================
# _s3_abort_multiparts: abort'ит висящие multipart uploads для конкретного key.
# =============================================================================
# При сбое `aws s3 cp` (особенно по таймауту/потерянной сети) на стороне
# storage остаются Initiated multipart uploads. У AWS они тарифицируются как
# Standard Storage, у MinIO/RustFS могут блокировать дальнейшие uploads того
# же ключа. Вызывать ПОСЛЕ failed upload с тем же $bucket/$key — abort'ит ВСЕ
# нашедшиеся uploads с этим Key. Не падает если их нет.
#
# Аргументы:
#   $1 - bucket
#   $2 - key (полный путь внутри bucket)
#   $3 - массив доп.опций (--endpoint-url, --region)
# =============================================================================
_s3_abort_multiparts() {
    local _bucket="$1"
    local _key="$2"
    shift 2
    local _opts=("$@")
    local _list_json
    # list-multipart-uploads с Prefix=key — фильтр по конкретному файлу.
    _list_json=$(_s3_aws_run s3api list-multipart-uploads \
        --bucket "$_bucket" --prefix "$_key" \
        "${_opts[@]}" --output json 2> "$SILENT_LOG") || {
        debug_log "S3" "list-multipart-uploads failed (provider не поддерживает или нет прав)"
        return 0
    }
    [[ -z "$_list_json" || "$_list_json" == "null" ]] && return 0
    # Достаём UploadId'ы для нашего key. Используем python3 (есть на всех Debian);
    # fallback на grep — крайний случай.
    local _ids=""
    if command -v python3 > "$SILENT_LOG" 2>&1; then
        _ids=$(echo "$_list_json" | python3 -c '
import json,sys
try:
    d=json.load(sys.stdin)
except Exception:
    sys.exit(0)
key=sys.argv[1]
for u in (d.get("Uploads") or []):
    if u.get("Key")==key:
        print(u.get("UploadId",""))
' "$_key" 2> "$SILENT_LOG")
    else
        # Грубый grep-fallback — может зацепить лишнее, но это всё равно abort,
        # не destructive операция: висящие multipart-parts чужих файлов нас не волнуют.
        _ids=$(echo "$_list_json" | grep -oE '"UploadId":\s*"[^"]+"' | sed -E 's/.*"([^"]+)"$/\1/')
    fi
    [[ -z "$_ids" ]] && return 0
    local _aborted=0 _id
    while IFS= read -r _id; do
        [[ -z "$_id" ]] && continue
        if _s3_aws_run s3api abort-multipart-upload \
                --bucket "$_bucket" --key "$_key" --upload-id "$_id" \
                "${_opts[@]}" > "$SILENT_LOG" 2>&1; then
            _aborted=$((_aborted + 1))
        fi
    done <<< "$_ids"
    [[ $_aborted -gt 0 ]] && debug_log "S3" "Aborted $_aborted orphaned multipart upload(s) for $_key"
    return 0
}

# =============================================================================
# _s3_verify_uploaded: подтверждает что объект реально доехал и не повреждён.
# =============================================================================
# 1. head-object → ContentLength должен совпадать с локальным size.
# 2. Для не-multipart upload (single PUT) — ETag это MD5 hex. Сравниваем
#    с локальным MD5 как доп.проверку.
#    Для multipart ETag имеет формат "<md5>-<parts>" — сравнить с локальным
#    MD5 нельзя (multipart хеш считается иначе). Только size match.
#
# Аргументы:
#   $1 - bucket
#   $2 - key
#   $3 - local_size
#   $4 - local_file (для MD5 — только для не-multipart)
#   $5+ - массив доп.опций (--endpoint-url, --region)
# Return: 0 — OK, 1 — mismatch, 2 — head-object не сработал (не fatal — warn)
# =============================================================================
_s3_verify_uploaded() {
    local _bucket="$1"
    local _key="$2"
    local _local_size="$3"
    local _local_file="$4"
    shift 4
    local _opts=("$@")
    local _head_json
    _head_json=$(_s3_aws_run s3api head-object \
        --bucket "$_bucket" --key "$_key" \
        "${_opts[@]}" --output json 2> "$SILENT_LOG") || {
        debug_log "S3" "head-object failed (нет прав / object не виден сразу — eventual consistency)"
        return 2
    }
    # Извлекаем ContentLength и ETag (без python — простой parse).
    local _remote_size _etag
    _remote_size=$(echo "$_head_json" | grep -oE '"ContentLength":\s*[0-9]+' | head -1 | grep -oE '[0-9]+$')
    _etag=$(echo "$_head_json" | grep -oE '"ETag":\s*"[^"]+"' | head -1 | sed -E 's/.*"([^"]+)"$/\1/' | tr -d '"\\')
    if [[ -z "$_remote_size" ]]; then
        debug_log "S3" "verify: не удалось распарсить ContentLength из head-object"
        return 2
    fi
    if [[ "$_remote_size" != "$_local_size" ]]; then
        debug_log "S3" "verify FAIL: remote size=$_remote_size, local size=$_local_size"
        return 1
    fi
    debug_log "S3" "verify: size match ($_remote_size bytes)"
    # MD5 проверка только для не-multipart (ETag без дефиса).
    if [[ -n "$_etag" && "$_etag" != *-* && -f "$_local_file" ]]; then
        if command -v md5sum > "$SILENT_LOG" 2>&1; then
            local _local_md5
            _local_md5=$(md5sum "$_local_file" 2> "$SILENT_LOG" | awk '{print $1}')
            if [[ -n "$_local_md5" && "$_local_md5" != "$_etag" ]]; then
                debug_log "S3" "verify FAIL: ETag=$_etag, local MD5=$_local_md5"
                return 1
            fi
            [[ -n "$_local_md5" ]] && debug_log "S3" "verify: ETag MD5 match"
        fi
    else
        debug_log "S3" "verify: multipart upload (ETag=$_etag) — size-only check"
    fi
    return 0
}

upload_to_remote() {
    if [[ "$SEND_TO_REMOTE" != "true" ]]; then 
        debug_log "REMOTE" "Remote upload disabled (SEND_TO_REMOTE=$SEND_TO_REMOTE)"
        return 0
    fi
    local file_path="$1"
    local filename=$(basename "$file_path")
    local file_size=$(stat -c%s "$file_path" 2> "$SILENT_LOG" || echo "0")
    REMOTE_UPLOAD_STATUS_TEXT="" 
    
    debug_log "REMOTE" "=== upload_to_remote ==="
    debug_log "REMOTE" "File: $file_path"
    debug_log "REMOTE" "Size: $file_size bytes"
    debug_log "REMOTE" "Type: $REMOTE_STORAGE_TYPE"
    debug_log "REMOTE" "URL: $REMOTE_STORAGE_URL"

    # S3 не использует REMOTE_STORAGE_URL (хранит endpoint/bucket в S3_*),
    # поэтому URL-check применяем только к FTP/WebDAV/Rclone.
    if [[ "$REMOTE_STORAGE_TYPE" == "off" ]]; then
        debug_log "REMOTE" "Remote storage disabled"
        return 0
    fi
    if [[ "$REMOTE_STORAGE_TYPE" != "s3" && -z "$REMOTE_STORAGE_URL" ]]; then
        debug_log "REMOTE" "Remote storage URL empty (type=$REMOTE_STORAGE_TYPE)"
        return 0
    fi
    
    if [[ ! -f "$file_path" ]]; then
        print_message "ERROR" "Файл для загрузки не найден: $file_path" >&2
        log_message "ERROR" "Upload failed: file not found $file_path"
        debug_log "REMOTE" "ERROR: File not found!"
        return 1
    fi

    print_message "INFO" "Загрузка на $REMOTE_STORAGE_TYPE ($(numfmt --to=iec $file_size 2> "$SILENT_LOG" || echo "${file_size}B"))..." >&2

    # === RCLONE ===
    if [[ "$REMOTE_STORAGE_TYPE" == "rclone" ]]; then
        debug_log "REMOTE" "Using rclone..."
        if ! command -v rclone > "$SILENT_LOG" 2>&1; then
            print_message "ERROR" "Rclone не установлен!"
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ Rclone: Не установлен'
            return 1
        fi
        local dest="${REMOTE_STORAGE_URL%/}"
        local rclone_opts=(--progress --retries 3 --low-level-retries 10)
        [[ "$IS_INTERACTIVE" != "true" ]] && rclone_opts=(--quiet --retries 3 --low-level-retries 10)
        debug_log "REMOTE" "Running: rclone copy $file_path $dest ${rclone_opts[*]}"
        
        if rclone copy "$file_path" "$dest" "${rclone_opts[@]}" 2>&1; then
            print_message "SUCCESS" "Файл загружен (rclone)." >&2
            debug_log "REMOTE" "Rclone upload SUCCESS"
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ Rclone: OK'
            log_message "SUCCESS" "Uploaded $filename to rclone:$dest"
            return 0
        else
            print_message "ERROR" "Ошибка загрузки rclone." >&2
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ Rclone: Ошибка'
            log_message "ERROR" "Failed upload $filename to rclone:$dest"
            return 1
        fi
    fi

    # === S3 (AWS, MinIO, RustFS, Yandex Cloud, etc.) ===
    if [[ "$REMOTE_STORAGE_TYPE" == "s3" ]]; then
        debug_log "REMOTE" "Using S3..."
        
        # Проверяем AWS CLI
        if ! command -v aws > "$SILENT_LOG" 2>&1; then
            print_message "ERROR" "AWS CLI не установлен!" >&2
            local _arch_hint
            _arch_hint=$(_s3_arch_suffix)
            [[ -z "$_arch_hint" ]] && _arch_hint="x86_64"
            echo -e "Установка: ${GRAY}curl \"https://awscli.amazonaws.com/awscli-exe-linux-${_arch_hint}.zip\" -o awscliv2.zip && unzip awscliv2.zip && sudo ./aws/install${RESET}" >&2
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ S3: AWS CLI не установлен'
            return 1
        fi
        
        # Проверяем настройки
        if [[ -z "$S3_BUCKET" ]]; then
            print_message "ERROR" "S3 bucket не настроен!" >&2
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ S3: Bucket не настроен'
            return 1
        fi
        
        # Формируем путь в bucket с защитой от path-traversal (.., leading /).
        local s3_path="${S3_PATH#/}"             # strip leading /
        s3_path="${s3_path%/}"                   # strip trailing /
        if [[ "$s3_path" == *".."* ]]; then
            print_message "ERROR" "S3_PATH содержит '..' — отказ для защиты от path-traversal: $S3_PATH" >&2
            log_message "ERROR" "S3_PATH contains '..': $S3_PATH"
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ S3: Ошибка (S3_PATH невалиден)'
            return 1
        fi
        [[ -n "$s3_path" ]] && s3_path="${s3_path}/"
        # Нормализуем S3_ENDPOINT — strip trailing /
        local _s3_endpoint="${S3_ENDPOINT%/}"
        local s3_dest="s3://${S3_BUCKET}/${s3_path}${filename}"

        # NB: маскируем credentials в URL если пользователь задал endpoint вида
        # https://AKIA...:secret@host (плохая практика, но встречается).
        local _s3_endpoint_masked
        _s3_endpoint_masked=$(_s3_mask_endpoint "$_s3_endpoint")
        debug_log "REMOTE" "S3 Endpoint: $_s3_endpoint_masked"
        debug_log "REMOTE" "S3 Bucket: $S3_BUCKET"
        debug_log "REMOTE" "S3 Region: $S3_REGION"
        debug_log "REMOTE" "S3 Destination: s3://${S3_BUCKET}/${s3_path}${filename}"
        debug_log "REMOTE" "AWS CLI version: $(_s3_aws_version)"

        # Формируем команду
        local aws_opts=()
        [[ -n "$_s3_endpoint" ]] && aws_opts+=(--endpoint-url "$_s3_endpoint")
        [[ -n "$S3_REGION" ]] && aws_opts+=(--region "$S3_REGION")
        # CLI таймауты: 30 сек на TCP-connect, 600 сек на read-один-чанк.
        aws_opts+=(--cli-connect-timeout 30 --cli-read-timeout 600)

        # Retry × 3 с exp backoff (5, 15, 45 сек) — приводим к паритету с FTP/WebDAV.
        # Timeout на весь call: 120s + 60s на каждые 50 MB, capped at 1800s (30 мин).
        # Аналог расчёта что для FTP (line ~4441).
        local s3_timeout=$((120 + (file_size / 50000000) * 60))
        [[ $s3_timeout -gt 1800 ]] && s3_timeout=1800
        debug_log "REMOTE" "S3 timeout per attempt: ${s3_timeout}s, max retries: 3"

        # `timeout` не используем — _s3_aws_run это bash-функция (не export'нутая).
        # Вместо этого полагаемся на --cli-connect-timeout/--cli-read-timeout (выше).
        # При совсем зависшей сессии aws сам прекратится по read-timeout.
        # Универсальный «тихий» флаг — работает на v1 и v2.
        local s3_quiet
        s3_quiet=$(_s3_quiet_flag)
        # Key для head-object / abort-multipart (без префикса s3://bucket/).
        local s3_key="${s3_path}${filename}"
        local s3_attempt=1
        local s3_max=3
        local s3_delay=5
        local s3_output=""
        local s3_result=1
        while [[ $s3_attempt -le $s3_max ]]; do
            debug_log "REMOTE" "S3 upload attempt $s3_attempt/$s3_max"
            [[ $s3_attempt -gt 1 ]] && print_message "INFO" "S3 retry $s3_attempt/$s3_max..." >&2
            s3_output=$(_s3_aws_run s3 cp "$file_path" "$s3_dest" "${aws_opts[@]}" "$s3_quiet" 2>&1)
            s3_result=$?

            [[ $s3_result -eq 0 ]] && break

            log_message "WARN" "S3 upload attempt $s3_attempt failed (rc=$s3_result): $(echo "$s3_output" | head -1)"
            # Перед retry — abort висящих multipart-parts (если есть). Не блокируется
            # на ошибку — просто best-effort cleanup.
            _s3_abort_multiparts "$S3_BUCKET" "$s3_key" "${aws_opts[@]}"
            s3_attempt=$((s3_attempt + 1))
            if [[ $s3_attempt -le $s3_max ]]; then
                sleep "$s3_delay"
                s3_delay=$((s3_delay * 3))   # 5 → 15 → 45
            fi
        done

        if [[ $s3_result -eq 0 ]]; then
            # Integrity verify — size match + ETag MD5 (для не-multipart).
            # eventual consistency у некоторых провайдеров: даём 1 retry с 2-сек паузой.
            local _verify_rc=2 _verify_try=1
            while [[ $_verify_try -le 2 ]]; do
                _s3_verify_uploaded "$S3_BUCKET" "$s3_key" "$file_size" "$file_path" "${aws_opts[@]}"
                _verify_rc=$?
                [[ $_verify_rc -ne 2 ]] && break
                sleep 2
                _verify_try=$((_verify_try + 1))
            done
            case $_verify_rc in
                0)
                    print_message "SUCCESS" "Файл загружен в S3 (verified)." >&2
                    debug_log "REMOTE" "S3 upload SUCCESS + verify OK"
                    REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ S3: OK'
                    log_message "SUCCESS" "Uploaded $filename to S3 ($s3_dest), size=$file_size verified"
                    return 0
                    ;;
                1)
                    # Size или MD5 не сходятся — это destructive corruption. Не считаем upload успешным.
                    print_message "ERROR" "S3 verify FAIL — size/ETag не совпадают, удалённый файл повреждён!" >&2
                    debug_log "REMOTE" "S3 upload OK, но verify FAILED → треат как fail"
                    REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ S3: Verify FAIL'
                    log_message "ERROR" "S3 verify FAIL for $filename — ContentLength/ETag mismatch"
                    return 1
                    ;;
                *)
                    # head-object недоступен (нет ListBucket/GetObject прав или provider не отвечает).
                    # Это не fail — продолжаем считать upload OK, но WARN'им.
                    print_message "SUCCESS" "Файл загружен в S3 (verify пропущен — нет прав на head-object)." >&2
                    debug_log "REMOTE" "S3 upload SUCCESS, verify skipped (head-object недоступен)"
                    REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ S3: OK (verify skipped)'
                    log_message "WARN" "Uploaded $filename to S3, но head-object verify пропущен"
                    return 0
                    ;;
            esac
        else
            # Берём первые 200 символов stderr — длинные python-tracebacks от aws CLI ломают TG MarkdownV2.
            local s3_err_short
            s3_err_short=$(echo "$s3_output" | head -3 | tr '\n' ' ' | head -c 200)
            print_message "ERROR" "Ошибка загрузки в S3 после $s3_max попыток: $s3_err_short" >&2
            debug_log "REMOTE" "S3 upload FAILED (rc=$s3_result): $s3_output"
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ S3: Ошибка'
            log_message "ERROR" "Failed upload $filename to S3 after $s3_max attempts (rc=$s3_result): $s3_err_short"
            # Финальный cleanup — vot эти multipart-parts билятся даже когда «retry-логика»
            # их не успела зачистить (например при exit по таймауту bash-цикла).
            _s3_abort_multiparts "$S3_BUCKET" "$s3_key" "${aws_opts[@]}"
            return 1
        fi
    fi

    # === FTP / WEBDAV ===
    local upload_url="${REMOTE_STORAGE_URL%/}/$filename"
    local max_retries=3
    local retry_delay=5
    local attempt=1
    local http_code=""
    local upload_success=false
    
    # Расчёт таймаута на основе размера файла (минимум 120 сек, +60 сек на каждые 50MB)
    local timeout=$((120 + (file_size / 50000000) * 60))
    [[ $timeout -gt 1800 ]] && timeout=1800  # Максимум 30 минут
    debug_log "UPLOAD" "Upload URL: $upload_url"
    debug_log "UPLOAD" "Timeout: ${timeout}s, Max retries: $max_retries"
    
    while [[ $attempt -le $max_retries ]]; do
        debug_log "UPLOAD" "Attempt $attempt/$max_retries"
        [[ $attempt -gt 1 ]] && print_message "INFO" "Повторная попытка $attempt/$max_retries..." >&2
        
        # Базовые опции curl
        local curl_opts=(-o "$SILENT_LOG" -w "%{http_code}" -m "$timeout" -T "$file_path")
        
        # Прогресс-бар или тихий режим
        if [[ "$IS_INTERACTIVE" == "true" ]]; then
            curl_opts+=(-#)
        else
            curl_opts+=(-s)
        fi
        
        # Аутентификация
        [[ -n "$REMOTE_STORAGE_USER" ]] && curl_opts+=(--user "$REMOTE_STORAGE_USER:$REMOTE_STORAGE_PASS")
        
        if [[ "$REMOTE_STORAGE_TYPE" == "ftp" ]]; then
            # FTP специфичные опции
            curl_opts+=(--ftp-pasv)              # Passive mode (работает за NAT)
            curl_opts+=(--ftp-create-dirs)       # Создать директории если нужно
            debug_log "UPLOAD" "FTP mode: passive, create-dirs"
            
            # Поддержка FTPS
            if [[ "$upload_url" == ftps://* ]]; then
                curl_opts+=(--ssl-reqd --insecure)
                debug_log "UPLOAD" "FTPS: SSL required"
            elif [[ "$upload_url" == ftp://* ]]; then
                curl_opts+=(--ssl --insecure)    # Попробовать TLS если доступен
                debug_log "UPLOAD" "FTP: Try TLS if available"
            fi
            
            curl_opts+=("$upload_url")
            debug_log "UPLOAD" "Executing FTP upload..."
            http_code=$(curl "${curl_opts[@]}" 2> "$SILENT_LOG") || http_code="000"
            debug_log "UPLOAD" "FTP response code: $http_code"
            
            # FTP коды успеха: 226 (Transfer complete), 250 (Requested file action okay)
            if [[ "$http_code" =~ ^(226|250|200)$ ]]; then
                upload_success=true
                debug_log "UPLOAD" "FTP upload SUCCESS"
                break
            fi
            
        elif [[ "$REMOTE_STORAGE_TYPE" == "webdav" ]]; then
            # WebDAV специфичные опции
            curl_opts+=(-L)                      # Следовать редиректам
            curl_opts+=(--retry 2)               # Встроенный retry curl
            curl_opts+=(--retry-delay 3)
            debug_log "UPLOAD" "WebDAV mode: follow redirects, retry 2"
            
            # Поддержка HTTPS с самоподписанными сертификатами
            if [[ "$upload_url" == https://* ]]; then
                curl_opts+=(--insecure)
                debug_log "UPLOAD" "WebDAV: HTTPS with insecure"
            fi
            
            curl_opts+=("$upload_url")
            debug_log "UPLOAD" "Executing WebDAV upload..."
            http_code=$(curl "${curl_opts[@]}" 2> "$SILENT_LOG") || http_code="000"
            debug_log "UPLOAD" "WebDAV response code: $http_code"
            
            # WebDAV коды успеха: 200 OK, 201 Created, 204 No Content
            if [[ "$http_code" =~ ^(200|201|204)$ ]]; then
                upload_success=true
                debug_log "UPLOAD" "WebDAV upload SUCCESS"
                break
            fi
        fi
        
        # Логируем неудачную попытку
        debug_log "UPLOAD" "Attempt $attempt FAILED with HTTP $http_code"
        log_message "WARN" "Upload attempt $attempt failed: HTTP $http_code for $upload_url"
        
        ((attempt++))
        [[ $attempt -le $max_retries ]] && sleep $retry_delay
    done
    
    if [[ "$upload_success" == true ]]; then
        print_message "SUCCESS" "Файл загружен в хранилище." >&2
        if [[ "$REMOTE_STORAGE_TYPE" == "ftp" ]]; then 
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ FTP: OK'
        else 
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ WebDAV: OK'
        fi
        log_message "SUCCESS" "Uploaded $filename to $REMOTE_STORAGE_TYPE ($upload_url) HTTP=$http_code"
        return 0
    else
        print_message "ERROR" "Ошибка загрузки после $max_retries попыток (Код: $http_code)" >&2
        if [[ "$REMOTE_STORAGE_TYPE" == "ftp" ]]; then 
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ FTP: Ошибка'
        else 
            REMOTE_UPLOAD_STATUS_TEXT=$'\n☁️ WebDAV: Ошибка'
        fi
        log_message "ERROR" "Failed upload $filename to $REMOTE_STORAGE_TYPE after $max_retries attempts. Last HTTP=$http_code"
        return 1
    fi
}

configure_remote_storage() {
    while true; do
        clear_screen
        echo -e "${GREEN}${BOLD}Настройка удалённого хранилища${RESET}"
        echo ""
        
        # Показываем текущий статус
        if [[ "$REMOTE_STORAGE_TYPE" == "s3" && -n "$S3_BUCKET" ]]; then
            echo -e "Текущие настройки:"
            echo -e "  Тип: ${YELLOW}S3${RESET}"
            echo -e "  Bucket: ${CYAN}${S3_BUCKET}${RESET}"
            [[ -n "$S3_PATH" ]] && echo -e "  Путь: ${GRAY}${S3_PATH}${RESET}"
            [[ -n "$S3_ENDPOINT" ]] && echo -e "  Endpoint: ${GRAY}${S3_ENDPOINT}${RESET}"
            echo ""
        elif [[ "$REMOTE_STORAGE_TYPE" != "off" && -n "$REMOTE_STORAGE_URL" ]]; then
            echo -e "Текущие настройки:"
            echo -e "  Тип: ${YELLOW}${REMOTE_STORAGE_TYPE^^}${RESET}"
            echo -e "  URL: ${CYAN}${REMOTE_STORAGE_URL}${RESET}"
            [[ -n "$REMOTE_STORAGE_USER" ]] && echo -e "  Пользователь: ${GRAY}${REMOTE_STORAGE_USER}${RESET}"
            echo ""
        fi
        
        echo " 1. FTP / FTPS"
        echo " 2. WebDAV (Яндекс.Диск, Nextcloud, и др.)"
        echo -e " 3. ${CYAN}S3 Storage${RESET} (AWS, MinIO, RustFS, Yandex Cloud)"
        echo " 4. Rclone (Google Drive, Dropbox, и др.)"
        echo ""
        echo -e " ${RED}0. Отключить${RESET}"
        echo ""
        read -erp "Выбор (Enter - Назад): " r_type
        [[ -z "$r_type" ]] && return
        
        local new_type="off"
        local input_url="" input_user="" input_pass="" input_folder=""
        local base_url=""
        
        case $r_type in
            1) new_type="ftp" ;;
            2) new_type="webdav" ;;
            3) new_type="s3" ;;
            4) new_type="rclone" ;;
            0) 
                REMOTE_STORAGE_TYPE="off"
                REMOTE_STORAGE_URL=""
                REMOTE_STORAGE_USER=""
                REMOTE_STORAGE_PASS=""
                save_config
                print_message "SUCCESS" "Удалённое хранилище отключено."
                sleep 1
                return 
                ;;
            *) continue ;;
        esac

        echo ""
        
        if [[ "$new_type" == "ftp" ]]; then
            echo -e "${CYAN}${BOLD}Настройка FTP/FTPS${RESET}"
            echo ""
            echo -e "${GRAY}Шаг 1/3: Адрес сервера${RESET}"
            echo ""
            echo "Примеры:"
            echo -e "  ${GRAY}ftp://backup.example.com${RESET}"
            echo -e "  ${GRAY}ftps://secure.example.com:990${RESET}"
            echo ""
            read -erp "Адрес сервера (Enter - назад): " base_url
            [[ -z "$base_url" ]] && continue
            
            # Убираем trailing slash
            base_url="${base_url%/}"
            
            echo ""
            echo -e "${GRAY}Шаг 2/3: Папка на сервере${RESET}"
            echo ""
            echo "Примеры:"
            echo -e "  ${GRAY}backups${RESET}           → ${CYAN}${base_url}/backups${RESET}"
            echo -e "  ${GRAY}backup/lazarus${RESET}    → ${CYAN}${base_url}/backup/lazarus${RESET}"
            echo -e "  ${GRAY}(пусто)${RESET}           → ${CYAN}${base_url}${RESET} (корень)"
            echo ""
            read -erp "Папка: " input_folder
            
            # Формируем итоговый URL
            if [[ -n "$input_folder" ]]; then
                input_folder="${input_folder#/}"  # Убираем leading slash
                input_folder="${input_folder%/}"  # Убираем trailing slash
                input_url="${base_url}/${input_folder}"
            else
                input_url="$base_url"
            fi
            
            echo ""
            echo -e "Итоговый путь: ${CYAN}${input_url}${RESET}"
            echo ""
            echo -e "${GRAY}Шаг 3/3: Авторизация${RESET}"
            read -erp "Пользователь: " input_user
            read -s -erp "Пароль: " input_pass
            echo ""
            
        elif [[ "$new_type" == "webdav" ]]; then
            echo -e "${CYAN}${BOLD}Настройка WebDAV${RESET}"
            echo ""
            echo -e "${GRAY}Шаг 1/3: Адрес сервера${RESET}"
            echo ""
            echo "Примеры базовых адресов:"
            echo -e "  ${GRAY}https://webdav.yandex.ru${RESET}                    (Яндекс.Диск)"
            echo -e "  ${GRAY}https://cloud.example.com/remote.php/dav/files/user${RESET} (Nextcloud)"
            echo ""
            read -erp "Адрес сервера (Enter - назад): " base_url
            [[ -z "$base_url" ]] && continue
            
            # Убираем trailing slash
            base_url="${base_url%/}"
            
            echo ""
            echo -e "${GRAY}Шаг 2/3: Папка для бэкапов${RESET}"
            echo ""
            echo "Примеры:"
            echo -e "  ${GRAY}backups${RESET}           → ${CYAN}${base_url}/backups${RESET}"
            echo -e "  ${GRAY}Backup/Lazarus${RESET}    → ${CYAN}${base_url}/Backup/Lazarus${RESET}"
            echo -e "  ${GRAY}(пусто)${RESET}           → ${CYAN}${base_url}${RESET} (корень)"
            echo ""
            read -erp "Папка: " input_folder
            
            # Формируем итоговый URL
            if [[ -n "$input_folder" ]]; then
                input_folder="${input_folder#/}"
                input_folder="${input_folder%/}"
                input_url="${base_url}/${input_folder}"
            else
                input_url="$base_url"
            fi
            
            echo ""
            echo -e "Итоговый путь: ${CYAN}${input_url}${RESET}"
            echo ""
            echo -e "${GRAY}Шаг 3/3: Авторизация${RESET}"
            read -erp "Пользователь: " input_user
            read -s -erp "Пароль (или токен приложения): " input_pass
            echo ""
        
        elif [[ "$new_type" == "s3" ]]; then
            echo -e "${CYAN}${BOLD}Настройка S3 Storage${RESET}"
            echo ""
            
            # Проверяем AWS CLI
            if ! command -v aws > "$SILENT_LOG" 2>&1; then
                print_message "WARN" "AWS CLI не установлен!"
                echo ""
                echo -e "Установить автоматически? (требуется ~100MB)"
                read -erp "(Y/n): " install_aws
                if [[ ! "$install_aws" =~ ^[Nn]$ ]]; then
                    # Определяем CPU arch — AWS CLI v2 поставляет линукс-бинари в x86_64 и aarch64.
                    # x86_64 на ARM-сервере (Oracle Ampere, AWS Graviton, RPi) даёт Exec format error.
                    _aws_arch=$(_s3_arch_suffix)
                    if [[ -z "$_aws_arch" ]]; then
                        print_message "ERROR" "Неподдерживаемая CPU арх: $(uname -m). Установите AWS CLI вручную."
                        echo -e "Документация: ${GRAY}https://docs.aws.amazon.com/cli/latest/userguide/getting-started-install.html${RESET}"
                        read -erp "Enter..." dummy
                        continue
                    fi
                    print_message "INFO" "Устанавливаю AWS CLI ($_aws_arch)..."
                    if curl -sL "https://awscli.amazonaws.com/awscli-exe-linux-${_aws_arch}.zip" -o /tmp/awscliv2.zip && \
                       unzip -q /tmp/awscliv2.zip -d /tmp && \
                       sudo /tmp/aws/install --update 2> "$SILENT_LOG"; then
                        rm -rf /tmp/awscliv2.zip /tmp/aws
                        print_message "SUCCESS" "AWS CLI установлен!"
                        _AWS_CLI_MAJOR_CACHED=""  # сбрасываем кэш — пересчитаем при первом вызове.
                    else
                        rm -rf /tmp/awscliv2.zip /tmp/aws
                        print_message "ERROR" "Ошибка установки AWS CLI"
                        echo -e "Установите вручную: ${GRAY}https://docs.aws.amazon.com/cli/latest/userguide/getting-started-install.html${RESET}"
                        read -erp "Enter..." dummy
                        continue
                    fi
                else
                    continue
                fi
            fi
            
            echo -e "${GRAY}Шаг 1/5: Выберите провайдер${RESET}"
            echo ""
            echo " 1. AWS S3"
            echo " 2. MinIO"
            echo " 3. RustFS"
            echo " 4. Yandex Cloud Object Storage"
            echo " 5. Selectel Cloud Storage"
            echo " 6. Cloudflare R2"
            echo " 7. Backblaze B2"
            echo " 8. Другой S3-совместимый"
            echo ""
            read -erp "Выбор (Enter - назад): " s3_provider
            [[ -z "$s3_provider" ]] && continue

            local default_endpoint="" default_region="" provider_hint=""
            case $s3_provider in
                1) # AWS
                    default_endpoint=""  # AWS CLI использует дефолтный endpoint
                    default_region="us-east-1"
                    ;;
                2) # MinIO
                    default_endpoint="http://localhost:9000"
                    default_region="us-east-1"
                    ;;
                3) # RustFS
                    default_endpoint="http://localhost:8333"
                    default_region="us-east-1"
                    ;;
                4) # Yandex Cloud
                    default_endpoint="https://storage.yandexcloud.net"
                    default_region="ru-central1"
                    ;;
                5) # Selectel
                    default_endpoint="https://s3.storage.selcloud.ru"
                    default_region="ru-1"
                    ;;
                6) # Cloudflare R2
                    # R2: endpoint вида https://<account-id>.r2.cloudflarestorage.com,
                    # region ОБЯЗАТЕЛЬНО "auto" — иначе SignatureDoesNotMatch.
                    default_endpoint=""
                    default_region="auto"
                    provider_hint="r2"
                    ;;
                7) # Backblaze B2 (S3-compatible API)
                    # B2: endpoint вида https://s3.<region>.backblazeb2.com,
                    # region из endpoint (us-west-001, eu-central-003 и т.д.).
                    default_endpoint=""
                    default_region="us-west-001"
                    provider_hint="b2"
                    ;;
                8) # Custom
                    default_endpoint=""
                    default_region="us-east-1"
                    ;;
                *) continue ;;
            esac
            
            echo ""
            echo -e "${GRAY}Шаг 2/5: Endpoint URL${RESET}"
            if [[ -n "$default_endpoint" ]]; then
                echo -e "По умолчанию: ${CYAN}${default_endpoint}${RESET}"
                echo "(Оставьте пустым для значения по умолчанию)"
            elif [[ "$s3_provider" == "1" ]]; then
                echo -e "${GRAY}Для AWS оставьте пустым (используется стандартный endpoint)${RESET}"
            elif [[ "$provider_hint" == "r2" ]]; then
                echo -e "Формат: ${GRAY}https://<account-id>.r2.cloudflarestorage.com${RESET}"
                echo -e "${GRAY}Account ID — в Cloudflare dashboard → R2 → Overview${RESET}"
            elif [[ "$provider_hint" == "b2" ]]; then
                echo -e "Формат: ${GRAY}https://s3.<region>.backblazeb2.com${RESET}"
                echo -e "${GRAY}Region виден в Backblaze B2 → Buckets → Endpoint${RESET}"
            else
                echo -e "Пример: ${GRAY}https://s3.example.com${RESET}"
            fi
            read -erp "Endpoint URL: " input_endpoint
            [[ -z "$input_endpoint" ]] && input_endpoint="$default_endpoint"

            # Валидация endpoint: должен быть http(s)://host, без \n / spaces / control chars.
            # Не блокирующая — только WARN, потому что custom S3 может быть IP+port.
            if [[ -n "$input_endpoint" ]]; then
                if [[ ! "$input_endpoint" =~ ^https?://[A-Za-z0-9._-]+(:[0-9]+)?(/.*)?$ ]]; then
                    print_message "WARN" "Endpoint выглядит подозрительно: $input_endpoint"
                    echo -e "${GRAY}Ожидается формат http(s)://host[:port][/path]${RESET}"
                    read -erp "Использовать всё равно? (y/N): " _ep_force
                    if [[ ! "$_ep_force" =~ ^[Yy]$ ]]; then
                        continue
                    fi
                fi
            fi
            
            echo ""
            echo -e "${GRAY}Шаг 3/5: Bucket и путь${RESET}"
            read -erp "Имя bucket: " input_bucket
            [[ -z "$input_bucket" ]] && { print_message "ERROR" "Bucket обязателен!"; sleep 1; continue; }
            
            echo ""
            echo -e "Путь внутри bucket (опционально):"
            echo -e "  ${GRAY}backups${RESET}         → s3://${input_bucket}/backups/"
            echo -e "  ${GRAY}lazarus/prod${RESET}    → s3://${input_bucket}/lazarus/prod/"
            echo -e "  ${GRAY}(пусто)${RESET}         → s3://${input_bucket}/"
            read -erp "Путь: " input_path
            input_path="${input_path#/}"
            input_path="${input_path%/}"
            
            echo ""
            echo -e "${GRAY}Шаг 4/5: Регион${RESET}"
            echo -e "По умолчанию: ${CYAN}${default_region}${RESET}"
            if [[ "$provider_hint" == "r2" ]]; then
                echo -e "${YELLOW}Для Cloudflare R2 регион ДОЛЖЕН быть \"auto\" — иначе SignatureDoesNotMatch${RESET}"
            fi
            read -erp "Регион: " input_region
            [[ -z "$input_region" ]] && input_region="$default_region"
            
            echo ""
            echo -e "${GRAY}Шаг 5/5: Credentials${RESET}"
            read -erp "Access Key ID: " input_access_key
            read -s -erp "Secret Access Key: " input_secret_key
            echo ""
            
            [[ -z "$input_access_key" || -z "$input_secret_key" ]] && { 
                print_message "ERROR" "Credentials обязательны!"
                sleep 1
                continue 
            }
            
            # Тестируем подключение
            echo ""
            print_message "INFO" "Проверка подключения к S3..."
            
            local test_opts=()
            [[ -n "$input_endpoint" ]] && test_opts+=(--endpoint-url "$input_endpoint")
            test_opts+=(--region "$input_region")

            if _S3_AWS_KEY_OVERRIDE="$input_access_key" _S3_AWS_SECRET_OVERRIDE="$input_secret_key" \
                    _s3_aws_run s3api head-bucket --bucket "$input_bucket" "${test_opts[@]}" > "$SILENT_LOG" 2>&1; then
                print_message "SUCCESS" "Подключение успешно!"
                
                # Сохраняем настройки
                REMOTE_STORAGE_TYPE="s3"
                REMOTE_STORAGE_URL=""  # Не используется для S3
                REMOTE_STORAGE_USER=""
                REMOTE_STORAGE_PASS=""
                S3_ENDPOINT="$input_endpoint"
                S3_BUCKET="$input_bucket"
                S3_PATH="$input_path"
                S3_REGION="$input_region"
                S3_ACCESS_KEY="$input_access_key"
                S3_SECRET_KEY="$input_secret_key"
                
                save_config
                print_message "SUCCESS" "Настройки S3 сохранены."
                sleep 1.5
                return
            else
                print_message "ERROR" "Не удалось подключиться к S3!"
                echo ""
                read -erp "Сохранить настройки несмотря на ошибку? (y/N): " force_save
                if [[ "$force_save" =~ ^[Yy]$ ]]; then
                    REMOTE_STORAGE_TYPE="s3"
                    REMOTE_STORAGE_URL=""
                    REMOTE_STORAGE_USER=""
                    REMOTE_STORAGE_PASS=""
                    S3_ENDPOINT="$input_endpoint"
                    S3_BUCKET="$input_bucket"
                    S3_PATH="$input_path"
                    S3_REGION="$input_region"
                    S3_ACCESS_KEY="$input_access_key"
                    S3_SECRET_KEY="$input_secret_key"
                    save_config
                    print_message "WARN" "Настройки сохранены (соединение не проверено)."
                    sleep 1.5
                    return
                fi
            fi
            continue
            
        elif [[ "$new_type" == "rclone" ]]; then
            echo -e "${CYAN}${BOLD}Настройка Rclone${RESET}"
            echo ""
            if ! command -v rclone > "$SILENT_LOG" 2>&1; then
                print_message "ERROR" "Rclone не установлен!"
                echo -e "Установка: ${GRAY}curl https://rclone.org/install.sh | sudo bash${RESET}"
                read -erp "Enter..." dummy
                continue
            fi
            
            echo -e "${GRAY}Шаг 1/2: Выбор remote${RESET}"
            echo ""
            echo "Доступные remotes:"
            local remotes=$(rclone listremotes 2> "$SILENT_LOG")
            if [[ -z "$remotes" ]]; then
                print_message "WARN" "Нет настроенных remotes!"
                echo -e "Настройте через: ${GRAY}rclone config${RESET}"
                read -erp "Enter..." dummy
                continue
            fi
            echo "$remotes" | sed 's/^/  /'
            echo ""
            read -erp "Имя remote (без двоеточия, Enter - назад): " base_url
            [[ -z "$base_url" ]] && continue
            
            # Убираем двоеточие если пользователь его добавил
            base_url="${base_url%:}"
            
            echo ""
            echo -e "${GRAY}Шаг 2/2: Папка в хранилище${RESET}"
            echo ""
            echo "Примеры:"
            echo -e "  ${GRAY}backups${RESET}           → ${CYAN}${base_url}:backups${RESET}"
            echo -e "  ${GRAY}Backup/Server1${RESET}    → ${CYAN}${base_url}:Backup/Server1${RESET}"
            echo -e "  ${GRAY}(пусто)${RESET}           → ${CYAN}${base_url}:${RESET} (корень)"
            echo ""
            read -erp "Папка: " input_folder
            
            # Формируем итоговый путь для rclone
            if [[ -n "$input_folder" ]]; then
                input_folder="${input_folder#/}"
                input_folder="${input_folder%/}"
                input_url="${base_url}:${input_folder}"
            else
                input_url="${base_url}:"
            fi
            
            echo ""
            echo -e "Итоговый путь: ${CYAN}${input_url}${RESET}"
            input_user=""
            input_pass=""
        fi

        echo ""
        print_message "INFO" "Проверка подключения..."
        
        if validate_remote_connection "$new_type" "$input_url" "$input_user" "$input_pass"; then
            print_message "SUCCESS" "Соединение установлено!"
            REMOTE_STORAGE_TYPE="$new_type"
            REMOTE_STORAGE_URL="$input_url"
            REMOTE_STORAGE_USER="$input_user"
            REMOTE_STORAGE_PASS="$input_pass"
            save_config
            print_message "SUCCESS" "Настройки сохранены."
            sleep 1.5
            return
        else
            print_message "ERROR" "Не удалось подключиться к серверу!"
            echo ""
            read -erp "Сохранить настройки несмотря на ошибку? (y/N): " force_save
            if [[ "$force_save" =~ ^[Yy]$ ]]; then
                REMOTE_STORAGE_TYPE="$new_type"
                REMOTE_STORAGE_URL="$input_url"
                REMOTE_STORAGE_USER="$input_user"
                REMOTE_STORAGE_PASS="$input_pass"
                save_config
                print_message "WARN" "Настройки сохранены (соединение не проверено)."
                sleep 1.5
                return
            else
                print_message "INFO" "Отменено. Возврат к выбору типа..."
                sleep 1
            fi
        fi
    done
}

