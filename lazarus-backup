# Trap для очистки при завершении (освобождение блокировки + временные файлы)
cleanup_on_exit() {
    # Освобождаем блокировку если была получена
    # NOTE: debug_log может не работать здесь если вызывается после закрытия stdout
    if [[ -n "$LOCK_FD" ]]; then
        flock -u "$LOCK_FD" 2>/dev/null || true
        eval "exec $LOCK_FD>&-" 2>/dev/null || true
    fi
    rm -f "$LOCK_FILE" 2>/dev/null || true
    
    # Очищаем временные директории миграции
    if [[ ${#TEMP_DIRS[@]} -gt 0 ]]; then
        for temp_dir in "${TEMP_DIRS[@]}"; do
            [[ -d "$temp_dir" ]] && rm -rf "$temp_dir" 2>/dev/null || true
        done
    fi
}
trap cleanup_on_exit EXIT INT TERM

