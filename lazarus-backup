                _s3_list_opts=()
                [[ -n "$S3_ENDPOINT" ]] && _s3_list_opts+=(--endpoint-url "$S3_ENDPOINT")
                [[ -n "$S3_REGION" ]] && _s3_list_opts+=(--region "$S3_REGION")
                _s3_list_path="${S3_PATH%/}"
                [[ -n "$_s3_list_path" ]] && _s3_list_path="${_s3_list_path}/"
                echo "Файлы в s3://${S3_BUCKET}/${_s3_list_path}:"
                _s3_aws_run s3 ls "s3://${S3_BUCKET}/${_s3_list_path}" "${_s3_list_opts[@]}" --human-readable
                ;;
            upload|-u)
                # Загрузить файл в S3
                if [[ "$REMOTE_STORAGE_TYPE" != "s3" ]]; then
                    echo -e "${RED}S3 не настроен!${RESET}"
                    exit 1
                fi
                _s3_file_to_upload="$3"
                if [[ -z "$_s3_file_to_upload" ]]; then
                    echo "Использование: lazarus s3 upload <файл>"
                    exit 1
                fi
                if [[ ! -f "$_s3_file_to_upload" ]]; then
                    echo -e "${RED}Файл не найден: $_s3_file_to_upload${RESET}"
                    exit 1
                fi
                # NB: subshell-обёртка — иначе SEND_TO_REMOTE="true" утечёт за пределы команды
                # и любой случайный save_config (например из других веток) запишет в .env
                # "true", даже если пользователь намеренно отключил автоматический upload.
                # Override локален к subshell, exit code пробрасывается через $?.
                (
                    SEND_TO_REMOTE="true"
                    upload_to_remote "$_s3_file_to_upload"
                )
                exit $?
                ;;
            *)
                echo "Использование: lazarus s3 <команда>"
                echo "           или: lazarus -S <команда>"
                echo ""
                echo "Команды:"
                echo "  test,   -t      - Проверить подключение к S3"
                echo "  list,   -l      - Список файлов в bucket"
                echo "  upload, -u      - Загрузить файл в S3"
                echo ""
                echo "Примеры:"
                echo "  lazarus s3 test"
                echo "  lazarus s3 list"
                echo "  lazarus s3 upload backup.tar.gz"
                echo "  lazarus -S -t"
                ;;
        esac
        ;;
    *)
        # Проверка несоответствия cron при первом запуске интерактивного режима
        check_cron_mismatch
        
        # === ПРОВЕРКА ТРЕБОВАНИЙ ЛИЦЕНЗИИ ДЛЯ БОТА v3.25.5+ ===
        # Проверяем конфигурацию бота при старте скрипта
        
        # Если BOT_PATH пуст — пробуем найти автоматически
        if [[ -z "$BOT_PATH" || ! -d "$BOT_PATH" ]]; then
            # Пробуем стандартные пути
            for _try_path in "$DEFAULT_BOT_PATH" "/opt/rwp_shop" "/opt/remnawave-telegram-shop"; do
                if [[ -d "$_try_path" && ( -f "$_try_path/docker-compose.yml" || -f "$_try_path/compose.yaml" ) ]]; then
                    BOT_PATH="$_try_path"
                    break
                fi
            done
        fi
        
        if [[ -n "$BOT_PATH" && -d "$BOT_PATH" ]]; then
            _current_bot_version=$(get_current_bot_version 2>/dev/null)
            if [[ -n "$_current_bot_version" ]] && version_gte "$_current_bot_version" "3.25.5"; then
                _has_key=false
                _has_mid=false
                has_license_key && _has_key=true
                has_machine_id_volume && _has_mid=true
                
                if [[ "$_has_key" == "false" || "$_has_mid" == "false" ]]; then
                    clear_screen
                    echo -e "${RED}${BOLD}═══════════════════════════════════════════════════${RESET}"
                    echo -e "${RED}${BOLD}  ⚠️  ВНИМАНИЕ: ТРЕБУЕТСЯ НАСТРОЙКА ЛИЦЕНЗИИ${RESET}"
                    echo -e "${RED}${BOLD}═══════════════════════════════════════════════════${RESET}"
                    echo ""
                    echo -e "Бот версии ${CYAN}$_current_bot_version${RESET} требует LICENSE_KEY и machine-id."
                    echo ""
                    echo -e "${YELLOW}${BOLD}Статус конфигурации:${RESET}"
                    if [[ "$_has_key" == "true" ]]; then
                        echo -e "  LICENSE_KEY:     ${GREEN}✓ настроен${RESET}"
                    else
                        echo -e "  LICENSE_KEY:     ${RED}✗ отсутствует в .env${RESET}"
                    fi
                    if [[ "$_has_mid" == "true" ]]; then
                        echo -e "  machine-id:      ${GREEN}✓ настроен${RESET}"
                    else
                        echo -e "  machine-id:      ${RED}✗ отсутствует в compose${RESET}"
                    fi
                    echo ""
                    echo -e "Получить ключ: ${CYAN}https://t.me/rwp_shop_bot${RESET}"
                    echo ""
                    read -erp "Настроить сейчас? [Y/n]: " setup_now
                    if [[ ! "$setup_now" =~ ^[Nn]$ ]]; then
                        if [[ "$_has_key" == "false" ]]; then
                            ensure_license_key_in_env
                        fi
                        if [[ "$_has_mid" == "false" ]]; then
                            _compose_file=""
                            [[ -f "$BOT_PATH/compose.yaml" ]] && _compose_file="$BOT_PATH/compose.yaml"
                            [[ -f "$BOT_PATH/docker-compose.yml" ]] && _compose_file="$BOT_PATH/docker-compose.yml"
                            [[ -n "$_compose_file" ]] && ensure_machine_id_volume "$_compose_file"
                        fi
                    fi
                fi
            fi
        fi
        
        # Тихая проверка обновлений скрипта при первом запуске меню
        check_updates_silent 2>/dev/null
        
        while true; do
            # Получаем актуальные статусы из cron
            CRON_STATUS_FULL=$(get_cron_status "full")
            CRON_STATUS_DB=$(get_cron_status "db")
            CRON_STATUS_FILES=$(get_cron_status "files")
            
            # Получаем статистику бэкапов
            get_backup_stats
            
            # Цветовая индикация статусов cron
            # Full и DB — обязательные (красные если выключены оба), Files — опциональный (серый если выключен)
            NO_CRITICAL_BACKUP=false
            [[ "$CRON_STATUS_FULL" == "Выкл" && "$CRON_STATUS_DB" == "Выкл" ]] && NO_CRITICAL_BACKUP=true
            
            COLOR_FULL="$GRAY"; [[ "$CRON_STATUS_FULL" != "Выкл" ]] && COLOR_FULL="$YELLOW"
            COLOR_DB="$GRAY"; [[ "$CRON_STATUS_DB" != "Выкл" ]] && COLOR_DB="$YELLOW"
            COLOR_FILES="$GRAY"; [[ "$CRON_STATUS_FILES" != "Выкл" ]] && COLOR_FILES="$YELLOW"
            
            BOT_VERSION=$(get_bot_version_display)
            CONTAINER_STATUS=$(get_container_status)
            
            # Цвет статуса контейнера
            STATUS_COLOR="$GREEN"
            [[ "$CONTAINER_STATUS" != "Online" ]] && STATUS_COLOR="$RED"
            
            clear_screen
            echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════${RESET}"
            echo -e "${GREEN}${BOLD}  LAZARUS Backup Manager v${VERSION}${RESET}"
            echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════${RESET}"
            echo -e "Бот: ${CYAN}${BOT_VERSION}${RESET} | Контейнер: ${STATUS_COLOR}${CONTAINER_STATUS}${RESET}"
            echo ""
            
            # Уведомление о доступном обновлении скрипта
            if [[ -n "$UPDATE_AVAILABLE" && -n "$UPDATE_REMOTE_VERSION" ]]; then
                echo -e "${CYAN}${BOLD}🆕 Доступно обновление скрипта: ${VERSION} → ${UPDATE_REMOTE_VERSION}${RESET}"
                echo -e "${GRAY}   Выберите пункт 7 для обновления${RESET}"
                echo ""
            fi

            # Уведомление о pending v1→v2 миграции (sentinel создан cron-режимом)
            if [[ -f "$INSTALL_DIR/.v2_migration_pending" ]]; then
                _V2_PENDING_COUNT=$(cat "$INSTALL_DIR/.v2_migration_pending" 2>/dev/null | head -1)
                if [[ "$_V2_PENDING_COUNT" =~ ^[0-9]+$ && "$_V2_PENDING_COUNT" -gt 0 ]]; then
                    echo -e "${YELLOW}${BOLD}🔐 Найдено ${_V2_PENDING_COUNT} backup'ов в формате v1 (без HMAC integrity)${RESET}"
                    echo -e "${GRAY}   Команда: ${CYAN}lazarus migrate-v2${GRAY} — конвертация в v2 (с HMAC)${RESET}"
                    echo ""
                fi
            fi
            
            # Статистика бэкапов
            echo -e "Бэкапы: ${STATS_FULL} Full | ${STATS_DB} DB | ${STATS_FILES} Files | ${BOLD}${STATS_SIZE}${RESET} всего"
            if [[ -n "$STATS_LAST" ]]; then
                echo -e "Последний: ${STATS_LAST} (${STATS_LAST_AGO})"
            fi
            echo ""
            
            # Предупреждение если нет критических авто-бэкапов
            if [[ "$NO_CRITICAL_BACKUP" == true ]]; then
                echo -e "${RED}${BOLD}⚠️  ВНИМАНИЕ: Авто-бэкап не настроен!${RESET}"
                echo -e "${RED}   Рекомендуется включить Full или DB бэкап${RESET}"
                echo ""
            fi
            
            # Предупреждение если Telegram не настроен
            if [[ -z "$BOT_TOKEN" || -z "$CHAT_ID" ]]; then
                echo -e "${YELLOW}ℹ️  Telegram не настроен (уведомления отключены)${RESET}"
                echo ""
            fi
            
            echo -e "Авто-бэкап (cron):"
            echo -e " • Full:  ${COLOR_FULL}${CRON_STATUS_FULL}${RESET}"
            echo -e " • DB:    ${COLOR_DB}${CRON_STATUS_DB}${RESET}"
            echo -e " • Files: ${COLOR_FILES}${CRON_STATUS_FILES}${RESET}"
            echo ""
            echo " --- ДЕЙСТВИЯ ---"
            echo " 1. Ручной бекап (Full / DB / Files)"
            echo " 2. Настроить авто-бекап"
            echo " 3. Восстановить из бэкапа"
            echo " 4. Настройки (Пути / Токены / Ротация)"
            
            CLEANUP_LABEL=""
            if [[ "$DELETE_MODE" == "time" ]]; then
                CLEANUP_LABEL="(>$RETENTION_DAYS дней)"
            else
                CLEANUP_LABEL="(>$MAX_BACKUPS_COUNT шт.)"
            fi
            echo " 5. Удалить старые бэкапы $CLEANUP_LABEL"
            echo -e " 6. ${CYAN}Обновить бота${RESET}"
            echo ""

            # Подсветка пункта обновления если доступно
            if [[ -n "$UPDATE_AVAILABLE" ]]; then
                echo -e " ${CYAN}${BOLD}7. Проверить обновления скрипта [NEW!]${RESET}"
            else
                echo -e " 7. Проверить обновления скрипта"
            fi
            echo -e "${RED} 666. Удалить скрипт (Uninstall)${RESET}"
            echo " 0. Выход"
            echo ""
            safe_read -erp "Выбор (Enter - выход): " opt; [[ -z "$opt" ]] && exit 0
            case $opt in
                1) menu_manual_backup ;; 2) menu_automation ;; 3) menu_restore ;;
                4) menu_settings ;; 5) cleanup_old_backups ;; 6) update_bot ;;
                7|8) check_for_updates ;; 666) uninstall_script ;; 0) exit 0 ;;
            esac
        done
        ;;
esac

fi
