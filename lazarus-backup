# lazarus bot up - Запустить контейнер бота (если не запущен)
bot_up() {
    echo -e "${GREEN}${BOLD}[BOT UP]${RESET} Проверка контейнера бота..."
    
    if [[ -z "$BOT_PATH" || ! -d "$BOT_PATH" ]]; then
        ensure_bot_path || {
            print_message "ERROR" "Путь к боту не найден"
            return 1
        }
    fi
    
    cd "$BOT_PATH" || return 1
    
    # Проверяем статус контейнера
    local bot_status=$(docker compose ps --format "{{.Status}}" 2>/dev/null | head -1)
    
    if [[ "$bot_status" == *"Up"* ]]; then
        local bot_ver=$(get_current_bot_version 2>/dev/null)
        print_message "SUCCESS" "Бот уже запущен (v${bot_ver:-?})"
        echo -e "Статус: ${GREEN}$bot_status${RESET}"
        return 0
    fi
    
    print_message "INFO" "Запуск контейнера..."
    if docker compose up -d 2>/dev/null || docker-compose up -d 2>/dev/null; then
        sleep 2
        bot_status=$(docker compose ps --format "{{.Status}}" 2>/dev/null | head -1)
        if [[ "$bot_status" == *"Up"* ]]; then
            print_message "SUCCESS" "Бот запущен"
        else
            print_message "WARN" "Контейнер запущен, статус: $bot_status"
        fi
    else
        print_message "ERROR" "Ошибка запуска контейнера"
        return 1
    fi
}

# lazarus bot down - Остановить контейнер бота
bot_down() {
    echo -e "${YELLOW}${BOLD}[BOT DOWN]${RESET} Остановка контейнера бота..."
    
    if [[ -z "$BOT_PATH" || ! -d "$BOT_PATH" ]]; then
        ensure_bot_path || {
            print_message "ERROR" "Путь к боту не найден"
            return 1
        }
    fi
    
    cd "$BOT_PATH" || return 1
    
    # Проверяем запущен ли
    local bot_status=$(docker compose ps --format "{{.Status}}" 2>/dev/null | head -1)
    
    if [[ -z "$bot_status" || "$bot_status" != *"Up"* ]]; then
        print_message "INFO" "Бот уже остановлен"
        return 0
    fi
    
    print_message "INFO" "Остановка..."
    if docker compose down 2>/dev/null || docker-compose down 2>/dev/null; then
        print_message "SUCCESS" "Бот остановлен"
    else
        print_message "ERROR" "Ошибка остановки"
        return 1
    fi
}

# lazarus bot status - Статус бота, версия, БД healthcheck
bot_status() {
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════════════════${RESET}"
    echo -e "${CYAN}${BOLD}  Статус бота${RESET}"
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════════════════${RESET}"
    echo ""
    
    if [[ -z "$BOT_PATH" || ! -d "$BOT_PATH" ]]; then
        ensure_bot_path || {
            print_message "ERROR" "Путь к боту не найден"
            return 1
        }
    fi
    
    cd "$BOT_PATH" || return 1
    
    # Версия бота
    local bot_ver=$(get_current_bot_version 2>/dev/null)
    echo -e "Версия бота:     ${CYAN}${bot_ver:-не определена}${RESET}"
    
    # Статус контейнера бота
    local bot_container=$(docker compose ps --format "{{.Name}}" 2>/dev/null | grep -E "bot|shop" | head -1)
    local bot_status=$(docker inspect --format='{{.State.Status}}' "$bot_container" 2>/dev/null)
    local bot_health=$(docker inspect --format='{{.State.Health.Status}}' "$bot_container" 2>/dev/null)
    
    if [[ "$bot_status" == "running" ]]; then
        echo -e "Контейнер бота:  ${GREEN}● Running${RESET}"
    elif [[ -n "$bot_status" ]]; then
        echo -e "Контейнер бота:  ${RED}○ $bot_status${RESET}"
    else
        echo -e "Контейнер бота:  ${RED}○ не найден${RESET}"
    fi
    
    if [[ -n "$bot_health" && "$bot_health" != "none" ]]; then
        if [[ "$bot_health" == "healthy" ]]; then
            echo -e "Health (бот):    ${GREEN}✓ healthy${RESET}"
        else
            echo -e "Health (бот):    ${YELLOW}$bot_health${RESET}"
        fi
    fi
    
    # Статус БД
    local db_container=$(docker compose ps --format "{{.Name}}" 2>/dev/null | grep -E "db|postgres" | head -1)
    local db_status=$(docker inspect --format='{{.State.Status}}' "$db_container" 2>/dev/null)
    local db_health=$(docker inspect --format='{{.State.Health.Status}}' "$db_container" 2>/dev/null)
    
    echo ""
    if [[ "$db_status" == "running" ]]; then
        echo -e "Контейнер БД:    ${GREEN}● Running${RESET}"
    elif [[ -n "$db_status" ]]; then
        echo -e "Контейнер БД:    ${RED}○ $db_status${RESET}"
    else
        echo -e "Контейнер БД:    ${GRAY}○ не найден${RESET}"
    fi
    
    if [[ -n "$db_health" && "$db_health" != "none" ]]; then
        if [[ "$db_health" == "healthy" ]]; then
            echo -e "Health (БД):     ${GREEN}✓ healthy${RESET}"
        else
            echo -e "Health (БД):     ${YELLOW}$db_health${RESET}"
        fi
    fi
    
    # Проверка LICENSE_KEY и machine-id (для v3.25.5+)
    if [[ -n "$bot_ver" ]] && version_gte "$bot_ver" "3.25.5"; then
        echo ""
        echo -e "${BOLD}Лицензия (v3.25.5+):${RESET}"
        if has_license_key; then
            echo -e "  LICENSE_KEY:   ${GREEN}✓ настроен${RESET}"
        else
            echo -e "  LICENSE_KEY:   ${RED}✗ отсутствует${RESET}"
        fi
        if has_machine_id_volume; then
            echo -e "  machine-id:    ${GREEN}✓ настроен${RESET}"
        else
            echo -e "  machine-id:    ${RED}✗ отсутствует${RESET}"
        fi
    fi
    
    # Путь
    echo ""
    echo -e "Путь:            ${GRAY}$BOT_PATH${RESET}"
    echo ""
}

# Главная функция обновления бота
update_bot() {
    debug_log "UPDATE" "=== Starting update_bot() ==="
    clear_screen
    echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════${RESET}"
    echo -e "${GREEN}${BOLD}  Обновление бота${RESET}"
    echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════${RESET}"
    echo ""
    
    # === ЭТАП 1: ОПРЕДЕЛЕНИЕ ПУТИ К БОТУ ===
    debug_log "UPDATE" "[STAGE 1] Checking bot path..."
    local bot_path_ok=false
    
    # Сначала проверяем текущий BOT_PATH
    if [[ -n "$BOT_PATH" && -d "$BOT_PATH" && ( -f "$BOT_PATH/docker-compose.yml" || -f "$BOT_PATH/compose.yaml" ) ]]; then
        bot_path_ok=true
        debug_log "UPDATE" "Bot path OK: $BOT_PATH"
    fi
    
    # Если не настроен — пробуем найти
    if [[ "$bot_path_ok" == "false" ]]; then
        debug_log "UPDATE" "Bot path not configured, starting search..."
        print_message "INFO" "Путь к боту не настроен. Запускаем поиск..."
        
        # Проверяем путь по умолчанию из документации
        if [[ -d "$DEFAULT_BOT_PATH" && ( -f "$DEFAULT_BOT_PATH/docker-compose.yml" || -f "$DEFAULT_BOT_PATH/compose.yaml" ) ]]; then
            debug_log "UPDATE" "Found bot at default path: $DEFAULT_BOT_PATH"
            print_message "SUCCESS" "Найден бот в $DEFAULT_BOT_PATH"
            BOT_PATH="$DEFAULT_BOT_PATH"
            save_config
            bot_path_ok=true
        else
            debug_log "UPDATE" "Default path not found, running ensure_bot_path()..."
            # Запускаем автопоиск
            if ! ensure_bot_path; then
                debug_log "UPDATE" "ensure_bot_path() failed, prompting manual input"
                echo ""
                print_message "ERROR" "Не удалось найти установку бота!"
                echo ""
                echo -e "Ожидаемые пути (из документации):"
                echo -e "  ${CYAN}/opt/private-remnawave-telegram-shop-bot/${RESET}"
                echo -e "  ${CYAN}/opt/remnawave-telegram-shop/${RESET}"
                echo ""
                echo -e "Ожидаемая структура:"
                echo -e "  ├── compose.yaml (или docker-compose.yml)"
                echo -e "  ├── .env"
                echo -e "  └── rwp_shop-X.Y.Z-amd64.tar"
                echo ""
                read -erp "Укажите путь вручную (Enter - $DEFAULT_BOT_PATH): " manual_path
                manual_path="${manual_path:-$DEFAULT_BOT_PATH}"
                
                if [[ -d "$manual_path" ]]; then
                    debug_log "UPDATE" "Manual path accepted: $manual_path"
                    BOT_PATH="$manual_path"
                    save_config
                    bot_path_ok=true
                else
                    debug_log "UPDATE" "Manual path not found: $manual_path"
                    print_message "ERROR" "Папка не найдена: $manual_path"
                    read -erp "Нажмите Enter..." dummy
                    return 1
                fi
            else
                debug_log "UPDATE" "ensure_bot_path() success, BOT_PATH=$BOT_PATH"
                bot_path_ok=true
            fi
        fi
    fi
    
    # Финальная проверка пути
    debug_log "UPDATE" "Final path check: bot_path_ok=$bot_path_ok, BOT_PATH=$BOT_PATH"
    if [[ "$bot_path_ok" == "false" || -z "$BOT_PATH" || ! -d "$BOT_PATH" ]]; then
        debug_log "UPDATE" "Path validation failed, aborting"
        print_message "ERROR" "Путь к боту не настроен!"
        read -erp "Нажмите Enter..." dummy
        return 1
    fi
    
    # === ЭТАП 2: ИНФОРМАЦИЯ О ТЕКУЩЕЙ УСТАНОВКЕ ===
    debug_log "UPDATE" "[STAGE 2] Getting current installation info..."
    local current_version=$(get_raw_bot_version)
    debug_log "UPDATE" "Current version raw: $current_version"
    if [[ -z "$current_version" || "$current_version" == "Unknown" ]]; then
        print_message "WARN" "Не удалось определить текущую версию бота"
        current_version="0.0.0"
    fi
    
    local container_status=$(get_container_status)
    debug_log "UPDATE" "Container status: $container_status"
    
    echo -e "Путь к боту:     ${CYAN}$BOT_PATH${RESET}"
    echo -e "Текущая версия:  ${CYAN}$current_version${RESET}"
    echo -e "Статус:          ${CYAN}$container_status${RESET}"
    echo ""
    
    # === ЭТАП 3: ПРОВЕРКА ОБРАЗОВ В DOCKER ===
    debug_log "UPDATE" "[STAGE 3] Checking loaded Docker images..."
    print_message "INFO" "Проверка загруженных образов Docker..."
    
    # Получаем все версии rwp_shop из docker images
    local docker_versions=$(docker images --format "{{.Tag}}" "rwp_shop" 2>/dev/null | grep -E "^[0-9]+\.[0-9]+\.[0-9]+" | sort -rV)
    
    # Также проверяем старые форматы образов
    local old_versions=$(docker images --format "{{.Tag}}" "private-remnawave-telegram-shop-bot" 2>/dev/null | grep -E "^[0-9]+\.[0-9]+\.[0-9]+" | sort -rV)
    
    # Находим самую новую версию в Docker
    local latest_docker_version=""
    local latest_docker_image=""
    
    if [[ -n "$docker_versions" ]]; then
        latest_docker_version=$(echo "$docker_versions" | head -1)
        latest_docker_image="rwp_shop"
    fi
    
    if [[ -n "$old_versions" ]]; then
        local old_latest=$(echo "$old_versions" | head -1)
        if [[ -z "$latest_docker_version" ]] || version_gt "$old_latest" "$latest_docker_version"; then
            latest_docker_version="$old_latest"
            latest_docker_image="private-remnawave-telegram-shop-bot"
        fi
    fi
    
    debug_log "UPDATE" "Latest Docker image: $latest_docker_image:$latest_docker_version"
    
    # Если в Docker есть версия новее текущей — предлагаем обновиться сразу
    if [[ -n "$latest_docker_version" ]] && version_gt "$latest_docker_version" "$current_version"; then
        debug_log "UPDATE" "Docker has newer version: $latest_docker_version > $current_version"
        print_message "SUCCESS" "Найден образ в Docker: ${latest_docker_image}:${latest_docker_version}"
        echo ""
        echo -e "${YELLOW}${BOLD}Доступно обновление: $current_version → $latest_docker_version${RESET}"
        echo ""
        echo -e "${GREEN}Образ уже загружен в Docker — загрузка из файла не требуется${RESET}"
        
        # Проверка требований для версий 3.25.5+
        if version_gte "$latest_docker_version" "3.25.5"; then
            local has_key=false
            local has_volume=false
            has_license_key && has_key=true
            has_machine_id_volume && has_volume=true
            
            echo ""
            # Сначала выводим критические предупреждения (красные) если чего-то нет
            if [[ "$has_key" == false ]]; then
                echo -e "${RED}${BOLD}⚠️  LICENSE_KEY отсутствует или пустой!${RESET}"
                echo -e "${RED}   Получите ключ в боте: https://t.me/rwp_shop_bot${RESET}"
                echo ""
            fi
            
            if [[ "$has_volume" == false ]]; then
                echo -e "${RED}${BOLD}⚠️  machine-id volume отсутствует в compose!${RESET}"
                echo -e "${RED}   Будет предложено добавить при обновлении${RESET}"
                echo ""
            fi
            
            # Затем выводим статус требований
            echo -e "${YELLOW}${BOLD}Требования для версии $latest_docker_version:${RESET}"
            echo ""
            
            # Проверяем LICENSE_KEY
            if [[ "$has_key" == true ]]; then
                echo -e "   ${GREEN}✓${RESET} LICENSE_KEY: ${GREEN}настроен${RESET}"
            else
                echo -e "   ${RED}✗${RESET} LICENSE_KEY: ${RED}не настроен${RESET}"
            fi
            
            # Проверяем machine-id volume
            if [[ "$has_volume" == true ]]; then
                echo -e "   ${GREEN}✓${RESET} machine-id volume: ${GREEN}настроен${RESET}"
            else
                echo -e "   ${RED}✗${RESET} machine-id volume: ${RED}не настроен${RESET}"
            fi
            echo ""
        fi
        
        local confirm=""
        while [[ ! "$confirm" =~ ^[YyNn]$ ]]; do
            read -erp "Обновить до версии $latest_docker_version? (y/n): " confirm
            if [[ ! "$confirm" =~ ^[YyNn]$ ]]; then
                echo -e "${YELLOW}Введите 'y' для да или 'n' для нет${RESET}"
            fi
        done
        
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            # Устанавливаем переменные для дальнейшего обновления
            local selected_version="$latest_docker_version"
            local selected_image_name="$latest_docker_image"
            local selected_file=""  # Файл не нужен
            local skip_docker_load=true
            
            # Переходим к этапу подтверждения и обновления
            # (код будет ниже)
        else
            print_message "INFO" "Отменено"
            read -erp "Нажмите Enter..." dummy
            return 0
        fi
    else
        # В Docker нет новых версий — ищем .tar файлы
        debug_log "UPDATE" "No newer version in Docker, searching for tar files..."
        
        # === ЭТАП 3b: ПОИСК ФАЙЛОВ ОБРАЗОВ ===
        print_message "INFO" "Поиск файлов образа в /opt/, /root/, $BOT_PATH..."
        local image_files=$(find_all_bot_image_files)
        debug_log "UPDATE" "Image files found: $(echo "$image_files" | wc -l) files"
        
        if [[ -z "$image_files" ]]; then
            debug_log "UPDATE" "No image files found"
            echo ""
            if [[ -n "$latest_docker_version" ]]; then
                # В Docker есть текущая или старая версия
                print_message "INFO" "Новых версий не найдено"
                echo ""
                echo -e "Текущая версия в Docker: ${CYAN}${latest_docker_image}:${latest_docker_version}${RESET}"
                echo -e "Установленная версия:    ${CYAN}${current_version}${RESET}"
                
                # Проверка требований для версий 3.25.5+ (даже если обновлений нет)
                if version_gte "$current_version" "3.25.5"; then
                    echo ""
                    local has_key=false
                    local has_mid=false
                    has_license_key && has_key=true
                    has_machine_id_volume && has_mid=true
                    
                    if [[ "$has_key" == "false" || "$has_mid" == "false" ]]; then
                        echo -e "${YELLOW}${BOLD}Проверка конфигурации (v3.25.5+):${RESET}"
                        if [[ "$has_key" == "true" ]]; then
                            echo -e "  LICENSE_KEY:     ${GREEN}✓ настроен${RESET}"
                        else
                            echo -e "  LICENSE_KEY:     ${RED}✗ отсутствует${RESET}"
                        fi
                        if [[ "$has_mid" == "true" ]]; then
                            echo -e "  machine-id:      ${GREEN}✓ настроен${RESET}"
                        else
                            echo -e "  machine-id:      ${RED}✗ отсутствует в compose${RESET}"
                        fi
                        
                        if [[ "$has_key" == "false" || "$has_mid" == "false" ]]; then
                            echo ""
                            echo -e "${YELLOW}Для работы бота требуется LICENSE_KEY и machine-id volume.${RESET}"
                            echo -e "Получить ключ: ${CYAN}https://t.me/rwp_shop_bot${RESET}"
                            echo ""
                            read -erp "Настроить сейчас? [Y/n]: " setup_now
                            if [[ ! "$setup_now" =~ ^[Nn]$ ]]; then
                                if [[ "$has_key" == "false" ]]; then
                                    ensure_license_key_in_env
                                fi
                                if [[ "$has_mid" == "false" ]]; then
                                    local _cf=""
                                    [[ -f "$BOT_PATH/compose.yaml" ]] && _cf="$BOT_PATH/compose.yaml"
                                    [[ -f "$BOT_PATH/docker-compose.yml" ]] && _cf="$BOT_PATH/docker-compose.yml"
                                    [[ -n "$_cf" ]] && ensure_machine_id_volume "$_cf"
                                fi
                            fi
                        fi
                    else
                        echo ""
                        echo -e "${GREEN}✓ LICENSE_KEY и machine-id настроены${RESET}"
                    fi
                fi
            else
                print_message "WARN" "Файлы образа не найдены"
                echo ""
                echo -e "${BOLD}Пути поиска:${RESET}"
                echo -e "  ${CYAN}/opt/${RESET} (с подпапками)"
                echo -e "  ${CYAN}/root/${RESET} (с подпапками)"
                [[ -n "$BOT_PATH" ]] && echo -e "  ${CYAN}$BOT_PATH/${RESET}"
                echo ""
                echo -e "${BOLD}Поддерживаемые форматы файлов:${RESET}"
                echo -e "  ${CYAN}rwp_shop-X.Y.Z-amd64.tar${RESET}  (новый, рекомендуемый)"
                echo -e "  ${GRAY}private-remnawave-telegram-shop-bot-X.Y.Z-amd64.tar${RESET}  (старый)"
                echo ""
                echo -e "Скачайте файл из приватного канала и положите в:"
                echo -e "  ${BOLD}$BOT_PATH/${RESET}"
            fi
            echo ""
            read -erp "Нажмите Enter..." dummy
            return 1
        fi
        
        # Фильтруем: показываем только файлы, которых НЕТ в Docker
        local files_to_show=""
        while IFS= read -r file; do
            [[ -z "$file" ]] && continue
            local fname=$(basename "$file")
            local fversion=$(extract_version_from_filename "$fname")
            local fimage=$(get_image_name_from_tar "$file")
            
            if ! is_image_loaded_in_docker "$fimage" "$fversion"; then
                files_to_show+="$file"$'\n'
            fi
        done <<< "$image_files"
        files_to_show=$(echo -n "$files_to_show" | sed '/^$/d')
        
        if [[ -z "$files_to_show" ]]; then
            debug_log "UPDATE" "All tar files already loaded in Docker"
            print_message "INFO" "Все найденные образы уже загружены в Docker"
            echo ""
            if [[ -n "$latest_docker_version" ]] && [[ "$latest_docker_version" == "$current_version" ]]; then
                print_message "SUCCESS" "Установлена последняя версия ($current_version)"
            elif [[ -n "$latest_docker_version" ]]; then
                echo -e "Версия в Docker: ${CYAN}${latest_docker_version}${RESET}"
                echo -e "Текущая версия:  ${CYAN}${current_version}${RESET}"
            fi
            
            # Проверка требований для версий 3.25.5+ (даже если обновлений нет)
            if version_gte "$current_version" "3.25.5"; then
                echo ""
                local has_key=false
                local has_mid=false
                has_license_key && has_key=true
                has_machine_id_volume && has_mid=true
                
                if [[ "$has_key" == "false" || "$has_mid" == "false" ]]; then
                    echo -e "${YELLOW}${BOLD}Проверка конфигурации (v3.25.5+):${RESET}"
                    if [[ "$has_key" == "true" ]]; then
                        echo -e "  LICENSE_KEY:     ${GREEN}✓ настроен${RESET}"
                    else
                        echo -e "  LICENSE_KEY:     ${RED}✗ отсутствует${RESET}"
                    fi
                    if [[ "$has_mid" == "true" ]]; then
                        echo -e "  machine-id:      ${GREEN}✓ настроен${RESET}"
                    else
                        echo -e "  machine-id:      ${RED}✗ отсутствует в compose${RESET}"
                    fi
                    
                    if [[ "$has_key" == "false" || "$has_mid" == "false" ]]; then
                        echo ""
                        echo -e "${YELLOW}Для работы бота требуется LICENSE_KEY и machine-id volume.${RESET}"
                        echo -e "Получить ключ: ${CYAN}https://t.me/rwp_shop_bot${RESET}"
                        echo ""
                        read -erp "Настроить сейчас? [Y/n]: " setup_now
                        if [[ ! "$setup_now" =~ ^[Nn]$ ]]; then
                            if [[ "$has_key" == "false" ]]; then
                                ensure_license_key_in_env
                            fi
                            if [[ "$has_mid" == "false" ]]; then
                                local _cf=""
                                [[ -f "$BOT_PATH/compose.yaml" ]] && _cf="$BOT_PATH/compose.yaml"
                                [[ -f "$BOT_PATH/docker-compose.yml" ]] && _cf="$BOT_PATH/docker-compose.yml"
                                [[ -n "$_cf" ]] && ensure_machine_id_volume "$_cf"
                            fi
                        fi
                    fi
                else
                    echo ""
                    echo -e "${GREEN}✓ LICENSE_KEY и machine-id настроены${RESET}"
                fi
            fi
            
            echo ""
            read -erp "Нажмите Enter..." dummy
            return 0
        fi
        
        # Показываем только файлы, которые ещё не загружены
        local files_count=$(echo "$files_to_show" | wc -l)
        debug_log "UPDATE" "Files to show (not in Docker): $files_count"
        print_message "SUCCESS" "Найдено новых файлов: $files_count"
        
        # === ЭТАП 4: ОТОБРАЖЕНИЕ НАЙДЕННЫХ ФАЙЛОВ ===
        debug_log "UPDATE" "[STAGE 4] Displaying found files..."
        echo ""
        echo -e "${BOLD}Найденные файлы образов (ещё не загружены в Docker):${RESET}"
        local i=1
        local files_array=()
        while IFS= read -r file; do
            [[ -z "$file" ]] && continue
            local fname=$(basename "$file")
            local fdir=$(dirname "$file")
            local fversion=$(extract_version_from_filename "$fname")
            local fsize=$(du -h "$file" 2>/dev/null | cut -f1)
            files_array+=("$file")
            debug_log "UPDATE" "  [$i] $fname (v$fversion, size=$fsize)"
            
            # Подсветка если версия новее
            if version_gt "$fversion" "$current_version"; then
                echo -e " ${GREEN}$i. $fname${RESET}"
                echo -e "    v$fversion | $fsize ${GREEN}← ОБНОВЛЕНИЕ${RESET}"
                echo -e "    ${GRAY}$fdir${RESET}"
            elif [[ "$fversion" == "$current_version" ]]; then
                echo -e " ${YELLOW}$i. $fname${RESET}"
                echo -e "    v$fversion | $fsize ${YELLOW}(текущая)${RESET}"
                echo -e "    ${GRAY}$fdir${RESET}"
            else
                echo -e " ${GRAY}$i. $fname${RESET}"
                echo -e "    v$fversion | $fsize"
                echo -e "    ${GRAY}$fdir${RESET}"
            fi
            ((i++))
        done <<< "$files_to_show"
        
        echo ""
        echo " 0. Назад"
        echo ""
        
        # === ЭТАП 5: ВЫБОР ФАЙЛА ===
        debug_log "UPDATE" "[STAGE 5] File selection..."
        local latest_file="${files_array[0]}"
        local latest_version=$(extract_version_from_filename "$(basename "$latest_file")")
        debug_log "UPDATE" "Latest file: $(basename "$latest_file"), version: $latest_version"
        
        # Проверка требований для версий 3.25.5+
        if version_gte "$latest_version" "3.25.5"; then
            local has_key=false
            local has_volume=false
            has_license_key && has_key=true
            has_machine_id_volume && has_volume=true
            
            # Сначала выводим критические предупреждения (красные) если чего-то нет
            if [[ "$has_key" == false ]]; then
                echo -e "${RED}${BOLD}⚠️  LICENSE_KEY отсутствует или пустой!${RESET}"
                echo -e "${RED}   Получите ключ в боте: https://t.me/rwp_shop_bot${RESET}"
                echo ""
            fi
            
            if [[ "$has_volume" == false ]]; then
                echo -e "${RED}${BOLD}⚠️  machine-id volume отсутствует в compose!${RESET}"
                echo -e "${RED}   Будет предложено добавить при обновлении${RESET}"
                echo ""
            fi
            
            # Затем выводим статус требований
            echo -e "${YELLOW}${BOLD}Требования для версий 3.25.5+:${RESET}"
            echo ""
            
            # Проверяем LICENSE_KEY
            if [[ "$has_key" == true ]]; then
                echo -e "   ${GREEN}✓${RESET} LICENSE_KEY: ${GREEN}настроен${RESET}"
            else
                echo -e "   ${RED}✗${RESET} LICENSE_KEY: ${RED}не настроен${RESET}"
            fi
            
            # Проверяем machine-id volume
            if [[ "$has_volume" == true ]]; then
                echo -e "   ${GREEN}✓${RESET} machine-id volume: ${GREEN}настроен${RESET}"
            else
                echo -e "   ${RED}✗${RESET} machine-id volume: ${RED}не настроен${RESET}"
            fi
            echo ""
        fi
        
        local choice=""
        if ! version_gt "$latest_version" "$current_version"; then
            debug_log "UPDATE" "Current version is latest ($current_version >= $latest_version)"
            print_message "INFO" "Установлена последняя версия ($current_version)"
            echo ""
            read -erp "Выберите файл для переустановки (или Enter - назад): " choice
            [[ -z "$choice" || "$choice" == "0" ]] && return 0
        else
            debug_log "UPDATE" "Update available: $current_version -> $latest_version"
            echo -e "${YELLOW}${BOLD}Доступно обновление: $current_version → $latest_version${RESET}"
            echo ""
            read -erp "Выберите файл (Enter - последний v$latest_version): " choice
            [[ -z "$choice" ]] && choice=1
        fi
        
        debug_log "UPDATE" "User choice: $choice"
        
        # Валидация выбора
        if [[ "$choice" == "0" ]]; then return 0; fi
        if ! [[ "$choice" =~ ^[0-9]+$ ]] || [[ "$choice" -lt 1 ]] || [[ "$choice" -gt "${#files_array[@]}" ]]; then
            debug_log "UPDATE" "Invalid choice: $choice (valid: 1-${#files_array[@]})"
            print_message "ERROR" "Неверный выбор"
            sleep 1
            return 1
        fi
        
        local selected_file="${files_array[$((choice-1))]}"
        local selected_version=$(extract_version_from_filename "$(basename "$selected_file")")
        local selected_image_name=$(get_image_name_from_tar "$selected_file")
        local skip_docker_load=false
        debug_log "UPDATE" "Selected: file=$selected_file, version=$selected_version, image=$selected_image_name"
    fi
    
    # === ЭТАП 6: ПОДТВЕРЖДЕНИЕ ===
    debug_log "UPDATE" "[STAGE 6] User confirmation..."
    echo ""
    echo -e "${BOLD}════════════════════════════════════════${RESET}"
    if [[ -n "$selected_file" ]]; then
        echo -e "${BOLD}Файл:${RESET}    $(basename "$selected_file")"
    fi
    echo -e "${BOLD}Версия:${RESET}  $selected_version"
    echo -e "${BOLD}Image:${RESET}   $selected_image_name"
    if [[ "$skip_docker_load" == true ]]; then
        echo -e "${BOLD}Статус:${RESET}  ${GREEN}Уже в Docker${RESET}"
    fi
    echo -e "${BOLD}════════════════════════════════════════${RESET}"
    echo ""
    
    echo -e "${YELLOW}${BOLD}⚠️  ВНИМАНИЕ — ОБЯЗАТЕЛЬНО К ПРОЧТЕНИЮ:${RESET}"
    echo ""
    echo -e " ${GREEN}✓${RESET} Будет создан полный бэкап (БД + файлы)"
    echo -e " ${GREEN}✓${RESET} Будет создан отдельный бэкап БД"
    echo -e " ${GREEN}✓${RESET} Compose файл будет обновлён автоматически"
    echo ""
    echo -e " ${YELLOW}!${RESET} Бот будет остановлен на время обновления"
    echo -e " ${YELLOW}!${RESET} При ошибке доступен откат из бэкапа"
    echo ""
    
    read -erp "Начать обновление? (y/N): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        debug_log "UPDATE" "User cancelled update"
        print_message "INFO" "Отменено"
        return 0
    fi
    
    # === ЭТАП 7: СОЗДАНИЕ БЭКАПОВ ===
    debug_log "UPDATE" "[STAGE 7] Creating pre-update backups..."
    echo ""
    echo -e "${CYAN}${BOLD}═══ СОЗДАНИЕ БЭКАПОВ ═══${RESET}"
    log_message "INFO" "Starting bot update: $current_version -> $selected_version"
    
    # Запоминаем время начала для поиска созданных бэкапов
    local update_start_time=$(date +%s)
    
    debug_log "UPDATE" "Creating full backup..."
    print_message "INFO" "[1/7] Создание полного бэкапа..."
    create_backup "full"
    local backup_result=$?
    debug_log "UPDATE" "Full backup result: $backup_result"
    
    if [[ $backup_result -ne 0 ]]; then
        debug_log "UPDATE" "Full backup FAILED, aborting update"
        print_message "ERROR" "Ошибка создания бэкапа! Обновление отменено."
        log_message "ERROR" "Bot update aborted: full backup failed"
        read -erp "Нажмите Enter..." dummy
        return 1
    fi
    print_message "SUCCESS" "Полный бэкап создан"
    
    debug_log "UPDATE" "Creating DB backup..."
    print_message "INFO" "[2/7] Создание бэкапа БД..."
    create_backup "db_only"
    local db_backup_result=$?
    debug_log "UPDATE" "DB backup result: $db_backup_result"
    
    if [[ $db_backup_result -ne 0 ]]; then
        print_message "WARN" "Бэкап БД не создан (полный бэкап есть)"
    else
        print_message "SUCCESS" "Бэкап БД создан"
    fi
    
    # Получаем путь к последнему бэкапу БД для возможного rollback
    local rollback_backup=$(get_latest_db_backup)
    debug_log "UPDATE" "Rollback backup: $rollback_backup"
    
    # === ЭТАП 8: ЗАГРУЗКА DOCKER IMAGE ===
    debug_log "UPDATE" "[STAGE 8] Loading Docker image..."
    echo ""
    echo -e "${CYAN}${BOLD}═══ ЗАГРУЗКА IMAGE ═══${RESET}"
    
    # Проверяем флаг skip_docker_load или наличие образа в Docker
    if [[ "$skip_docker_load" == true ]] || is_image_loaded_in_docker "$selected_image_name" "$selected_version"; then
        debug_log "DOCKER" "Image $selected_image_name:$selected_version already loaded in Docker (skip_docker_load=$skip_docker_load)"
        print_message "INFO" "[3/7] Image уже загружен в Docker"
        print_message "SUCCESS" "Пропускаем docker load: ${selected_image_name}:${selected_version}"
    else
        print_message "INFO" "[3/7] Загрузка Docker image..."
        debug_log "DOCKER" "Running: docker load -i $selected_file"
        
        local load_output
        load_output=$(docker load -i "$selected_file" 2>&1)
        local load_result=$?
        debug_log "DOCKER" "docker load result: $load_result"
        debug_log "DOCKER" "docker load output: $load_output"
        
        if [[ $load_result -ne 0 ]]; then
            debug_log "DOCKER" "docker load FAILED"
            print_message "ERROR" "Ошибка загрузки image!"
            echo "$load_output"
            log_message "ERROR" "Bot update failed: docker load error"
            echo ""
            print_message "INFO" "Бэкапы созданы. Данные не потеряны."
            read -erp "Нажмите Enter..." dummy
            return 1
        fi
        
        # Извлекаем реальное имя загруженного image
        local loaded_image=$(echo "$load_output" | grep -oE "Loaded image: [^ ]+" | cut -d' ' -f3)
        debug_log "DOCKER" "Loaded image from output: $loaded_image"
        if [[ -n "$loaded_image" ]]; then
            print_message "SUCCESS" "Image загружен: $loaded_image"
            # Извлекаем имя image без версии
            selected_image_name="${loaded_image%%:*}"
            debug_log "DOCKER" "Image name extracted: $selected_image_name"
        else
            print_message "SUCCESS" "Image загружен"
            echo "$load_output" | grep -i "loaded" | head -1
        fi
        
        # Проверяем что image появился
        debug_log "DOCKER" "Verifying image in docker images..."
        if ! docker images | grep -q "$selected_image_name.*$selected_version"; then
            debug_log "DOCKER" "Image not found in list, showing available:"
            print_message "WARN" "Image загружен, но не найден в списке"
            docker images | grep -E "(rwp_shop|telegram-shop|private-remnawave)" | head -5
        else
            debug_log "DOCKER" "Image verified in docker images list"
        fi
    fi
    
    # === ЭТАП 9: ОБНОВЛЕНИЕ COMPOSE ФАЙЛА ===
    debug_log "UPDATE" "[STAGE 9] Updating compose file..."
    echo ""
    echo -e "${CYAN}${BOLD}═══ ОБНОВЛЕНИЕ КОНФИГУРАЦИИ ═══${RESET}"
    
    local compose_file=""
    [[ -f "$BOT_PATH/compose.yaml" ]] && compose_file="$BOT_PATH/compose.yaml"
    [[ -f "$BOT_PATH/docker-compose.yml" ]] && compose_file="$BOT_PATH/docker-compose.yml"
    debug_log "COMPOSE" "Compose file: $compose_file"
    
    if [[ -z "$compose_file" ]]; then
        debug_log "COMPOSE" "No compose file found in $BOT_PATH"
        print_message "ERROR" "Compose файл не найден!"
        log_message "ERROR" "Bot update failed: compose file not found"
        read -erp "Нажмите Enter..." dummy
        return 1
    fi
    
    print_message "INFO" "[4/7] Обновление compose файла..."
    
    # Создаём бэкап compose файла
    debug_log "COMPOSE" "Creating backup: ${compose_file}.pre-update.bak"
    cp "$compose_file" "${compose_file}.pre-update.bak"
    
    debug_log "COMPOSE" "Calling update_compose_image_version($compose_file, $selected_version, $selected_image_name)"
    if ! update_compose_image_version "$compose_file" "$selected_version" "$selected_image_name"; then
        debug_log "COMPOSE" "update_compose_image_version FAILED, restoring backup"
        print_message "ERROR" "Ошибка обновления compose!"
        mv "${compose_file}.pre-update.bak" "$compose_file"
        log_message "ERROR" "Bot update failed: compose update error"
        echo ""
        print_message "INFO" "Compose файл восстановлен из бэкапа."
        read -erp "Нажмите Enter..." dummy
        return 1
    fi
    
    # === ЭТАП 9.5: ПРОВЕРКА ТРЕБОВАНИЙ ЛИЦЕНЗИИ (v3.25.5+) ===
    if version_gte "$selected_version" "3.25.5"; then
        debug_log "UPDATE" "[STAGE 9.5] Checking license requirements for v$selected_version..."
        print_message "INFO" "Проверка требований лицензии для v$selected_version..."
        
        # Проверяем и добавляем machine-id volume
        ensure_machine_id_volume "$compose_file"
        
        # Проверяем и добавляем LICENSE_KEY в .env
        ensure_license_key_in_env
    fi
    
    # === ЭТАП 10: ОСТАНОВКА КОНТЕЙНЕРОВ ===
    debug_log "UPDATE" "[STAGE 10] Stopping containers..."
    echo ""
    echo -e "${CYAN}${BOLD}═══ ПЕРЕЗАПУСК КОНТЕЙНЕРОВ ═══${RESET}"
    print_message "INFO" "[5/7] Остановка контейнеров..."
    
    cd "$BOT_PATH"
    debug_log "CONTAINER" "Running: docker compose down in $BOT_PATH"
    docker compose down 2> "$SILENT_LOG"
    local down_result=$?
    debug_log "CONTAINER" "docker compose down result: $down_result"
    sleep 2
    
    # === ЭТАП 11: ЗАПУСК КОНТЕЙНЕРОВ ===
    debug_log "UPDATE" "[STAGE 11] Starting containers..."
    print_message "INFO" "[6/7] Запуск контейнеров..."
    debug_log "CONTAINER" "Running: docker compose up -d"
    docker compose up -d 2> "$SILENT_LOG"
    local up_result=$?
    debug_log "CONTAINER" "docker compose up result: $up_result"
    
    # === ЭТАП 12: ПРОВЕРКА ЗДОРОВЬЯ ===
    debug_log "UPDATE" "[STAGE 12] Health checks..."
    print_message "INFO" "[7/7] Проверка работоспособности..."
    echo ""
    
    # Ждём БД
    if [[ -n "$DB_CONTAINER_NAME" ]]; then
        debug_log "HEALTH" "Checking DB health for: $DB_CONTAINER_NAME"
        echo -n "  Проверка БД..."
        if check_db_health "$DB_CONTAINER_NAME" 30; then
            debug_log "HEALTH" "DB health check: OK"
            echo -e " ${GREEN}OK${RESET}"
        else
            debug_log "HEALTH" "DB health check: WARN (may still be initializing)"
            echo -e " ${YELLOW}WARN${RESET}"
            print_message "WARN" "БД не отвечает, но может ещё инициализироваться"
        fi
    fi
    
    # Ждём бота
    if [[ -n "$BOT_CONTAINER_NAME" ]]; then
        debug_log "HEALTH" "Checking bot health for: $BOT_CONTAINER_NAME"
        echo -n "  Проверка бота..."
        if check_bot_health "$BOT_CONTAINER_NAME" 20; then
            debug_log "HEALTH" "Bot health check: OK"
            echo -e " ${GREEN}OK${RESET}"
        else
            debug_log "HEALTH" "Bot health check: FAIL"
            echo -e " ${RED}FAIL${RESET}"
        fi
    fi
    
    sleep 2
    
    # === ЭТАП 13: ФИНАЛЬНАЯ ПРОВЕРКА ===
    debug_log "UPDATE" "[STAGE 13] Final verification..."
    local new_version=$(get_raw_bot_version)
    local new_status=$(get_container_status)
    debug_log "UPDATE" "New version: $new_version, status: $new_status"
    
    echo ""
    echo -e "${BOLD}═══════════════════════════════════════════════════${RESET}"
    
    if [[ "$new_status" == "Online" ]]; then
        if [[ "$new_version" == "$selected_version" ]]; then
            debug_log "UPDATE" "=== Update SUCCESS: $current_version -> $new_version ==="
            echo -e "${GREEN}${BOLD}✓ ОБНОВЛЕНИЕ УСПЕШНО ЗАВЕРШЕНО${RESET}"
            echo ""
            echo -e "  Версия: ${CYAN}$current_version${RESET} → ${GREEN}$new_version${RESET}"
            echo -e "  Статус: ${GREEN}$new_status${RESET}"
            log_message "SUCCESS" "Bot updated successfully: $current_version -> $new_version"
            
            # Удаляем бэкап compose файла
            debug_log "UPDATE" "Removing compose backup file"
            rm -f "${compose_file}.pre-update.bak"
            
            echo ""
            read -erp "Удалить файл образа $(basename "$selected_file")? (y/N): " del_confirm
            if [[ "$del_confirm" == "y" || "$del_confirm" == "Y" ]]; then
                debug_log "UPDATE" "Deleting image file: $selected_file"
                rm -f "$selected_file"
                print_message "SUCCESS" "Файл удалён"
            fi
        else
            debug_log "UPDATE" "=== Update WARN: version mismatch (expected=$selected_version, got=$new_version) ==="
            echo -e "${YELLOW}${BOLD}⚠ ОБНОВЛЕНИЕ ЗАВЕРШЕНО С ПРЕДУПРЕЖДЕНИЕМ${RESET}"
            echo ""
            echo -e "  Ожидалась версия: ${CYAN}$selected_version${RESET}"
            echo -e "  Текущая версия:   ${YELLOW}$new_version${RESET}"
            echo -e "  Статус:           ${GREEN}$new_status${RESET}"
            echo ""
            print_message "INFO" "Бот работает, но версия отличается"
            log_message "WARN" "Bot update: version mismatch (expected=$selected_version, got=$new_version)"
        fi
    else
        debug_log "UPDATE" "=== Update FAILED: container not running (status=$new_status) ==="
        echo -e "${RED}${BOLD}✗ ОБНОВЛЕНИЕ ЗАВЕРШЕНО С ОШИБКОЙ${RESET}"
        echo ""
        echo -e "  Статус: ${RED}$new_status${RESET}"
        echo ""
        log_message "ERROR" "Bot update failed: container not running after update"
        
        echo -e "${YELLOW}Диагностика:${RESET}"
        echo "  docker compose ps"
        echo "  docker compose logs -f bot"
        echo ""
        
        echo -e "${YELLOW}Для отката:${RESET}"
        if [[ -n "$rollback_backup" ]]; then
            echo "  1. Восстановите из бэкапа (меню 3)"
            echo "  2. Или вручную: docker compose down && mv ${compose_file}.pre-update.bak $compose_file && docker compose up -d"
        fi
        echo ""
        
        # Показываем последние логи
        echo -e "${GRAY}Последние логи бота:${RESET}"
        docker compose logs --tail 10 bot 2> "$SILENT_LOG" | tail -5
    fi
    
    echo -e "${BOLD}═══════════════════════════════════════════════════${RESET}"
    echo ""
    read -erp "Нажмите Enter..." dummy
    return 0
}

# --- ОБНАРУЖЕНИЕ УСТАНОВКИ БОТА ---

find_db_container_for_path() {
    local path="$1"
    [[ -z "$path" || ! -d "$path" ]] && return 1
    local db_services=("db" "postgres" "database" "postgresql")
    local db_name=""
    if cd "$path" 2> "$SILENT_LOG"; then
        for svc in "${db_services[@]}"; do
            db_name=$(docker compose ps -a --format '{{.Name}}' "$svc" 2> "$SILENT_LOG")
            if [[ -n "$db_name" && "$db_name" != "remnawave-db" && "$db_name" != *"remnawave_"* ]]; then
                cd - > "$SILENT_LOG"
                echo "$db_name"
                return 0
            fi
        done
        cd - > "$SILENT_LOG"
    fi
    return 1
}

detect_bot_installation() {
    debug_log "SCAN" "=== detect_bot_installation ==="
    print_message "INFO" "Запуск интеллектуального поиска..."
    scan_system_for_bot 
    if [[ ${#FOUND_PATHS[@]} -gt 1 ]]; then
        echo ""; print_message "WARN" "Найдено несколько установок. Выберите нужную:"
        local idx=1
        for path in "${FOUND_PATHS[@]}"; do
            local bot="${FOUND_BOTS[$((idx-1))]}"
            echo -e "  $idx. ${BOLD}$path${RESET} ${bot:+(bot: $bot)}"
            idx=$((idx + 1))
        done
        echo "  0. Отмена"
        read -erp "Ваш выбор: " sel
        if [[ "$sel" =~ ^[0-9]+$ && "$sel" -ge 1 && "$sel" -le ${#FOUND_PATHS[@]} ]]; then
            local selected_path="${FOUND_PATHS[$((sel-1))]}"
            local selected_bot="${FOUND_BOTS[$((sel-1))]}"
            BOT_PATH="$selected_path"
            [[ -n "$selected_bot" ]] && BOT_CONTAINER_NAME="$selected_bot"
            DB_CONTAINER_NAME=$(find_db_container_for_path "$BOT_PATH")
            save_config; print_message "SUCCESS" "Настройки сохранены."; return 0
        fi
    elif [[ -n "$FOUND_PATH" ]]; then
        debug_log "SCAN" "Found installation: PATH=$FOUND_PATH, BOT=$FOUND_BOT, DB=$FOUND_DB"
        echo ""; print_message "SUCCESS" "Обнаружена установка!"
        echo -e "   Путь:      ${BOLD}$FOUND_PATH${RESET}"
        [[ -n "$FOUND_BOT" ]] && echo -e "   Бот:       ${BOLD}$FOUND_BOT${RESET}"
        [[ -n "$FOUND_DB" ]]  && echo -e "   БД:        ${BOLD}$FOUND_DB${RESET}"
        echo ""
        read -erp "Использовать эти настройки? (Y/n): " confirm
        if [[ -z "$confirm" || "$confirm" =~ ^[Yy]$ ]]; then
            debug_log "SCAN" "User confirmed, applying settings"
            BOT_PATH="$FOUND_PATH"
            if [[ -n "$FOUND_BOT" ]]; then BOT_CONTAINER_NAME="$FOUND_BOT"; fi
            if [[ -n "$FOUND_DB" ]]; then DB_CONTAINER_NAME="$FOUND_DB"; fi
            save_config; print_message "SUCCESS" "Настройки сохранены."; return 0
        else
            debug_log "SCAN" "User declined auto-detected settings"
        fi
    else
        debug_log "SCAN" "No installation found by auto-detection"
    fi
    print_message "WARN" "Авто-поиск не дал результата. Введите данные вручную в Настройках."
    return 1
}

# --- ПРОВЕРКА НЕСООТВЕТСТВИЙ ---

check_config_mismatch() {
    debug_log "CONFIG" "=== check_config_mismatch ==="
    debug_log "CONFIG" "BOT_CONTAINER_NAME=$BOT_CONTAINER_NAME, IGNORE_MISMATCH=$IGNORE_MISMATCH"
    if [[ -n "$BOT_CONTAINER_NAME" && "$IGNORE_MISMATCH" != "true" ]]; then
        debug_log "CONFIG" "Checking if container exists..."
        if ! docker inspect "$BOT_CONTAINER_NAME" > /dev/null 2> "$SILENT_LOG"; then
            debug_log "CONFIG" "Container '$BOT_CONTAINER_NAME' NOT found, scanning for alternatives"
            scan_system_for_bot
            if [[ -n "$FOUND_BOT" && "$FOUND_BOT" != "$BOT_CONTAINER_NAME" ]]; then
                debug_log "CONFIG" "Found alternative: $FOUND_BOT (was: $BOT_CONTAINER_NAME)"
                echo ""; print_message "WARN" "Контейнер '$BOT_CONTAINER_NAME' не найден, но найден '$FOUND_BOT'."
                echo -e " ${GREEN}Предлагаю обновить настройки.${RESET}"
                read -erp "Обновить? (Y/n): " upd
                if [[ -z "$upd" || "$upd" =~ ^[Yy]$ ]]; then
                    debug_log "CONFIG" "User confirmed update to new container"
                    BOT_CONTAINER_NAME="$FOUND_BOT"
                    [[ -n "$FOUND_DB" ]] && DB_CONTAINER_NAME="$FOUND_DB"
                    [[ -n "$FOUND_PATH" ]] && BOT_PATH="$FOUND_PATH"
                    save_config; print_message "SUCCESS" "Обновлено."; sleep 1
                else
                    debug_log "CONFIG" "User declined, setting IGNORE_MISMATCH=true"
                    IGNORE_MISMATCH="true"; save_config
                fi
            fi
        else
            debug_log "CONFIG" "Container '$BOT_CONTAINER_NAME' exists"
        fi
    fi
}

ensure_bot_path() {
    debug_log "CONFIG" "=== ensure_bot_path ==="
    debug_log "CONFIG" "Current: BOT_PATH=$BOT_PATH, BOT=$BOT_CONTAINER_NAME, DB=$DB_CONTAINER_NAME"
    
    if [[ -z "$BOT_CONTAINER_NAME" || -z "$DB_CONTAINER_NAME" ]]; then
        debug_log "CONFIG" "Container names empty, starting detection"
        echo ""; print_message "WARN" "Настройки контейнеров пусты."
        detect_bot_installation; load_or_create_config 
    fi

    local path_valid=false
    if [[ -n "$BOT_PATH" && -d "$BOT_PATH" && ( -f "$BOT_PATH/docker-compose.yml" || -f "$BOT_PATH/compose.yaml" ) ]]; then path_valid=true; fi
    debug_log "CONFIG" "path_valid=$path_valid (BOT_PATH=$BOT_PATH)"
    
    local container_valid=false
    if [[ -n "$BOT_CONTAINER_NAME" ]] && docker inspect "$BOT_CONTAINER_NAME" > /dev/null 2> "$SILENT_LOG"; then container_valid=true; fi
    debug_log "CONFIG" "container_valid=$container_valid (BOT_CONTAINER=$BOT_CONTAINER_NAME)"
    
    local db_valid=false
    if [[ -n "$DB_CONTAINER_NAME" ]] && docker inspect "$DB_CONTAINER_NAME" > /dev/null 2> "$SILENT_LOG"; then db_valid=true; fi
    debug_log "CONFIG" "db_valid=$db_valid (DB_CONTAINER=$DB_CONTAINER_NAME)"

    if [[ "$path_valid" == "false" || "$container_valid" == "false" || "$db_valid" == "false" ]]; then
        debug_log "CONFIG" "Some validations failed, attempting auto-detection"
        if [[ "$path_valid" == "false" ]]; then
            detect_bot_installation; load_or_create_config
            if [[ -n "$BOT_PATH" ]]; then path_valid=true; fi
            if [[ -n "$BOT_CONTAINER_NAME" ]]; then container_valid=true; fi
            if [[ -n "$DB_CONTAINER_NAME" ]]; then db_valid=true; fi
            debug_log "CONFIG" "After detection: path=$path_valid, container=$container_valid, db=$db_valid"
        fi

        if [[ -z "$BOT_PATH" || ! -d "$BOT_PATH" ]]; then
            debug_log "CONFIG" "BOT_PATH still invalid, prompting user"
            echo ""; print_message "ACTION" "Укажите путь к папке бота вручную."
            read -erp "Путь (Enter для '$DEFAULT_BOT_PATH'): " input_path
            BOT_PATH="${input_path:-$DEFAULT_BOT_PATH}"
            debug_log "CONFIG" "User entered BOT_PATH=$BOT_PATH"
            if [[ ! -d "$BOT_PATH" ]]; then 
                debug_log "CONFIG" "ERROR: Path does not exist"
                print_message "ERROR" "Папка не найдена!"; return 1
            fi
            save_config
        fi

        if [[ -z "$BOT_CONTAINER_NAME" ]] || ! docker inspect "$BOT_CONTAINER_NAME" > /dev/null 2> "$SILENT_LOG"; then
            debug_log "CONFIG" "BOT_CONTAINER_NAME invalid, prompting user"
            echo ""; print_message "WARN" "Контейнер бота не определен."
            print_message "ACTION" "Введите имя контейнера бота (как в 'docker ps')."
            read -erp "Имя (Enter для '$DEFAULT_BOT_CONTAINER'): " input_name
            BOT_CONTAINER_NAME="${input_name:-$DEFAULT_BOT_CONTAINER}"
            debug_log "CONFIG" "User entered BOT_CONTAINER_NAME=$BOT_CONTAINER_NAME"
            save_config
        fi

        if [[ -z "$DB_CONTAINER_NAME" ]] || ! docker inspect "$DB_CONTAINER_NAME" > /dev/null 2> "$SILENT_LOG"; then
            debug_log "CONFIG" "DB_CONTAINER_NAME invalid, prompting user"
            echo ""; print_message "WARN" "Контейнер Базы Данных не найден."
            print_message "ACTION" "Введите имя контейнера БД."
            read -erp "Имя БД (Enter для '$DEFAULT_DB_CONTAINER'): " input_db
            DB_CONTAINER_NAME="${input_db:-$DEFAULT_DB_CONTAINER}"
            debug_log "CONFIG" "User entered DB_CONTAINER_NAME=$DB_CONTAINER_NAME"
            save_config
        fi
    fi
    debug_log "CONFIG" "=== ensure_bot_path completed ==="
    return 0
}

trim_ws() {
    local s="$1"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    echo "$s"
}

parse_env_value() {
    local val
    val=$(trim_ws "$1")
    if [[ $val == "\""*"\"" && $val == *"\"" ]]; then
        val="${val:1:${#val}-2}"
        val="${val//\\\\/\\}"
        val="${val//\\\"/\"}"
    elif [[ $val == "'"*"'" && $val == *"'" ]]; then
        val="${val:1:${#val}-2}"
        val=$(printf '%s' "$val" | sed "s/'\\''/'/g")
    fi
    echo "$val"
}

load_config_file() {
    local file="$1"
    [[ ! -f "$file" ]] && return 1
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        [[ "$line" != *"="* ]] && continue
        local key="${line%%=*}"
        key=$(trim_ws "$key")
        local raw_val="${line#*=}"
        local val
        val=$(parse_env_value "$raw_val")

        case "$key" in
            BOT_TOKEN) BOT_TOKEN="$val" ;;
            CHAT_ID) CHAT_ID="$val" ;;
            TG_MESSAGE_THREAD_ID) TG_MESSAGE_THREAD_ID="$val" ;;
            BOT_PATH) BOT_PATH="$val" ;;
            BOT_CONTAINER_NAME) BOT_CONTAINER_NAME="$val" ;;
            DB_CONTAINER_NAME) DB_CONTAINER_NAME="$val" ;;
            DB_USER) DB_USER="$val" ;;
            IGNORE_MISMATCH) IGNORE_MISMATCH="$val" ;;
            EXCLUDE_DIRS) EXCLUDE_DIRS="$val" ;;
            MAX_FILE_SIZE_MB) MAX_FILE_SIZE_MB="$val" ;;
            REMOTE_STORAGE_TYPE) REMOTE_STORAGE_TYPE="$val" ;;
            REMOTE_STORAGE_URL) REMOTE_STORAGE_URL="$val" ;;
            REMOTE_STORAGE_USER) REMOTE_STORAGE_USER="$val" ;;
            REMOTE_STORAGE_PASS) REMOTE_STORAGE_PASS="$val" ;;
            SEND_TO_TELEGRAM) SEND_TO_TELEGRAM="$val" ;;
            TG_SEND_FILE) TG_SEND_FILE="$val" ;;
            SEND_TO_REMOTE) SEND_TO_REMOTE="$val" ;;
            DELETE_MODE) DELETE_MODE="$val" ;;
            RETENTION_DAYS) RETENTION_DAYS="$val" ;;
            MAX_BACKUPS_COUNT) MAX_BACKUPS_COUNT="$val" ;;
            MAX_BACKUP_SIZE_MB) MAX_BACKUP_SIZE_MB="$val" ;;
            SCHEDULE_FULL) SCHEDULE_FULL="$val" ;;
            SCHEDULE_DB) SCHEDULE_DB="$val" ;;
            SCHEDULE_FILES) SCHEDULE_FILES="$val" ;;
            S3_ENDPOINT) S3_ENDPOINT="$val" ;;
            S3_BUCKET) S3_BUCKET="$val" ;;
            S3_PATH) S3_PATH="$val" ;;
            S3_ACCESS_KEY) S3_ACCESS_KEY="$val" ;;
            S3_SECRET_KEY) S3_SECRET_KEY="$val" ;;
            S3_REGION) S3_REGION="$val" ;;
            BACKUP_PASSWORD) BACKUP_PASSWORD="$val" ;;
            BACKUP_PASSWORD_FILE) BACKUP_PASSWORD_FILE="$val" ;;
        esac
    done < "$file"
}

env_escape() {
    local val="$1"
    val="${val//\\/\\\\}"
    val="${val//\"/\\\"}"
    echo "$val"
}

write_password_file() {
    local file="$BACKUP_PASSWORD_FILE"
    mkdir -p "$(dirname "$file")"
    printf '%s' "$1" > "$file"
    chmod 600 "$file" 2> "$SILENT_LOG" || true
}

read_password_file() {
    local file="$BACKUP_PASSWORD_FILE"
    if [[ -n "$file" && -f "$file" ]]; then
        IFS= read -r BACKUP_PASSWORD < "$file" || true
        return 0
    fi
    return 1
}

