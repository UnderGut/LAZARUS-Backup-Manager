        local ST_TG_NOTIFY="${RED}Выкл${RESET}"; [[ "$SEND_TO_TELEGRAM" == "true" ]] && ST_TG_NOTIFY="${GREEN}Вкл${RESET}"
        local ST_TG_FILE="${RED}Выкл${RESET}"; [[ "$TG_SEND_FILE" == "true" ]] && ST_TG_FILE="${GREEN}Вкл${RESET}"
        local ST_REM="${RED}Выкл${RESET}"; [[ "$SEND_TO_REMOTE" == "true" ]] && ST_REM="${GREEN}Вкл${RESET}"
        
        local STORAGE_TYPE_DISP="Выкл"
        if [[ "$REMOTE_STORAGE_TYPE" != "off" ]]; then STORAGE_TYPE_DISP="${REMOTE_STORAGE_TYPE^^}"; fi

        echo -e "${CYAN}--- ОБЩИЕ ---${RESET}"
        echo -e " 1. Путь к боту:        ${GRAY}${BOT_PATH}${RESET}"
        echo -e " 2. Контейнер бота:     ${GRAY}${BOT_CONTAINER_NAME}${RESET}"
        echo -e " 3. Контейнер БД:       ${GRAY}${DB_CONTAINER_NAME}${RESET}"
        echo -e " 4. Пользователь БД:    ${GRAY}${DB_USER}${RESET}"
        echo -e " 5. Исключить папки:    ${GRAY}${EXCLUDE_DIRS:-Нет}${RESET}"
        echo -e " 6. Макс. размер файла: ${GRAY}${MAX_FILE_SIZE_MB} MB${RESET}"
        
        echo -e "\n${CYAN}--- TELEGRAM ---${RESET}"
        echo -e " 7.  Token:             ${GRAY}${MASKED_TOKEN}${RESET}"
        echo -e " 8.  Chat ID:           ${GRAY}${MASKED_CHAT_ID}${RESET}"
        echo -e " 9.  Thread ID:         ${GRAY}${TG_MESSAGE_THREAD_ID:-Нет}${RESET}"
        echo -e " 10. Уведомления:       $ST_TG_NOTIFY"
        echo -e " 11. Отправка файла:    $ST_TG_FILE"
        echo -e " 12. Проверить связь"

        echo -e "\n${CYAN}--- УДАЛЁННОЕ ХРАНИЛИЩЕ ---${RESET}"
        echo -e " 13. Тип:               ${GRAY}${STORAGE_TYPE_DISP}${RESET}"
        echo -e " 14. URL:               ${GRAY}${REMOTE_STORAGE_URL:-Нет}${RESET}"
        echo -e " 15. Пользователь:      ${GRAY}${MASKED_REMOTE_USER}${RESET}"
        echo -e " 16. Загрузка:          $ST_REM"
        echo -e " 17. Настроить / Проверить"

        echo -e "\n${CYAN}--- БЕЗОПАСНОСТЬ ---${RESET}"
        echo -e " 18. Пароль шифрования: ${GRAY}${PASS_MASK}${RESET}"
        
        echo -e "\n${CYAN}--- РОТАЦИЯ БЭКАПОВ ---${RESET}"
        local DM_DISPLAY="По времени"; [[ "$DELETE_MODE" == "count" ]] && DM_DISPLAY="По количеству"
        echo -e " 19. Режим удаления:    ${GRAY}${DM_DISPLAY}${RESET}"
        if [[ "$DELETE_MODE" == "count" ]]; then
            echo -e " 20. Макс. бэкапов:     ${GRAY}${MAX_BACKUPS_COUNT} шт.${RESET}"
        else
            echo -e " 20. Срок хранения:     ${GRAY}${RETENTION_DAYS} дней${RESET}"
        fi
        echo -e " 21. Лимит размера:     ${GRAY}$(format_size_mb "$MAX_BACKUP_SIZE_MB")${RESET}"
        
        echo -e "\n 0. Назад"
        echo ""
        read -erp "Выбор: " s
        [[ -z "$s" ]] && return
        
        case $s in
            1) read -erp "Новый путь: " np
               if [[ -n "$np" ]]; then 
                   if [[ -d "$np" ]]; then BOT_PATH="$np"; save_config; print_message "SUCCESS" "Сохранено"
                   else print_message "ERROR" "Папка не найдена!"; fi
               fi ;;
            
            2) 
                scan_system_for_bot
                local def_cont="${FOUND_BOT:-$BOT_CONTAINER_NAME}"
                local prompt_msg="Имя контейнера бота"
                [[ -n "$FOUND_BOT" ]] && prompt_msg+=" (Enter = '$FOUND_BOT')"
                read -erp "$prompt_msg: " nc; nc="${nc:-$def_cont}"
                if [[ -n "$nc" ]]; then BOT_CONTAINER_NAME="$nc"; save_config; print_message "SUCCESS" "Сохранено"; fi ;;
                
            3) 
                scan_system_for_bot
                local def_db="${FOUND_DB:-$DB_CONTAINER_NAME}"
                local prompt_msg="Имя контейнера БД"
                [[ -n "$FOUND_DB" ]] && prompt_msg+=" (Enter = '$FOUND_DB')"
                read -erp "$prompt_msg: " ndb_c; ndb_c="${ndb_c:-$def_db}"
                if [[ -n "$ndb_c" ]]; then DB_CONTAINER_NAME="$ndb_c"; save_config; print_message "SUCCESS" "Сохранено"; fi ;;

            4) read -erp "Новый DB User: " ndb
               if [[ -n "$ndb" ]]; then DB_USER="$ndb"; save_config; print_message "SUCCESS" "Сохранено"; fi ;;
               
            5) read -erp "Исключить (например: uploads/cache): " ed
               if [[ -n "$ed" ]]; then 
                   EXCLUDE_DIRS="$ed"; save_config; print_message "SUCCESS" "Сохранено"
               else 
                   if [[ -n "$EXCLUDE_DIRS" ]]; then 
                       read -erp "Очистить? (y/N): " clr
                       if [[ "$clr" =~ ^[Yy]$ ]]; then EXCLUDE_DIRS=""; save_config; fi
                   fi
               fi ;;
               
            6) read -erp "Макс. размер файла в MB: " msize
               if [[ "$msize" =~ ^[0-9]+$ ]] && [ "$msize" -gt 0 ]; then 
                   MAX_FILE_SIZE_MB="$msize"; save_config; print_message "SUCCESS" "Сохранено"
               fi ;;
            
            7) read -erp "Новый Token: " nt
               if [[ -n "$nt" ]]; then BOT_TOKEN="$nt"; save_config; print_message "SUCCESS" "Сохранено"; fi ;;
               
            8) echo -e "Текущий Chat ID: ${CYAN}${CHAT_ID}${RESET}"
               read -erp "Новый Chat ID: " nid
               if [[ -n "$nid" ]]; then CHAT_ID="$nid"; save_config; print_message "SUCCESS" "Сохранено"; fi ;;
               
            9) read -erp "Новый Thread ID (пусто - сбросить): " ntid
                TG_MESSAGE_THREAD_ID="$ntid"; save_config; print_message "SUCCESS" "Сохранено" ;;
                
            10) # Переключение уведомлений
                if [[ "$SEND_TO_TELEGRAM" == "true" ]]; then 
                    SEND_TO_TELEGRAM="false"
                    print_message "INFO" "Уведомления Telegram отключены"
                else 
                    SEND_TO_TELEGRAM="true"
                    print_message "SUCCESS" "Уведомления Telegram включены"
                fi
                save_config ;;
                
            11) # Переключение отправки файла
                if [[ "$TG_SEND_FILE" == "true" ]]; then
                    # Проверяем есть ли альтернативное хранилище
                    if [[ "$REMOTE_STORAGE_TYPE" == "off" || "$SEND_TO_REMOTE" != "true" ]]; then
                        echo ""
                        print_message "WARN" "Удалённое хранилище не настроено!"
                        print_message "WARN" "Бэкапы будут только на локальном диске."
                        read -erp "Всё равно отключить отправку файла в TG? (y/N): " confirm
                        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
                            print_message "INFO" "Отменено"
                            sleep 1
                            continue
                        fi
                    fi
                    TG_SEND_FILE="false"
                    print_message "INFO" "Отправка файла в TG отключена (уведомления сохранены)"
                else
                    TG_SEND_FILE="true"
                    print_message "SUCCESS" "Отправка файла в TG включена"
                fi
                save_config ;;
                
            12) test_telegram_connection ;;

            13|14|15|17) configure_remote_storage ;;
            
            16) # Переключение загрузки на удалённое хранилище
                if [[ "$SEND_TO_REMOTE" == "true" ]]; then 
                    SEND_TO_REMOTE="false"
                    print_message "INFO" "Загрузка на удалённое хранилище отключена"
                else 
                    if [[ "$REMOTE_STORAGE_TYPE" == "off" ]]; then
                        print_message "WARN" "Сначала настройте хранилище (пункт 17)"
                        sleep 1.5
                        continue
                    fi
                    SEND_TO_REMOTE="true"
                    print_message "SUCCESS" "Загрузка на удалённое хранилище включена"
                fi
                save_config ;;

            18) echo ""
                read -s -erp "Новый пароль шифрования (пусто - отключить): " new_pass
                echo ""
                BACKUP_PASSWORD="$new_pass"
                save_config
                if [[ -n "$new_pass" ]]; then
                    print_message "SUCCESS" "Шифрование включено"
                else
                    print_message "INFO" "Шифрование отключено"
                fi ;;
                
            19) echo ""
                echo "Режим удаления старых бэкапов:"
                echo " 1. По времени (старше N дней)"
                echo " 2. По количеству (оставлять N последних)"
                read -erp "Выбор (1/2): " dm
                if [[ "$dm" == "1" ]]; then DELETE_MODE="time"; elif [[ "$dm" == "2" ]]; then DELETE_MODE="count"; fi
                save_config; print_message "SUCCESS" "Сохранено" ;;
                
            20) # Настройка параметра ротации в зависимости от режима
                if [[ "$DELETE_MODE" == "count" ]]; then
                    read -erp "Макс. количество бэкапов: " nd
                    if [[ "$nd" =~ ^[0-9]+$ ]] && [ "$nd" -ge 1 ]; then 
                        MAX_BACKUPS_COUNT="$nd"; save_config; print_message "SUCCESS" "Сохранено"
                    else 
                        print_message "ERROR" "Введите число >= 1"
                    fi
                else
                    read -erp "Срок хранения в днях: " ndays
                    if [[ "$ndays" =~ ^[0-9]+$ ]] && [ "$ndays" -ge 1 ]; then 
                        RETENTION_DAYS="$ndays"; save_config; print_message "SUCCESS" "Сохранено"
                    else 
                        print_message "ERROR" "Введите число >= 1"
                    fi
                fi ;;
                
            21) # Лимит размера бэкапов
                echo ""
                echo "Лимит размера папки с бэкапами (в MB)"
                echo "Введите 0 для отключения лимита"
                echo ""
                local current_mb="$MAX_BACKUP_SIZE_MB"
                echo -e "Текущий лимит: ${CYAN}$(format_size_mb "$current_mb")${RESET}"
                read -erp "Новый лимит (MB): " new_limit
                if [[ "$new_limit" =~ ^[0-9]+$ ]]; then 
                    MAX_BACKUP_SIZE_MB="$new_limit"
                    save_config
                    if [[ "$new_limit" == "0" ]]; then
                        print_message "INFO" "Лимит размера отключён"
                    else
                        print_message "SUCCESS" "Установлен лимит: $(format_size_mb "$new_limit")"
                    fi
                else 
                    print_message "ERROR" "Введите целое число (0 для отключения)"
                fi ;;
            
            0) return ;;
        esac
        [[ -n "$s" ]] && sleep 0.5
    done
}

# =============================================================================
# МИГРАЦИЯ МЕЖДУ БОТАМИ (Bedolaga → RWP-Shop) — plugin entry
# =============================================================================
# Реальный код миграции вынесен в отдельный плагин: lazarus-migrator
# Расположение: $LAZARUS_MIGRATOR_PATH (по умолчанию /opt/lazarus-backup/lazarus-migrator)
#
# Если плагин установлен — main script подхватывает его через source и все
# функции migrate_*/migration_*/menu_migration становятся доступны как раньше.
# Если плагина нет — определяется stub menu_migration() с инструкцией по установке.
# Это позволяет держать main script компактным (~7300 строк vs 14k) и обновлять
# логику миграции независимо.

LAZARUS_MIGRATOR_PATH="${LAZARUS_MIGRATOR_PATH:-/opt/lazarus-backup/lazarus-migrator}"
LAZARUS_MIGRATOR_LOADED=0

# install_migrator: скачивает плагин миграции с GitHub, проверяет валидность,
# сохраняет в $LAZARUS_MIGRATOR_PATH с правами 644. Использует те же зеркала,
# что и check_for_updates (REMOTE_URLS) — берёт первое доступное.
install_migrator() {
    local target="$LAZARUS_MIGRATOR_PATH"
    local target_dir; target_dir="$(dirname "$target")"
    local cache_buster="?t=$(date +%s)"
    local timeout=20

    # Список зеркал для плагина (соответствует REMOTE_URLS, но для lazarus-migrator)
    local mirrors=(
        "https://raw.githubusercontent.com/UnderGut/LAZARUS-Backup-Manager/main/lazarus-migrator"
        "https://raw.githack.com/UnderGut/LAZARUS-Backup-Manager/main/lazarus-migrator"
        "https://cdn.jsdelivr.net/gh/UnderGut/LAZARUS-Backup-Manager@main/lazarus-migrator"
    )

    clear_screen
    echo -e "${CYAN}${BOLD}Установка плагина миграции (lazarus-migrator)${RESET}"
    echo ""

    # Проверка прав записи
    if [[ ! -d "$target_dir" ]]; then
        if ! mkdir -p "$target_dir" 2> "$SILENT_LOG"; then
            print_message "ERROR" "Не удалось создать каталог: $target_dir"
            return 1
        fi
    fi
    if [[ ! -w "$target_dir" ]]; then
        print_message "ERROR" "Нет прав записи в $target_dir (запустите от root)."
        return 1
    fi

    # Проверка наличия curl/wget
    local fetcher=""
    if command -v curl > "$SILENT_LOG" 2>&1; then
        fetcher="curl"
    elif command -v wget > "$SILENT_LOG" 2>&1; then
        fetcher="wget"
    else
        print_message "ERROR" "Нет curl или wget — установка невозможна."
        return 1
    fi

    local tmp; tmp=$(mktemp 2> "$SILENT_LOG") || {
        print_message "ERROR" "Не удалось создать временный файл."
        return 1
    }
    # shellcheck disable=SC2064
    trap "rm -f '$tmp'" RETURN

    local downloaded=0
    local source_url=""
    for url in "${mirrors[@]}"; do
        local fetch_url="${url}${cache_buster}"
        echo -e "${GRAY}Загружаю: ${url}...${RESET}"
        : > "$tmp"
        if [[ "$fetcher" == "curl" ]]; then
            curl $CURL_SILENT -L --connect-timeout "$timeout" --max-time 60 -o "$tmp" "$fetch_url" 2> "$SILENT_LOG" || true
        else
            wget $WGET_SILENT -O "$tmp" --timeout="$timeout" "$fetch_url" 2> "$SILENT_LOG" || true
        fi

        # Валидация: shebang + plugin guard + версия
        if [[ -s "$tmp" ]] \
            && head -1 "$tmp" | grep -q '^#!/bin/bash' \
            && grep -q 'LAZARUS_MIGRATOR_VERSION=' "$tmp" \
            && grep -q 'BASH_SOURCE\[0\]' "$tmp"; then
            downloaded=1
            source_url="$url"
            echo -e "${GREEN}  ✓ OK${RESET}"
            break
        fi
        echo -e "${YELLOW}  ✗ Невалидный или недоступен${RESET}"
    done

    if [[ "$downloaded" != "1" ]]; then
        print_message "ERROR" "Не удалось скачать плагин ни с одного зеркала."
        return 1
    fi

    # Синтакс-проверка перед установкой
    if ! bash -n "$tmp" 2> "$SILENT_LOG"; then
        print_message "ERROR" "Скачанный плагин не прошёл проверку синтаксиса (bash -n)."
        return 1
    fi

    # Извлекаем версию плагина для отчёта
    local plugin_version
    plugin_version=$(grep '^LAZARUS_MIGRATOR_VERSION=' "$tmp" | head -1 | cut -d'"' -f2)
    [[ -z "$plugin_version" ]] && plugin_version="(unknown)"

    # Атомарная установка
    if ! install -m 0644 "$tmp" "$target" 2> "$SILENT_LOG"; then
        # fallback на cp+chmod если install отсутствует
        cp "$tmp" "$target" 2> "$SILENT_LOG" || {
            print_message "ERROR" "Не удалось записать плагин в $target."
            return 1
        }
        chmod 0644 "$target" 2> "$SILENT_LOG" || true
    fi

    echo ""
    print_message "OK" "Плагин установлен: $target"
    echo -e "  Версия: ${GREEN}${plugin_version}${RESET}"
    echo -e "  Источник: ${GRAY}${source_url}${RESET}"
    echo ""
    echo -e "${CYAN}Перезапустите ${SCRIPT_NAME}, чтобы плагин загрузился.${RESET}"
    return 0
}

if [[ -f "$LAZARUS_MIGRATOR_PATH" && -r "$LAZARUS_MIGRATOR_PATH" ]]; then
    # shellcheck source=/dev/null
    if source "$LAZARUS_MIGRATOR_PATH" 2> "$SILENT_LOG"; then
        LAZARUS_MIGRATOR_LOADED=1
        debug_log "PLUGIN" "Bedolaga migrator loaded from: $LAZARUS_MIGRATOR_PATH"
    else
        debug_log "PLUGIN" "Failed to source migrator: $LAZARUS_MIGRATOR_PATH"
    fi
else
    debug_log "PLUGIN" "Migrator plugin not installed (expected at: $LAZARUS_MIGRATOR_PATH)"
fi

# Stub: показывается если плагин не установлен. Перекрывается реальной menu_migration
# из плагина при наличии (определения функций в bash работают по принципу last-wins,
# поэтому source ВЫШЕ перекрывает этот stub если плагин загружен).
if [[ "$LAZARUS_MIGRATOR_LOADED" != "1" ]]; then
    menu_migration() {
        clear_screen
        echo ""
        echo -e "${MAGENTA}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
        echo -e "${MAGENTA}${BOLD}    🔄  МИГРАЦИЯ Bedolaga → RWP-Shop (требуется плагин)           ${RESET}"
        echo -e "${MAGENTA}${BOLD}═══════════════════════════════════════════════════════════════════${RESET}"
        echo ""
        echo -e "${YELLOW}⚠  Плагин миграции не установлен.${RESET}"
        echo ""
        echo "Это дополнительный модуль для переноса данных из Bedolaga в RWP-Shop."
        echo "Он не нужен для обычной работы с бэкапами и обновлением бота."
        echo ""
        echo -e "${CYAN}Установка:${RESET}"
        echo ""
        echo -e "  ${BOLD}Вариант 1${RESET} (рекомендуется):"
        echo "    lazarus install-migrator"
        echo ""
        echo -e "  ${BOLD}Вариант 2${RESET} (вручную):"
        echo "    curl -fsSL https://raw.githubusercontent.com/UnderGut/LAZARUS-Backup-Manager/main/lazarus-migrator \\"
        echo "      -o $LAZARUS_MIGRATOR_PATH && chmod 644 $LAZARUS_MIGRATOR_PATH"
        echo ""
        local _ans=""
        read -erp "Установить плагин сейчас? [y/N]: " _ans
        if [[ "$_ans" =~ ^[YyДд]$ ]]; then
            install_migrator
        fi
        echo ""
        read -erp "Нажмите Enter для возврата в главное меню..." _dummy
        return 0
    }

    menu_migrate_settings() {
        print_message "WARN" "Плагин миграции не установлен. См. пункт 7 главного меню."
        return 1
    }
fi

cleanup_old_backups() {
    clear_screen; echo -e "${RED}Очистка старых бэкапов${RESET}"
    
    local del_full=0; local del_db=0; local del_files=0
    local size_exceeded=false

    echo -e "Текущий режим очистки: ${YELLOW}$DELETE_MODE${RESET}"
    if [[ "$DELETE_MODE" == "count" ]]; then
        echo "Лимит хранения: $MAX_BACKUPS_COUNT шт."
    else
        echo -e "Срок хранения: ${YELLOW}$RETENTION_DAYS дней${RESET}"
    fi
    echo -e "Лимит размера: ${YELLOW}$(format_size_mb "$MAX_BACKUP_SIZE_MB")${RESET}"
    echo ""
    
    if [[ "$DELETE_MODE" == "count" ]]; then
        del_full=$(rotate_backups_by_count "lazarus_full" "Полные бэкапы" "false" | tail -n1)
        del_db=$(rotate_backups_by_count "lazarus_db" "Базы данных" "false" | tail -n1)
        del_files=$(rotate_backups_by_count "lazarus_files" "Архивы файлов" "false" | tail -n1)
    else
        # time-based
        del_full=$(rotate_backups_by_age "lazarus_full" "Полные бэкапы" "$RETENTION_DAYS" "false" | tail -n1)
        del_db=$(rotate_backups_by_age "lazarus_db" "Базы данных" "$RETENTION_DAYS" "false" | tail -n1)
        del_files=$(rotate_backups_by_age "lazarus_files" "Архивы файлов" "$RETENTION_DAYS" "false" | tail -n1)
    fi
    
    # Проверка лимита размера (показываем статус)
    if [[ -n "$MAX_BACKUP_SIZE_MB" && "$MAX_BACKUP_SIZE_MB" != "0" ]]; then
        local current_size_bytes=$(du -sb "$BACKUP_DIR" 2>/dev/null | awk '{print $1}')
        local limit_bytes=$((MAX_BACKUP_SIZE_MB * 1024 * 1024))
        if [[ $current_size_bytes -gt $limit_bytes ]]; then
            size_exceeded=true
            rotate_backups_by_size "false"  # Показать статус без удаления
        else
            rotate_backups_by_size "false"  # Показать что в пределах лимита
        fi
    fi

    echo ""
    # normalize empty to 0
    del_full=${del_full:-0}; del_db=${del_db:-0}; del_files=${del_files:-0}
    local total_del=$((del_full + del_db + del_files))

    if [[ "$total_del" -eq 0 && "$size_exceeded" != "true" ]]; then
        print_message "SUCCESS" "Чистка не требуется. Все в пределах лимита."
        read -erp "Enter..." dummy
        return
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        print_message "WARN" "[DRY-RUN] Кандидатов на удаление: $total_del"
    else
        if [[ "$size_exceeded" == "true" ]]; then
            print_message "WARN" "Превышен лимит размера! Старые файлы будут удалены."
        fi
        if [[ "$total_del" -gt 0 ]]; then
            print_message "WARN" "Будет удалено старых архивов: $total_del"
        fi
    fi
    # support non-interactive auto-confirm
    if [[ "$AUTO_CONFIRM" == "true" ]]; then
        confirm="y"
    else
        read -erp "Удалить эти файлы? (y/N): " confirm
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        # In dry-run we never delete
        log_message "INFO" "[DRY_RUN] Cleanup preview (mode=$DELETE_MODE, retention_days=$RETENTION_DAYS, max_count=$MAX_BACKUPS_COUNT, candidates=$total_del)"
        if [[ "$REPORT_TO_TG" == "true" && "$SEND_TO_TELEGRAM" == "true" ]]; then
            send_telegram_text "$(escape_markdown_v2 "🧹 DRY-RUN очистка: кандидатов=$total_del, mode=$DELETE_MODE")"
        fi
        read -erp "Enter..." dummy
        return
    fi

    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo ""
        if [[ "$DELETE_MODE" == "count" ]]; then
            rotate_backups_by_count "lazarus_full" "Полные бэкапы" "true" > "$SILENT_LOG"
            rotate_backups_by_count "lazarus_db" "Базы данных" "true" > "$SILENT_LOG"
            rotate_backups_by_count "lazarus_files" "Архивы файлов" "true" > "$SILENT_LOG"
        else
            rotate_backups_by_age "lazarus_full" "Полные бэкапы" "$RETENTION_DAYS" "true" > "$SILENT_LOG"
            rotate_backups_by_age "lazarus_db" "Базы данных" "$RETENTION_DAYS" "true" > "$SILENT_LOG"
            rotate_backups_by_age "lazarus_files" "Архивы файлов" "$RETENTION_DAYS" "true" > "$SILENT_LOG"
        fi
        # Также очистка по лимиту размера
        if [[ "$size_exceeded" == "true" ]]; then
            rotate_backups_by_size "true"
        fi
        echo ""; print_message "SUCCESS" "Очистка завершена."
        log_message "INFO" "Cleanup completed (mode=$DELETE_MODE, retention_days=$RETENTION_DAYS, max_count=$MAX_BACKUPS_COUNT, deleted=$total_del)"
        if [[ "$REPORT_TO_TG" == "true" && "$SEND_TO_TELEGRAM" == "true" ]]; then
            send_telegram_text "$(escape_markdown_v2 "🧹 Очистка завершена: удалено=$total_del, mode=$DELETE_MODE")"
        fi
    else
        echo ""; print_message "INFO" "Отменено."
    fi
    read -erp "Enter..." dummy
}

